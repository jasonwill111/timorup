{
  "name": "timorbiz",
  "version": "1.0.0",
  "description": "Business Directory Platform for Timor-Leste",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:api": "wrangler dev --port 8787 --local --persist-to .wrangler/local-db src/server/index.ts",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "deploy": "wrangler pages deploy dist",
    "deploy:api": "wrangler deploy src/server/index.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/node": "^9.5.4",
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.7.0",
    "@aws-sdk/client-s3": "^3.744.0",
    "@aws-sdk/lib-storage": "^3.744.0",
    "@base-ui/react": "^1.2.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/oswald": "^5.2.8",
    "@lexical/link": "^0.41.0",
    "@lexical/list": "^0.41.0",
    "@lexical/react": "^0.27.0",
    "@lexical/rich-text": "^0.41.0",
    "@libsql/client": "^0.17.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.18.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "lexical": "^0.27.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18",
    "wrangler": "^3.101.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
