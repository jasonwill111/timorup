{
  "name": "timorlist",
  "version": "1.0.0",
  "description": "Business Directory Platform for Timor-Leste",
  "type": "module",
  "scripts": {
    "dev": "USE_CLOUDFLARE=0 astro dev",
    "dev:cf": "USE_CLOUDFLARE=1 astro dev",
    "build": "astro build && cp public/_routes.json dist/_routes.json",
    "build:cf": "USE_CLOUDFLARE=1 astro build && cp public/_routes.json dist/_routes.json",
    "preview": "astro preview",
    "preview:cf": "wrangler dev ./dist",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "pnpm test && pnpm test:e2e",
    "test:kuri": "kuri screenshot http://localhost:4321",
    "test:kuri:compare": "kuri compare --baseline ./test-results/baseline --current ./test-results/current",
    "test:quick": "playwright-cli open http://localhost:4321",
    "test:agent": "browser-use --url http://localhost:4321 --task \"navigate and verify page loads correctly\"",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "deploy": "USE_CLOUDFLARE=1 wrangler deploy",
    "deploy:dry": "USE_CLOUDFLARE=1 wrangler deploy --dry-run",
    "wrangler": "wrangler",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.0",
    "@astrojs/sitemap": "^3.7.2",
    "@aws-sdk/client-s3": "^3.1039.0",
    "@aws-sdk/lib-storage": "^3.1039.0",
    "@better-auth/drizzle-adapter": "^1.6.9",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/oswald": "^5.2.8",
    "@libsql/client": "^0.17.3",
    "@lucide/astro": "^1.14.0",
    "@mastra/core": "^1.29.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@types/leaflet": "^1.9.21",
    "astro": "^6.2.1",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.9",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "leaflet": "^1.9.4",
    "nanoid": "^5.1.9",
    "nanostores": "^1.3.0",
    "node-fetch": "3",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@astrojs/compiler-rs": "^0.1.10",
    "@astrojs/node": "^10.0.6",
    "@noble/hashes": "^2.2.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bcryptjs": "^3.0.0",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "miniflare": "^4.20260426.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
