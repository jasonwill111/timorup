---
// Public Sector detail page with SSR
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Card from '../../components/ui/Card.astro';
import LocationMap from '../../components/ui/LocationMap.astro';
import MediaGallery from '../../components/ui/MediaGallery.astro';
import UpdatesSection from '../../components/UpdatesSection.astro';
import { Eye, Heart, Bookmark, Globe, MapPin, Tag, Clock } from '@lucide/astro';
import ShareDialog from '@/components/ui/ShareDialog.astro';
import { getDb } from '@/lib/db';
import { createBreadcrumbSchema } from '@/lib/seo';
import { publicSectors, publicSectorCategories, media, latestUpdates } from '@/db/schema';
import { eq, desc, inArray } from 'drizzle-orm';

const db = await getDb();

const { slug } = Astro.params;
const siteUrl = import.meta.env.SITE || 'https://timorup.com';
const canonicalUrl = `${siteUrl}/public-sector/${slug}`;

// SSR: Load public sector data
const org = await db.select()
  .from(publicSectors)
  .where(eq(publicSectors.slug, slug ?? ''))
  .get();

// CDN Cache: 2min for detail pages
Astro.response.headers.set('Cache-Control', 'public, max-age=120, s-maxage=600, stale-while-revalidate=600');

if (!org) {
  return Astro.redirect('/public-sectors');
}

const category = org.categoryId
  ? await db.select().from(publicSectorCategories).where(eq(publicSectorCategories.id, org.categoryId)).get()
  : null;

const tags = org.tags ? JSON.parse(org.tags) : [];
const openingHours = org.openingHours ? JSON.parse(org.openingHours) : null;
const socialLinks = org.socialLinks ? JSON.parse(org.socialLinks) : {};

// Load photo gallery from media table (entityType: 'public-sectors')
let galleryImages: { id: string; url: string }[] = [];
const galleryMedia = await db.select({ id: media.id })
  .from(media)
  .where(eq(media.entityId, org.id))
  .where(eq(media.entityType, 'public-sectors'))
  .where(eq(media.purpose, 'gallery'))
  .orderBy(media.sortOrder)
  .all();
galleryImages = galleryMedia.map(m => ({ id: m.id, url: `/api/media/${m.id}` }));

// Load updates from latestUpdates table
const updatesData = await db.select()
  .from(latestUpdates)
  .where(eq(latestUpdates.typeId, org.id))
  .where(eq(latestUpdates.type, 'public_sector'))
  .orderBy(desc(latestUpdates.createdAt))
  .limit(4)
  .all();

const updates = updatesData.map(u => ({
  ...u,
  images: u.imageIds ? JSON.parse(u.imageIds) : [],
}));

const pageTitle = `${org.title} - TimorUp`;
const pageDesc = org.aboutUs?.substring(0, 160) || `${org.title} - Public Sector in Timor-Leste`;

// JSON-Ld type
const jsonLdType = 'GovernmentOrganization';
---

<Layout title={pageTitle} description={pageDesc} canonical={canonicalUrl}>
  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": jsonLdType,
    "name": org.title,
    "description": org.aboutUs,
    "url": canonicalUrl,
    "image": org.profileImageId ? `/api/media/${org.profileImageId}` : undefined,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": org.address,
      "addressLocality": "Dili",
      "addressCountry": "TL"
    },
    "telephone": org.contactNumber ? `${org.countryCode} ${org.contactNumber}` : undefined,
  })} />

  <!-- Breadcrumb JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(createBreadcrumbSchema([
    { name: 'Home', url: `${siteUrl}/` },
    { name: 'Public Sectors', url: `${siteUrl}/public-sectors` },
    { name: org.title || slug }
  ]))} />

  <div class="bg-background min-h-screen">
    <!-- Banner -->
    <div class="relative h-48 md:h-64 bg-gradient-to-br from-blue-100 to-blue-200 dark:from-blue-900/30 dark:to-blue-800/30">
      {org.bannerImageId && (
        <img src={`/api/media/${org.bannerImageId}`} class="w-full h-full object-cover" alt="" loading="eager" decoding="auto" />
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
    </div>

    <div class="container max-w-6xl mx-auto px-4 md:px-6 -mt-16 relative z-10 pb-12">
      <!-- Header Card -->
      <div class="bg-card border rounded-2xl shadow-lg p-4 md:p-5 mb-6">
        <div class="flex flex-col lg:flex-row gap-5">
          <!-- Left Column: Profile + Info -->
          <div class="flex flex-row gap-4 lg:w-1/2 lg:items-start">
            <!-- Profile Image -->
            <div class="flex-shrink-0">
              <div class="w-20 h-20 md:w-24 md:h-24 rounded-xl overflow-hidden bg-muted border-2 border-background shadow-lg">
                {org.profileImageId ? (
                  <img src={`/api/media/${org.profileImageId}`} class="w-full h-full object-cover" alt={org.title} loading="eager" decoding="auto" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-4xl md:text-5xl font-bold text-muted-foreground bg-blue-100 dark:bg-blue-900/30">
                    {org.title.charAt(0)}
                  </div>
                )}
              </div>
            </div>

            <!-- Name + Contact Info -->
            <div class="flex-1 min-w-0">
              <h1 class="text-xl md:text-2xl font-bold">{org.title}</h1>
              {category && (
                <p class="text-xs text-muted-foreground mt-0.5">{category.name}</p>
              )}
              <div class="mt-1 space-y-1">
                {org.contactNumber && (
                  <div class="flex items-center gap-2 text-sm">
                    <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    <span class="text-muted-foreground">{org.countryCode} {org.contactNumber}</span>
                  </div>
                )}
                {org.contactName && (
                  <div class="flex items-center gap-2 text-sm">
                    <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    <span class="text-muted-foreground">{org.contactName}</span>
                  </div>
                )}
                {org.email && (
                  <div class="flex items-center gap-2 text-sm">
                    <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    <span class="text-muted-foreground truncate">{org.email}</span>
                  </div>
                )}
                {org.yearOfEstablishment && (
                  <div class="flex items-center gap-2 text-xs text-muted-foreground">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <span>Est. {org.yearOfEstablishment}</span>
                  </div>
                )}
              </div>
            </div>
          </div>

          <!-- Right Column: Stats + Share | WhatsApp -->
          <div class="flex flex-col lg:w-1/2 lg:items-end lg:justify-start gap-3">
            <!-- Stats + Share -->
            <div class="flex items-center gap-4 text-xs text-muted-foreground">
              <div class="flex items-center gap-1" title="Views">
                <Eye class="w-3.5 h-3.5" />
                <span>{org.views || 0}</span>
              </div>
              <div class="flex items-center gap-1" title="Likes">
                <Heart class="w-3.5 h-3.5" />
                <span>{org.likes || 0}</span>
              </div>
              <div class="flex items-center gap-1" title="Saves">
                <Bookmark class="w-3.5 h-3.5" />
                <span>{org.saves || 0}</span>
              </div>
              <ShareDialog url={canonicalUrl} title={org.title} class="p-1.5" />
            </div>

            <!-- WhatsApp -->
            {org.contactNumber && (
              <a href={`https://wa.me/${org.contactNumber.replace(/\s/g, '')}?text=Hi, I'm interested in ${encodeURIComponent(org.title)}`} target="_blank" class="flex items-center gap-1.5 px-3 py-2 bg-[#25D366] hover:bg-[#20BD5A] text-white rounded-lg text-sm font-medium transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp
              </a>
            )}
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="grid lg:grid-cols-10 gap-6">
        <!-- Left Column (60%) -->
        <div class="lg:col-span-6 space-y-3">
          <!-- About Us -->
          {org.aboutUs && (
            <Card>
              <div class="p-4">
                <h2 class="font-semibold text-base mb-2">About Us</h2>
                <p class="text-sm text-muted-foreground leading-relaxed whitespace-pre-wrap">{org.aboutUs}</p>
              </div>
            </Card>
          )}

          <!-- Updates Section -->
          {updates.length > 0 && (
            <Card>
              <div class="p-4">
                <h2 class="font-semibold text-base mb-3 flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
                  </svg>
                  Updates
                </h2>
                <UpdatesSection updates={updates} slug={slug} isOwner={false} />
              </div>
            </Card>
          )}

          <!-- Latest Update -->
          {updates.length === 0 && (
            <Card class="border-l-4 border-l-primary">
              <div class="p-3">
                <h3 class="font-semibold text-sm mb-2 flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/>
                  </svg>
                  Latest Update
                </h3>
                <p class="text-sm text-muted-foreground">No updates yet</p>
              </div>
            </Card>
          )}
        </div>

        <!-- Right Sidebar (40%) -->
        <div class="lg:col-span-4 space-y-3">
          <!-- Social Links -->
          {(socialLinks.facebook || socialLinks.instagram || socialLinks.tiktok) && (
            <Card>
              <div class="p-3">
                <h3 class="font-semibold text-sm mb-3 flex items-center gap-2">
                  <Globe class="w-4 h-4" />
                  Follow Us
                </h3>
                <div class="flex gap-3">
                  {socialLinks.facebook && (
                    <a href={socialLinks.facebook} target="_blank" class="p-2 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-600 hover:bg-blue-200 transition-colors">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                      </svg>
                    </a>
                  )}
                  {socialLinks.instagram && (
                    <a href={socialLinks.instagram} target="_blank" class="p-2 rounded-full bg-pink-100 dark:bg-pink-900/30 text-pink-600 hover:bg-pink-200 transition-colors">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                      </svg>
                    </a>
                  )}
                  {socialLinks.tiktok && (
                    <a href={socialLinks.tiktok} target="_blank" class="p-2 rounded-full bg-black dark:bg-gray-800 text-white hover:bg-gray-700 transition-colors">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1-.1z"/>
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </Card>
          )}

          <!-- Photo Gallery -->
          <Card>
            <div class="p-3">
              <MediaGallery items={galleryImages} title="Photo Gallery" gridCols={3} maxDisplay={6} />
            </div>
          </Card>

          <!-- Map -->
          <Card>
            <div class="p-3">
              <h3 class="font-semibold text-sm mb-2 flex items-center gap-2">
                <MapPin class="w-4 h-4" />
                Location
              </h3>
              {org.locationLat && org.locationLng ? (
                <LocationMap
                  id="org-map"
                  lat={org.locationLat}
                  lng={org.locationLng}
                  address={org.address || 'View Location'}
                  openFn="openOrgMap"
                />
              ) : (
                <p class="text-xs text-muted-foreground italic">Location not available.</p>
              )}
            </div>
          </Card>

          <!-- Tags -->
          {tags.length > 0 && (
            <Card>
              <div class="p-3">
                <h3 class="font-semibold text-sm mb-2 flex items-center gap-2">
                  <Tag class="w-4 h-4" />
                  Tags
                </h3>
                <div class="flex flex-wrap gap-1.5">
                  {tags.map((tag: string) => (
                    <span class="px-2 py-0.5 text-xs bg-muted rounded-full">{tag}</span>
                  ))}
                </div>
              </div>
            </Card>
          )}

          <!-- Hours -->
          <Card>
            <div class="p-3">
              <h3 class="font-semibold text-sm mb-2 flex items-center gap-2">
                <Clock class="w-4 h-4" />
                Hours
              </h3>
              {openingHours ? (
                <div class="space-y-1 text-xs">
                  {['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'].map(day => {
                    const dayData = openingHours[day];
                    const dayName = day.charAt(0).toUpperCase() + day.slice(1);
                    if (dayData?.open === 'closed') {
                      return <div class="flex justify-between"><span>{dayName}</span><span class="text-red-500">Closed</span></div>;
                    }
                    if (dayData?.open && dayData?.close) {
                      return <div class="flex justify-between"><span>{dayName}</span><span>{dayData.open} - {dayData.close}</span></div>;
                    }
                    return null;
                  })}
                </div>
              ) : (
                <p class="text-xs text-muted-foreground italic">Hours not available.</p>
              )}
            </div>
          </Card>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Global map navigation function
  window.openOrgMap = function(lat: string, lng: string) {
    const isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
    if (isMobile) {
      const url = navigator.userAgent.includes('iPhone')
        ? `http://maps.apple.com/?daddr=${lat},${lng}`
        : `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}`;
      window.open(url, '_blank');
    } else {
      window.open(`https://www.google.com/maps/search/?api=1&query=${lat},${lng}`, '_blank');
    }
  };
</script>
