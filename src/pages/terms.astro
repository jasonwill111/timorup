---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms of Service - TimorLink">
  <div class="container py-12">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-bold mb-8">Terms of Service</h1>
      
      <div class="prose dark:prose-invert max-w-none">
        <p class="text-muted-foreground mb-6">Last updated: {new Date().toLocaleDateString()}</p>
        
        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">Acceptance of Terms</h2>
          <p class="text-muted-foreground">
            By accessing and using TimorLink ("the Service"), you accept and agree to be bound by the terms and provision of this agreement. If you do not agree to abide by these terms, please do not use this Service.
          </p>
        </section>
        
        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">Description of Service</h2>
          <p class="text-muted-foreground mb-4">
            TimorLink is a business directory platform that helps users discover and connect with local businesses in Timor-Leste. We provide:
          </p>
          <ul class="list-disc pl-6 text-muted-foreground space-y-2">
            <li>Business listings and profiles</li>
            <li>Product and service catalogs</li>
            <li>Customer reviews and ratings</li>
            <li>Business categorization and search</li>
          </ul>
        </section>
        
        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">User Responsibilities</h2>
          <p class="text-muted-foreground mb-4">You agree to:</p>
          <ul class="list-disc pl-6 text-muted-foreground space-y-2">
            <li>Provide accurate and complete information</li>
            <li>Maintain the security of your account</li>
            <li>Not engage in any illegal or harmful activities</li>
            <li>Not attempt to gain unauthorized access to the Service</li>
            <li>Not post false, misleading, or defamatory content</li>
            <li>Respect the rights of other users and businesses</li>
          </ul>
        </section>
        
        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">Business Listings</h2>
          <p class="text-muted-foreground mb-4">
            Businesses listed on TimorLink are responsible for:
          </p>
          <ul class="list-disc pl-6 text-muted-foreground space-y-2">
            <li>Accuracy of their business information</li>
            <li>Owning or having permission to use any content they submit</li>
            <li>Complying with applicable laws and regulations</li>
            <li>Maintaining appropriate business licenses and permits</li>
          </ul>
        </section>
        
        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">Intellectual Property</h2>
          <p class="text-muted-foreground">
            The content, design, and functionality of TimorLink are protected by copyright and other intellectual property rights. You may not reproduce, distribute, or create derivative works from any part of this Service without our prior written consent.
          </p>
        </section>
        
        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">Disclaimer of Warranties</h2>
          <p class="text-muted-foreground">
            THE SERVICE IS PROVIDED "AS IS" WITHOUT WARRANTY OF ANY KIND. WE DO NOT WARRANT THAT THE SERVICE WILL BE UNINTERRUPTED OR ERROR-FREE. WE DISCLAIM ALL IMPLIED WARRANTIES, INCLUDING MERCHANTABILITY AND FITNESS FOR A PARTICULAR PURPOSE.
          </p>
        </section>
        
        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">Limitation of Liability</h2>
          <p class="text-muted-foreground">
            IN NO EVENT SHALL TimorLink BE LIABLE FOR ANY INDIRECT, INCIDENTAL, SPECIAL, CONSEQUENTIAL, OR PUNITIVE DAMAGES ARISING OUT OF OR RELATED TO YOUR USE OF THE SERVICE.
          </p>
        </section>
        
        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">Indemnification</h2>
          <p class="text-muted-foreground">
            You agree to indemnify, defend, and hold harmless TimorLink and its officers, directors, employees, and agents from any claims, damages, losses, liabilities, costs, or expenses arising out of your use of the Service or violation of these Terms.
          </p>
        </section>
        
        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">Termination</h2>
          <p class="text-muted-foreground">
            We reserve the right to terminate or suspend your access to the Service at any time, without prior notice, for any reason, including violation of these Terms.
          </p>
        </section>
        
        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">Changes to Terms</h2>
          <p class="text-muted-foreground">
            We may modify these Terms at any time. Your continued use of the Service after any such modifications constitutes your acceptance of the new Terms.
          </p>
        </section>
        
        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">Governing Law</h2>
          <p class="text-muted-foreground">
            These Terms shall be governed by and construed in accordance with the laws of Timor-Leste.
          </p>
        </section>
        
        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">Contact Us</h2>
          <p class="text-muted-foreground">
            If you have any questions about these Terms, please contact us at: <a href="mailto:contact@TimorLink.com" class="text-primary hover:underline">contact@TimorLink.com</a>
          </p>
        </section>
      </div>
    </div>
  </div>
</ Layout>

