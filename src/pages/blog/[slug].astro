---
import Layout from '@/layouts/Layout.astro';
import { getDb } from '@/lib/db';
import { blogPosts } from '@/db/schema';
import { eq } from 'drizzle-orm';

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/blog');
}

const db = await getDb();

// Fetch the post
const post = await db
  .select()
  .from(blogPosts)
  .where(eq(blogPosts.slug, slug))
  .get();

if (!post || post.status !== 'published') {
  return Astro.redirect('/blog');
}

// Cache: 5min browser, 30min CDN (blog content changes less often)
Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=1800, stale-while-revalidate=3600');

// Parse tags
const postTags = post.tags ? JSON.parse(post.tags as string) : [];

// Format date
const publishDate = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : post.createdAt
    ? new Date(post.createdAt).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })
    : '';

// SEO
const metaTitle = post.metaTitle || post.title;
const metaDescription = post.metaDescription || post.excerpt || '';
---

<Layout title={metaTitle} description={metaDescription}>
  <main class="container mx-auto px-4 py-8 max-w-4xl">
    <!-- Back Link -->
    <a
      href="/blog"
      class="inline-flex items-center gap-2 text-muted-foreground hover:text-primary transition-colors mb-8"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Blog
    </a>

    <!-- Cover Image -->
    {post.coverImageId ? (
      <div class="aspect-video rounded-2xl overflow-hidden mb-8 bg-gradient-to-br from-primary/20 to-primary/5">
        <!-- Image would be rendered here from R2 -->
        <div class="w-full h-full flex items-center justify-center">
          <svg class="w-16 h-16 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      </div>
    ) : (
      <div class="aspect-video rounded-2xl overflow-hidden mb-8 bg-gradient-to-br from-primary/20 to-primary/5 flex items-center justify-center">
        <svg class="w-16 h-16 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
      </div>
    )}

    <!-- Tags -->
    {postTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-4">
        {postTags.map((tag: string) => (
          <span class="px-3 py-1 bg-primary/10 text-primary text-sm rounded-full">
            {tag}
          </span>
        ))}
      </div>
    )}

    <!-- Title -->
    <h1 class="text-3xl md:text-4xl font-bold text-foreground mb-4">
      {post.title}
    </h1>

    <!-- Meta -->
    <div class="flex flex-wrap items-center gap-4 text-muted-foreground mb-8 pb-8 border-b border-border">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        <span>{post.authorName || 'TimorUp'}</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span>{publishDate}</span>
      </div>
    </div>

    <!-- Content (TipTap HTML) -->
    <article class="prose prose-lg max-w-none">
      <div class="tiptap-content" set:html={post.content} />
    </article>

    <!-- Share Section -->
    <div class="mt-12 pt-8 border-t border-border">
      <h3 class="text-lg font-semibold mb-4">Share this article</h3>
      <div class="flex gap-3">
        <a
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(Astro.url.href)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 bg-[#1DA1F2] text-white rounded-lg hover:opacity-90 transition-opacity"
        >
          Twitter
        </a>
        <a
          href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 bg-[#4267B2] text-white rounded-lg hover:opacity-90 transition-opacity"
        >
          Facebook
        </a>
        <a
          href={`https://wa.me/?text=${encodeURIComponent(post.title + ' ' + Astro.url.href)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 bg-[#25D366] text-white rounded-lg hover:opacity-90 transition-opacity"
        >
          WhatsApp
        </a>
      </div>
    </div>

    <!-- Back to Blog -->
    <div class="mt-8">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-primary-foreground rounded-lg hover:opacity-90 transition-opacity font-medium"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Blog
      </a>
    </div>
  </main>
</Layout>

<style>
  .tiptap-content {
    color: var(--foreground);
    line-height: 1.625;
  }

  .tiptap-content h1 {
    font-size: 1.875rem;
    font-weight: 700;
    margin-bottom: 1rem;
    margin-top: 2rem;
  }

  .tiptap-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    margin-top: 1.5rem;
  }

  .tiptap-content h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    margin-top: 1rem;
  }

  .tiptap-content p {
    margin-bottom: 1rem;
  }

  .tiptap-content ul,
  .tiptap-content ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .tiptap-content ul {
    list-style-type: disc;
  }

  .tiptap-content ol {
    list-style-type: decimal;
  }

  .tiptap-content li {
    margin-bottom: 0.5rem;
  }

  .tiptap-content a {
    color: var(--primary);
    text-decoration: underline;
  }

  .tiptap-content blockquote {
    border-left: 4px solid var(--primary);
    padding-left: 1rem;
    font-style: italic;
    color: var(--muted-foreground);
    margin: 1rem 0;
  }

  .tiptap-content img {
    border-radius: 0.5rem;
    max-width: 100%;
    margin: 1rem 0;
  }

  .tiptap-content pre {
    background-color: var(--muted);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1rem 0;
  }

  .tiptap-content code {
    background-color: var(--muted);
    padding: 0.125rem 0.25rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
  }

  .tiptap-content pre code {
    background-color: transparent;
    padding: 0;
  }

  .tiptap-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
  }

  .tiptap-content th,
  .tiptap-content td {
    border: 1px solid var(--border);
    padding: 0.5rem 1rem;
    text-align: left;
  }

  .tiptap-content th {
    background-color: var(--muted);
    font-weight: 600;
  }

  .tiptap-content hr {
    border-color: var(--border);
    margin: 2rem 0;
  }
</style>
