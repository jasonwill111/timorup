---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getDb } from '@/lib/db';
import { listings } from '@/db/schema';
import { eq, sql } from 'drizzle-orm';
import { Eye, Heart, Bookmark } from '@lucide/astro';
import ShareDialog from '@/components/ui/ShareDialog.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const db = await getDb();
const listing = await db.select().from(listings).where(eq(listings.slug, slug)).get();
if (!listing) return Astro.redirect('/listings');

// Cache: 2min browser, 10min CDN
Astro.response.headers.set('Cache-Control', 'public, max-age=120, s-maxage=600, stale-while-revalidate=600');

// Query raw columns not in schema using drizzle sql
const raw = await db.get<any>(sql`SELECT listing_type, price, condition, image_ids, contact_name, contact_number, country_code FROM listings WHERE slug = ${slug}`) || {};

// Merge schema + raw data
const listingType = raw.listing_type || '';
const price = raw.price || '';
const condition = raw.condition || '';
const imageIds = raw.image_ids || '[]';
const contactName = raw.contact_name || '';
const contactNumber = raw.contact_number || '';
const countryCode = raw.country_code || '+670';

// Parse tags
const tags = listing.tags ? (typeof listing.tags === 'string' ? JSON.parse(listing.tags) : listing.tags) : [];

const waNumber = contactNumber.replace(/\D/g, '');
const waLink = contactNumber
  ? `https://wa.me/${countryCode.replace('+', '')}${waNumber}?text=${encodeURIComponent('Hi, I saw your listing: ' + listing.title)}`
  : '';

const shareUrl = `${import.meta.env.SITE || 'https://timorlist.com'}/listing/${listing.slug}`;

const parsedImages = typeof imageIds === 'string' ? JSON.parse(imageIds) : imageIds;
const createdAt = listing.createdAt ? new Date(listing.createdAt as unknown as number * 1000) : null;

// Check grace period using subscription fields
const subscriptionStatus = listing.subscriptionStatus || 'none';
const gracePeriodEndDate = listing.gracePeriodEndDate
  ? new Date(listing.gracePeriodEndDate * 1000)
  : null;
const now = new Date();
const isInGracePeriod = gracePeriodEndDate
  ? subscriptionStatus === 'expired' && now < gracePeriodEndDate
  : false;
const isExpiredBeyondGrace = subscriptionStatus === 'expired' && (!gracePeriodEndDate || now >= gracePeriodEndDate);
const daysRemaining = gracePeriodEndDate
  ? Math.max(0, Math.ceil((gracePeriodEndDate.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)))
  : 0;
---

<Layout title={`${listing.title} - TimorList`} description={listing.description?.slice(0,160)}>
  <!-- Grace Period / Expired - Show only title, hide all other content -->
  {(isInGracePeriod || isExpiredBeyondGrace) && (
    <div class="fixed inset-0 z-[100] flex items-center justify-center bg-background/95 backdrop-blur-sm">
      <div class="bg-card border rounded-xl p-8 max-w-md mx-4 text-center shadow-2xl">
        {isExpiredBeyondGrace ? (
          <>
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
              <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold mb-2">{listing.title}</h2>
            <p class="text-muted-foreground mb-4">此页面已过期，内容不再公开显示。</p>
          </>
        ) : (
          <>
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center">
              <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold mb-2">{listing.title}</h2>
            <p class="text-muted-foreground mb-4">请及时为 Listing 续费，否则 7 天之后会删除。</p>
            <p class="text-lg font-semibold text-primary mb-6">剩余 {daysRemaining} 天</p>
          </>
        )}
        <a href="/subscribe" class="inline-block px-6 py-3 bg-primary text-primary-foreground font-semibold rounded-lg hover:opacity-90 transition-opacity">
          立即续费
        </a>
      </div>
    </div>
  )}

  <div class="bg-background min-h-screen" class:list={{ 'blur-sm pointer-events-none select-none': isInGracePeriod || isExpiredBeyondGrace }}>
    <div class="container py-8 max-w-4xl mx-auto">
      <div class="flex items-center gap-2 mb-2">
        {listingType && <span class="text-sm px-3 py-1 rounded-full bg-primary/10 text-primary capitalize">{listingType}</span>}
        {condition && <span class="text-sm px-3 py-1 rounded-full bg-muted capitalize">{condition}</span>}
      </div>

      <h1 class="text-2xl sm:text-3xl font-bold mb-2">{listing.title}</h1>
      {listing.location && <p class="text-muted-foreground mb-4 flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        {listing.location}
      </p>}

      {price && <div class="mb-6 pb-6 border-b">
        <span class="text-3xl sm:text-4xl font-bold text-primary">{price}</span>
      </div>}

      <!-- Stats Row with Icons -->
      <div class="flex items-center gap-4 text-sm text-muted-foreground mb-6 pb-6 border-b">
        <div class="flex items-center gap-1.5" title="Views">
          <Eye class="w-4 h-4" />
          <span>{listing.views || 0}</span>
        </div>
        <div class="flex items-center gap-1.5" title="Likes">
          <Heart class="w-4 h-4" />
          <span>{listing.likes || 0}</span>
        </div>
        <div class="flex items-center gap-1.5" title="Saves">
          <Bookmark class="w-4 h-4" />
          <span>{listing.saves || 0}</span>
        </div>
        <div class="flex-1"></div>
        <ShareDialog url={shareUrl} title={listing.title} class="px-3 py-1.5" />
      </div>

      {parsedImages.length > 0 && (
        <div class="mb-8">
          {parsedImages.length === 1 ? (
            <img src={`/api/media/${parsedImages[0]}`} alt={listing.title} class="w-full max-h-96 object-cover rounded-lg" />
          ) : (
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
              {parsedImages.slice(0,6).map((imgId: string, i: number) => (
                <img src={`/api/media/${imgId}`} alt={`${listing.title} ${i + 1}`} class={`w-full h-48 sm:h-64 object-cover rounded-lg ${i === 0 && parsedImages.length > 1 ? 'col-span-2 sm:col-span-2' : ''}`} />
              ))}
            </div>
          )}
        </div>
      )}

      {listing.description && (
        <div class="mb-8">
          <h2 class="text-xl font-semibold mb-3">Description</h2>
          <p class="whitespace-pre-wrap">{listing.description}</p>
        </div>
      )}

      {tags.length > 0 && (
        <div class="mb-8">
          <h2 class="text-xl font-semibold mb-3">Tags</h2>
          <div class="flex flex-wrap gap-2">
            {tags.map((tag: string) => <span class="text-sm px-3 py-1 rounded-full bg-muted">{tag}</span>)}
          </div>
        </div>
      )}

      <div class="bg-card border rounded-xl p-6">
        <h2 class="text-xl font-semibold mb-4">Contact Seller</h2>
        {contactName && <p class="mb-3"><strong>Name:</strong> {contactName}</p>}
        <div class="flex flex-wrap gap-3">
          {waLink && (
            <a href={waLink} target="_blank" class="flex items-center gap-2 px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          )}
          {contactNumber && (
            <a href={`tel:${countryCode}${contactNumber}`} class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Call
            </a>
          )}
          {listing.email && (
            <a href={`mailto:${listing.email}`} class="px-4 py-2 border rounded-lg hover:bg-muted flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              Email
            </a>
          )}
        </div>
      </div>

      <p class="text-sm text-muted-foreground mt-6">Posted {createdAt ? createdAt.toLocaleDateString() : 'recently'}</p>
    </div>
  </div>
</Layout>
