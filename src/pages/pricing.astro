---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
---

<Layout title="Pricing - TimorList">
  <div class="container py-12">
    <!-- Business Page Plans -->
    <div class="mb-16">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold mb-4">Business Page Plans</h1>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          Get a professional business page with your products, photos, and contact info.
        </p>
      </div>

      <!-- Billing Toggle -->
      <div class="flex justify-center mb-8">
        <div class="bg-muted p-1 rounded-lg flex">
          <button id="monthly-btn" class="px-4 py-2 rounded-md text-sm font-medium transition-colors bg-background shadow-sm">
            Monthly
          </button>
          <button id="yearly-btn" class="px-4 py-2 rounded-md text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">
            Yearly <span class="text-xs text-green-500 ml-1">Save 17%</span>
          </button>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <!-- Basic Plan -->
        <div class="bg-card border rounded-2xl p-8">
          <div class="text-center mb-6">
            <h3 class="text-2xl font-bold mb-2">Basic</h3>
            <p class="text-sm text-muted-foreground mb-4">For small businesses</p>
            <div id="basic-price" class="text-4xl font-bold">$29<span class="text-lg text-muted-foreground">/mo</span></div>
            <p id="basic-yearly" class="text-sm font-medium text-green-600 dark:text-green-400 mt-2 hidden">
              $290/year (save $58)
            </p>
          </div>

          <div class="bg-muted/50 rounded-lg p-3 mb-6 text-center">
            <span>Up to <strong class="font-bold text-primary">10</strong> products</span>
          </div>

          <ul class="text-left space-y-3 text-sm mb-8">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Business page with details</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>16 photos + 2 videos</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Map location</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Customer reviews</span>
            </li>
          </ul>

          <a href="/listings/create?plan=basic" class="block">
            <Button class="w-full">Get Started</Button>
          </a>
        </div>

        <!-- Pro Plan -->
        <div class="bg-card border-2 border-primary rounded-2xl p-8 relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-white px-3 py-1 text-sm font-medium rounded-full">
            Most Popular
          </div>
          <div class="text-center mb-6">
            <h3 class="text-2xl font-bold mb-2">Pro</h3>
            <p class="text-sm text-muted-foreground mb-4">For growing businesses</p>
            <div id="pro-price" class="text-4xl font-bold">$59<span class="text-lg text-muted-foreground">/mo</span></div>
            <p id="pro-yearly" class="text-sm font-medium text-green-600 dark:text-green-400 mt-2 hidden">
              $590/year (save $118)
            </p>
          </div>

          <div class="bg-primary/10 dark:bg-primary/20 rounded-lg p-3 mb-6 text-center">
            <span>Up to <strong class="font-bold text-primary">30</strong> products</span>
          </div>

          <ul class="text-left space-y-3 text-sm mb-8">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Everything in Basic</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Featured listings</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>5 photos per product</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Priority support</span>
            </li>
          </ul>

          <a href="/listings/create?plan=pro" class="block">
            <Button class="w-full">Get Started</Button>
          </a>
        </div>

        <!-- Max Plan -->
        <div class="bg-card border-2 border-amber-500 rounded-2xl p-8 relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-amber-500 text-white px-3 py-1 text-sm font-medium rounded-full">
            Best Value
          </div>
          <div class="text-center mb-6">
            <h3 class="text-2xl font-bold mb-2">Max</h3>
            <p class="text-sm text-muted-foreground mb-4">For large businesses</p>
            <div id="max-price" class="text-4xl font-bold">$89<span class="text-lg text-muted-foreground">/mo</span></div>
            <p id="max-yearly" class="text-sm font-medium text-green-600 dark:text-green-400 mt-2 hidden">
              $890/year (save $178)
            </p>
          </div>

          <div class="bg-amber-500/10 rounded-lg p-3 mb-6 text-center">
            <span>Up to <strong class="font-bold text-amber-600">60</strong> products</span>
          </div>

          <ul class="text-left space-y-3 text-sm mb-8">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Everything in Pro</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Top of search results</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>1 video per product</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Dedicated support</span>
            </li>
          </ul>

          <a href="/listings/create?plan=max" class="block">
            <Button class="w-full bg-amber-500 hover:bg-amber-600">Get Started</Button>
          </a>
        </div>
      </div>
    </div>

    <!-- Classified Ads -->
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-4">Classified Ads</h2>
        <p class="text-lg text-muted-foreground">
          Jobs, vehicles, property, services — post a listing and reach thousands of buyers.
        </p>
      </div>

      <div class="bg-card border rounded-2xl p-8 mb-8">
        <div class="text-center mb-6">
          <div class="inline-flex items-center bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-4 py-2 rounded-full text-sm font-medium mb-4">
            Free for 3 days
          </div>
          <p class="text-muted-foreground">Post your first listing at no cost.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="bg-muted/30 rounded-xl p-6 text-center">
            <div class="text-2xl font-bold mb-2">3 Days</div>
            <p class="text-sm text-muted-foreground mb-3">Free trial</p>
            <div class="text-lg font-bold text-green-600">Free</div>
          </div>
          <div class="bg-muted/30 rounded-xl p-6 text-center">
            <div class="text-2xl font-bold mb-2">7 Days</div>
            <p class="text-sm text-muted-foreground mb-3">Short-term listing</p>
            <div class="text-lg font-bold">$5</div>
          </div>
          <div class="bg-muted/30 rounded-xl p-6 text-center">
            <div class="text-2xl font-bold mb-2">30 Days</div>
            <p class="text-sm text-muted-foreground mb-3">Standard listing</p>
            <div class="text-lg font-bold">$15</div>
          </div>
        </div>

        <div class="text-center mt-6">
          <a href="/listings/create?type=classified" class="inline-block">
            <Button>Post a Listing</Button>
          </a>
        </div>
      </div>

      <div class="bg-muted/30 rounded-xl p-6 text-center">
        <p class="text-muted-foreground mb-2">Long-term listings?</p>
        <p class="text-lg font-bold">$50/year</p>
        <p class="text-sm text-muted-foreground">365 days visibility</p>
      </div>
    </div>

    <!-- Feature comparison -->
    <div class="mt-16 text-center">
      <div class="bg-muted/30 rounded-lg p-6 max-w-2xl mx-auto">
        <h3 class="font-semibold mb-4">All Business Plans Include:</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm text-muted-foreground">
          <div>Business page</div>
          <div>Photo gallery</div>
          <div>Map location</div>
          <div>Reviews</div>
        </div>
      </div>
    </div>

    <div class="text-center mt-8">
      <p class="text-muted-foreground">
        Questions? <a href="mailto:hello@timorlist.com" class="text-primary hover:underline">Contact us</a>
      </p>
    </div>
  </div>
</Layout>
