---
import Layout from '../layouts/Layout.astro';
import { Button } from '../components/ui/button';
import { Input } from '../components/ui/input';
import { Card, CardContent } from '../components/ui/card';
---

<Layout title="Search Businesses - TMBIZ">
  <div class="container max-w-6xl py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold">Search Results</h1>
      <p class="text-muted-foreground mt-2">Find businesses in Timor-Leste</p>
    </div>

    <!-- Search Form -->
    <form id="search-form" class="mb-8">
      <div class="flex gap-4">
        <Input
          type="search"
          id="search-input"
          name="q"
          placeholder="Search businesses, services, products..."
          class="flex-1 text-lg py-6"
        />
        <Button type="submit" size="lg">Search</Button>
      </div>
    </form>

    <!-- Results -->
    <div id="search-results">
      <p class="text-muted-foreground text-center py-8">
        Enter a search term to find businesses
      </p>
    </div>
  </div>
</Layout>

<script>
  const searchForm = document.getElementById('search-form') as HTMLFormElement;
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('search-results');

  // Get query from URL
  const urlParams = new URLSearchParams(window.location.search);
  const query = urlParams.get('q');

  if (query) {
    searchInput.value = query;
    performSearch(query);
  }

  searchForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const q = searchInput.value.trim();
    if (q) {
      window.location.href = `/search?q=${encodeURIComponent(q)}`;
    }
  });

  async function performSearch(query: string) {
    if (!resultsContainer) return;

    resultsContainer.innerHTML = '<p class="text-center py-8">Searching...</p>';

    try {
      const response = await fetch(`/api/businesses?search=${encodeURIComponent(query)}`);
      const data = await response.json();

      if (data.success && data.data && data.data.length > 0) {
        const html = `
          <div class="grid sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            ${data.data.map((business: any) => `
              <a href="/business/${business.slug}" class="block group">
                <Card class="overflow-hidden transition-shadow hover:shadow-lg">
                  <div class="aspect-[3/2] bg-muted relative">
                    ${business.bannerImageId ? 
                      `<img src="/api/media/${business.bannerImageId}" alt="${business.title}" class="w-full h-full object-cover" />` :
                      `<div class="w-full h-full flex items-center justify-center text-4xl font-bold text-muted-foreground">${business.title?.charAt(0) || 'B'}</div>`
                    }
                  </div>
                  <CardContent class="p-4">
                    <h3 class="font-semibold group-hover:text-primary transition-colors">${business.title}</h3>
                    ${business.categoryId ? `<p class="text-sm text-muted-foreground">${business.categoryId}</p>` : ''}
                    ${business.address ? `<p class="text-sm text-muted-foreground mt-1">${business.address}</p>` : ''}
                  </CardContent>
                </Card>
              </a>
            `).join('')}
          </div>
          <p class="text-center text-muted-foreground mt-4">Found ${data.data.length} result(s)</p>
        `;
        resultsContainer.innerHTML = html;
      } else {
        resultsContainer.innerHTML = `
          <div class="text-center py-8">
            <p class="text-lg text-muted-foreground">No businesses found for "${query}"</p>
            <p class="text-sm text-muted-foreground mt-2">Try different keywords or browse our directory</p>
            <a href="/businesses" class="inline-block mt-4">
              <Button variant="outline">Browse All Businesses</Button>
            </a>
          </div>
        `;
      }
    } catch (error) {
      console.error('Search error:', error);
      resultsContainer.innerHTML = '<p class="text-center py-8 text-red-500">Error performing search. Please try again.</p>';
    }
  }
</script>
