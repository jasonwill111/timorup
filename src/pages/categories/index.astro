---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Input from '../../components/ui/Input.astro';
import { getDb } from '@/lib/db';
import { businessCategories, businesses, nonProfits, publicSectors } from '@/db/schema';
import { eq, desc, count } from 'drizzle-orm';

const db = await getDb();
const PAGE_SIZE = 6;

// Get all business categories
const categoriesData = await db.select().from(businessCategories).all();

const categoriesWithListings = await Promise.all(
  categoriesData.map(async (cat) => {
    // Query businesses only (non-profits and public sectors have their own pages)
    const bizListings = await db
      .select({
        id: businesses.id,
        title: businesses.title,
        slug: businesses.slug,
        profileImageId: businesses.profileImageId,
        address: businesses.address,
        tags: businesses.tags,
      })
      .from(businesses)
      .where(eq(businesses.categoryId, cat.id))
      .orderBy(desc(businesses.likes));

    const npListings = await db
      .select({
        id: nonProfits.id,
        title: nonProfits.title,
        slug: nonProfits.slug,
        entityType: nonProfits.entityType,
        profileImageId: nonProfits.profileImageId,
        address: nonProfits.address,
        tags: nonProfits.tags,
      })
      .from(nonProfits)
      .where(eq(nonProfits.categoryId, cat.id))
      .orderBy(desc(nonProfits.likes));

    const psListings = await db
      .select({
        id: publicSectors.id,
        title: publicSectors.title,
        slug: publicSectors.slug,
        entityType: publicSectors.entityType,
        profileImageId: publicSectors.profileImageId,
        address: publicSectors.address,
        tags: publicSectors.tags,
      })
      .from(publicSectors)
      .where(eq(publicSectors.categoryId, cat.id))
      .orderBy(desc(publicSectors.likes));

    // Combine and sort by likes
    const allListings = [...bizListings, ...npListings, ...psListings]
      .sort((a, b) => b.likes - a.likes)
      .slice(0, PAGE_SIZE);

    const totalCount = bizListings.length + npListings.length + psListings.length;

    return {
      ...cat,
      listings: allListings,
      totalCount
    };
  })
);

// Filter out empty categories
const sortedCategories = categoriesWithListings
  .filter(c => c.listings.length > 0)
  .sort((a, b) => b.listings.length - a.listings.length);

// Serialize for client
const categoriesJson = JSON.stringify(sortedCategories.map(c => {
  const allTags = c.listings
    .map(l => {
      try { return l.tags ? JSON.parse(l.tags) : []; }
      catch { return []; }
    })
    .flat()
    .filter(Boolean);
  const uniqueTags = [...new Set(allTags)].slice(0, 8);

  return {
    id: c.id,
    slug: c.slug,
    name: c.name,
    icon: c.icon?.replace('emoji:', '') || c.icon,
    description: c.description,
    entityType: c.entityType,
    listings: c.listings.map(l => ({
      id: l.id,
      title: l.title,
      slug: l.slug,
      entityType: l.entityType,
      profileImageId: l.profileImageId,
      address: l.address,
      tags: (() => { try { return JSON.parse(l.tags || '[]'); } catch { return []; } })()
    })),
    totalCount: c.totalCount,
    tags: uniqueTags
  };
}));
---

<Layout
  title="Categories - TimorList"
  description="Browse all categories of businesses and organizations in Timor-Leste."
>
  <div class="container py-8">
    <h1 class="text-3xl font-bold mb-2">Explore</h1>
    <p class="text-muted-foreground mb-6">Browse by category</p>

    <!-- Search -->
    <div class="mb-6">
      <Input
        id="search"
        type="search"
        placeholder="Search categories or listings..."
        class="w-full md:w-96"
      />
    </div>

    <!-- Type Filter Tabs -->
    <div class="flex gap-4 mb-8 border-b">
      <button
        data-filter="all"
        class="filter-tab px-4 py-2 border-b-2 border-transparent text-sm font-medium text-muted-foreground hover:text-foreground transition-colors cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded"
      >
        All
      </button>
      <button
        data-filter="business"
        class="filter-tab px-4 py-2 border-b-2 border-transparent text-sm font-medium text-muted-foreground hover:text-foreground transition-colors cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded"
      >
        Businesses
      </button>
      <button
        data-filter="nonprofit"
        class="filter-tab px-4 py-2 border-b-2 border-transparent text-sm font-medium text-muted-foreground hover:text-foreground transition-colors cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded"
      >
        Non-profits
      </button>
    </div>

    <!-- Categories with Listings -->
    <div id="categories-container" class="space-y-12">
      <!-- Initial skeleton while JS renders -->
      <div class="space-y-8">
        {[...Array(3)].map(() => (
          <div>
            <div class="flex items-center gap-3 mb-3">
              <div class="w-8 h-8 rounded-lg bg-muted animate-pulse"></div>
              <div class="h-5 w-32 bg-muted rounded animate-pulse"></div>
            </div>
            <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-2">
              {[...Array(8)].map(() => (
                <div class="bg-muted rounded-lg animate-pulse aspect-square"></div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    {sortedCategories.length === 0 && (
      <div class="text-center py-12">
        <p class="text-lg text-muted-foreground">No listings yet</p>
      </div>
    )}
  </div>

  <!-- Embed data for client-side filtering -->
  <script is:inline>
    window.__CATEGORIES_DATA__ = JSON.parse(`${categoriesJson}`);
    window.__PAGE_SIZE__ = PAGE_SIZE;
  </script>

  <script is:inline>
    const PAGE_SIZE = window.__PAGE_SIZE__;
    const categories = window.__CATEGORIES_DATA__;
    let currentFilter = 'all';
    let visibleCounts = {};
    const container = document.getElementById('categories-container');

    function escapeHtml(str) {
      if (str == null) return '';
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    const getUrl = (item) => {
      return item.entityType === 'nonprofit'
        ? `/non-profit/${item.slug}`
        : `/business/${item.slug}`;
    };

    const renderCategory = (cat, filter = 'all', searchTerm = '', activeTag = null) => {
      let filteredListings = cat.listings.filter(l => {
        const filterToEntity = filter === 'organization' ? 'nonprofit' : filter;
        const matchesType = filter === 'all' || l.entityType === filterToEntity;
        const matchesSearch = !searchTerm || l.title.toLowerCase().includes(searchTerm);
        const matchesTag = !activeTag || (l.tags && l.tags.includes(activeTag));
        return matchesType && matchesSearch && matchesTag;
      });

      const visible = visibleCounts[cat.id] || PAGE_SIZE;
      const hasMore = filteredListings.length > visible;
      filteredListings = filteredListings.slice(0, visible);

      if (filteredListings.length === 0 && (searchTerm || activeTag)) return '';

      return `
        <div class="category-section" data-category="${cat.slug}">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center text-lg">
                ${cat.icon || cat.name.charAt(0)}
              </div>
              <h2 class="text-lg font-semibold">${escapeHtml(cat.name)}</h2>
            </div>
            <span class="text-xs text-muted-foreground">
              ${filteredListings.length} / ${cat.totalCount}
            </span>
          </div>

          ${cat.tags && cat.tags.length > 0 ? `
            <div class="flex flex-wrap gap-1 mb-3">
              <button class="tag-filter px-2 py-0.5 text-[10px] rounded-full border transition-colors cursor-pointer ${!activeTag ? 'bg-primary text-primary-foreground border-primary' : 'bg-muted hover:bg-muted/80'}" data-category="${cat.id}" data-tag="">
                All
              </button>
              ${cat.tags.map(tag => `
                <button class="tag-filter px-2 py-0.5 text-[10px] rounded-full border transition-colors cursor-pointer ${activeTag === tag ? 'bg-primary text-primary-foreground border-primary' : 'bg-muted hover:bg-muted/80'}" data-category="${cat.id}" data-tag="${escapeHtml(tag)}">
                  ${escapeHtml(tag)}
                </button>
              `).join('')}
            </div>
          ` : ''}

          <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-2">
            ${filteredListings.map(item => `
              <a href="${getUrl(item)}" class="block bg-card rounded-lg border shadow-sm hover:shadow-md hover:border-primary/30 transition-all duration-200 overflow-hidden group cursor-pointer">
                <div class="aspect-square bg-gradient-to-br from-amber-100 to-orange-100 dark:from-amber-900/40 dark:to-orange-900/40 relative">
                  ${item.profileImageId
                    ? `<img src="/api/media/${item.profileImageId}" alt="${escapeHtml(item.title)}" class="w-full h-full object-cover" />`
                    : `<div class="absolute inset-0 flex items-center justify-center text-xl font-bold text-amber-500/40">${escapeHtml(item.title.charAt(0))}</div>`
                  }
                </div>
                <div class="p-1.5">
                  <h3 class="font-medium text-[11px] truncate group-hover:text-primary transition-colors leading-tight">${escapeHtml(item.title)}</h3>
                </div>
              </a>
            `).join('')}
          </div>

          ${hasMore ? `
            <div class="text-center mt-3">
              <button class="load-more-btn text-xs text-primary hover:underline" data-category="${cat.slug}" data-filter="${filter}" data-tag="${activeTag || ''}" data-page="1">
                Load more
              </button>
            </div>
          ` : ''}
        </div>
      `;
    };

    let activeTags = {};

    const renderAll = () => {
      const searchTerm = document.getElementById('search')?.value.toLowerCase() || '';

      categories.forEach(cat => {
        if (!visibleCounts[cat.id]) visibleCounts[cat.id] = PAGE_SIZE;
        if (!(cat.id in activeTags)) activeTags[cat.id] = null;
      });

      const filteredCategories = categories.filter(cat => {
        const matchesSearch = !searchTerm || cat.name.toLowerCase().includes(searchTerm);
        // Filter by category entity_type first
        const matchesCategoryType = currentFilter === 'all' ||
          (currentFilter === 'business' && cat.entityType === 'business') ||
          (currentFilter === 'nonprofit' && cat.entityType === 'nonprofit');
        const hasListings = cat.listings.some(l => {
          const filterToEntity = currentFilter;
          const matchesType = currentFilter === 'all' || l.entityType === filterToEntity;
          const matchesSearch = !searchTerm || l.title.toLowerCase().includes(searchTerm);
          const matchesTag = !activeTags[cat.id] || (l.tags && l.tags.includes(activeTags[cat.id]));
          return matchesType && matchesSearch && matchesTag;
        });
        return matchesSearch && matchesCategoryType && hasListings;
      });

      container.innerHTML = filteredCategories.map(cat => renderCategory(cat, currentFilter, searchTerm, activeTags[cat.id])).join('');
    };

    document.querySelectorAll('.filter-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        currentFilter = tab.dataset.filter || 'all';
        document.querySelectorAll('.filter-tab').forEach(t => {
          if (t.dataset.filter === currentFilter) {
            t.classList.add('border-primary', 'text-foreground');
            t.classList.remove('border-transparent', 'text-muted-foreground');
          } else {
            t.classList.remove('border-primary', 'text-foreground');
            t.classList.add('border-transparent', 'text-muted-foreground');
          }
        });
        renderAll();
      });
    });

    document.getElementById('search')?.addEventListener('input', () => renderAll());

    container.addEventListener('click', (e) => {
      if (e.target.classList.contains('tag-filter')) {
        const btn = e.target;
        const catId = btn.dataset.category;
        const tag = btn.dataset.tag;
        activeTags[catId] = tag || null;
        visibleCounts[catId] = PAGE_SIZE;
        renderAll();
      }
    });

    container.addEventListener('click', async (e) => {
      if (e.target.classList.contains('load-more-btn')) {
        const btn = e.target;
        const catSlug = btn.dataset.category;
        const filter = btn.dataset.filter || 'all';
        const activeTag = btn.dataset.tag || null;
        const nextPage = parseInt(btn.dataset.page || '1') + 1;

        btn.textContent = 'Loading...';
        btn.disabled = true;

        try {
          const typeParam = filter !== 'all' ? `&type=${filter}` : '';
          const res = await fetch(`/api/categories/${catSlug}/listingss?page=${nextPage}&limit=${PAGE_SIZE}${typeParam}`);
          const data = await res.json();

          const section = document.querySelector(`[data-category="${catSlug}"] .grid`);
          if (section && data.listings?.length > 0) {
            data.listings.forEach(item => {
              const html = `
                <a href="${getUrl(item)}" class="block bg-card rounded-lg border shadow-sm hover:shadow-md hover:border-primary/30 transition-all duration-200 overflow-hidden group">
                  <div class="aspect-square bg-gradient-to-br from-amber-100 to-orange-100 dark:from-amber-900/40 dark:to-orange-900/40 relative">
                    ${item.profileImageId
                      ? `<img src="/api/media/${item.profileImageId}" alt="${item.title}" class="w-full h-full object-cover" />`
                      : `<div class="absolute inset-0 flex items-center justify-center text-xl font-bold text-amber-500/40">${item.title.charAt(0)}</div>`
                    }
                  </div>
                  <div class="p-1.5">
                    <h3 class="font-medium text-[11px] truncate group-hover:text-primary transition-colors leading-tight">${item.title}</h3>
                  </div>
                </a>
              `;
              section.insertAdjacentHTML('beforeend', html);
            });
          }

          if (data.hasMore) {
            btn.dataset.page = String(nextPage);
            btn.textContent = 'Load more';
            btn.disabled = false;
          } else {
            btn.remove();
          }
        } catch (err) {
          console.error('Failed to load more:', err);
          btn.textContent = 'Load more';
          btn.disabled = false;
        }
      }
    });

    renderAll();
  </script>
</Layout>