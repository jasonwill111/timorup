---
// Business detail page with SSR + Server Islands
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import ProductsSection from '../../components/islands/ProductsSection.astro';
import BusinessSidebar from '../../components/islands/BusinessSidebar.astro';
import { Share2, Eye, Heart, Bookmark, Globe, MapPin, Tag, Clock } from '@lucide/astro';
import { getDb } from '@/lib/db';
const db = await getDb();
import { businessPages, categories, reviews, media } from '@/db/schema';
import { eq, desc, inArray } from 'drizzle-orm';

const { slug } = Astro.params;
const siteUrl = import.meta.env.SITE || 'https://timorlist.com';
const canonicalUrl = `${siteUrl}/business/${slug}`;

// SSR: Load business data
const business = await db.select()
  .from(businessPages)
  .where(eq(businessPages.slug, slug ?? ''))
  .get();

if (!business || business.entityType !== 'business') {
  return Astro.redirect('/businesses');
}

// Draft pages only visible to owner (check via session)
let isOwner = false;
if (business.status === 'draft') {
  const cookieHeader = Astro.request.headers.get('cookie') || '';
  const tokenMatch = cookieHeader.match(/better-auth\.session_token=([^;]+)/);

  if (tokenMatch) {
    const { sessions } = await import('@/db/schema');
    const session = await db.select()
      .from(sessions)
      .where(eq(sessions.token, tokenMatch[1]))
      .limit(1)
      .get();

    if (session && session.userId === business.ownerId) {
      isOwner = true;
    }
  }

  // Non-owner viewing draft = redirect
  if (!isOwner) {
    return Astro.redirect('/businesses');
  }
}

// Check if business is expired
const isExpired = business.expiryDate && business.expiryDate < new Date();
const daysSinceExpiry = business.expiryDate
  ? Math.floor((Date.now() - business.expiryDate.getTime()) / (1000 * 60 * 60 * 24))
  : 0;

// If expired < 60 days, show modal only
const showExpiredModal = isExpired && daysSinceExpiry < 60;

const category = business.categoryId
  ? await db.select().from(categories).where(eq(categories.id, business.categoryId)).get()
  : null;

const businessReviews = await db.select()
  .from(reviews)
  .where(eq(reviews.businessPageId, business.id))
  .orderBy(desc(reviews.createdAt))
  .all();

const tags = business.tags ? JSON.parse(business.tags) : [];
const openingHours = business.openingHours ? JSON.parse(business.openingHours) : null;
const socialLinks = business.socialLinks ? JSON.parse(business.socialLinks) : {};
const photoGallery = business.photoGallery ? JSON.parse(business.photoGallery) : [];
const latestUpdate = business.latestUpdate || null;

// Load photo gallery images
let galleryImages: { id: string; url: string }[] = [];
if (photoGallery.length > 0) {
  const mediaItems = await db.select({ id: media.id, url: media.url })
    .from(media)
    .where(inArray(media.id, photoGallery))
    .all();
  galleryImages = mediaItems.map(m => ({ id: m.id, url: `/api/media/${m.id}` }));
}

const pageTitle = `${business.title} - TimorList`;
const pageDesc = business.aboutUs?.substring(0, 160) || `${business.title} - ${category?.name || 'Business'} in Timor-Leste`;
---

<Layout title={pageTitle} description={pageDesc} canonical={canonicalUrl}>
  <!-- Expired Business Modal -->
  {showExpiredModal && (
    <div id="expired-modal" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/70">
      <div class="bg-card border rounded-xl p-8 max-w-md mx-4 text-center shadow-2xl">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center">
          <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h2 class="text-xl font-bold mb-2">{business.title}</h2>
        <p class="text-muted-foreground mb-2">此商家未付费</p>
        <p class="text-sm text-muted-foreground mb-6">
          已过期 <span class="font-semibold text-foreground">{daysSinceExpiry}</span> 天
          {daysSinceExpiry >= 50 && '，即将被删除'}
        </p>
        <a
          href="/pricing"
          class="inline-block px-6 py-3 bg-primary text-primary-foreground font-semibold rounded-lg hover:opacity-90 transition-opacity"
        >
          立即续费
        </a>
        <p class="text-xs text-muted-foreground mt-4">续费后可恢复正常展示</p>
      </div>
    </div>
  )}

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": category?.slug === 'restaurants-cafes' ? 'Restaurant' :
            category?.slug === 'hotels-accommodation' ? 'Hotel' : 'LocalBusiness',
    "name": business.title,
    "description": business.aboutUs,
    "url": canonicalUrl,
    "image": business.profileImageId ? `/api/media/${business.profileImageId}` : undefined,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": business.address,
      "addressLocality": "Dili",
      "addressCountry": "TL"
    },
    "geo": business.locationLat && business.locationLng ? {
      "@type": "GeoCoordinates",
      "latitude": business.locationLat,
      "longitude": business.locationLng
    } : undefined,
    "telephone": business.contactNumber ? `${business.countryCode} ${business.contactNumber}` : undefined,
    "aggregateRating": business.ratingCount > 0 ? {
      "@type": "AggregateRating",
      "ratingValue": business.ratingAverage,
      "reviewCount": business.ratingCount
    } : undefined
  })} />

  <div class="bg-background min-h-screen">
    <!-- Banner -->
    <div class="relative h-48 md:h-64 bg-gradient-to-br from-amber-100 to-amber-200 dark:from-amber-900/30 dark:to-amber-800/30">
      {business.bannerImageId && (
        <img src={`/api/media/${business.bannerImageId}`} class="w-full h-full object-cover" alt="" />
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
    </div>

    <div class="container max-w-6xl mx-auto px-4 md:px-6 -mt-16 relative z-10 pb-12">
      <!-- Header (full width) -->
      <div class="bg-card border rounded-xl shadow p-4 mb-6">
        <div class="flex items-start gap-4">
          <!-- Profile -->
          <div class="w-16 h-16 md:w-20 md:h-20 rounded-full overflow-hidden bg-muted flex-shrink-0 border-2 border-background shadow">
            {business.profileImageId ? (
              <img src={`/api/media/${business.profileImageId}`} class="w-full h-full object-cover" alt={business.title} />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-2xl font-bold text-muted-foreground bg-primary/10">
                {business.title.charAt(0)}
              </div>
            )}
          </div>

          <!-- Info + Actions -->
          <div class="flex-1 min-w-0">
            <!-- Top row: Title + Actions -->
            <div class="flex items-start justify-between gap-3">
              <div class="space-y-1">
                <div class="flex items-center gap-2 flex-wrap">
                  <h1 class="text-xl md:text-2xl font-bold">{business.title}</h1>
                  {business.status === 'live' && (
                    <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400">Live</span>
                  )}
                  {business.status === 'draft' && (
                    <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400">Preview</span>
                  )}
                  {category && <span class="text-xs text-muted-foreground">{category.name}</span>}
                </div>
                <!-- Contact info -->
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs">
                  {business.contactNumber && (
                    <a href={`tel:${business.countryCode}${business.contactNumber}`} class="text-foreground hover:text-primary font-medium">
                      {business.countryCode} {business.contactNumber}
                    </a>
                  )}
                  {business.contactName && <span class="text-muted-foreground">{business.contactName}</span>}
                  {business.email && (
                    <a href={`mailto:${business.email}`} class="text-muted-foreground hover:text-primary">{business.email}</a>
                  )}
                  {business.yearOfEstablishment && (
                    <span class="text-muted-foreground">Est. {business.yearOfEstablishment}</span>
                  )}
                </div>
                <!-- About -->
                {business.aboutUs && (
                  <p class="text-xs text-muted-foreground/70 italic">{business.aboutUs}</p>
                )}
              </div>
              <!-- Actions: icons row + WhatsApp row -->
              <div class="flex flex-col items-end gap-1 flex-shrink-0">
                <div class="flex items-center gap-1">
                  <div class="flex flex-col items-center px-1" title="Views">
                    <Eye class="w-4 h-4 text-muted-foreground" />
                    <span class="text-[10px] text-muted-foreground">{business.views || 0}</span>
                  </div>
                  <div class="flex flex-col items-center px-1" title="Likes">
                    <Heart class="w-4 h-4 text-muted-foreground" />
                    <span class="text-[10px] text-muted-foreground">{business.likes || 0}</span>
                  </div>
                  <div class="flex flex-col items-center px-1" title="Saves">
                    <Bookmark class="w-4 h-4 text-muted-foreground" />
                    <span class="text-[10px] text-muted-foreground">{business.saves || 0}</span>
                  </div>
                  <button id="share-btn" class="p-1 rounded-full hover:bg-muted transition-colors" title="Share">
                    <Share2 class="w-4 h-4" />
                  </button>
                </div>
                {business.contactNumber && (
                  <a href={`https://wa.me/${business.contactNumber.replace(/\s/g, '')}?text=Hi, I'm interested in ${encodeURIComponent(business.title)}`} target="_blank">
                    <Button size="sm" class="!bg-[#25D366] hover:!bg-[#20BD5A] text-white shadow-sm">
                      <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                      </svg>
                      WhatsApp
                    </Button>
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Main Grid: Products (60%) + Sidebar (40%) -->
      <div class="grid lg:grid-cols-10 gap-4">
        <!-- Left: Products + Reviews (60%) -->
        <div class="lg:col-span-6 space-y-4">
          <!-- Latest Update -->
          {latestUpdate && (
            <Card class="border-l-4 border-l-primary">
            <div class="p-3">
              <h3 class="font-semibold text-sm mb-2 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/>
                </svg>
                Latest Update
              </h3>
              <p class="text-sm text-muted-foreground">{latestUpdate}</p>
              {business.latestUpdateDate && (
                <p class="text-xs text-muted-foreground/60 mt-2">
                  {new Date(business.latestUpdateDate).toLocaleDateString()}
                </p>
              )}
            </div>
          </Card>
          )}

          <!-- Products & Services - Server Island (dynamic content) -->
          <ProductsSection server:defer="2min" businessId={business.id} slug={slug ?? ''} />

          {/* Reviews section disabled - will enable when data volume increases */}
          {/*
          <!-- Reviews -->
          <Card>
            <div class="p-3 border-b">
              <div class="flex items-center justify-between">
                <h2 class="text-lg font-semibold">Reviews</h2>
                <div class="flex items-center gap-2">
                  <span class="text-lg font-bold">{business.ratingAverage?.toFixed(1) || '0.0'}</span>
                  <div class="flex">
                    {[1, 2, 3, 4, 5].map(i => (
                      <Star class={`w-4 h-4 ${i <= Math.round(business.ratingAverage || 0) ? 'text-yellow-500 fill-yellow-500' : 'text-gray-300'}`} />
                    ))}
                  </div>
                  <span class="text-xs text-muted-foreground">({businessReviews.length})</span>
                </div>
              </div>
            </div>

            {businessReviews.length > 0 ? (
              <div class="divide-y">
                {businessReviews.slice(0, 5).map(review => (
                  <div class="p-4">
                    <div class="flex items-center justify-between mb-2">
                      <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-sm font-medium">U</div>
                        <span class="font-medium text-sm">User</span>
                      </div>
                      <div class="flex">
                        {[1, 2, 3, 4, 5].map(i => (
                          <Star class={`w-4 h-4 ${i <= review.rating ? 'text-yellow-500 fill-yellow-500' : 'text-gray-300'}`} />
                        ))}
                      </div>
                    </div>
                    {review.comment && <p class="text-sm text-muted-foreground">{review.comment}</p>}
                    <p class="text-xs text-muted-foreground mt-2">{new Date(review.createdAt).toLocaleDateString()}</p>

                    {review.reply && (
                      <div class="mt-3 bg-gray-50 dark:bg-gray-800 rounded-lg p-3 border-l-4 border-primary">
                        <p class="text-xs font-medium text-muted-foreground mb-1">Owner Reply:</p>
                        <p class="text-sm">{review.reply}</p>
                        {review.repliedAt && (
                          <p class="text-xs text-muted-foreground mt-1">
                            Replied on {new Date(review.repliedAt).toLocaleDateString()}
                          </p>
                        )}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            ) : (
              <div class="p-8 text-center">
                <p class="text-muted-foreground">No reviews yet.</p>
              </div>
            )}
          </Card>
          */}
        </div>

        <!-- Right Sidebar (40%) -->
        <div class="lg:col-span-4 space-y-4">
          <!-- Social Links -->
          {(socialLinks.facebook || socialLinks.instagram || socialLinks.tiktok) && (
            <Card>
              <div class="p-3">
                <h3 class="font-semibold text-sm mb-3 flex items-center gap-2">
                  <Globe class="w-4 h-4" />
                  Follow Us
                </h3>
                <div class="flex gap-3">
                  {socialLinks.facebook && (
                    <a href={socialLinks.facebook} target="_blank" class="p-2 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-600 hover:bg-blue-200 transition-colors">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                      </svg>
                    </a>
                  )}
                  {socialLinks.instagram && (
                    <a href={socialLinks.instagram} target="_blank" class="p-2 rounded-full bg-pink-100 dark:bg-pink-900/30 text-pink-600 hover:bg-pink-200 transition-colors">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                      </svg>
                    </a>
                  )}
                  {socialLinks.tiktok && (
                    <a href={socialLinks.tiktok} target="_blank" class="p-2 rounded-full bg-black dark:bg-gray-800 text-white hover:bg-gray-700 transition-colors">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1-.1z"/>
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </Card>
          )}

          <!-- Photo Gallery -->
          <Card>
            <div class="p-3">
              <h3 class="font-semibold text-sm mb-3 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                Photo Gallery
              </h3>
              {galleryImages.length > 0 ? (
                <div class="grid grid-cols-3 gap-2" id="gallery-grid">
                  {galleryImages.slice(0, 6).map((img, idx) => (
                    <div class={`aspect-square rounded-lg overflow-hidden bg-muted cursor-pointer hover:opacity-90 transition-opacity ${galleryImages.length === 1 ? 'col-span-3' : ''}`} data-gallery-idx={idx}>
                      <img src={img.url} alt={`Gallery ${idx + 1}`} class="w-full h-full object-cover" />
                    </div>
                  ))}
                </div>
              ) : (
                <div class="grid grid-cols-3 gap-2">
                  {[1, 2, 3, 4, 5, 6].map(() => (
                    <div class="aspect-square rounded-lg border-2 border-dashed border-muted-foreground/20 flex items-center justify-center bg-muted/30">
                      <svg class="w-6 h-6 text-muted-foreground/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                      </svg>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </Card>

          <!-- Map -->
          <Card>
            <div class="p-3">
              <h3 class="font-semibold text-sm mb-2 flex items-center gap-2">
                <MapPin class="w-4 h-4" />
                Location
              </h3>
              {business.locationLat && business.locationLng ? (
                <>
                  <div class="aspect-video rounded-lg overflow-hidden border mb-2">
                    <img
                      src={`https://static-maps.yandex.ru/1.x/?ll=${business.locationLng},${business.locationLat}&z=15&l=map&size=400,200&pt=${business.locationLng},${business.locationLat},pm2rdm`}
                      alt="Map"
                      class="w-full h-full object-cover"
                      onerror={`this.src='https://www.openstreetmap.org/export/embed.html?bbox=${(business.locationLng - 0.01).toFixed(4)},${(business.locationLat - 0.01).toFixed(4)},${(business.locationLng + 0.01).toFixed(4)},${(business.locationLat + 0.01).toFixed(4)}&layer=mapnik&marker=${business.locationLat},${business.locationLng}'`}
                    />
                  </div>
                  {business.address && <p class="text-xs text-muted-foreground mb-2">{business.address}</p>}
                  <a href={`https://www.openstreetmap.org/?mlat=${business.locationLat}&mlon=${business.locationLng}#map=15/${business.locationLat}/${business.locationLng}`} target="_blank" class="text-xs text-primary hover:underline">
                    Open in Maps →
                  </a>
                </>
              ) : (
                <p class="text-xs text-muted-foreground italic">Location not available.</p>
              )}
            </div>
          </Card>

          <!-- Tags -->
          {tags.length > 0 && (
            <Card>
              <div class="p-3">
                <h3 class="font-semibold text-sm mb-2 flex items-center gap-2">
                  <Tag class="w-4 h-4" />
                  Tags
                </h3>
                <div class="flex flex-wrap gap-1.5">
                  {tags.map((tag: string) => (
                    <span class="px-2 py-0.5 text-xs bg-muted rounded-full">{tag}</span>
                  ))}
                </div>
              </div>
            </Card>
          )}

          <!-- Hours -->
          <Card>
            <div class="p-3">
              <h3 class="font-semibold text-sm mb-2 flex items-center gap-2">
                <Clock class="w-4 h-4" />
                Hours
              </h3>
              {openingHours ? (
                <div class="space-y-1 text-xs">
                  {['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'].map(day => {
                    const dayData = openingHours[day];
                    const dayName = day.charAt(0).toUpperCase() + day.slice(1);
                    if (dayData?.open === 'closed') {
                      return <div class="flex justify-between"><span>{dayName}</span><span class="text-red-500">Closed</span></div>;
                    }
                    if (dayData?.open && dayData?.close) {
                      return <div class="flex justify-between"><span>{dayName}</span><span>{dayData.open} - {dayData.close}</span></div>;
                    }
                    return null;
                  })}
                </div>
              ) : (
                <p class="text-xs text-muted-foreground italic">Hours not available.</p>
              )}
            </div>
          </Card>
        </div>
      </div>
    </div>
  </div>

  <!-- Gallery Lightbox Modal -->
  <div id="lightbox-modal" class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center">
    <button id="lightbox-close" class="absolute top-4 right-4 p-2 text-white hover:bg-white/20 rounded-full transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 p-2 text-white hover:bg-white/20 rounded-full transition-colors">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    </button>
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 p-2 text-white hover:bg-white/20 rounded-full transition-colors">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </button>
    <div id="lightbox-content" class="max-w-4xl max-h-[90vh]"></div>
    <div id="lightbox-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white text-sm"></div>
  </div>
</Layout>

<script>
  // Gallery Lightbox
  const modal = document.getElementById('lightbox-modal');
  const content = document.getElementById('lightbox-content');
  const counter = document.getElementById('lightbox-counter');
  const galleryItems = document.querySelectorAll('[data-gallery-idx]');
  let currentIdx = 0;

  function openLightbox(idx: number) {
    currentIdx = idx;
    showItem(currentIdx);
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function showItem(idx: number) {
    if (!content || !counter) return;
    const imgs = document.querySelectorAll('[data-gallery-idx] img');
    const total = imgs.length;
    if (total === 0) return;

    currentIdx = (idx + total) % total;
    const img = imgs[currentIdx] as HTMLImageElement;
    // Use DOM APIs instead of innerHTML to prevent XSS
    content.textContent = '';
    const imgEl = document.createElement('img');
    imgEl.src = img.src;
    imgEl.alt = img.alt || '';
    imgEl.className = 'max-w-full max-h-[85vh] object-contain rounded-lg';
    content.appendChild(imgEl);
    counter.textContent = `${currentIdx + 1} / ${total}`;
  }

  galleryItems.forEach((item, idx) => {
    item.addEventListener('click', () => openLightbox(idx));
  });

  document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
  document.getElementById('lightbox-prev')?.addEventListener('click', () => showItem(currentIdx - 1));
  document.getElementById('lightbox-next')?.addEventListener('click', () => showItem(currentIdx + 1));

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (modal?.classList.contains('flex')) {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') showItem(currentIdx - 1);
      if (e.key === 'ArrowRight') showItem(currentIdx + 1);
    }
  });

  // Share
  document.getElementById('share-btn')?.addEventListener('click', () => {
    if (navigator.share) {
      navigator.share({ title: document.title, text: 'Check out this business on TimorLIST', url: window.location.href });
    } else {
      navigator.clipboard.writeText(window.location.href);
      alert('Link copied!');
    }
  });

  // Save
  document.getElementById('save-btn')?.addEventListener('click', () => {
    alert('Save feature coming soon!');
  });

  // Like
  document.getElementById('like-btn')?.addEventListener('click', () => {
    alert('Like feature coming soon!');
  });
</script>