---
// Business detail page with SSR + Server Islands
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import LocationMap from '../../components/ui/LocationMap.astro';
import MediaGallery from '../../components/ui/MediaGallery.astro';
import UpdatesSection from '../../components/UpdatesSection.astro';
import ProductsSection from '../../components/islands/ProductsSection.astro';
import BusinessSidebar from '../../components/islands/BusinessSidebar.astro';
import { Eye, Heart, Bookmark, Globe, MapPin, Tag, Clock } from '@lucide/astro';
import ShareDialog from '@/components/ui/ShareDialog.astro';
import { getDb } from '@/lib/db';
import { createBreadcrumbSchema } from '@/lib/seo';
const db = await getDb();
import { businesses, businessCategories, reviews, media, latestUpdates } from '@/db/schema';
import { eq, desc, inArray } from 'drizzle-orm';

const { slug } = Astro.params;
const siteUrl = import.meta.env.SITE || 'https://timorup.com';
const canonicalUrl = `${siteUrl}/business/${slug}`;

// SSR: Load business data from businesses table with error handling
let business;
try {
  business = await db.select()
    .from(businesses)
    .where(eq(businesses.slug, slug ?? ''))
    .get();
} catch (e) {
  console.error('Business query failed:', e instanceof Error ? e.message : String(e));
  return Astro.redirect('/businesses');
}

if (!business) {
  return Astro.redirect('/businesses');
}

// Draft pages only visible to owner (check via session)
let isOwner = false;
let cacheControl = 'public, max-age=120, s-maxage=600, stale-while-revalidate=600';

if (business.status === 'draft') {
  const cookieHeader = Astro.request.headers.get('cookie') || '';
  const tokenMatch = cookieHeader.match(/better-auth\.session_token=([^;]+)/);

  if (tokenMatch) {
    const { sessions } = await import('@/db/schema');
    const session = await db.select()
      .from(sessions)
      .where(eq(sessions.token, tokenMatch[1]))
      .limit(1)
      .get();

    if (session && session.userId === business.ownerId) {
      isOwner = true;
      cacheControl = 'no-store'; // Don't cache draft pages
    }
  }

  // Non-owner viewing draft = redirect
  if (!isOwner) {
    return Astro.redirect('/businesses');
  }
}


// Check pending_payment status - show message to owner
const isPending = business.status === 'pending_payment';

// Check grace period using subscription fields
const subscriptionStatus = business.subscriptionStatus || 'none';
const gracePeriodEndDate = business.gracePeriodEndDate
  ? new Date(business.gracePeriodEndDate * 1000)
  : null;

const now = new Date();
const isInGracePeriod = gracePeriodEndDate
  ? subscriptionStatus === 'expired' && now < gracePeriodEndDate
  : false;

const isExpiredBeyondGrace = subscriptionStatus === 'expired' && (!gracePeriodEndDate || now >= gracePeriodEndDate);

const daysRemaining = gracePeriodEndDate
  ? Math.max(0, Math.ceil((gracePeriodEndDate.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)))
  : 0;

// Safe JSON parser with fallback
function safeJsonParse(str: unknown, fallback: unknown): unknown {
  if (!str || typeof str !== 'string') return fallback;
  try {
    return JSON.parse(str);
  } catch {
    return fallback;
  }
}

const tags = safeJsonParse(business.tags, []) as string[];
const openingHours = safeJsonParse(business.openingHours, null);
const socialLinks = safeJsonParse(business.socialLinks, {}) as Record<string, string>;

// Load related data with error handling
interface ReviewRecord {
  id: string;
  rating: number;
  comment: string | null;
  userName: string | null;
  createdAt: number;
}
interface UpdateRecord {
  id: string;
  content: string;
  createdAt: number;
}
let category = null;
let businessReviews: ReviewRecord[] = [];
let galleryImages: { id: string; url: string }[] = [];
let updates: UpdateRecord[] = [];

try {
  category = business.categoryId
    ? await db.select().from(businessCategories).where(eq(businessCategories.id, business.categoryId)).get()
    : null;
} catch (e) {
  console.error('Category query failed:', e);
}

try {
  businessReviews = await db.select()
    .from(reviews)
    .where(eq(reviews.businessId, business.id))
    .orderBy(desc(reviews.createdAt))
    .all();
} catch (e) {
  console.error('Reviews query failed:', e);
}

try {
  const galleryMedia = await db.select({ id: media.id })
    .from(media)
    .where(eq(media.entityId, business.id))
    .where(eq(media.entityType, 'businesses'))
    .where(eq(media.purpose, 'gallery'))
    .orderBy(media.sortOrder)
    .all();
  galleryImages = galleryMedia.map(m => ({ id: m.id, url: `/api/media/${m.id}` }));
} catch (e) {
  console.error('Gallery query failed:', e);
}

try {
  const latestUpdatesData = await db.select()
    .from(latestUpdates)
    .where(eq(latestUpdates.typeId, business.id))
    .where(eq(latestUpdates.type, 'business'))
    .orderBy(desc(latestUpdates.createdAt))
    .limit(4)
    .all();
  updates = latestUpdatesData.map(u => ({
    ...u,
    images: safeJsonParse(u.imageIds, []),
  }));
} catch (e) {
  console.error('Updates query failed:', e);
}

const pageTitle = `${business.title} - TimorUp`;
const pageDesc = business.aboutUs?.substring(0, 160) || `${business.title} - ${category?.name || 'Business'} in Timor-Leste`;
---

<Layout title={pageTitle} description={pageDesc} canonical={canonicalUrl}>
  <!-- Pending Approval Banner -->
  {isPending && (
    <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-4 mb-6">
      <div class="flex items-center gap-3">
        <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div>
          <p class="font-semibold text-amber-800 dark:text-amber-200">Pending Approval</p>
          <p class="text-sm text-amber-700 dark:text-amber-300">等待管理员确认付款后，您的商家页面将公开发布。</p>
          <a href="/subscribe" class="inline-block mt-2 text-sm font-medium text-amber-600 hover:text-amber-700 dark:text-amber-400">
            完成付款 →
          </a>
        </div>
      </div>
    </div>
  )}

  <!-- Expired Banner (shown in grace period only - full page overlay handles expired beyond grace) -->
  {isInGracePeriod && (
    <div class="bg-red-100 dark:bg-red-900/30 border border-red-300 dark:border-red-700 rounded-lg p-4 mb-4">
      <div class="flex items-center gap-3">
        <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div>
          <p class="font-semibold text-red-800 dark:text-red-300">Subscription Expired</p>
          <p class="text-sm text-red-600 dark:text-red-400">Your subscription has expired. <a href="/subscribe" class="underline">Renew now</a> to restore full visibility.</p>
        </div>
      </div>
    </div>
  )}

  <!-- Grace Period / Expired - Show only title, hide all other content -->
  {(isInGracePeriod || isExpiredBeyondGrace) && (
    <div class="fixed inset-0 z-[100] flex items-center justify-center bg-background/95 backdrop-blur-sm">
      <div class="bg-card border rounded-xl p-8 max-w-md mx-4 text-center shadow-2xl">
        {isExpiredBeyondGrace ? (
          <>
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
              <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold mb-2">{business.title}</h2>
            <p class="text-muted-foreground mb-4">此页面已过期，内容不再公开显示。</p>
          </>
        ) : (
          <>
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center">
              <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold mb-2">{business.title}</h2>
            <p class="text-muted-foreground mb-4">请及时为 Business Page 续费，否则 60 天之后会删除。</p>
            <p class="text-lg font-semibold text-primary mb-6">剩余 {daysRemaining} 天</p>
          </>
        )}
        <a
          href={`/subscribe?business=${business.slug}`}
          class="inline-block px-6 py-3 bg-primary text-primary-foreground font-semibold rounded-lg hover:opacity-90 transition-opacity"
        >
          立即续费
        </a>
      </div>
    </div>
  )}

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": category?.slug === 'restaurants-cafes' ? 'Restaurant' :
            category?.slug === 'hotels-accommodation' ? 'Hotel' : 'LocalBusiness',
    "name": business.title,
    "description": business.aboutUs,
    "url": canonicalUrl,
    "image": business.profileImageId ? `/api/media/${business.profileImageId}` : undefined,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": business.address,
      "addressLocality": "Dili",
      "addressCountry": "TL"
    },
    "geo": business.locationLat && business.locationLng ? {
      "@type": "GeoCoordinates",
      "latitude": business.locationLat,
      "longitude": business.locationLng
    } : undefined,
    "telephone": business.contactNumber ? `${business.countryCode} ${business.contactNumber}` : undefined,
    "aggregateRating": business.ratingCount > 0 ? {
      "@type": "AggregateRating",
      "ratingValue": business.ratingAverage,
      "reviewCount": business.ratingCount
    } : undefined
  })} />

  <!-- Breadcrumb JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(createBreadcrumbSchema([
    { name: 'Home', url: `${siteUrl}/` },
    { name: 'Businesses', url: `${siteUrl}/businesses` },
    { name: business.title || slug }
  ]))} />

  <div class="bg-background min-h-screen" class:list={{ 'blur-sm pointer-events-none select-none': isInGracePeriod || isExpiredBeyondGrace }}>
    <!-- Banner -->
    <div class="relative h-48 md:h-64 bg-gradient-to-br from-amber-100 to-amber-200 dark:from-amber-900/30 dark:to-amber-800/30">
      {business.bannerImageId && (
        <img src={`/api/media/${business.bannerImageId}`} class="w-full h-full object-cover" alt="" loading="eager" decoding="auto" />
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
    </div>

    <div class="container max-w-6xl mx-auto px-4 md:px-6 -mt-16 relative z-10 pb-12">
      <!-- Header Card -->
      <div class="bg-card border rounded-2xl shadow-lg p-4 md:p-5 mb-6">
        <!-- Mobile: Stack vertically | Desktop: Two columns -->
        <div class="flex flex-col lg:flex-row gap-5">
          <!-- Left Column: Profile + Info -->
          <div class="flex flex-row gap-4 lg:w-1/2 lg:items-start">
            <!-- Profile Image -->
            <div class="flex-shrink-0">
              <div class="w-20 h-20 md:w-24 md:h-24 rounded-xl overflow-hidden bg-muted border-2 border-background shadow-lg">
                {business.profileImageId ? (
                  <img src={`/api/media/${business.profileImageId}`} class="w-full h-full object-cover" alt={business.title} loading="eager" decoding="auto" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-4xl md:text-5xl font-bold text-muted-foreground bg-primary/10">
                    {business.title.charAt(0)}
                  </div>
                )}
              </div>
            </div>

            <!-- Name + Contact Info -->
            <div class="flex-1 min-w-0">
              <h1 class="text-xl md:text-2xl font-bold">{business.title}</h1>
              {category && (
                <p class="text-xs text-muted-foreground mt-0.5">{category.name}</p>
              )}
              <div class="mt-1 space-y-1">
                {business.contactNumber && (
                  <div class="flex items-center gap-2 text-sm">
                    <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    <span class="text-muted-foreground">{business.countryCode} {business.contactNumber}</span>
                  </div>
                )}
                {business.contactName && (
                  <div class="flex items-center gap-2 text-sm">
                    <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    <span class="text-muted-foreground">{business.contactName}</span>
                  </div>
                )}
                {business.email && (
                  <div class="flex items-center gap-2 text-sm">
                    <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    <span class="text-muted-foreground truncate">{business.email}</span>
                  </div>
                )}
                {business.yearOfEstablishment && (
                  <div class="flex items-center gap-2 text-xs text-muted-foreground">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <span>Est. {business.yearOfEstablishment}</span>
                  </div>
                )}
              </div>
            </div>
          </div>

          <!-- Right Column: Stats + Share | WhatsApp -->
          <div class="flex flex-col lg:w-1/2 lg:items-end lg:justify-start gap-3">
            <!-- Stats + Share in one row -->
            <div class="flex items-center gap-4 text-xs text-muted-foreground">
              <div class="flex items-center gap-1" title="Views">
                <Eye class="w-3.5 h-3.5" />
                <span>{business.views || 0}</span>
              </div>
              <div class="flex items-center gap-1" title="Likes">
                <Heart class="w-3.5 h-3.5" />
                <span>{business.likes || 0}</span>
              </div>
              <div class="flex items-center gap-1" title="Saves">
                <Bookmark class="w-3.5 h-3.5" />
                <span>{business.saves || 0}</span>
              </div>
              <ShareDialog url={canonicalUrl} title={business.title} class="p-1.5" />
            </div>

            <!-- WhatsApp -->
            {business.contactNumber && (
              <a href={`https://wa.me/${business.contactNumber.replace(/\s/g, '')}?text=Hi, I'm interested in ${encodeURIComponent(business.title)}`} target="_blank" class="flex items-center gap-1.5 px-3 py-2 bg-[#25D366] hover:bg-[#20BD5A] text-white rounded-lg text-sm font-medium transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp
              </a>
            )}
          </div>
        </div>
      </div>

      <!-- Main Content: About Us + Products (left) | Sidebar (right) -->
      <div class="grid lg:grid-cols-10 gap-6">
        <!-- Left Column: About Us + Products (60%) -->
        <div class="lg:col-span-6 space-y-3">
          <!-- About Us -->
          {business.aboutUs && (
            <Card>
              <div class="p-4">
                <h2 class="font-semibold text-base mb-2">About Us</h2>
                <p class="text-sm text-muted-foreground leading-relaxed whitespace-pre-wrap">{business.aboutUs}</p>
              </div>
            </Card>
          )}

          <!-- Updates Section -->
          {updates.length > 0 && (
            <Card>
              <div class="p-4">
                <h2 class="font-semibold text-base mb-3 flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
                  </svg>
                  Updates
                </h2>
                <UpdatesSection updates={updates} slug={slug} isOwner={isOwner} />
              </div>
            </Card>
          )}

          <!-- Legacy Latest Update (hidden when new Updates exist) -->
          {updates.length === 0 && (
            <Card class="border-l-4 border-l-primary">
              <div class="p-3">
                <h3 class="font-semibold text-sm mb-2 flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/>
                  </svg>
                  Latest Update
                </h3>
                <p class="text-sm text-muted-foreground">No updates yet</p>
              </div>
            </Card>
          )}

          <!-- Products & Services - Server Island -->
          <ProductsSection businessId={business.id} slug={slug ?? ''}>
            <!-- Skeleton fallback -->
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
              {[...Array(5)].map(() => (
                <div class="bg-muted rounded-lg animate-pulse">
                  <div class="aspect-square mb-2"></div>
                  <div class="h-4 w-3/4 mx-2 mb-1"></div>
                  <div class="h-3 w-1/2 mx-2 mb-3"></div>
                </div>
              ))}
            </div>
          </ProductsSection>
        </div>

        <!-- Right Sidebar (40%) -->
        <div class="lg:col-span-4 space-y-3">
          <!-- Social Links -->
          {(socialLinks.facebook || socialLinks.instagram || socialLinks.tiktok) && (
            <Card>
              <div class="p-3">
                <h3 class="font-semibold text-sm mb-3 flex items-center gap-2">
                  <Globe class="w-4 h-4" />
                  Follow Us
                </h3>
                <div class="flex gap-3">
                  {socialLinks.facebook && (
                    <a href={socialLinks.facebook} target="_blank" class="p-2 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-600 hover:bg-blue-200 transition-colors">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                      </svg>
                    </a>
                  )}
                  {socialLinks.instagram && (
                    <a href={socialLinks.instagram} target="_blank" class="p-2 rounded-full bg-pink-100 dark:bg-pink-900/30 text-pink-600 hover:bg-pink-200 transition-colors">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                      </svg>
                    </a>
                  )}
                  {socialLinks.tiktok && (
                    <a href={socialLinks.tiktok} target="_blank" class="p-2 rounded-full bg-black dark:bg-gray-800 text-white hover:bg-gray-700 transition-colors">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1-.1z"/>
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </Card>
          )}

          <!-- Photo Gallery -->
          <Card>
            <div class="p-3">
              <MediaGallery items={galleryImages} title="Photo Gallery" gridCols={3} maxDisplay={6} />
            </div>
          </Card>

          <!-- Map -->
          <Card>
            <div class="p-3">
              <h3 class="font-semibold text-sm mb-2 flex items-center gap-2">
                <MapPin class="w-4 h-4" />
                Location
              </h3>
              {business.locationLat && business.locationLng ? (
                <LocationMap
                  id="business-map"
                  lat={business.locationLat}
                  lng={business.locationLng}
                  address={business.address || 'View Location'}
                  openFn="openBusinessMap"
                />
              ) : (
                <p class="text-xs text-muted-foreground italic">Location not available.</p>
              )}
            </div>
          </Card>

          <!-- Tags -->
          {tags.length > 0 && (
            <Card>
              <div class="p-3">
                <h3 class="font-semibold text-sm mb-2 flex items-center gap-2">
                  <Tag class="w-4 h-4" />
                  Tags
                </h3>
                <div class="flex flex-wrap gap-1.5">
                  {tags.map((tag: string) => (
                    <span class="px-2 py-0.5 text-xs bg-muted rounded-full">{tag}</span>
                  ))}
                </div>
              </div>
            </Card>
          )}

          <!-- Hours -->
          <Card>
            <div class="p-3">
              <h3 class="font-semibold text-sm mb-2 flex items-center gap-2">
                <Clock class="w-4 h-4" />
                Hours
              </h3>
              {openingHours ? (
                <div class="space-y-1 text-xs">
                  {['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'].map(day => {
                    const dayData = openingHours[day];
                    const dayName = day.charAt(0).toUpperCase() + day.slice(1);
                    if (dayData?.open === 'closed') {
                      return <div class="flex justify-between"><span>{dayName}</span><span class="text-red-500">Closed</span></div>;
                    }
                    if (dayData?.open && dayData?.close) {
                      return <div class="flex justify-between"><span>{dayName}</span><span>{dayData.open} - {dayData.close}</span></div>;
                    }
                    return null;
                  })}
                </div>
              ) : (
                <p class="text-xs text-muted-foreground italic">Hours not available.</p>
              )}
            </div>
          </Card>
        </div>
      </div>
    </div>
  </div>

</Layout>

<script>
  // Save
  document.getElementById('save-btn')?.addEventListener('click', () => {
    alert('Save feature coming soon!');
  });

  // Like
  document.getElementById('like-btn')?.addEventListener('click', () => {
    alert('Like feature coming soon!');
  });

  // Global map navigation function
  window.openBusinessMap = function(lat: string, lng: string) {
    const isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
    if (isMobile) {
      const url = navigator.userAgent.includes('iPhone')
        ? `http://maps.apple.com/?daddr=${lat},${lng}`
        : `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}`;
      window.open(url, '_blank');
    } else {
      window.open(`https://www.google.com/maps/search/?api=1&query=${lat},${lng}`, '_blank');
    }
  };
</script>