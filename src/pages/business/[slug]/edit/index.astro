---
export const prerender = false;

import Layout from '@/layouts/Layout.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import CardHeader from '@/components/ui/CardHeader.astro';
import CardTitle from '@/components/ui/CardTitle.astro';
import CardDescription from '@/components/ui/CardDescription.astro';
import CardContent from '@/components/ui/CardContent.astro';
---

<Layout title="Edit Business - TimorList">
  <!-- TipTap CSS -->
  <link rel="stylesheet" href="https://unpkg.com/@tiptap/core@3.22.3/dist/tiptap.min.css" />
  <div class="container py-12">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-3xl font-bold mb-2">Edit Business</h1>
      <p class="text-muted-foreground mb-8">Update your business information</p>

      <!-- Loading state -->
      <div id="loading-state" class="text-center py-20">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
        <p class="text-muted-foreground mt-2">Loading your business...</p>
      </div>

      <!-- Not found / unauthorized -->
      <div id="not-found-state" class="hidden text-center py-20">
        <p class="text-muted-foreground mb-4">Business not found or you don't have permission to edit it.</p>
        <a href="/account">
          <Button variant="outline">Back to Account</Button>
        </a>
      </div>

      <!-- Edit form -->
      <div id="edit-form-container" class="hidden">
        <form id="business-form" class="space-y-8">
          <!-- Basic Info -->
          <Card>
            <CardHeader>
              <CardTitle>Basic Information</CardTitle>
              <CardDescription>The main details about your business</CardDescription>
            </CardHeader>
            <CardContent class="space-y-4">
              <div>
                <label for="title" class="block text-sm font-medium mb-1">Business Name *</label>
                <input
                  type="text"
                  id="title"
                  name="title"
                  required
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                  placeholder="Your business name"
                />
              </div>

              <div>
                <label for="slug" class="block text-sm font-medium mb-1">URL Slug *</label>
                <input
                  type="text"
                  id="slug"
                  name="slug"
                  required
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                  placeholder="your-business-name"
                />
                <p class="text-xs text-muted-foreground mt-1">This will be your URL: timorlist.com/business/your-business-name</p>
              </div>

              <div>
                <label for="category" class="block text-sm font-medium mb-1">Category *</label>
                <select
                  id="category"
                  name="categoryId"
                  required
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                >
                  <option value="">Select a category</option>
                </select>
              </div>
            </CardContent>
          </Card>

          <!-- Contact Info -->
          <Card>
            <CardHeader>
              <CardTitle>Contact Information</CardTitle>
              <CardDescription>How customers can reach you</CardDescription>
            </CardHeader>
            <CardContent class="space-y-4">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label for="contactName" class="block text-sm font-medium mb-1">Contact Person</label>
                  <input
                    type="text"
                    id="contactName"
                    name="contactName"
                    class="w-full px-3 py-2 border rounded-lg bg-background"
                    placeholder="Your name"
                  />
                </div>
                <div>
                  <label for="contactNumber" class="block text-sm font-medium mb-1">Phone Number</label>
                  <input
                    type="tel"
                    id="contactNumber"
                    name="contactNumber"
                    class="w-full px-3 py-2 border rounded-lg bg-background"
                    placeholder="+670 7x xxx xxx"
                  />
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-medium mb-1">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                  placeholder="business@email.com"
                />
              </div>

              <div>
                <label for="address" class="block text-sm font-medium mb-1">Address</label>
                <textarea
                  id="address"
                  name="address"
                  rows="2"
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                  placeholder="Your business address"
                ></textarea>
              </div>

              <!-- Map Location -->
              <div class="mt-4">
                <label class="block text-sm font-medium mb-2">Business Location</label>
                <p class="text-xs text-muted-foreground mb-2">Click on the map to set your location, or enter coordinates manually</p>

                <div id="map-container" class="h-64 rounded-lg border mb-3" style="min-height: 250px;">
                  <div id="map-placeholder" class="h-full flex items-center justify-center bg-muted rounded-lg">
                    <p class="text-muted-foreground">Loading map...</p>
                  </div>
                  <div id="map" class="hidden h-full rounded-lg" style="min-height: 250px;"></div>
                </div>

                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label for="latitude" class="block text-xs font-medium mb-1">Latitude</label>
                    <input
                      type="number"
                      id="latitude"
                      name="latitude"
                      step="any"
                      class="w-full px-3 py-2 border rounded-lg bg-background text-sm"
                      placeholder="-8.5569"
                    />
                  </div>
                  <div>
                    <label for="longitude" class="block text-xs font-medium mb-1">Longitude</label>
                    <input
                      type="number"
                      id="longitude"
                      name="longitude"
                      step="any"
                      class="w-full px-3 py-2 border rounded-lg bg-background text-sm"
                      placeholder="125.5603"
                    />
                  </div>
                </div>

                <button type="button" id="get-coords-btn" class="mt-2 text-sm text-primary hover:underline">
                  Get coordinates from address
                </button>
              </div>
            </CardContent>
          </Card>

          <!-- About -->
          <Card>
            <CardHeader>
              <CardTitle>About Your Business</CardTitle>
              <CardDescription>Tell customers more about what you do</CardDescription>
            </CardHeader>
            <CardContent>
              <div>
                <label for="aboutUs" class="block text-sm font-medium mb-1">About Us</label>
                <div id="aboutUs-editor"></div>
                <input type="hidden" id="aboutUs" name="aboutUs" />
              </div>
            </CardContent>
          </Card>

          <!-- Opening Hours -->
          <Card>
            <CardHeader>
              <CardTitle>Opening Hours</CardTitle>
              <CardDescription>Set your business hours</CardDescription>
            </CardHeader>
            <CardContent class="space-y-3">
              <p class="text-xs text-muted-foreground">Leave time empty or check "Closed" for days you're not open</p>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-sm" id="hours-container">
                <!-- Hours will be generated by JavaScript -->
              </div>
            </CardContent>
          </Card>

          <!-- Additional Info -->
          <Card>
            <CardHeader>
              <CardTitle>Additional Details</CardTitle>
            </CardHeader>
            <CardContent class="space-y-4">
              <div>
                <label for="yearOfEstablishment" class="block text-sm font-medium mb-1">Year Established</label>
                <input
                  type="number"
                  id="yearOfEstablishment"
                  name="yearOfEstablishment"
                  min="1900"
                  max="2100"
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                  placeholder="2020"
                />
              </div>

              <div>
                <label for="tags" class="block text-sm font-medium mb-1">Tags</label>
                <input
                  type="text"
                  id="tags"
                  name="tags"
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                  placeholder="restaurant, cafe, coffee (comma separated)"
                />
              </div>
            </CardContent>
          </Card>

          <!-- Social Links -->
          <Card>
            <CardHeader>
              <CardTitle>Social Media Links</CardTitle>
            </CardHeader>
            <CardContent class="space-y-4">
              <div>
                <label for="facebookUrl" class="block text-sm font-medium mb-1">
                  <span class="inline-flex items-center gap-2">
                    <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                    Facebook
                  </span>
                </label>
                <input
                  type="url"
                  id="facebookUrl"
                  name="facebookUrl"
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                  placeholder="https://facebook.com/yourpage"
                />
              </div>

              <div>
                <label for="instagramUrl" class="block text-sm font-medium mb-1">
                  <span class="inline-flex items-center gap-2">
                    <svg class="w-4 h-4 text-pink-600" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                    </svg>
                    Instagram
                  </span>
                </label>
                <input
                  type="url"
                  id="instagramUrl"
                  name="instagramUrl"
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                  placeholder="https://instagram.com/yourpage"
                />
              </div>

              <div>
                <label for="tiktokUrl" class="block text-sm font-medium mb-1">
                  <span class="inline-flex items-center gap-2">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1-.1z"/>
                    </svg>
                    TikTok
                  </span>
                </label>
                <input
                  type="url"
                  id="tiktokUrl"
                  name="tiktokUrl"
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                  placeholder="https://tiktok.com/@yourpage"
                />
              </div>
            </CardContent>
          </Card>

          <!-- Latest Update -->
          <Card>
            <CardHeader>
              <CardTitle>Latest Update</CardTitle>
              <CardDescription>Share news or announcements (updates weekly)</CardDescription>
            </CardHeader>
            <CardContent class="space-y-4">
              <div>
                <label for="latestUpdate" class="block text-sm font-medium mb-1">Update Message</label>
                <textarea
                  id="latestUpdate"
                  name="latestUpdate"
                  rows="3"
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                  placeholder="Share your latest news, promotions, or announcements..."
                  maxlength="500"
                ></textarea>
                <p class="text-xs text-muted-foreground mt-1">Max 500 characters. Can be updated once per week.</p>
                <p id="update-cooldown" class="text-xs text-muted-foreground mt-1 hidden"></p>
              </div>
            </CardContent>
          </Card>

          <!-- Photo Gallery -->
          <Card>
            <CardHeader>
              <CardTitle>Photo Gallery</CardTitle>
              <CardDescription>Add up to 6 photos to showcase your business</CardDescription>
            </CardHeader>
            <CardContent class="space-y-4">
              <div id="gallery-upload-area" class="border-2 border-dashed border-muted-foreground/25 rounded-lg p-8 text-center hover:border-primary/50 transition-colors cursor-pointer">
                <input type="file" id="gallery-files" accept="image/*,video/mp4,video/webm,video/quicktime" multiple class="hidden" />
                <svg class="w-12 h-12 mx-auto text-muted-foreground mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <p class="text-muted-foreground mb-2">Click or drag photos here</p>
                <p class="text-xs text-muted-foreground">JPG, PNG up to 5MB each (max 6 photos)</p>
              </div>
              <div id="gallery-preview" class="grid grid-cols-3 gap-2"></div>
              <input type="hidden" id="gallery-media-ids" name="galleryMediaIds" />
            </CardContent>
          </Card>

          <!-- Submit -->
          <div class="flex gap-4">
            <Button type="submit" id="submit-btn">Save Changes</Button>
            <a id="cancel-link" href="#">
              <Button type="button" variant="outline">Cancel</Button>
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { geocodeAddress } from '@/lib/geo';

  // ── TipTap Editor Helper ─────────────────────────────────────────────────────
  async function initTipTapEditor(element: HTMLElement, options: { placeholder?: string; content?: string } = {}) {
    const textareaId = `${element.id}-content`;

    // Create hidden textarea for form submission
    const textarea = document.createElement('textarea');
    textarea.id = textareaId;
    textarea.name = 'aboutUs';
    textarea.className = 'hidden';
    element.insertAdjacentElement('afterend', textarea);

    // Dynamic imports for TipTap
    const [tiptapCore, tiptapStarterKit, tiptapLink, tiptapPlaceholder] = await Promise.all([
      import('https://esm.sh/@tiptap/core@3.22.3'),
      import('https://esm.sh/@tiptap/starter-kit@3.22.3'),
      import('https://esm.sh/@tiptap/extension-link@3.22.3'),
      import('https://esm.sh/@tiptap/extension-placeholder@3.22.3'),
    ]);

    const { Editor } = tiptapCore;
    const { default: StarterKit } = tiptapStarterKit;
    const { default: Link } = tiptapLink;
    const { default: Placeholder } = tiptapPlaceholder;

    const editor = new Editor({
      element,
      extensions: [
        StarterKit.configure({
          heading: { levels: [2, 3] },
        }),
        Link.configure({
          openOnClick: false,
          HTMLAttributes: { class: 'text-primary underline' },
        }),
        Placeholder.configure({
          placeholder: options.placeholder || 'Tell customers about your business...',
          emptyEditorClass: 'is-editor-empty',
        }),
      ],
      content: options.content || '',
      onUpdate: ({ editor }) => {
        textarea.value = editor.getHTML();
      },
      editorProps: {
        attributes: {
          class: 'prose prose-sm dark:prose-invert max-w-none focus:outline-none min-h-[150px] px-3 py-2 border rounded-lg bg-background',
        },
      },
    });

    // Initial sync
    textarea.value = editor.getHTML();

    return editor;
  }

  let userId: string | null = null;
  let businessSlug = '';
  let map: any = null;
  let marker: any = null;
  let leafletLoaded = false;
  let aboutUsEditor: any = null;
  let galleryMediaIds: string[] = [];
  const MAX_GALLERY_PHOTOS = 6;
  const MAX_VIDEO_SIZE = 8 * 1024 * 1024; // 8MB
  const MAX_IMAGE_SIZE = 2 * 1024 * 1024; // 2MB
  const VIDEO_TYPES = ['video/mp4', 'video/webm', 'video/quicktime'];
  const IMAGE_TYPES = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];

  // Photo Gallery Upload
  function initGalleryUpload() {
    const uploadArea = document.getElementById('gallery-upload-area');
    const fileInput = document.getElementById('gallery-files') as HTMLInputElement;
    const previewContainer = document.getElementById('gallery-preview');
    const mediaIdsInput = document.getElementById('gallery-media-ids') as HTMLInputElement;

    if (!uploadArea || !fileInput || !previewContainer || !mediaIdsInput) return;

    uploadArea.addEventListener('click', () => fileInput.click());

    uploadArea.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadArea.classList.add('border-primary');
    });

    uploadArea.addEventListener('dragleave', () => {
      uploadArea.classList.remove('border-primary');
    });

    uploadArea.addEventListener('drop', async (e) => {
      e.preventDefault();
      uploadArea.classList.remove('border-primary');
      const files = e.dataTransfer?.files;
      if (files) await handleFiles(files);
    });

    fileInput.addEventListener('change', async () => {
      if (fileInput.files) await handleFiles(fileInput.files);
      fileInput.value = '';
    });

    async function handleFiles(files: FileList) {
      const remaining = MAX_GALLERY_PHOTOS - galleryMediaIds.length;
      const filesToUpload = Array.from(files).slice(0, remaining);

      for (const file of filesToUpload) {
        const isImage = IMAGE_TYPES.includes(file.type);
        const isVideo = VIDEO_TYPES.includes(file.type);

        if (!isImage && !isVideo) {
          console.log('Unsupported file type:', file.type);
          continue;
        }

        // Size validation
        if (isImage && file.size > MAX_IMAGE_SIZE) {
          alert(`Image too large: ${(file.size / 1024 / 1024).toFixed(1)}MB. Max: 2MB`);
          continue;
        }
        if (isVideo && file.size > MAX_VIDEO_SIZE) {
          alert(`Video too large: ${(file.size / 1024 / 1024).toFixed(1)}MB. Max: 8MB`);
          continue;
        }

        try {
          let fileToUpload: File = file;

          // Compress videos
          if (isVideo) {
            const statusDiv = document.createElement('div');
            statusDiv.className = 'absolute inset-0 bg-black/50 flex items-center justify-center text-white text-sm rounded-lg';
            statusDiv.textContent = 'Loading video processor...';
            uploadArea.appendChild(statusDiv);

            try {
              const { compressVideo } = await import('@/lib/video-compress');
              const result = await compressVideo(file, {
                maxSize: MAX_VIDEO_SIZE,
                onProgress: (p) => {
                  statusDiv.textContent = p.message;
                }
              });

              if (!result.withinLimit) {
                alert(`Video still too large after compression: ${(result.compressedSize / 1024 / 1024).toFixed(1)}MB`);
                statusDiv.remove();
                continue;
              }

              fileToUpload = result.file;
              statusDiv.textContent = 'Uploading...';
            } catch (err) {
              console.error('Video compression error:', err);
              statusDiv.remove();
              alert('Video compression failed. Please try a smaller file.');
              continue;
            }
          }

          const formData = new FormData();
          formData.append('file', fileToUpload);

          const res = await fetch('/api/media/upload', {
            method: 'POST',
            body: formData,
          });

          const result = await res.json();
          if (result.success && result.data?.id) {
            galleryMediaIds.push(result.data.id);
            addPreview(result.data.id, result.data.url, isVideo ? 'video' : 'image');
            mediaIdsInput.value = JSON.stringify(galleryMediaIds);
          } else {
            alert(result.error?.message || 'Upload failed');
          }
        } catch (err) {
          console.error('Upload error:', err);
        }
      }
    }

    function addPreview(id: string, url: string, type: 'image' | 'video' = 'image') {
      const div = document.createElement('div');
      div.className = 'relative aspect-square rounded-lg overflow-hidden bg-muted group';
      div.dataset.id = id;

      if (type === 'video') {
        div.innerHTML = `
          <video src="${url}" class="w-full h-full object-cover" muted loop />
          <div class="absolute inset-0 flex items-center justify-center bg-black/30">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
          <button type="button" class="remove-gallery absolute top-1 right-1 w-6 h-6 bg-black/50 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-opacity">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        `;
      } else {
        div.innerHTML = `
          <img src="${url}" alt="Gallery photo" class="w-full h-full object-cover" />
          <button type="button" class="remove-gallery absolute top-1 right-1 w-6 h-6 bg-black/50 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-opacity">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        `;
      }

      div.querySelector('.remove-gallery')?.addEventListener('click', () => {
        galleryMediaIds = galleryMediaIds.filter(mid => mid !== id);
        div.remove();
        mediaIdsInput.value = JSON.stringify(galleryMediaIds);
      });
      previewContainer.appendChild(div);
    }

    // Preload video processor in background
    import('@/lib/video-compress').then(({ preloadFFmpeg }) => preloadFFmpeg());

    (window as any).loadGalleryPreview = function(ids: string[]) {
      ids.forEach(async (id: string) => {
        try {
          const res = await fetch(`/api/media/${id}`);
          const result = await res.json();
          if (result.success && result.data?.url) {
            galleryMediaIds.push(id);
            addPreview(id, result.data.url);
          }
        } catch { /* ignore */ }
      });
    };
  }

  // Get slug from URL
  const pathParts = window.location.pathname.split('/');
  businessSlug = pathParts[2] || '';

  // Get session
  async function getSession() {
    try {
      const res = await fetch('/api/auth/session');
      const data = await res.json();

      if (data.session?.user) {
        return data.session.user;
      }
      window.location.href = '/login';
      return null;
    } catch (err) {
      console.error('Error getting session:', err);
      window.location.href = '/login';
      return null;
    }
  }

  // Initialize page
  async function init() {
    const user = await getSession();
    if (!user) return;

    userId = user.id;
    const cancelLink = document.getElementById('cancel-link') as HTMLAnchorElement;
    if (cancelLink) cancelLink.href = `/business/${businessSlug}`;

    // Initialize gallery upload
    initGalleryUpload();

    // Load business data
    try {
      const res = await fetch(`/api/businesses/${businessSlug}`);
      const data = await res.json();

      if (!data.success || !data.data) {
        showNotFound();
        return;
      }

      // Check ownership
      if (data.data.ownerId !== userId) {
        showNotFound();
        return;
      }

      populateForm(data.data);
      showForm();
      loadCategories();
    } catch (err) {
      console.error('Error loading business:', err);
      showNotFound();
    }
  }

  function showForm() {
    document.getElementById('loading-state')?.classList.add('hidden');
    document.getElementById('edit-form-container')?.classList.remove('hidden');
  }

  function showNotFound() {
    document.getElementById('loading-state')?.classList.add('hidden');
    document.getElementById('not-found-state')?.classList.remove('hidden');
  }

  async function populateForm(business: any) {
    // Basic info
    const titleInput = document.getElementById('title') as HTMLInputElement;
    const slugInput = document.getElementById('slug') as HTMLInputElement;
    const contactNameInput = document.getElementById('contactName') as HTMLInputElement;
    const contactNumberInput = document.getElementById('contactNumber') as HTMLInputElement;
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const addressInput = document.getElementById('address') as HTMLTextAreaElement;
    const latInput = document.getElementById('latitude') as HTMLInputElement;
    const lngInput = document.getElementById('longitude') as HTMLInputElement;
    const aboutUsInput = document.getElementById('aboutUs') as HTMLTextAreaElement;
    const yearInput = document.getElementById('yearOfEstablishment') as HTMLInputElement;
    const tagsInput = document.getElementById('tags') as HTMLInputElement;

    if (titleInput) titleInput.value = business.title || '';
    if (slugInput) slugInput.value = business.slug || '';
    if (contactNameInput) contactNameInput.value = business.contactName || '';
    if (contactNumberInput) contactNumberInput.value = business.contactNumber || '';
    if (emailInput) emailInput.value = business.email || '';
    if (addressInput) addressInput.value = business.address || '';

    // Initialize TipTap editor with existing content
    const aboutUsContainer = document.getElementById('aboutUs-editor');
    if (aboutUsContainer) {
      aboutUsEditor = await initTipTapEditor(aboutUsContainer, {
        placeholder: 'Tell customers about your business, products, and services...',
        content: business.aboutUs || '',
      });
    }

    if (yearInput && business.yearOfEstablishment) yearInput.value = String(business.yearOfEstablishment);
    if (tagsInput && business.tags) {
      try {
        const tags = typeof business.tags === 'string' ? JSON.parse(business.tags) : business.tags;
        if (Array.isArray(tags)) tagsInput.value = tags.join(', ');
      } catch { tagsInput.value = business.tags || ''; }
    }

    // Social links
    const fbInput = document.getElementById('facebookUrl') as HTMLInputElement;
    const igInput = document.getElementById('instagramUrl') as HTMLInputElement;
    const ttInput = document.getElementById('tiktokUrl') as HTMLInputElement;
    if (business.socialLinks) {
      try {
        const links = typeof business.socialLinks === 'string' ? JSON.parse(business.socialLinks) : business.socialLinks;
        if (fbInput && links.facebook) fbInput.value = links.facebook;
        if (igInput && links.instagram) igInput.value = links.instagram;
        if (ttInput && links.tiktok) ttInput.value = links.tiktok;
      } catch { /* ignore */ }
    }

    // Latest update
    const updateInput = document.getElementById('latestUpdate') as HTMLTextAreaElement;
    const updateCooldown = document.getElementById('update-cooldown');
    if (updateInput && business.latestUpdate) updateInput.value = business.latestUpdate;
    if (updateCooldown && business.latestUpdateDate) {
      const lastUpdate = new Date(business.latestUpdateDate);
      const now = new Date();
      const daysSince = Math.floor((now.getTime() - lastUpdate.getTime()) / (1000 * 60 * 60 * 24));
      if (daysSince < 7) {
        const daysLeft = 7 - daysSince;
        updateCooldown.textContent = `You can update again in ${daysLeft} day${daysLeft > 1 ? 's' : ''}.`;
        updateCooldown.classList.remove('hidden');
      }
    }

    // Photo gallery
    const galleryInput = document.getElementById('gallery-media-ids') as HTMLInputElement;
    if (business.photoGallery && galleryInput) {
      try {
        const gallery = typeof business.photoGallery === 'string' ? JSON.parse(business.photoGallery) : business.photoGallery;
        if (Array.isArray(gallery)) {
          galleryInput.value = JSON.stringify(gallery);
          // Show existing gallery previews
          loadGalleryPreview(gallery);
        }
      } catch { /* ignore */ }
    }

    // Coordinates
    if (latInput && business.locationLat != null) latInput.value = String(business.locationLat);
    if (lngInput && business.locationLng != null) lngInput.value = String(business.locationLng);

    // Pre-select category after loadCategories runs
    (window as any).__pendingCategoryId = business.categoryId;

    // Opening hours
    populateOpeningHours(business.openingHours);

    // Init map with existing coords
    const lat = business.locationLat;
    const lng = business.locationLng;
    if (lat && lng) {
      setTimeout(() => initMap(lat, lng), 1000);
    } else {
      setTimeout(() => initMap(-8.5569, 125.5603), 1000);
    }
  }

  // Load categories and pre-select
  async function loadCategories() {
    try {
      const res = await fetch('/api/categories');
      const data = await res.json();

      const select = document.getElementById('category') as HTMLSelectElement;
      if (!data.success || !data.data?.length || !select) return;

      data.data.forEach((cat: any) => {
        const option = document.createElement('option');
        option.value = cat.id;
        option.textContent = cat.name;
        select.appendChild(option);
      });

      // Pre-select category
      const pendingCategoryId = (window as any).__pendingCategoryId;
      if (pendingCategoryId) {
        select.value = pendingCategoryId;
      }
    } catch (err) {
      console.error('Error loading categories:', err);
    }
  }

  // Opening hours
  const days = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'];
  const dayLabels = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];

  function populateOpeningHours(hoursJson: string | null) {
    let hours: Record<string, string> = {};
    if (hoursJson) {
      try { hours = typeof hoursJson === 'string' ? JSON.parse(hoursJson) : hoursJson; } catch { hours = {}; }
    }

    const container = document.getElementById('hours-container');
    if (!container) return;

    container.innerHTML = days.map((day, index) => {
      const value = hours[day] || '';
      const isClosed = value === 'closed';
      const [open = '09:00', close = '18:00'] = isClosed ? ['09:00', '18:00'] : value.split('-');

      return `
        <div class="flex items-center gap-2 p-2 border rounded-lg">
          <input type="checkbox" id="${day}-closed" name="${day}-closed" class="rounded" ${isClosed ? 'checked' : ''} />
          <label for="${day}-closed" class="w-20 font-medium">${dayLabels[index]}</label>
          <input
            type="time"
            id="${day}-open"
            name="${day}-open"
            class="border rounded px-2 py-1 text-sm"
            value="${open}"
          />
          <span>to</span>
          <input
            type="time"
            id="${day}-close"
            name="${day}-close"
            class="border rounded px-2 py-1 text-sm"
            value="${close}"
          />
        </div>
      `;
    }).join('');
  }

  // Map
  async function loadLeaflet() {
    if (leafletLoaded) return;

    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
    document.head.appendChild(link);

    await new Promise<void>((resolve) => {
      const script = document.createElement('script');
      script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      script.onload = () => resolve();
      document.head.appendChild(script);
    });

    leafletLoaded = true;
  }

  async function initMap(lat: number, lng: number) {
    await loadLeaflet();

    const mapEl = document.getElementById('map') as HTMLElement;
    const placeholder = document.getElementById('map-placeholder');
    if (!mapEl || !(window as any).L) return;

    map = (window as any).L.map('map').setView([lat, lng], 13);

    (window as any).L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    map.on('click', (e: any) => {
      setMarker(e.latlng.lat, e.latlng.lng);
    });

    mapEl.classList.remove('hidden');
    if (placeholder) placeholder.classList.add('hidden');

    // Show existing marker
    const latInput = document.getElementById('latitude') as HTMLInputElement;
    const lngInput = document.getElementById('longitude') as HTMLInputElement;
    if (latInput.value && lngInput.value) {
      setMarker(parseFloat(latInput.value), parseFloat(lngInput.value));
    }
  }

  function setMarker(lat: number, lng: number) {
    if (!map) return;

    if (marker) map.removeLayer(marker);

    marker = (window as any).L.marker([lat, lng]).addTo(map);
    map.setView([lat, lng], 15);

    const latInput = document.getElementById('latitude') as HTMLInputElement;
    const lngInput = document.getElementById('longitude') as HTMLInputElement;
    if (latInput) latInput.value = lat.toFixed(6);
    if (lngInput) lngInput.value = lng.toFixed(6);
  }

  // Geocoding button
  const getCoordsBtn = document.getElementById('get-coords-btn');
  getCoordsBtn?.addEventListener('click', async () => {
    const addressInput = document.getElementById('address') as HTMLTextAreaElement;
    const address = addressInput?.value;

    if (!address) {
      alert('Please enter an address first');
      return;
    }

    getCoordsBtn.textContent = 'Searching...';
    getCoordsBtn.setAttribute('disabled', 'true');

    try {
      const result = await geocodeAddress(address);

      if (result) {
        const { lat, lng } = result;
        if (!map) await initMap(lat, lng);
        setMarker(lat, lng);
      } else {
        alert('Address not found. Please try a more specific address or enter coordinates manually.');
      }
    } catch (err) {
      console.error('Geocoding error:', err);
      alert('Address not found. Please try a more specific address or enter coordinates manually.');
    } finally {
      getCoordsBtn.textContent = 'Get coordinates from address';
      getCoordsBtn.removeAttribute('disabled');
    }
  });

  // Manual coordinate input handlers
  const latInput = document.getElementById('latitude') as HTMLInputElement;
  const lngInput = document.getElementById('longitude') as HTMLInputElement;

  latInput?.addEventListener('change', async () => {
    const lat = parseFloat(latInput.value);
    const lng = parseFloat(lngInput.value);
    if (!isNaN(lat) && !isNaN(lng)) {
      if (!map) await initMap(lat, lng);
      setMarker(lat, lng);
    }
  });

  lngInput?.addEventListener('change', async () => {
    const lat = parseFloat(latInput.value);
    const lng = parseFloat(lngInput.value);
    if (!isNaN(lat) && !isNaN(lng)) {
      if (!map) await initMap(lat, lng);
      setMarker(lat, lng);
    }
  });

  // Collect opening hours
  function collectOpeningHours(): Record<string, string> | null {
    const hours: Record<string, string> = {};
    let hasAnyHours = false;

    days.forEach(day => {
      const closed = (document.getElementById(`${day}-closed`) as HTMLInputElement)?.checked;
      const open = (document.getElementById(`${day}-open`) as HTMLInputElement)?.value;
      const close = (document.getElementById(`${day}-close`) as HTMLInputElement)?.value;

      if (closed) {
        hours[day] = 'closed';
        hasAnyHours = true;
      } else if (open && close) {
        hours[day] = `${open}-${close}`;
        hasAnyHours = true;
      }
    });

    return hasAnyHours ? hours : null;
  }

  // Form submit
  document.getElementById('business-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!userId) {
      window.location.href = '/login';
      return;
    }

    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving...';

    const formData = new FormData(e.target as HTMLFormElement);

    const data: Record<string, unknown> = {
      title: formData.get('title'),
      slug: formData.get('slug'),
      categoryId: formData.get('categoryId'),
      contactName: formData.get('contactName'),
      contactNumber: formData.get('contactNumber'),
      email: formData.get('email'),
      address: formData.get('address'),
      latitude: formData.get('latitude') ? parseFloat(formData.get('latitude') as string) : null,
      longitude: formData.get('longitude') ? parseFloat(formData.get('longitude') as string) : null,
      aboutUs: formData.get('aboutUs'),
      openingHours: collectOpeningHours(),
      yearOfEstablishment: formData.get('yearOfEstablishment')
        ? parseInt(formData.get('yearOfEstablishment') as string)
        : null,
      tags: formData.get('tags')
        ? (formData.get('tags') as string).split(',').map(t => t.trim()).filter(Boolean)
        : [],
    };

    // Social links
    const fbUrl = formData.get('facebookUrl') as string;
    const igUrl = formData.get('instagramUrl') as string;
    const ttUrl = formData.get('tiktokUrl') as string;
    if (fbUrl || igUrl || ttUrl) {
      data.socialLinks = JSON.stringify({
        facebook: fbUrl || null,
        instagram: igUrl || null,
        tiktok: ttUrl || null,
      });
    }

    // Latest update
    const latestUpdate = formData.get('latestUpdate') as string;
    if (latestUpdate) {
      data.latestUpdate = latestUpdate;
      data.latestUpdateDate = new Date();
    }

    // Photo gallery
    const galleryMediaIds = formData.get('galleryMediaIds') as string;
    if (galleryMediaIds) {
      try {
        data.photoGallery = galleryMediaIds;
      } catch { /* ignore */ }
    }

    try {
      const res = await fetch(`/api/businesses/${businessSlug}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (result.success) {
        window.location.href = `/business/${data.slug}`;
      } else {
        alert(result.error?.message || 'Failed to save changes');
      }
    } catch (err) {
      console.error('Save error:', err);
      alert('Failed to save changes. Please try again.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Save Changes';
    }
  });

  // Auto-generate slug from title
  const titleInput = document.getElementById('title') as HTMLInputElement;
  const slugInput = document.getElementById('slug') as HTMLInputElement;

  titleInput?.addEventListener('input', () => {
    const slug = titleInput.value
      .toLowerCase()
      .replace(/[^a-z0-9\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-')
      .trim();
    slugInput.value = slug;
  });

  // Start
  init();
</script>

