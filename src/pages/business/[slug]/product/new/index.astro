---
// New Product page - for creating products
export const prerender = false;

import Layout from '@layouts/Layout.astro';
import Button from '@components/ui/Button.astro';
import Input from '@components/ui/Input.astro';
import Label from '@components/ui/Label.astro';
import Card from '@components/ui/Card.astro';
import { getDb } from '@/lib/db';
import { productCategories } from '@/db/schema';

const db = await getDb();
const allCategories = db ? await db.select().from(productCategories).all() : [];

// Product types
const PRODUCT_TYPES = [
  { value: 'product', label: 'Product (Physical/Digital)' },
  { value: 'service', label: 'Service' },
  { value: 'rental', label: 'Rental' },
  { value: 'food', label: 'Food & Dining' },
  { value: 'accommodation', label: 'Accommodation' },
  { value: 'automotive', label: 'Automotive/Vehicle' },
  { value: 'healthcare', label: 'Healthcare' },
  { value: 'education', label: 'Education' },
  { value: 'beauty', label: 'Beauty & Wellness' },
  { value: 'event', label: 'Event' },
];

// Common unit options for pricing
const UNIT_OPTIONS = [
  { value: '', label: 'No unit' },
  { value: 'piece', label: 'per piece' },
  { value: 'unit', label: 'per unit' },
  { value: 'hour', label: 'per hour' },
  { value: 'day', label: 'per day' },
  { value: 'night', label: 'per night' },
  { value: 'week', label: 'per week' },
  { value: 'month', label: 'per month' },
  { value: 'bottle', label: 'per bottle' },
  { value: 'box', label: 'per box' },
  { value: 'pack', label: 'per pack' },
  { value: 'set', label: 'per set' },
  { value: 'kg', label: 'per kg' },
  { value: 'g', label: 'per gram' },
  { value: 'litre', label: 'per litre' },
  { value: 'ml', label: 'per ml' },
  { value: 'meal', label: 'per meal' },
  { value: 'person', label: 'per person' },
  { value: 'session', label: 'per session' },
  { value: 'visit', label: 'per visit' },
  { value: 'course', label: 'per course' },
  { value: 'lesson', label: 'per lesson' },
  { value: 'treatment', label: 'per treatment' },
];
---

<Layout title="Add Product - TimorUp">
  <!-- TipTap CSS -->
  <link rel="stylesheet" href="https://unpkg.com/@tiptap/core@3.22.3/dist/tiptap.min.css" />
  <div class="container py-8">
    <!-- Back Link -->
    <a id="back-link" href="#" class="inline-flex items-center text-sm text-muted-foreground hover:text-foreground mb-6">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Products
    </a>

    <!-- Loading -->
    <div id="loading" class="flex items-center justify-center min-h-[400px]">
      <div class="text-center">
        <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary"></div>
        <p class="mt-4 text-muted-foreground">Loading...</p>
      </div>
    </div>

    <!-- Access Denied -->
    <div id="access-denied" class="hidden text-center py-12">
      <h1 class="text-2xl font-bold mb-2">Access Denied</h1>
      <p class="text-muted-foreground mb-6">You don't have permission to manage this business.</p>
      <a href="/account">
        <Button>Go to My Account</Button>
      </a>
    </div>

    <!-- Not Found -->
    <div id="not-found" class="hidden text-center py-12">
      <h1 class="text-2xl font-bold mb-2">Business Not Found</h1>
      <p class="text-muted-foreground mb-6">The business you're looking for doesn't exist.</p>
      <a href="/account">
        <Button>Go to My Account</Button>
      </a>
    </div>

    <!-- Upgrade Required -->
    <div id="upgrade-required" class="hidden text-center py-12">
      <h1 class="text-2xl font-bold mb-2">Upgrade Required</h1>
      <p class="text-muted-foreground mb-2">You need an active subscription to create products.</p>
      <p class="text-sm text-amber-600 mb-6">You're on a free trial. Upgrade to add products.</p>
      <a href="/pricing">
        <Button>View Plans</Button>
      </a>
    </div>

    <!-- SKU Limit Reached -->
    <div id="sku-limit" class="hidden text-center py-12">
      <h1 class="text-2xl font-bold mb-2">Product Limit Reached</h1>
      <p class="text-muted-foreground mb-6">You have reached your product limit. Upgrade your plan to add more products.</p>
      <a href="/pricing">
        <Button>View Plans</Button>
      </a>
    </div>

    <!-- Main Content -->
    <div id="content" class="hidden">
      <Card class="max-w-2xl mx-auto">
        <CardHeader>
          <CardTitle>Add New Product</CardTitle>
          <CardDescription>Create a new product or service for your business</CardDescription>
        </CardHeader>
        <CardContent>
          <form id="product-form" class="space-y-6">
            <!-- Product Category -->
            <div>
              <Label for="categoryId">Category *</Label>
              <select id="categoryId" name="categoryId" required class="w-full h-10 px-3 rounded-md border border-input bg-background">
                <option value="">Select a category</option>
                {allCategories.map(cat => (
                  <option value={cat.id}>{cat.name}</option>
                ))}
              </select>
              <p class="text-xs text-muted-foreground mt-1">Choose the product category</p>
            </div>

            <!-- Product Name -->
            <div>
              <Label for="title">Product Name *</Label>
              <Input
                id="title"
                name="title"
                placeholder="e.g., Professional Photography Service"
                required
              />
            </div>

            <!-- Product Type -->
            <div>
              <Label for="productType">Product Type *</Label>
              <select id="productType" name="productType" required class="w-full h-10 px-3 rounded-md border border-input bg-background">
                {PRODUCT_TYPES.map(type => (
                  <option value={type.value}>{type.label}</option>
                ))}
              </select>
            </div>

            <!-- Price Section -->
            <div class="grid grid-cols-3 gap-4">
              <div class="col-span-2">
                <Label for="basePrice">Price *</Label>
                <Input
                  id="basePrice"
                  name="basePrice"
                  type="number"
                  step="0.01"
                  min="0"
                  placeholder="0.00"
                  required
                />
              </div>
              <div>
                <Label for="currency">Currency</Label>
                <select id="currency" name="currency" class="w-full h-10 px-3 rounded-md border border-input bg-background">
                  <option value="USD">USD ($)</option>
                  <option value="IDR">IDR (Rp)</option>
                  <option value="TLS">TLS ($)</option>
                </select>
              </div>
            </div>

            <!-- Unit -->
            <div>
              <Label for="unit">Price Unit</Label>
              <select id="unit" name="unit" class="w-full h-10 px-3 rounded-md border border-input bg-background">
                {UNIT_OPTIONS.map(opt => (
                  <option value={opt.value}>{opt.label}</option>
                ))}
              </select>
              <p class="text-xs text-muted-foreground mt-1">How the price is displayed (e.g., "$150 per hour")</p>
            </div>

            <!-- Description -->
            <div>
              <Label for="description">Description</Label>
              <div id="description-editor"></div>
              <input type="hidden" id="description" name="description" value="" />
            </div>

            <!-- Product Images -->
            <div>
              <Label>Product Images (up to 4)</Label>
              <div id="image-upload-area" class="mt-2">
                <div class="border-2 border-dashed border-muted-foreground/25 rounded-lg p-6 text-center hover:border-muted-foreground/50 transition-colors cursor-pointer" id="upload-trigger">
                  <svg class="w-10 h-10 mx-auto text-muted-foreground mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                  <p class="text-sm text-muted-foreground">Click to upload images</p>
                  <p class="text-xs text-muted-foreground mt-1">JPG, PNG, WebP - Max 5MB each</p>
                </div>
                <input type="file" id="file-input" accept="image/*,video/mp4,video/webm,video/quicktime" multiple class="hidden" />
              </div>
              
              <!-- Image Preview -->
              <div id="image-preview" class="grid grid-cols-4 gap-2 mt-4"></div>
              <input type="hidden" id="media-ids" name="mediaIds" value="" />
            </div>

            <!-- Error Message -->
            <div id="error-message" class="hidden bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
              <p class="text-sm text-red-600 dark:text-red-400" id="error-text"></p>
            </div>

            <!-- Submit -->
            <div class="flex gap-3">
              <Button type="submit" class="flex-1">Create Product</Button>
              <Button type="button" variant="outline" id="cancel-btn">Cancel</Button>
            </div>
          </form>
        </CardContent>
      </Card>
    </div>
  </div>
</Layout>

<script>
  // ── TipTap Editor Helper ─────────────────────────────────────────────────────
  async function initTipTapEditor(element: HTMLElement, options: { placeholder?: string; content?: string } = {}) {
    const textareaId = `${element.id}-content`;

    // Create hidden textarea for form submission
    const textarea = document.createElement('textarea');
    textarea.id = textareaId;
    textarea.name = 'description';
    textarea.className = 'hidden';
    element.insertAdjacentElement('afterend', textarea);

    // Dynamic imports for TipTap
    const [tiptapCore, tiptapStarterKit, tiptapLink, tiptapPlaceholder] = await Promise.all([
      import('https://esm.sh/@tiptap/core@3.22.3'),
      import('https://esm.sh/@tiptap/starter-kit@3.22.3'),
      import('https://esm.sh/@tiptap/extension-link@3.22.3'),
      import('https://esm.sh/@tiptap/extension-placeholder@3.22.3'),
    ]);

    const { Editor } = tiptapCore;
    const { default: StarterKit } = tiptapStarterKit;
    const { default: Link } = tiptapLink;
    const { default: Placeholder } = tiptapPlaceholder;

    const editor = new Editor({
      element,
      extensions: [
        StarterKit.configure({
          heading: { levels: [2, 3] },
        }),
        Link.configure({
          openOnClick: false,
          HTMLAttributes: { class: 'text-primary underline' },
        }),
        Placeholder.configure({
          placeholder: options.placeholder || 'Describe your product or service...',
          emptyEditorClass: 'is-editor-empty',
        }),
      ],
      content: options.content || '',
      onUpdate: ({ editor }) => {
        textarea.value = editor.getHTML();
      },
      editorProps: {
        attributes: {
          class: 'prose prose-sm dark:prose-invert max-w-none focus:outline-none min-h-[100px] px-3 py-2 border rounded-lg bg-background',
        },
      },
    });

    // Initial sync
    textarea.value = editor.getHTML();

    return editor;
  }

  // Get slug from URL
  const pathParts = window.location.pathname.split('/').filter(Boolean);
  const slugIndex = pathParts.indexOf('business');
  const slug = slugIndex >= 0 ? pathParts[slugIndex + 1] : '';

  let currentUser: ProductData = null;
  let currentBusiness: ProductData = null;
  let uploadedImages: string[] = [];

  const loading = document.getElementById('loading');
  const accessDenied = document.getElementById('access-denied');
  const notFound = document.getElementById('not-found');
  const upgradeRequired = document.getElementById('upgrade-required');
  const skuLimit = document.getElementById('sku-limit');
  const content = document.getElementById('content');

  // Get session (simplified - in production use proper auth)
  async function getSession() {
    try {
      const res = await fetch('/api/auth/session');
      const data = await res.json();
      return data.user || null;
    } catch (err) {
      console.error('Error getting session:', err);
      return null;
    }
  }

  // Load business by slug
  async function loadBusiness() {
    try {
      const res = await fetch(`/api/businesses/${slug}`);
      const data = await res.json();
      
      if (data.success) {
        return data.data;
      }
    } catch (err) {
      console.error('Error loading business:', err);
    }
    return null;
  }

  // Check subscription status
  async function checkSubscription(businessId: string) {
    try {
      const res = await fetch(`/api/account/subscription/${businessId}`);
      const data = await res.json();
      return data;
    } catch (err) {
      console.error('Error loading subscription:', err);
    }
    return null;
  }

  // Initialize
  async function init() {
    currentUser = await getSession();
    
    if (!currentUser) {
      loading?.classList.add('hidden');
      accessDenied?.classList.remove('hidden');
      return;
    }

    currentBusiness = await loadBusiness();
    
    if (!currentBusiness) {
      loading?.classList.add('hidden');
      notFound?.classList.remove('hidden');
      return;
    }

    // Check ownership
    if (currentBusiness.ownerId !== currentUser.id) {
      loading?.classList.add('hidden');
      accessDenied?.classList.remove('hidden');
      return;
    }

    // Check subscription status
    const subscription = await checkSubscription(currentBusiness.id);
    
    if (!subscription || subscription.status !== 'active') {
      loading?.classList.add('hidden');
      upgradeRequired?.classList.remove('hidden');
      return;
    }

    // Check SKU limit
    if (subscription.atLimit) {
      loading?.classList.add('hidden');
      skuLimit?.classList.remove('hidden');
      return;
    }

    // Set back link
    const backLink = document.getElementById('back-link');
    if (backLink) {
      backLink.setAttribute('href', `/business/${slug}/products`);
    }

    // Initialize TipTap editor for description
    const descEditor = document.getElementById('description-editor');
    if (descEditor) {
      await initTipTapEditor(descEditor, {
        placeholder: 'Describe your product or service...',
      });
    }

    // Show content
    loading?.classList.add('hidden');
    content?.classList.remove('hidden');
  }

  // Handle form submission
  document.getElementById('product-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const categoryId = (document.getElementById('categoryId') as HTMLSelectElement).value;
    const title = (document.getElementById('title') as HTMLInputElement).value;
    const productType = (document.getElementById('productType') as HTMLSelectElement).value;
    const basePrice = (document.getElementById('basePrice') as HTMLInputElement).value;
    const currency = (document.getElementById('currency') as HTMLSelectElement).value;
    const unit = (document.getElementById('unit') as HTMLSelectElement).value;
    const description = (document.getElementById('description') as HTMLInputElement).value;
    const mediaIdsInput = document.getElementById('media-ids') as HTMLInputElement;
    const images = mediaIdsInput?.value ? mediaIdsInput.value.split(',').filter(Boolean) : [];

    if (!title || !categoryId || !basePrice) {
      showError('Please fill in all required fields');
      return;
    }

    // Build specifications JSON
    const specifications = {
      pricing: {
        basePrice: parseFloat(basePrice) || 0,
        currency: currency || 'USD',
        unit: unit || '',
        unitOptions: [
          '', 'piece', 'unit', 'hour', 'day', 'night', 'week', 'month',
          'bottle', 'box', 'pack', 'set', 'kg', 'g', 'litre', 'ml',
          'meal', 'person', 'session', 'visit', 'course', 'lesson', 'treatment'
        ],
        minOrder: 1,
        discount: 0,
        deposit: 0
      }
    };

    try {
      const result = await actions.products.createProduct({
        businessId: currentBusiness.id,
        title,
        description,
        categoryId,
        productType: productType as 'product' | 'service' | 'rental' | 'food' | 'accommodation' | 'automotive' | 'healthcare' | 'education' | 'beauty' | 'event' | 'virtual' | 'ticket' | 'subscription',
        specifications,
        images,
      });

      if (result.success) {
        window.location.href = `/business/${slug}/products`;
      } else {
        if (result.error?.code === 'SKU_LIMIT_REACHED' || result.error?.code === 'SKU_NOT_ALLOWED') {
          loading?.classList.add('hidden');
          content?.classList.add('hidden');
          skuLimit?.classList.remove('hidden');
        } else {
          showError(result.error?.message || 'Failed to create product');
        }
      }
    } catch (err) {
      console.error('Error creating product:', err);
      showError('An error occurred. Please try again.');
    }
  });

  // Cancel button
  document.getElementById('cancel-btn')?.addEventListener('click', () => {
    window.location.href = `/business/${slug}/products`;
  });

  // Show error
  function showError(message: string) {
    const errorDiv = document.getElementById('error-message');
    const errorText = document.getElementById('error-text');
    if (errorDiv && errorText) {
      errorText.textContent = message;
      errorDiv.classList.remove('hidden');
    }
  }

  // File upload handling
  const uploadTrigger = document.getElementById('upload-trigger');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const uploadArea = document.getElementById('image-upload-area');

  const MAX_IMAGE_SIZE = 2 * 1024 * 1024;
  const MAX_VIDEO_SIZE = 8 * 1024 * 1024;
  const IMAGE_TYPES = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
  const VIDEO_TYPES = ['video/mp4', 'video/webm', 'video/quicktime'];

  // Preload video processor
  import('@/lib/video-compress').then(({ preloadFFmpeg }) => preloadFFmpeg());

  uploadTrigger?.addEventListener('click', () => {
    fileInput?.click();
  });

  fileInput?.addEventListener('change', async (e) => {
    const files = (e.target as HTMLInputElement).files;
    if (!files || files.length === 0) return;

    // Check max images
    if (uploadedImages.length + files.length > 4) {
      showError('Maximum 4 images allowed');
      return;
    }

    // Upload each file
    for (const file of files) {
      if (uploadedImages.length >= 4) break;

      const isImage = IMAGE_TYPES.includes(file.type);
      const isVideo = VIDEO_TYPES.includes(file.type);

      if (!isImage && !isVideo) {
        showError('Unsupported file type');
        continue;
      }

      if (isImage && file.size > MAX_IMAGE_SIZE) {
        showError(`Image too large: ${(file.size / 1024 / 1024).toFixed(1)}MB. Max: 2MB`);
        continue;
      }
      if (isVideo && file.size > MAX_VIDEO_SIZE) {
        showError(`Video too large: ${(file.size / 1024 / 1024).toFixed(1)}MB. Max: 8MB`);
        continue;
      }

      let fileToUpload: File = file;

      // Compress video
      if (isVideo) {
        const statusDiv = document.createElement('div');
        statusDiv.className = 'absolute inset-0 bg-black/50 flex items-center justify-center text-white text-xs rounded-lg z-10';
        statusDiv.textContent = 'Processing...';
        uploadArea?.appendChild(statusDiv);

        try {
          const { compressVideo } = await import('@/lib/video-compress');
          const result = await compressVideo(file, {
            maxSize: MAX_VIDEO_SIZE,
            onProgress: (p) => { statusDiv.textContent = p.message; }
          });

          if (!result.withinLimit) {
            showError(`Video still too large after compression`);
            statusDiv.remove();
            continue;
          }
          fileToUpload = result.file;
          statusDiv.textContent = 'Uploading...';
        } catch (err) {
          console.error('Video compression error:', err);
          statusDiv.remove();
          showError('Video processing failed');
          continue;
        }
      }

      const formData = new FormData();
      formData.append('file', fileToUpload);

      try {
        const res = await actions.media.uploadMedia(formData);

        if (res.success) {
          uploadedImages.push(res.data.id);
          renderImagePreview(res.data.id, file);
        }
      } catch (err) {
        console.error('Error uploading image:', err);
      }
    }

    // Update hidden input
    const mediaIdsInput = document.getElementById('media-ids') as HTMLInputElement;
    if (mediaIdsInput) {
      mediaIdsInput.value = uploadedImages.join(',');
    }
  });

  // Render image preview
  function renderImagePreview(mediaId: string, file: File) {
    const preview = document.getElementById('image-preview');
    if (!preview) return;

    const reader = new FileReader();
    reader.onload = (e) => {
      const div = document.createElement('div');
      div.className = 'relative aspect-square rounded-lg overflow-hidden bg-muted';
      div.innerHTML = `
        <img src="${e.target?.result}" class="w-full h-full object-cover" />
        <button type="button" data-remove="${mediaId}" class="absolute top-1 right-1 bg-red-500 text-white rounded-full p-1 hover:bg-red-600">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      `;
      
      // Remove button handler
      div.querySelector('button')?.addEventListener('click', (e) => {
        e.preventDefault();
        const id = (e.currentTarget as HTMLElement).dataset.remove;
        uploadedImages = uploadedImages.filter(imgId => imgId !== id);
        div.remove();
        
        const mediaIdsInput = document.getElementById('media-ids') as HTMLInputElement;
        if (mediaIdsInput) {
          mediaIdsInput.value = uploadedImages.join(',');
        }
      });
      
      preview.appendChild(div);
    };
    reader.readAsDataURL(file);
  }

  init();
</script>
