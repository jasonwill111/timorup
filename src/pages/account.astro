---
// Account page with SSR
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import CardHeader from '../components/ui/CardHeader.astro';
import CardTitle from '../components/ui/CardTitle.astro';
import CardDescription from '../components/ui/CardDescription.astro';
import CardContent from '../components/ui/CardContent.astro';
import CardFooter from '../components/ui/CardFooter.astro';

// Check auth via session cookie
const cookieHeader = Astro.request.headers.get('cookie') || '';
let user: { id: string; name: string; email: string } | null = null;
let userBusiness: { id: string; title: string; slug: string; planType: string | null; expiryDate: Date | null } | null = null;
let subscription: { planType: string; amount: number; status: string; expiryDate: Date | null } | null = null;
let businessReviews: Array<{ id: string; rating: number; comment: string | null; reviewerName: string; createdAt: Date | null; reply: string | null; repliedAt: Date | null }> = [];

try {
  const tokenMatch = cookieHeader.match(/better-auth\.session_token=([^;]+)/);

  if (tokenMatch) {
    const { db } = await import('@/lib/db');
    const { sessions, users, businessPages, orders, reviews } = await import('@/db/schema');
    const { eq, and, desc, sql } = await import('drizzle-orm');

    const session = await db.select()
      .from(sessions)
      .where(eq(sessions.token, tokenMatch[1]))
      .limit(1)
      .get();

    if (session && session.expiresAt && new Date(session.expiresAt) > new Date()) {
      const userRecord = await db.select()
        .from(users)
        .where(eq(users.id, session.userId))
        .limit(1)
        .get();

      if (userRecord) {
        user = { id: userRecord.id, name: userRecord.name || '', email: userRecord.email };

        // Get user's business
        const business = await db.select({
          id: businessPages.id,
          title: businessPages.title,
          slug: businessPages.slug,
          planType: businessPages.planType,
          expiryDate: businessPages.expiryDate,
        })
        .from(businessPages)
        .where(eq(businessPages.ownerId, user.id))
        .limit(1)
        .get();

        if (business) {
          userBusiness = business;

          // Get reviews for this business
          const reviewsList = await db.select()
            .from(reviews)
            .where(eq(reviews.businessPageId, business.id))
            .orderBy(desc(reviews.createdAt))
            .limit(20);

          // Get user info for reviewers
          const reviewerIds = [...new Set(reviewsList.map(r => r.userId))];
          const reviewerList = reviewerIds.length > 0
            ? await db.select({ id: users.id, name: users.name })
                .from(users)
                .where(sql`${users.id} IN (${sql.join(reviewerIds.map(id => sql`${id}`), sql`, `)})`)
            : [];
          const reviewerMap = new Map(reviewerList.map(u => [u.id, u]));

          // Attach reviewer names to reviews
          businessReviews = reviewsList.map(r => ({
            ...r,
            reviewerName: reviewerMap.get(r.userId)?.name || 'Anonymous',
          }));

          // Get latest paid subscription
          const latestOrder = await db.select()
            .from(orders)
            .where(and(
              eq(orders.businessPageId, business.id),
              eq(orders.status, 'paid')
            ))
            .orderBy(desc(orders.paidDate))
            .limit(1)
            .get();

          if (latestOrder) {
            subscription = {
              planType: latestOrder.planType || 'basic',
              amount: latestOrder.amount || 0,
              status: latestOrder.status,
              expiryDate: latestOrder.expiryDate,
            };
          }
        }
      }
    }
  }
} catch (e) {
  console.error('Auth check failed:', e);
}

// Redirect if not logged in
if (!user) {
  return Astro.redirect('/login?redirect=/account');
}

// Check if subscription is expired
const isSubscriptionExpired = subscription?.expiryDate ? new Date(subscription.expiryDate) < new Date() : false;

// Check if subscription is active (paid and not expired)
const isSubscriptionActive = subscription?.status === 'paid' && !isSubscriptionExpired;
---

<Layout title="My Account - TimorList">
  <div class="container py-8">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-bold">My Account</h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <!-- Profile Section -->
        <Card class="mb-6">
          <CardHeader>
            <CardTitle>Profile Information</CardTitle>
            <CardDescription>Manage your account details</CardDescription>
          </CardHeader>
          <CardContent>
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 rounded-full bg-primary flex items-center justify-center text-2xl font-bold">
                {user.name.charAt(0).toUpperCase()}
              </div>
              <div>
                <p class="font-semibold">{user.name}</p>
                <p class="text-sm text-muted-foreground">{user.email}</p>
              </div>
            </div>
          </CardContent>
        </Card>

        <!-- My Business -->
        {userBusiness ? (
          <Card>
            <CardHeader class="flex flex-row items-center justify-between">
              <div>
                <CardTitle>My Business</CardTitle>
                <CardDescription>{userBusiness.title}</CardDescription>
              </div>
              <div class="flex gap-2">
                <a href={`/business/${userBusiness.slug}`}>
                  <Button variant="outline" size="sm">View</Button>
                </a>
                <a href={`/business/${userBusiness.slug}/edit`}>
                  <Button size="sm">Edit</Button>
                </a>
              </div>
            </CardHeader>
            <CardContent>
              <div class="flex items-center gap-4">
                <span class={`px-3 py-1 text-sm rounded-full ${isSubscriptionActive ? 'bg-green-100 text-green-800' : isSubscriptionExpired ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800'}`}>
                  {isSubscriptionActive ? 'Active' : isSubscriptionExpired ? 'Expired' : 'Inactive'}
                </span>
                <span class="text-sm text-muted-foreground">
                  {subscription ? `${subscription.planType.replace('-', ' ').toUpperCase()} Plan` : 'Free Plan'}
                </span>
              </div>
            </CardContent>
          </Card>

          <!-- Business Reviews -->
          <Card class="mt-6">
            <CardHeader>
              <CardTitle>Customer Reviews</CardTitle>
              <CardDescription>View and reply to customer reviews</CardDescription>
            </CardHeader>
            <CardContent>
              {businessReviews.length > 0 ? (
                <div class="space-y-4">
                  {businessReviews.map(review => (
                    <div class="border rounded-lg p-4">
                      <div class="flex items-center justify-between mb-2">
                        <div class="flex items-center gap-2">
                          <span class="font-medium">{review.reviewerName}</span>
                          <div class="flex">
                            {Array.from({ length: 5 }).map((_, i) => (
                              <span key={i} class={i < review.rating ? 'text-yellow-400' : 'text-gray-300'}>★</span>
                            ))}
                          </div>
                        </div>
                        <span class="text-sm text-muted-foreground">
                          {review.createdAt ? new Date(review.createdAt).toLocaleDateString() : ''}
                        </span>
                      </div>
                      <p class="text-gray-700 mb-3">{review.comment || 'No comment'}</p>

                      {review.reply ? (
                        <div class="bg-gray-50 rounded-lg p-3 ml-4 border-l-4 border-primary">
                          <p class="text-sm font-medium mb-1">Your Reply:</p>
                          <p class="text-sm">{review.reply}</p>
                          <p class="text-xs text-muted-foreground mt-1">
                            {review.repliedAt ? `Replied on ${new Date(review.repliedAt).toLocaleDateString()}` : ''}
                          </p>
                          <div class="flex gap-2 mt-2">
                            <button
                              class="text-sm text-blue-600 hover:text-blue-800 edit-reply-btn"
                              data-review-id={review.id}
                              data-reply={review.reply}
                            >
                              Edit Reply
                            </button>
                            <button
                              class="text-sm text-red-600 hover:text-red-800 delete-reply-btn"
                              data-review-id={review.id}
                            >
                              Delete Reply
                            </button>
                          </div>
                        </div>
                      ) : (
                        <button
                          class="text-sm text-primary hover:text-primary/80 reply-btn"
                          data-review-id={review.id}
                        >
                          Reply to Review
                        </button>
                      )}
                    </div>
                  ))}
                </div>
              ) : (
                <p class="text-muted-foreground text-center py-4">No reviews yet</p>
              )}
            </CardContent>
          </Card>
        ) : (
          <Card>
            <CardHeader>
              <CardTitle>Create Your Business</CardTitle>
              <CardDescription>Get started with your first business listing</CardDescription>
            </CardHeader>
            <CardContent>
              <a href="/listing/create?type=business">
                <Button>Create Business</Button>
              </a>
            </CardContent>
          </Card>
        )}
      </div>

      <!-- Sidebar -->
      <div>
        <!-- Subscription Card -->
        <Card class="mb-6">
          <CardHeader>
            <CardTitle>Subscription</CardTitle>
          </CardHeader>
          <CardContent>
            {isSubscriptionActive ? (
              <div class="text-center">
                <p class="text-2xl font-bold text-green-600">Active</p>
                <p class="text-sm text-muted-foreground mt-1">
                  {subscription?.planType.replace('-', ' ').toUpperCase()} Plan
                </p>
                {subscription?.expiryDate && (
                  <p class="text-xs text-muted-foreground mt-2">
                    Expires: {new Date(subscription.expiryDate).toLocaleDateString()}
                  </p>
                )}
              </div>
            ) : (
              <div class="text-center">
                {isSubscriptionExpired ? (
                  <>
                    <p class="text-2xl font-bold text-red-600">Expired</p>
                    <p class="text-sm text-muted-foreground mt-1">
                      Your subscription has expired
                    </p>
                    <p class="text-xs text-muted-foreground mt-2">
                      Renew to continue enjoying premium features
                    </p>
                  </>
                ) : userBusiness ? (
                  <>
                    <p class="text-2xl font-bold text-yellow-600">Inactive</p>
                    <p class="text-sm text-muted-foreground mt-1">
                      No active subscription
                    </p>
                  </>
                ) : (
                  <>
                    <p class="text-2xl font-bold text-gray-500">Free</p>
                    <p class="text-sm text-muted-foreground mt-1">
                      Create a business to get started
                    </p>
                  </>
                )}
              </div>
            )}
          </CardContent>
          <CardFooter class="flex-col gap-2">
            <a href="/pricing" class="w-full">
              <Button variant="outline" class="w-full">
                {isSubscriptionExpired ? 'Renew Subscription' : isSubscriptionActive ? 'Change Plan' : 'View Plans'}
              </Button>
            </a>
            {!isSubscriptionActive && userBusiness && (
              <a href={`/subscribe?plan=basic-monthly`} class="w-full">
                <Button class="w-full">Subscribe Now</Button>
              </a>
            )}
          </CardFooter>
        </Card>

        <!-- Quick Links -->
        <Card>
          <CardHeader>
            <CardTitle>Quick Links</CardTitle>
          </CardHeader>
          <CardContent class="space-y-2">
            <a href="/listing" class="block">
              <Button variant="ghost" class="w-full justify-start">Browse Directory</Button>
            </a>
            <a href="/products-services" class="block">
              <Button variant="ghost" class="w-full justify-start">Products & Services</Button>
            </a>
            <a href="/pricing" class="block">
              <Button variant="ghost" class="w-full justify-start">Pricing</Button>
            </a>
            <form action="/api/auth/sign-out" method="POST">
              <Button type="submit" variant="ghost" class="w-full justify-start text-red-500 hover:text-red-600">
                Log Out
              </Button>
            </form>
          </CardContent>
        </Card>
      </div>
    </div>
  </div>

  <!-- Reply Modal -->
  <div id="reply-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
    <div class="bg-background rounded-lg p-6 max-w-md w-full mx-4">
      <h3 class="text-lg font-semibold mb-4" id="reply-modal-title">Reply to Review</h3>
      <textarea id="reply-text" class="w-full border rounded-lg p-3 h-32 resize-none" placeholder="Write your reply..."></textarea>
      <input type="hidden" id="reply-review-id" value="" />
      <input type="hidden" id="reply-action" value="create" />
      <div class="flex gap-2 mt-4 justify-end">
        <Button variant="outline" id="reply-modal-cancel">Cancel</Button>
        <Button id="reply-modal-submit">Submit</Button>
      </div>
    </div>
  </div>

  <script>
    // Reply button handlers
    document.querySelectorAll('.reply-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const reviewId = btn.getAttribute('data-review-id');
        document.getElementById('reply-review-id').value = reviewId;
        document.getElementById('reply-action').value = 'create';
        document.getElementById('reply-modal-title').textContent = 'Reply to Review';
        document.getElementById('reply-text').value = '';
        document.getElementById('reply-modal').classList.remove('hidden');
        document.getElementById('reply-modal').classList.add('flex');
      });
    });

    // Edit reply button handlers
    document.querySelectorAll('.edit-reply-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const reviewId = btn.getAttribute('data-review-id');
        const reply = btn.getAttribute('data-reply');
        document.getElementById('reply-review-id').value = reviewId;
        document.getElementById('reply-action').value = 'edit';
        document.getElementById('reply-modal-title').textContent = 'Edit Reply';
        document.getElementById('reply-text').value = reply || '';
        document.getElementById('reply-modal').classList.remove('hidden');
        document.getElementById('reply-modal').classList.add('flex');
      });
    });

    // Delete reply button handlers
    document.querySelectorAll('.delete-reply-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Are you sure you want to delete this reply?')) return;
        const reviewId = btn.getAttribute('data-review-id');
        const res = await fetch(`/api/reviews/${reviewId}/reply`, { method: 'DELETE' });
        if (res.ok) {
          window.location.reload();
        } else {
          alert('Failed to delete reply');
        }
      });
    });

    // Modal handlers
    document.getElementById('reply-modal-cancel')?.addEventListener('click', () => {
      document.getElementById('reply-modal').classList.add('hidden');
      document.getElementById('reply-modal').classList.remove('flex');
    });

    document.getElementById('reply-modal-submit')?.addEventListener('click', async () => {
      const reviewId = document.getElementById('reply-review-id').value;
      const action = document.getElementById('reply-action').value;
      const comment = document.getElementById('reply-text').value;

      if (!comment.trim()) {
        alert('Please enter a reply');
        return;
      }

      const method = action === 'create' ? 'POST' : 'PUT';
      const res = await fetch(`/api/reviews/${reviewId}/reply`, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ comment }),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        const data = await res.json();
        alert(data.error?.message || 'Failed to submit reply');
      }
    });
  </script>
</Layout>
