---
// Account page with SSR
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import CardHeader from '../components/ui/CardHeader.astro';
import CardTitle from '../components/ui/CardTitle.astro';
import CardDescription from '../components/ui/CardDescription.astro';
import CardContent from '../components/ui/CardContent.astro';
import CardFooter from '../components/ui/CardFooter.astro';

// Check auth via session cookie
const cookieHeader = Astro.request.headers.get('cookie') || '';
let user: { id: string; name: string; email: string } | null = null;
let userBusiness: { id: string; title: string; slug: string; planType: string | null; expiryDate: Date | null } | null = null;
let subscription: { planType: string; amount: number; status: string; expiryDate: Date | null } | null = null;

try {
  const tokenMatch = cookieHeader.match(/better-auth\.session_token=([^;]+)/);

  if (tokenMatch) {
    const { db } = await import('@/lib/db');
    const { sessions, users, businessPages, orders } = await import('@/db/schema');
    const { eq, and, desc } = await import('drizzle-orm');

    const session = await db.select()
      .from(sessions)
      .where(eq(sessions.token, tokenMatch[1]))
      .limit(1)
      .get();

    if (session && session.expiresAt && new Date(session.expiresAt) > new Date()) {
      const userRecord = await db.select()
        .from(users)
        .where(eq(users.id, session.userId))
        .limit(1)
        .get();

      if (userRecord) {
        user = { id: userRecord.id, name: userRecord.name || '', email: userRecord.email };

        // Get user's business
        const business = await db.select({
          id: businessPages.id,
          title: businessPages.title,
          slug: businessPages.slug,
          planType: businessPages.planType,
          expiryDate: businessPages.expiryDate,
        })
        .from(businessPages)
        .where(eq(businessPages.ownerId, user.id))
        .limit(1)
        .get();

        if (business) {
          userBusiness = business;

          // Get latest paid subscription
          const latestOrder = await db.select()
            .from(orders)
            .where(and(
              eq(orders.businessPageId, business.id),
              eq(orders.status, 'paid')
            ))
            .orderBy(desc(orders.paidDate))
            .limit(1)
            .get();

          if (latestOrder) {
            subscription = {
              planType: latestOrder.planType || 'basic',
              amount: latestOrder.amount || 0,
              status: latestOrder.status,
              expiryDate: latestOrder.expiryDate,
            };
          }
        }
      }
    }
  }
} catch (e) {
  console.error('Auth check failed:', e);
}

// Redirect if not logged in
if (!user) {
  return Astro.redirect('/login?redirect=/account');
}

// Check if subscription is expired
const isSubscriptionExpired = subscription?.expiryDate ? new Date(subscription.expiryDate) < new Date() : false;

// Check if subscription is active (paid and not expired)
const isSubscriptionActive = subscription?.status === 'paid' && !isSubscriptionExpired;
---

<Layout title="My Account - TIMORLIST">
  <div class="container py-8">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-bold">My Account</h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <!-- Profile Section -->
        <Card class="mb-6">
          <CardHeader>
            <CardTitle>Profile Information</CardTitle>
            <CardDescription>Manage your account details</CardDescription>
          </CardHeader>
          <CardContent>
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 rounded-full bg-primary flex items-center justify-center text-2xl font-bold">
                {user.name.charAt(0).toUpperCase()}
              </div>
              <div>
                <p class="font-semibold">{user.name}</p>
                <p class="text-sm text-muted-foreground">{user.email}</p>
              </div>
            </div>
          </CardContent>
        </Card>

        <!-- My Business -->
        {userBusiness ? (
          <Card>
            <CardHeader class="flex flex-row items-center justify-between">
              <div>
                <CardTitle>My Business</CardTitle>
                <CardDescription>{userBusiness.title}</CardDescription>
              </div>
              <div class="flex gap-2">
                <a href={`/business/${userBusiness.slug}`}>
                  <Button variant="outline" size="sm">View</Button>
                </a>
                <a href={`/business/${userBusiness.slug}/edit`}>
                  <Button size="sm">Edit</Button>
                </a>
              </div>
            </CardHeader>
            <CardContent>
              <div class="flex items-center gap-4">
                <span class={`px-3 py-1 text-sm rounded-full ${isSubscriptionActive ? 'bg-green-100 text-green-800' : isSubscriptionExpired ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800'}`}>
                  {isSubscriptionActive ? 'Active' : isSubscriptionExpired ? 'Expired' : 'Inactive'}
                </span>
                <span class="text-sm text-muted-foreground">
                  {subscription ? `${subscription.planType.replace('-', ' ').toUpperCase()} Plan` : 'Free Plan'}
                </span>
              </div>
            </CardContent>
          </Card>
        ) : (
          <Card>
            <CardHeader>
              <CardTitle>Create Your Business</CardTitle>
              <CardDescription>Get started with your first business listing</CardDescription>
            </CardHeader>
            <CardContent>
              <a href="/listing/create?type=business">
                <Button>Create Business</Button>
              </a>
            </CardContent>
          </Card>
        )}
      </div>

      <!-- Sidebar -->
      <div>
        <!-- Subscription Card -->
        <Card class="mb-6">
          <CardHeader>
            <CardTitle>Subscription</CardTitle>
          </CardHeader>
          <CardContent>
            {isSubscriptionActive ? (
              <div class="text-center">
                <p class="text-2xl font-bold text-green-600">Active</p>
                <p class="text-sm text-muted-foreground mt-1">
                  {subscription?.planType.replace('-', ' ').toUpperCase()} Plan
                </p>
                {subscription?.expiryDate && (
                  <p class="text-xs text-muted-foreground mt-2">
                    Expires: {new Date(subscription.expiryDate).toLocaleDateString()}
                  </p>
                )}
              </div>
            ) : (
              <div class="text-center">
                {isSubscriptionExpired ? (
                  <>
                    <p class="text-2xl font-bold text-red-600">Expired</p>
                    <p class="text-sm text-muted-foreground mt-1">
                      Your subscription has expired
                    </p>
                    <p class="text-xs text-muted-foreground mt-2">
                      Renew to continue enjoying premium features
                    </p>
                  </>
                ) : userBusiness ? (
                  <>
                    <p class="text-2xl font-bold text-yellow-600">Inactive</p>
                    <p class="text-sm text-muted-foreground mt-1">
                      No active subscription
                    </p>
                  </>
                ) : (
                  <>
                    <p class="text-2xl font-bold text-gray-500">Free</p>
                    <p class="text-sm text-muted-foreground mt-1">
                      Create a business to get started
                    </p>
                  </>
                )}
              </div>
            )}
          </CardContent>
          <CardFooter class="flex-col gap-2">
            <a href="/pricing" class="w-full">
              <Button variant="outline" class="w-full">
                {isSubscriptionExpired ? 'Renew Subscription' : isSubscriptionActive ? 'Change Plan' : 'View Plans'}
              </Button>
            </a>
            {!isSubscriptionActive && userBusiness && (
              <a href={`/subscribe?plan=basic-monthly`} class="w-full">
                <Button class="w-full">Subscribe Now</Button>
              </a>
            )}
          </CardFooter>
        </Card>

        <!-- Quick Links -->
        <Card>
          <CardHeader>
            <CardTitle>Quick Links</CardTitle>
          </CardHeader>
          <CardContent class="space-y-2">
            <a href="/listing" class="block">
              <Button variant="ghost" class="w-full justify-start">Browse Directory</Button>
            </a>
            <a href="/products-services" class="block">
              <Button variant="ghost" class="w-full justify-start">Products & Services</Button>
            </a>
            <a href="/pricing" class="block">
              <Button variant="ghost" class="w-full justify-start">Pricing</Button>
            </a>
            <form action="/api/auth/sign-out" method="POST">
              <Button type="submit" variant="ghost" class="w-full justify-start text-red-500 hover:text-red-600">
                Log Out
              </Button>
            </form>
          </CardContent>
        </Card>
      </div>
    </div>
  </div>
</Layout>
