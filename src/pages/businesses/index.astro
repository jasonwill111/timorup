---
// Businesses page - Astro 6 Server Islands pattern
// Banner renders immediately, business list loads async via is:defer
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import CarouselBanner from '../../components/ui/CarouselBanner.astro';
import BusinessListIsland from '../../components/islands/BusinessListNew.astro';

// Astro 6: Set streaming headers for progressive page load
// The banner will render immediately, islands load async
Astro.response.headers.set('X-Accel-Buffering', 'plain');
---

<Layout title="Businesses - TimorUp">
  <!-- Banner - renders immediately, no DB dependency -->
  <CarouselBanner position="businesses" class="mb-6" />

  <!-- Business List - inline render (no is:defer) -->
  <BusinessListIsland />
</Layout>