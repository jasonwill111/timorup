---
// Businesses page - Debug version using API directly
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import CarouselBanner from '../../components/ui/CarouselBanner.astro';
---

<Layout title="Businesses - TimorUp">
  <CarouselBanner position="businesses" class="mb-6" />

  <!-- Debug: Direct render with API call -->
  <div id="business-list" hx-get="/api/businesses?limit=100" hx-trigger="load" hx-swap="innerHTML">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold">Businesses</h1>
      <span class="text-sm text-muted-foreground">Loading...</span>
    </div>
  </div>
</Layout>

<script>
  // Fetch businesses directly
  fetch('/api/businesses?limit=100')
    .then(r => r.json())
    .then(data => {
      const container = document.getElementById('business-list');
      if (!container) return;

      if (data.success && data.data.length > 0) {
        const total = data.pagination?.total || data.data.length;
        container.innerHTML = `
          <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl sm:text-3xl font-bold">Businesses</h1>
            <span class="text-sm text-muted-foreground">${total} total</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            ${data.data.map(b => `
              <a href="/business/${b.slug}" class="group block bg-card rounded-2xl border border-border/50 shadow-sm hover:shadow-lg hover:border-primary/60 overflow-hidden cursor-pointer transition-all duration-200 hover:scale-[1.02] hover:-translate-y-1">
                <div class="aspect-[4/3] bg-gradient-to-br from-primary/10 to-primary/5 relative flex items-center justify-center">
                  <svg class="w-16 h-16 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/>
                  </svg>
                </div>
                <div class="p-4 space-y-3">
                  <h3 class="font-bold text-base line-clamp-2 group-hover:text-primary transition-colors">${b.title}</h3>
                  ${b.address ? `<p class="text-sm text-muted-foreground flex items-start gap-2">
                    <svg class="w-4 h-4 mt-0.5 shrink-0 text-primary/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span class="truncate">${b.address.split(',')[0]}</span>
                  </p>` : ''}
                  <div class="flex items-center gap-4 pt-2 border-t border-border/50">
                    ${b.ratingAverage > 0 ? `<div class="flex items-center gap-1.5">
                      <div class="flex">
                        ${[1,2,3,4,5].map(n => `<svg class="w-3.5 h-3.5 ${n <= Math.round(b.ratingAverage) ? 'text-amber-400 fill-amber-400' : 'text-gray-300 fill-gray-300'}" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`).join('')}
                      </div>
                      <span class="text-xs font-semibold">${b.ratingAverage.toFixed(1)}</span>
                    </div>` : ''}
                    ${b.likes > 0 ? `<span class="flex items-center gap-1 text-xs text-muted-foreground">
                      <svg class="w-3.5 h-3.5 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.682l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                      ${b.likes}
                    </span>` : ''}
                    <span class="flex items-center gap-1 text-xs text-muted-foreground ml-auto">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                      ${b.views > 999 ? (b.views/1000).toFixed(1) + 'k' : b.views}
                    </span>
                  </div>
                </div>
              </a>
            `).join('')}
          </div>
        `;
      } else {
        container.innerHTML = `
          <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl sm:text-3xl font-bold">Businesses</h1>
            <span class="text-sm text-muted-foreground">0 total</span>
          </div>
          <div class="text-center py-16">
            <svg class="w-16 h-16 mx-auto text-muted-foreground/50 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/>
            </svg>
            <h3 class="text-lg font-medium mb-2">No businesses found</h3>
            <p class="text-muted-foreground">Try adjusting your search or filters</p>
          </div>
        `;
      }
    })
    .catch(err => {
      console.error('Failed to load businesses:', err);
    });
</script>