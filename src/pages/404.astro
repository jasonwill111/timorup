---

import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found - TimorBiz">
  <main class="min-h-[60vh] flex items-center justify-center px-4">
    <div class="text-center">
      <h1 class="text-9xl font-bold text-primary">404</h1>
      <h2 class="text-2xl font-semibold mt-4 text-foreground">Page Not Found</h2>
      <p class="text-muted-foreground mt-2 mb-8">
        Sorry, the page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex gap-4 justify-center">
        <a href="/" class="px-6 py-3 bg-primary text-black font-semibold rounded-lg hover:bg-primary/90 transition-colors">
          Go Home
        </a>
        <a href="/businesses" class="px-6 py-3 border border-border text-foreground font-semibold rounded-lg hover:bg-muted transition-colors">
          Browse Businesses
        </a>
      </div>
    </div>
  </main>
</Layout>
