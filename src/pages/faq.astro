---
export const prerender = true;
import Layout from '../layouts/Layout.astro';

// FAQ structured data
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What's the difference between Business Directories and Classified Ads",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Business Directories are permanent listings for established businesses like restaurants, hotels, and shops with reviews and photos. Classified Ads are temporary listings for buying, selling, or finding jobs, vehicles, property, and services."
      }
    },
    {
      "@type": "Question",
      "name": "Are classified ads really free",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes! Classified ads are free for the first 3 days. After that, you can renew for 7, 30, or 365 days at affordable rates."
      }
    },
    {
      "@type": "Question",
      "name": "Can I list products or services directly",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely! Business directory members can add products and services with photos, descriptions, and pricing in our Products & Services section."
      }
    },
    {
      "@type": "Question",
      "name": "How do I find NGOs or government services",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Visit the Non-Profits or Public Sectors sections to discover NGOs, charitable organizations, ministries, and government agencies in Timor-Leste."
      }
    }
  ]
};

const faqs = [
  {
    question: "What's the difference between Business Directories and Classified Ads",
    answer: "Business Directories are permanent listings for established businesses like restaurants, hotels, and shops complete with reviews, photos, and contact info. Classified Ads are temporary listings for buying, selling, or finding jobs, vehicles, property, and services. Think of it like the difference between a Yelp listing and a Craigslist post."
  },
  {
    question: "How do I list my business on TimorUp",
    answer: "Click 'Add Your Listing' on the homepage, choose your listing type (Business, Classified Ad, NGO, or Government), fill in details, and submit. Business listings require a subscription plan; classified ads are free for the first few days."
  },
  {
    question: "Are classified ads really free",
    answer: "Yes! Classified ads are free for the first 3 days. After that, you can renew for 7, 30, or 365 days at affordable rates. Business directory listings offer subscription plans with enhanced features."
  },
  {
    question: "Can I list products or services directly",
    answer: "Absolutely! Business directory members can add products and services with photos, descriptions, and pricing. Browse the Products & Services section to see what's available from local businesses."
  },
  {
    question: "How do I find NGOs or non-profit organizations",
    answer: "Visit the Non-Profits section to discover NGOs and charitable organizations in Timor-Leste. Filter by category to find volunteer opportunities, community initiatives, or social services near you."
  },
  {
    question: "Where can I find government contact information",
    answer: "The Public Sectors section lists all ministries, government agencies, and public institutions. Each entry includes contact details, locations, and descriptions of their services."
  },
  {
    question: "What subscription plans are available",
    answer: "We offer Basic (free) for standard business listings, Pro ($25/month) with product listings and enhanced visibility, and Max ($50/month) with all features plus priority placement. NGOs and public sectors are always free."
  },
  {
    question: "How can I contact TimorUp support",
    answer: "Email us at hello@TimorUp.com or use the contact form on our website. We typically respond within 24 hours on business days."
  }
];
---

<Layout
  title="FAQ - Frequently Asked Questions"
  description="Find answers about TimorUp business directories, classified ads, NGOs, government services, and more."
  structuredData={faqSchema}
>
  <div class="container py-12 max-w-4xl">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold mb-4">Frequently Asked Questions</h1>
      <p class="text-lg text-muted-foreground">
        Discover local businesses, products & services near you
      </p>
    </div>

    <!-- FAQ Grid -->
    <div class="space-y-4">
      {faqs.map((faq, index) => (
        <details class="group bg-card border rounded-lg overflow-hidden" key={index}>
          <summary class="flex items-center justify-between cursor-pointer p-6 font-semibold hover:bg-muted/50 transition-colors list-none">
            <span>{faq.question}</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-6 text-muted-foreground">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center bg-gradient-to-r from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 rounded-2xl p-8">
      <h2 class="text-2xl font-bold mb-4">Still have questions</h2>
      <p class="text-muted-foreground mb-6">
        Can't find what you're looking for Contact us directly.
      </p>
      <a href="mailto:hello@TimorUp.com" class="inline-flex items-center justify-center px-6 py-3 bg-primary text-primary-foreground font-semibold rounded-lg hover:opacity-90 transition-opacity">
        Contact Us
      </a>
    </div>
  </div>
</Layout>

