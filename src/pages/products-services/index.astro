---
// Products & Services page - Astro 6 Server Islands pattern
// Banner renders immediately, products load async via is:defer
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import CarouselBanner from '../../components/ui/CarouselBanner.astro';
import ProductsIsland from '../../components/islands/ProductsIsland.astro';

// Structured data for SEO
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "TimorUp Products & Services",
  "description": "Browse products and services from businesses in Timor-Leste",
  "url": "https://timorup.com/products-services",
};
---

<Layout
  title="Products & Services - TimorUp"
  description="Browse all products and services from businesses in Timor-Leste"
  structuredData={structuredData}
>
  <div class="container py-4 sm:py-8">
    <!-- Banner - renders immediately, no DB dependency -->
    <CarouselBanner position="products-services" class="mb-6" />

    <!-- Products Island - loads async from D1 -->
    <ProductsIsland is:defer />
  </div>
</Layout>