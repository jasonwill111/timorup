---
// Products & Services page - SSR with client-side filtering
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Input from '../../components/ui/Input.astro';
import { getDb } from '@/lib/db';
import { products, businesses } from '@/db/schema';
import { desc, eq } from 'drizzle-orm';

// Get database instance
const db = await getDb();

// If database is not available, show error
if (!db) {
  return new Response('Service temporarily unavailable', { status: 503 });
}

// Get all businesses for filter
interface BusinessRecord {
  id: string;
  title: string;
  slug: string;
}
let allBusinesses: BusinessRecord[] = [];
try {
  allBusinesses = await db
    .select({
      id: businesses.id,
      title: businesses.title,
      slug: businesses.slug,
    })
    .from(businesses)
    .where(eq(businesses.status, 'live'))
    .all();
} catch (e) {
  console.error('Failed to fetch businesses:', e);
  allBusinesses = [];
}

// Get all products with business info
interface ProductRecord {
  id: string;
  title: string;
  slug: string;
  description: string;
  price: number | null;
  priceUnit: string | null;
  priceFields: string | null;
  productType: string | null;
  businessId: string;
  categoryId: string | null;
  tags: string[];
  status: string;
  createdAt: number;
}
let allProducts: ProductRecord[] = [];
try {
  allProducts = await db
    .select()
    .from(products)
    .orderBy(desc(products.createdAt))
    .all();
} catch (e) {
  console.error('Failed to fetch products:', e);
  allProducts = [];
}

// Join with business data
const productsWithBusiness = allProducts
  .map((p: ProductRecord) => {
    const business = allBusinesses.find((b: BusinessRecord) => b.id === p.businessId);
    return {
      id: p.id,
      title: p.title,
      price: p.price,
      priceFields: p.priceFields,
      productType: p.productType,
      businessId: p.businessId,
      businessTitle: business?.title || 'Unknown',
      businessSlug: business?.slug || '',
      businessType: business?.entityType || 'business',
    };
  })
  .filter((p: any) => p.businessTitle !== 'Unknown');

// Serialize for client - ensure all values are strings or primitives
const safeBusinesses = allBusinesses.map((b: any) => ({
  id: String(b.id || ''),
  title: String(b.title || ''),
  slug: String(b.slug || ''),
}));

const safeProducts = productsWithBusiness.map((p: any) => ({
  id: String(p.id || ''),
  title: String(p.title || ''),
  price: p.price ? String(p.price) : null,
  priceFields: p.priceFields ? String(p.priceFields) : null,
  productType: p.productType ? String(p.productType) : null,
  businessId: String(p.businessId || ''),
  businessTitle: String(p.businessTitle || ''),
  businessSlug: String(p.businessSlug || ''),
  businessType: String(p.businessType || 'business'),
}));

const businessesJson = JSON.stringify(safeBusinesses);
const productsJson = JSON.stringify(safeProducts);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "TimorList Products & Services",
  "description": "Browse products and services from businesses in Timor-Leste",
  "url": "https://timorlist.com/products-services",
};
---

<Layout
  title="Products & Services - TimorList"
  description="Browse all products and services from businesses in Timor-Leste"
  structuredData={structuredData}
>
  <div class="container py-4 sm:py-8">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2 mb-4 sm:mb-6">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold">Products & Services</h1>
        <p class="text-xs sm:text-sm text-muted-foreground">Browse all products and services</p>
      </div>
      <a href="/listings" class="text-xs sm:text-sm text-primary hover:underline">← Directory</a>
    </div>

    <!-- Filters -->
    <form id="filter-form" class="flex flex-wrap gap-2 sm:gap-4 mb-4 sm:mb-6">
      <Input
        id="search"
        name="search"
        type="search"
        placeholder="Search..."
        class="w-full sm:w-48 md:w-64"
      />

      <select id="business-filter" name="business" class="h-9 sm:h-10 px-2 sm:px-3 rounded-md border border-input bg-background text-xs sm:text-sm">
        <option value="">All Businesses</option>
        {allBusinesses.slice(0, 50).map(b => (
          <option value={b.id}>{b.title}</option>
        ))}
      </select>

      <select id="sort-filter" name="sort" class="h-9 sm:h-10 px-2 sm:px-3 rounded-md border border-input bg-background text-xs sm:text-sm">
        <option value="recent">Recent</option>
        <option value="name">Name A-Z</option>
        <option value="price-low">Price ↑</option>
        <option value="price-high">Price ↓</option>
      </select>
    </form>

    <!-- Results -->
    <div id="results-container" class="mb-3 sm:mb-4 text-xs sm:text-sm text-muted-foreground">
      Loading...
    </div>

    <!-- Products Grid -->
    <div id="products-grid" class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2 sm:gap-4">
      <!-- Rendered by JS -->
    </div>
  </div>
</Layout>

<script define:vars={{ businessesJson, productsJson }}>
  const businesses = JSON.parse(businessesJson);
  let products = JSON.parse(productsJson);

  const form = document.getElementById('filter-form');
  const resultsContainer = document.getElementById('results-container');
  const grid = document.getElementById('products-grid');

  function formatPrice(product) {
    if (product.priceFields) {
      try {
        const fields = JSON.parse(product.priceFields);
        if (fields.length > 0 && fields[0].value) {
          const unit = fields[0].unit ? `/${fields[0].unit.replace('/', '')}` : '';
          return `$${fields[0].value}${unit}`;
        }
      } catch {}
    }
    if (product.price) {
      const unit = product.priceUnit ? `/${product.priceUnit.replace('/', '')}` : '';
      return `$${product.price}${unit}`;
    }
    return 'Ask for price';
  }

  function getProductUrl(product) {
    return product.businessType === 'business'
      ? `/business/${product.businessSlug}/product/${product.id}`
      : `/${product.businessType}/${product.businessSlug}`;
  }

  function renderProducts(filteredProducts) {
    resultsContainer.textContent = `Showing ${filteredProducts.length} products`;

    if (filteredProducts.length === 0) {
      grid.innerHTML = '<div class="col-span-full text-center py-12 text-muted-foreground">No products found</div>';
      return;
    }

    grid.innerHTML = filteredProducts.slice(0, 24).map(product => `
      <a href="${getProductUrl(product)}" class="block bg-card rounded-lg border shadow-sm hover:shadow-md hover:border-primary/30 transition-all duration-200 overflow-hidden group cursor-pointer">
        <div class="aspect-square bg-gradient-to-br from-amber-100 to-orange-100 dark:from-amber-900/40 dark:to-orange-900/40 relative flex items-center justify-center">
          <span class="text-4xl font-bold text-amber-500/40">${product.title.charAt(0)}</span>
          ${product.productType ? `
            <span class="absolute top-1.5 left-1.5 sm:top-2 px-1.5 py-0.5 text-[10px] sm:text-[11px] bg-black/75 text-white rounded-full capitalize">
              ${product.productType}
            </span>
          ` : ''}
        </div>
        <div class="p-2 sm:p-3">
          <h3 class="font-medium sm:font-semibold text-xs sm:text-sm truncate group-hover:text-primary transition-colors">${product.title}</h3>
          <p class="text-[10px] sm:text-xs text-muted-foreground truncate">${product.businessTitle}</p>
          <p class="text-xs sm:text-sm font-bold text-primary mt-0.5">${formatPrice(product)}</p>
        </div>
      </a>
    `).join('');
  }

  function applyFilters() {
    const formData = new FormData(form);
    const search = (formData.get('search') || '').toString().toLowerCase();
    const businessId = (formData.get('business') || '').toString();
    const sort = (formData.get('sort') || 'recent').toString();

    let filtered = products;

    if (search) {
      filtered = filtered.filter(p =>
        p.title.toLowerCase().includes(search) ||
        p.businessTitle.toLowerCase().includes(search)
      );
    }

    if (businessId) {
      filtered = filtered.filter(p => p.businessId === businessId);
    }

    if (sort === 'name') {
      filtered.sort((a, b) => a.title.localeCompare(b.title));
    } else if (sort === 'price-low') {
      filtered.sort((a, b) => parseFloat(a.price || '0') - parseFloat(b.price || '0'));
    } else if (sort === 'price-high') {
      filtered.sort((a, b) => parseFloat(b.price || '0') - parseFloat(a.price || '0'));
    }

    renderProducts(filtered);
  }

  form.addEventListener('input', () => setTimeout(applyFilters, 300));
  form.addEventListener('change', applyFilters);

  // Init
  applyFilters();
</script>