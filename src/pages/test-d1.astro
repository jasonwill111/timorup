---
export const prerender = false;

import { getDb } from '@/lib/db';
import { businesses } from '@/db/schema';
import { eq } from 'drizzle-orm';

const db = await getDb();
const result = await db.select().from(businesses).limit(3).all();

console.log('Test D1 - businesses count:', result.length);
---

<!DOCTYPE html>
<html>
<head><title>D1 Test</title></head>
<body>
<h1>D1 Test</h1>
<p>Businesses found: {result.length}</p>
<ul>
{result.map(b => (
  <li>{b.title} ({b.slug})</li>
))}
</ul>
</body>
</html>
