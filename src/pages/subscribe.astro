---
import Layout from '../layouts/Layout.astro';
import { Button } from '../components/ui/button';
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter } from '../components/ui/card';
---

<Layout title="Subscribe - TMBIZ">
  <div class="container py-12">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-3xl font-bold text-center mb-4">Complete Your Subscription</h1>
      <p class="text-center text-muted-foreground mb-8">
        You've chosen the <span id="plan-name" class="font-semibold text-primary"></span> plan.
      </p>
      
      <!-- Order Summary -->
      <Card class="mb-8">
        <CardHeader>
          <CardTitle>Order Summary</CardTitle>
        </CardHeader>
        <CardContent>
          <div class="flex justify-between items-center py-2">
            <span>Plan</span>
            <span id="plan-display" class="font-medium"></span>
          </div>
          <div class="flex justify-between items-center py-2 border-t">
            <span>Amount</span>
            <span id="plan-price" class="font-bold text-xl"></span>
          </div>
          <div class="mt-4 p-3 bg-yellow-50 dark:bg-yellow-900/20 rounded-lg">
            <p class="text-sm text-yellow-800 dark:text-yellow-200">
              <strong>3-Day Free Trial:</strong> Your business will be live for 3 days. If you don't complete payment, it will be downgraded to basic display.
            </p>
          </div>
        </CardContent>
      </Card>
      
      <!-- Payment Instructions -->
      <Card class="mb-8">
        <CardHeader>
          <CardTitle>Payment Instructions</CardTitle>
          <CardDescription>Choose your preferred payment method</CardDescription>
        </CardHeader>
        <CardContent class="space-y-6">
          <!-- QR Code -->
          <div class="text-center">
            <p class="font-medium mb-2">Scan QR Code</p>
            <div class="inline-block p-4 bg-white rounded-lg border">
              <img id="qr-code" src="/images/payment-qr.png" alt="Payment QR Code" class="w-48 h-48 object-contain" />
            </div>
          </div>
          
          <div class="border-t pt-6">
            <p class="font-medium mb-3">Other Payment Methods:</p>
            <ul class="space-y-2 text-muted-foreground">
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Cash payment at our office
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Bank transfer
              </li>
            </ul>
          </div>
          
          <div class="border-t pt-6">
            <p class="font-medium mb-2">Contact Information:</p>
            <p class="text-muted-foreground">Email: contact@timorbiz.com</p>
            <p class="text-muted-foreground">Phone: +670</p>
          </div>
        </CardContent>
      </Card>
      
      <!-- Confirmation -->
      <Card class="bg-green-50 dark:bg-green-900/20 border-green-200 dark:border-green-800">
        <CardContent class="pt-6">
          <div class="flex gap-4">
            <svg class="w-6 h-6 text-green-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div>
              <p class="font-medium text-green-800 dark:text-green-200">How to confirm your payment:</p>
              <ol class="mt-2 text-sm text-green-700 dark:text-green-300 space-y-1">
                <li>1. Make your payment using any method above</li>
                <li>2. Contact us via WhatsApp with your payment proof</li>
                <li>3. We'll confirm and activate your subscription within 24 hours</li>
              </ol>
              <a 
                href="https://wa.me/670" 
                class="inline-flex items-center gap-2 mt-4 bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Contact via WhatsApp
              </a>
            </div>
          </div>
        </CardContent>
      </Card>
    </div>
  </div>
</ Layout>

<script>
  // Get plan from URL params
  const urlParams = new URLSearchParams(window.location.search);
  const plan = urlParams.get('plan') || 'monthly';
  
  const plans: Record<string, { name: string; price: string }> = {
    monthly: { name: 'Monthly Plan', price: '$39/month' },
    yearly: { name: 'Yearly Plan', price: '$390/year' },
  };
  
  const selectedPlan = plans[plan] || plans.monthly;
  
  // Update UI
  const planName = document.getElementById('plan-name');
  const planDisplay = document.getElementById('plan-display');
  const planPrice = document.getElementById('plan-price');
  
  if (planName) planName.textContent = selectedPlan.name;
  if (planDisplay) planDisplay.textContent = selectedPlan.name;
  if (planPrice) planPrice.textContent = selectedPlan.price;
</script>
