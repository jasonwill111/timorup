---
// Subscribe page - subscription confirmation with offline payment
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import CardHeader from '../components/ui/CardHeader.astro';
import CardTitle from '../components/ui/CardTitle.astro';
import CardDescription from '../components/ui/CardDescription.astro';
import CardContent from '../components/ui/CardContent.astro';
import CardFooter from '../components/ui/CardFooter.astro';

// Check auth
const cookieHeader = Astro.request.headers.get('cookie') || '';
let user: { id: string; name: string; email: string } | null = null;
let userBusiness: {
  id: string;
  title: string;
  contactName: string | null;
  contactNumber: string | null;
  email: string | null;
  countryCode: string | null;
} | null = null;

try {
  const tokenMatch = cookieHeader.match(/better-auth\.session_token=([^;]+)/);

  if (tokenMatch) {
    const { getDb } = await import('@/lib/db');
    const db = await getDb();
    const { sessions, users, businessPages } = await import('@/db/schema');
    const { eq } = await import('drizzle-orm');

    const session = await db.select()
      .from(sessions)
      .where(eq(sessions.token, tokenMatch[1]))
      .limit(1)
      .get();

    if (session && session.expiresAt && new Date(session.expiresAt) > new Date()) {
      const userRecord = await db.select()
        .from(users)
        .where(eq(users.id, session.userId))
        .limit(1)
        .get();

      if (userRecord) {
        user = {
          id: userRecord.id,
          name: userRecord.name || '',
          email: userRecord.email || ''
        };

        const business = await db.select({
          id: businessPages.id,
          title: businessPages.title,
          contactName: businessPages.contactName,
          contactNumber: businessPages.contactNumber,
          email: businessPages.email,
          countryCode: businessPages.countryCode,
        })
        .from(businessPages)
        .where(eq(businessPages.ownerId, user.id))
        .limit(1)
        .get();

        userBusiness = business || null;
      }
    }
  }
} catch (e) {
  console.error('Auth check failed:', e);
}

// Debug: log session check result
console.log('[Subscribe] Auth check result:', { userId: user?.id, userName: user?.name });

if (!user) {
  return Astro.redirect('/login?redirect=/subscribe');
}

// Parse plan from URL
const url = new URL(Astro.request.url);
const planParam = url.searchParams.get('plan') || 'basic-monthly';
const isConfirmed = url.searchParams.get('confirmed') === 'true';

// Plan details
const PLAN_INFO: Record<string, {
  name: string;
  amount: number;
  period: string;
  skuLimit: number;
  features: string[];
  description: string;
}> = {
  'basic-monthly': { name: 'Basic', amount: 29, period: 'Monthly', skuLimit: 10, features: ['10 products/services', '5 images per product', 'Photo gallery', 'Map integration', 'Customer reviews'], description: 'For small businesses getting started' },
  'basic-yearly': { name: 'Basic', amount: 290, period: 'Yearly', skuLimit: 10, features: ['10 products/services', '5 images per product', 'Photo gallery', 'Map integration', 'Customer reviews'], description: 'Save 17% with annual billing' },
  'pro-monthly': { name: 'Pro', amount: 59, period: 'Monthly', skuLimit: 30, features: ['30 products/services', '5 images per product', 'Priority support', 'Enhanced visibility', 'All Basic features'], description: 'For growing businesses' },
  'pro-yearly': { name: 'Pro', amount: 590, period: 'Yearly', skuLimit: 30, features: ['30 products/services', '5 images per product', 'Priority support', 'Enhanced visibility', 'All Basic features'], description: 'Save 17% with annual billing' },
  'max-monthly': { name: 'Max', amount: 89, period: 'Monthly', skuLimit: 60, features: ['60 products/services', '5 images per product', 'Dedicated support', 'Featured placement', 'All Pro features'], description: 'For established businesses' },
  'max-yearly': { name: 'Max', amount: 890, period: 'Yearly', skuLimit: 60, features: ['60 products/services', '5 images per product', 'Dedicated support', 'Featured placement', 'All Pro features'], description: 'Save 17% with annual billing' },
};

const selectedPlan = PLAN_INFO[planParam] || PLAN_INFO['basic-monthly'];

// Get or create order
let orderId: string | null = null;
let isOrderCreated = false;

try {
  const { getDb } = await import('@/lib/db');
  const db = await getDb();
  const { orders } = await import('@/db/schema');
  const { eq, and } = await import('drizzle-orm');

  // Check for existing unpaid order
  const existingOrder = await db.select({ id: orders.id })
    .from(orders)
    .where(and(
      eq(orders.userId, user.id),
      eq(orders.planType, planParam),
      eq(orders.status, 'unpaid')
    ))
    .limit(1)
    .get();

  if (existingOrder) {
    orderId = existingOrder.id;
    isOrderCreated = true;
  } else if (userBusiness) {
    // Create new order
    orderId = `order-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;
    await db.insert(orders).values({
      id: orderId,
      userId: user.id,
      businessPageId: userBusiness.id,
      planType: planParam,
      amount: selectedPlan.amount,
      status: 'unpaid',
    }).run();
    isOrderCreated = true;
  }
} catch (e) {
  console.error('Order handling failed:', e);
}

// Admin contact info (configurable in production)
const adminInfo = {
  address: 'Rua target, Dili, Timor-Leste',
  phone: '+670 7700 0000',
  whatsapp: '67077000000',
  email: 'contact@timorlist.com',
  officeHours: 'Mon-Fri 9:00-17:00',
};
---

<Layout title={`Subscribe - ${selectedPlan.name} Plan`}>
  <div class="container py-8 md:py-12">
    <div class="max-w-2xl mx-auto">

      {!userBusiness ? (
        <!-- No business created -->
        <div class="text-center py-12">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center">
            <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          <h1 class="text-2xl font-bold mb-2">Create Business First</h1>
          <p class="text-muted-foreground mb-6">You need to create a business listing before subscribing.</p>
          <a href="/listing/create?type=business">
            <Button>Create Business Listing</Button>
          </a>
        </div>

      ) : !isConfirmed ? (
        <!-- Step 1: Review and confirm subscription -->
        <div>
          <div class="text-center mb-8">
            <h1 class="text-2xl md:text-3xl font-bold mb-2">Confirm Your Subscription</h1>
            <p class="text-muted-foreground">Review your details and confirm to proceed with payment</p>
          </div>

          <!-- User Information -->
          <Card class="mb-4">
            <CardHeader>
              <CardTitle>Your Information</CardTitle>
            </CardHeader>
            <CardContent class="space-y-2">
              <div class="flex justify-between">
                <span class="text-muted-foreground">Name</span>
                <span class="font-medium">{user.name}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-muted-foreground">Email</span>
                <span class="font-medium">{user.email}</span>
              </div>
            </CardContent>
          </Card>

          <!-- Business Information -->
          <Card class="mb-4">
            <CardHeader>
              <CardTitle>Business Details</CardTitle>
            </CardHeader>
            <CardContent class="space-y-2">
              <div class="flex justify-between">
                <span class="text-muted-foreground">Business Name</span>
                <span class="font-medium">{userBusiness.title}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-muted-foreground">Contact Person</span>
                <span class="font-medium">{userBusiness.contactName || '-'}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-muted-foreground">Phone</span>
                <span class="font-medium">
                  {userBusiness.contactNumber
                    ? `${userBusiness.countryCode || '+670'} ${userBusiness.contactNumber}`
                    : '-'}
                </span>
              </div>
            </CardContent>
          </Card>

          <!-- Selected Plan -->
          <Card class="mb-6 border-2 border-primary">
            <CardHeader>
              <CardTitle class="flex items-center justify-between">
                <span>Selected Plan</span>
                <span class="px-3 py-1 bg-primary text-black text-sm rounded-full">{selectedPlan.name}</span>
              </CardTitle>
              <CardDescription>{selectedPlan.description}</CardDescription>
            </CardHeader>
            <CardContent>
              <div class="flex justify-between items-center mb-4">
                <span class="text-3xl font-bold text-primary">${selectedPlan.amount}</span>
                <span class="text-muted-foreground">/{selectedPlan.period.toLowerCase()}</span>
              </div>

              <div class="border-t pt-4">
                <p class="text-sm font-medium mb-2">What's included:</p>
                <ul class="space-y-1">
                  {selectedPlan.features.map(feature => (
                    <li class="flex items-center gap-2 text-sm">
                      <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
            </CardContent>
            <CardFooter class="bg-muted/30">
              <div class="flex justify-between w-full text-sm">
                <span class="text-muted-foreground">SKU Limit</span>
                <span class="font-medium">{selectedPlan.skuLimit} products</span>
              </div>
            </CardFooter>
          </Card>

          <!-- Confirm Button -->
          <div class="text-center">
            <a href={`/subscribe?plan=${planParam}&confirmed=true`}>
              <Button size="lg" class="px-8">
                Confirm Subscription
              </Button>
            </a>
            <p class="text-sm text-muted-foreground mt-2">You'll be redirected to payment instructions</p>
          </div>

          <!-- Back to pricing -->
          <div class="text-center mt-4">
            <a href="/pricing" class="text-sm text-muted-foreground hover:text-foreground">
              ← Change plan
            </a>
          </div>
        </div>

      ) : (
        <!-- Step 2: Payment instructions (offline) -->
        <div>
          <div class="text-center mb-8">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
              <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h1 class="text-2xl md:text-3xl font-bold mb-2">Subscription Confirmed</h1>
            <p class="text-muted-foreground">Complete your payment using the information below</p>
          </div>

          <!-- Order Summary -->
          <Card class="mb-6">
            <CardHeader>
              <CardTitle>Order Summary</CardTitle>
            </CardHeader>
            <CardContent class="space-y-2">
              <div class="flex justify-between">
                <span class="text-muted-foreground">Business</span>
                <span class="font-medium">{userBusiness.title}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-muted-foreground">Plan</span>
                <span class="font-medium">{selectedPlan.name} ({selectedPlan.period})</span>
              </div>
              <div class="flex justify-between border-t pt-2">
                <span class="font-semibold">Total Amount</span>
                <span class="font-bold text-xl text-primary">${selectedPlan.amount}</span>
              </div>
            </CardContent>
          </Card>

          <!-- Payment Options -->
          <Card class="mb-6">
            <CardHeader>
              <CardTitle>Payment Options</CardTitle>
              <CardDescription>Payment can only be made offline</CardDescription>
            </CardHeader>
            <CardContent class="space-y-4">
              <!-- WhatsApp Contact -->
              <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-4">
                <h3 class="font-semibold text-green-800 dark:text-green-200 mb-3 flex items-center gap-2">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  Contact via WhatsApp
                </h3>
                <p class="text-sm text-green-700 dark:text-green-300 mb-3">
                  Send your payment proof and we'll confirm within 24 hours
                </p>
                <a
                  href={`https://wa.me/${adminInfo.whatsapp}?text=${encodeURIComponent(
                    `Hi, I want to confirm my TimorList subscription.\n\n` +
                    `Order ID: ${orderId?.slice(0, 20)}...\n` +
                    `Plan: ${selectedPlan.name} (${selectedPlan.period})\n` +
                    `Amount: $${selectedPlan.amount}\n` +
                    `Business: ${userBusiness.title}`
                  )}`}
                  target="_blank"
                  class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  Contact on WhatsApp
                </a>
              </div>

              <!-- Office Visit -->
              <div class="border-t pt-4">
                <h3 class="font-semibold mb-3 flex items-center gap-2">
                  <svg class="w-5 h-5 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                  Visit Our Office
                </h3>
                <div class="bg-muted/30 rounded-lg p-4 space-y-2">
                  <p class="font-medium">{adminInfo.address}</p>
                  <p class="text-sm text-muted-foreground">{adminInfo.officeHours}</p>
                </div>
              </div>

              <!-- Bank Transfer -->
              <div class="border-t pt-4">
                <h3 class="font-semibold mb-3 flex items-center gap-2">
                  <svg class="w-5 h-5 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16M3 21h18M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                  Bank Transfer
                </h3>
                <p class="text-sm text-muted-foreground">Contact us via WhatsApp for bank details.</p>
              </div>
            </CardContent>
          </Card>

          <!-- Admin Contact Card -->
          <Card class="bg-amber-50 dark:bg-amber-900/20 border-amber-200 dark:border-amber-800">
            <CardContent class="pt-6">
              <h3 class="font-semibold text-amber-800 dark:text-amber-200 mb-3">Admin Contact</h3>
              <div class="space-y-2 text-sm">
                <p class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  {adminInfo.address}
                </p>
                <p class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  {adminInfo.phone}
                </p>
                <p class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  {adminInfo.email}
                </p>
              </div>
            </CardContent>
          </Card>

          <!-- What happens next -->
          <div class="mt-6 text-center text-sm text-muted-foreground">
            <p>After your payment is confirmed, your subscription will be activated within 24 hours.</p>
            <p class="mt-2">You'll be notified via email when your subscription is active.</p>
          </div>

          <!-- Back to account -->
          <div class="text-center mt-4">
            <a href="/account" class="text-sm text-muted-foreground hover:text-foreground">
              ← Go to My Account
            </a>
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>