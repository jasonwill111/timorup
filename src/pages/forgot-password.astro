---

export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Input from '../components/ui/Input.astro';
import AuthCard from '../components/forms/AuthCard.astro';
import FormMessage from '../components/forms/FormMessage.astro';
import LoadingButton from '../components/forms/LoadingButton.astro';
---

<Layout title="Forgot Password - TimorLink">
  <AuthCard
    title="Forgot Password?"
    description="Enter your email address and we'll send you a link to reset your password"
    footerText="Back to Login"
    footerLink={{ href: '/login', text: 'Sign in' }}
  >
    <form id="forgot-password-form" action="/api/auth/forgot-password" class="space-y-4">
      <FormMessage id="form-message" type="error" />

      <div>
        <label for="email" class="block text-sm font-medium mb-1">Email Address</label>
        <Input
          id="email"
          name="email"
          type="email"
          placeholder="your@email.com"
          required
        />
      </div>

      <LoadingButton id="submit-btn" defaultText="Send Reset Link" loadingText="Sending..." />
    </form>
  </AuthCard>
</Layout>

<script>
  import { actions } from 'astro:actions';

  const form = document.getElementById('forgot-password-form');
  const message = document.getElementById('form-message');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const btnText = document.getElementById('submit-btn-text');
  const btnLoading = document.getElementById('submit-btn-loading');

  function setLoading(loading: boolean) {
    if (submitBtn) submitBtn.disabled = loading;
    btnText?.classList.toggle('hidden', loading);
    btnLoading?.classList.toggle('hidden', !loading);
  }

  function showMessage(text: string, isSuccess: boolean) {
    if (!message) return;
    message.textContent = text;
    if (isSuccess) {
      message.className = message.className
        .replace(/bg-red-\d+/g, 'bg-green-50')
        .replace(/text-red-\d+/g, 'text-green-700')
        .replace(/dark:bg-red-\d+/g, 'dark:bg-green-900/20')
        .replace(/dark:text-red-\d+/g, 'dark:text-green-400');
    }
    message.classList.remove('hidden');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const email = formData.get('email') as string;

    setLoading(true);

    try {
      const result = await actions.auth.forgotPassword({ email });

      setLoading(false);

      if (result.success) {
        showMessage('Check your email for reset instructions. The link will expire in 1 hour.', true);
        form.reset();
      } else {
        showMessage(result.error?.message || 'Failed to send reset email', false);
      }
    } catch {
      setLoading(false);
      showMessage('An error occurred. Please try again.', false);
    }
  });
</script>

