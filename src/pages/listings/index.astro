---
// Listings page - Astro 6 Server Islands pattern
// Banner renders immediately, listings load async via is:defer
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import CarouselBanner from '../../components/ui/CarouselBanner.astro';
import ListingListIsland from '../../components/islands/ListingListNew.astro';

// Astro 6: Set streaming headers for progressive page load
---

<Layout title="Classified Ads - TimorUp">
  <!-- Banner - renders immediately, no DB dependency -->
  <CarouselBanner position="listings" class="mb-6" />

  <!-- Listing List Island - loads async from D1 -->
  <ListingListIsland is:defer />
</Layout>