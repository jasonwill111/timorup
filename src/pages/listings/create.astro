---
// Create Listing - /listing/create
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import CardHeader from '../../components/ui/CardHeader.astro';
import CardTitle from '../../components/ui/CardTitle.astro';
import CardDescription from '../../components/ui/CardDescription.astro';
import CardContent from '../../components/ui/CardContent.astro';

// Check auth via session cookie
const cookieHeader = Astro.request.headers.get('cookie') || '';
let user: { id: string } | null = null;
let hasExistingListing = false;
let existingListing: { title: string; slug: string; entityType: string } | null = null;

try {
  // Get user from session table directly
  const tokenMatch = cookieHeader.match(/better-auth\.session_token=([^;]+)/);

  if (tokenMatch) {
    const { getDb } = await import('@/lib/db');
    const db = await getDb();
    const { sessions, users, businessPages, categories } = await import('@/db/schema');
    const { eq } = await import('drizzle-orm');

    // Find session by token
    const session = await db.select()
      .from(sessions)
      .where(eq(sessions.token, tokenMatch[1]))
      .limit(1)
      .get();

    if (session && session.expiresAt) {
      // expiresAt in D1 is Unix timestamp (seconds)
      const expiresAtMs = typeof session.expiresAt === 'number'
        ? session.expiresAt * 1000
        : new Date(session.expiresAt).getTime();

      if (expiresAtMs > Date.now()) {
        // Session valid, get user
        const userRecord = await db.select()
          .from(users)
          .where(eq(users.id, session.userId))
          .limit(1)
          .get();

        if (userRecord) {
          user = { id: userRecord.id };

          // Get existing listing
          const existing = await db.select()
            .from(businessPages)
            .where(eq(businessPages.ownerId, user.id))
            .limit(1)
            .get();

          if (existing) {
            hasExistingListing = true;
            existingListing = existing;
          }
        }
      }
    }
  }
} catch (e) {
  console.error('Auth check failed:', e);
}

// Redirect if not logged in
if (!user) {
  return Astro.redirect('/login?redirect=/listing/create');
}

const url = new URL(Astro.request.url);
const selectedType = url.searchParams.get('type') || '';
const showTypeSelector = !selectedType;
const showForm = Boolean(selectedType);
const isBusiness = selectedType === 'business';
const isFreeType = selectedType === 'government' || selectedType === 'nonprofit';

// Get categories for selection
let allCategories: { id: string; name: string; slug: string }[] = [];
try {
  const { getDb } = await import('@/lib/db');
  const db = await getDb();
  const { categories } = await import('@/db/schema');
  allCategories = await db.select().from(categories).orderBy(categories.name).all();
} catch (e) {
  console.error('Failed to load categories:', e);
}
---

<Layout title="Create Listing - TimorList">
  <div class="container py-8 max-w-4xl">
    {hasExistingListing ? (
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 text-center">
        <div class="w-16 h-16 mx-auto mb-4 bg-amber-100 rounded-full flex items-center justify-center">
          <svg class="w-8 h-8 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <h2 class="text-xl font-bold text-amber-900 mb-2">You Already Have a Listing</h2>
        <p class="text-amber-700 mb-4">Each account can only create one listing.</p>

        <div class="bg-white rounded-lg p-4 mb-6 text-left max-w-md mx-auto border border-amber-100">
          <p class="font-medium">{existingListing?.title}</p>
          <p class="text-sm text-muted-foreground capitalize">{existingListing?.entityType}</p>
        </div>

        <div class="flex gap-4 justify-center">
          <a href="/account" class="px-6 py-2 bg-primary text-black font-medium rounded-lg hover:bg-primary/90 transition-colors">
            Go to Dashboard
          </a>
          <a href={`/business/${existingListing?.slug}`} class="px-6 py-2 border border-amber-300 text-amber-800 font-medium rounded-lg hover:bg-amber-100 transition-colors">
            View Listing
          </a>
        </div>
      </div>
    ) : null}

    {!hasExistingListing && showTypeSelector ? (
      <div>
        <div class="mb-8">
          <h1 class="text-3xl font-bold">Create Your Listing</h1>
          <p class="text-muted-foreground mt-2">Fill in your details to get started</p>
        </div>

        <h2 class="text-lg font-semibold mb-4">What type of listing?</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <a href="/listing/create?type=business" class="block">
            <div class="border rounded-xl p-6 hover:border-primary hover:bg-primary/5 transition-all h-full">
              <div class="text-4xl mb-3">🏪</div>
              <h3 class="font-semibold text-lg mb-1">Business</h3>
              <p class="text-sm text-muted-foreground">For commercial businesses and enterprises</p>
              <p class="text-xs text-amber-600 mt-2">Requires subscription</p>
            </div>
          </a>
          <a href="/listing/create?type=government" class="block">
            <div class="border rounded-xl p-6 hover:border-purple-500 hover:bg-purple-50 dark:hover:bg-purple-900/20 transition-all h-full">
              <div class="text-4xl mb-3">🏛️</div>
              <h3 class="font-semibold text-lg mb-1">Government</h3>
              <p class="text-sm text-muted-foreground">For government agencies and offices</p>
              <p class="text-xs text-green-600 mt-2">Free listing</p>
            </div>
          </a>
          <a href="/listing/create?type=nonprofit" class="block">
            <div class="border rounded-xl p-6 hover:border-orange-500 hover:bg-orange-50 dark:hover:bg-orange-900/20 transition-all h-full">
              <div class="text-4xl mb-3">❤️</div>
              <h3 class="font-semibold text-lg mb-1">NGO / Nonprofit</h3>
              <p class="text-sm text-muted-foreground">For NGOs, nonprofits, and foundations</p>
              <p class="text-xs text-green-600 mt-2">Free listing</p>
            </div>
          </a>
        </div>
      </div>
    ) : null}

    {!hasExistingListing && showForm ? (
      <div id="create-form">
        <div class="flex items-center mb-6">
          <a href="/listing/create" class="text-sm text-muted-foreground hover:text-foreground flex items-center gap-1">
            <span>←</span> Back to type selection
          </a>
        </div>

        {isBusiness ? (
          <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
            <p class="text-amber-800 text-sm">
              <strong>Business listings require a subscription.</strong>
              <a href="/pricing" class="underline ml-1">View pricing plans →</a>
            </p>
          </div>
        ) : null}

        {isFreeType ? (
          <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
            <p class="text-green-800 text-sm">
              <strong>Free listing!</strong> Government and nonprofit organizations get a free listing on TimorList.
            </p>
          </div>
        ) : null}

        <form id="listing-form" class="space-y-6">
          <input type="hidden" id="entityType" name="entityType" value={selectedType} />

          {/* Basic Information */}
          <Card>
            <CardHeader>
              <CardTitle>Basic Information</CardTitle>
              <CardDescription>The main details about your listing</CardDescription>
            </CardHeader>
            <CardContent class="space-y-4">
              <div>
                <label for="title" class="block text-sm font-medium mb-1">Name *</label>
                <input
                  type="text"
                  id="title"
                  name="title"
                  required
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                  placeholder="Your business name"
                />
              </div>

              <div>
                <label for="slug" class="block text-sm font-medium mb-1">URL Slug *</label>
                <input
                  type="text"
                  id="slug"
                  name="slug"
                  required
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                  placeholder="your-business-name"
                />
                <p class="text-xs text-muted-foreground mt-1" id="slug-help">
                  Your URL will be: timorlist.com/business/your-slug
                </p>
              </div>

              <div>
                <label for="categoryId" class="block text-sm font-medium mb-1">Category *</label>
                <select id="categoryId" name="categoryId" required class="w-full px-3 py-2 border rounded-lg bg-background">
                  <option value="">Select a category</option>
                  {allCategories.map(cat => (
                    <option value={cat.id}>{cat.name}</option>
                  ))}
                </select>
              </div>

              <div>
                <label for="aboutUs" class="block text-sm font-medium mb-1">About Us *</label>
                <textarea
                  id="aboutUs"
                  name="aboutUs"
                  rows="4"
                  required
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                  placeholder="Tell people about your business, what you offer, and what makes you unique..."
                ></textarea>
                <p class="text-xs text-muted-foreground mt-1">Minimum 50 characters</p>
              </div>

              <div>
                <label for="yearOfEstablishment" class="block text-sm font-medium mb-1">Year Established</label>
                <input
                  type="number"
                  id="yearOfEstablishment"
                  name="yearOfEstablishment"
                  min="1900"
                  max={new Date().getFullYear()}
                  class="w-full px-3 py-2 border rounded-lg bg-background"
                  placeholder="2020"
                />
              </div>
            </CardContent>
          </Card>

          {/* Contact Information */}
          <Card>
            <CardHeader>
              <CardTitle>Contact Information</CardTitle>
              <CardDescription>How people can reach you</CardDescription>
            </CardHeader>
            <CardContent class="space-y-4">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label for="contactName" class="block text-sm font-medium mb-1">Contact Person *</label>
                  <input type="text" id="contactName" name="contactName" required class="w-full px-3 py-2 border rounded-lg bg-background" placeholder="Your name" />
                </div>
                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label for="countryCode" class="block text-sm font-medium mb-1">Code *</label>
                    <select id="countryCode" name="countryCode" required class="w-full px-3 py-2 border rounded-lg bg-background">
                      <option value="+670">+670 TL</option>
                      <option value="+62">+62 ID</option>
                      <option value="+63">+63 PH</option>
                      <option value="+60">+60 MY</option>
                      <option value="+65">+65 SG</option>
                      <option value="+61">+61 AU</option>
                      <option value="+351">+351 PT</option>
                      <option value="+1">+1 US</option>
                      <option value="+86">+86 CN</option>
                      <option value="+852">+852 HK</option>
                      <option value="+886">+886 TW</option>
                      <option value="+81">+81 JP</option>
                      <option value="+82">+82 KR</option>
                      <option value="+66">+66 TH</option>
                      <option value="+84">+84 VN</option>
                    </select>
                  </div>
                  <div>
                    <label for="contactNumber" class="block text-sm font-medium mb-1">Phone *</label>
                    <input type="tel" id="contactNumber" name="contactNumber" required class="w-full px-3 py-2 border rounded-lg bg-background" placeholder="7xxxxxxx" />
                  </div>
                </div>
              </div>
              <div>
                <label for="email" class="block text-sm font-medium mb-1">Email *</label>
                <input type="email" id="email" name="email" required class="w-full px-3 py-2 border rounded-lg bg-background" placeholder="contact@example.com" />
              </div>
              <div>
                <label for="address" class="block text-sm font-medium mb-1">Address *</label>
                <textarea id="address" name="address" rows="2" required class="w-full px-3 py-2 border rounded-lg bg-background" placeholder="Street address, area, city"></textarea>
              </div>

              {/* Location Map */}
              <div>
                <label class="block text-sm font-medium mb-2">Location on Map *</label>
                <div class="grid grid-cols-2 gap-3 mb-2">
                  <input type="number" step="any" id="locationLat" name="locationLat" required class="w-full px-3 py-2 border rounded-lg bg-background" placeholder="Latitude (e.g., -8.5569)" />
                  <input type="number" step="any" id="locationLng" name="locationLng" required class="w-full px-3 py-2 border rounded-lg bg-background" placeholder="Longitude (e.g., 125.5603)" />
                </div>
                <p class="text-xs text-muted-foreground mb-2">Enter coordinates or click the map below to set location</p>
                <div id="map-picker" class="w-full h-48 rounded-lg border bg-muted flex items-center justify-center cursor-pointer">
                  <div class="text-center text-muted-foreground">
                    <svg class="w-8 h-8 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <p class="text-sm">Click to open map picker</p>
                    <p class="text-xs">Or enter coordinates above</p>
                  </div>
                </div>
                <input type="hidden" id="mapCoords" name="mapCoords" value="" />
              </div>
            </CardContent>
          </Card>

          {/* Opening Hours */}
          <Card>
            <CardHeader>
              <CardTitle>Opening Hours</CardTitle>
              <CardDescription>When are you open for business?</CardDescription>
            </CardHeader>
            <CardContent class="space-y-3">
              {['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'].map(day => (
                <div class="flex items-center gap-4" data-day={day}>
                  <span class="w-24 text-sm capitalize">{day}</span>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="checkbox" class="day-closed" data-day={day} />
                    <span class="text-sm">Closed</span>
                  </label>
                  <div class="flex items-center gap-2 day-hours">
                    <input type="time" class="day-open px-3 py-2 border rounded-lg bg-background text-sm" data-day={day} value="09:00" />
                    <span>to</span>
                    <input type="time" class="day-close px-3 py-2 border rounded-lg bg-background text-sm" data-day={day} value="17:00" />
                  </div>
                </div>
              ))}
            </CardContent>
          </Card>

          {/* Tags */}
          <Card>
            <CardHeader>
              <CardTitle>Tags</CardTitle>
              <CardDescription>Keywords to help people find your listing (comma separated)</CardDescription>
            </CardHeader>
            <CardContent>
              <input
                type="text"
                id="tags"
                name="tags"
                class="w-full px-3 py-2 border rounded-lg bg-background"
                placeholder="wifi, parking, air-conditioning, credit card accepted"
              />
              <p class="text-xs text-muted-foreground mt-1">Add up to 10 tags to improve search visibility</p>
            </CardContent>
          </Card>

          {/* Social Links */}
          <Card>
            <CardHeader>
              <CardTitle>Social Media Links</CardTitle>
              <CardDescription>Connect your social media profiles</CardDescription>
            </CardHeader>
            <CardContent class="space-y-4">
              <div>
                <label for="facebook" class="block text-sm font-medium mb-1">
                  <span class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    Facebook
                  </span>
                </label>
                <input type="url" id="facebook" name="facebook" class="w-full px-3 py-2 border rounded-lg bg-background" placeholder="https://facebook.com/yourpage" />
              </div>
              <div>
                <label for="instagram" class="block text-sm font-medium mb-1">
                  <span class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-pink-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                    Instagram
                  </span>
                </label>
                <input type="url" id="instagram" name="instagram" class="w-full px-3 py-2 border rounded-lg bg-background" placeholder="https://instagram.com/yourpage" />
              </div>
              <div>
                <label for="tiktok" class="block text-sm font-medium mb-1">
                  <span class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1-.1z"/></svg>
                    TikTok
                  </span>
                </label>
                <input type="url" id="tiktok" name="tiktok" class="w-full px-3 py-2 border rounded-lg bg-background" placeholder="https://tiktok.com/@yourpage" />
              </div>
            </CardContent>
          </Card>

          {/* Images */}
          <Card>
            <CardHeader>
              <CardTitle>Images</CardTitle>
              <CardDescription>Upload photos for your listing</CardDescription>
            </CardHeader>
            <CardContent class="space-y-4">
              <div>
                <label for="bannerImage" class="block text-sm font-medium mb-1">Banner Image</label>
                <input type="file" id="bannerImage" name="bannerImage" accept="image/*" class="w-full px-3 py-2 border rounded-lg bg-background" />
                <p class="text-xs text-muted-foreground mt-1">Recommended size: 1200x400px</p>
              </div>
              <div>
                <label for="profileImage" class="block text-sm font-medium mb-1">Profile Image</label>
                <input type="file" id="profileImage" name="profileImage" accept="image/*" class="w-full px-3 py-2 border rounded-lg bg-background" />
                <p class="text-xs text-muted-foreground mt-1">Recommended size: 400x400px (square)</p>
              </div>
              <div>
                <label for="galleryImages" class="block text-sm font-medium mb-1">Gallery Images (up to 6)</label>
                <input type="file" id="galleryImages" name="galleryImages" accept="image/*" multiple class="w-full px-3 py-2 border rounded-lg bg-background" />
                <p class="text-xs text-muted-foreground mt-1">Select multiple images for your photo gallery</p>
              </div>
            </CardContent>
          </Card>

          <div class="flex gap-4 pt-4">
            <Button type="button" id="save-draft-btn" variant="outline">Save as Draft</Button>
            {isBusiness ? (
              <Button type="button" id="subscribe-btn" class="bg-amber-600 hover:bg-amber-700">Subscribe & Publish</Button>
            ) : (
              <Button type="button" id="publish-btn" class="bg-green-600 hover:bg-green-700">Publish (Free)</Button>
            )}
          </div>
        </form>
      </div>
    ) : null}
  </div>
</Layout>

<script>
  const form = document.getElementById('listing-form') as HTMLFormElement | null;
  const slugInput = document.getElementById('slug') as HTMLInputElement | null;
  const titleInput = document.getElementById('title') as HTMLInputElement | null;
  const saveDraftBtn = document.getElementById('save-draft-btn');
  const publishBtn = document.getElementById('publish-btn');
  const subscribeBtn = document.getElementById('subscribe-btn');
  const entityTypeInput = document.getElementById('entityType') as HTMLInputElement | null;

  // Auto-generate slug from title
  titleInput?.addEventListener('input', () => {
    if (slugInput && !slugInput.dataset.manual) {
      slugInput.value = titleInput.value
        .toLowerCase()
        .replace(/\s+/g, '-')
        .replace(/[^a-z0-9-]/g, '')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');
    }
  });

  slugInput?.addEventListener('input', () => {
    if (slugInput) {
      slugInput.dataset.manual = 'true';
    }
  });

  // Handle closed days
  document.querySelectorAll('.day-closed').forEach(checkbox => {
    checkbox.addEventListener('change', (e) => {
      const day = (e.target as HTMLElement).dataset.day;
      const hoursDiv = document.querySelector(`[data-day="${day}"].day-hours`);
      if (hoursDiv) {
        hoursDiv.classList.toggle('hidden', (e.target as HTMLInputElement).checked);
      }
    });
  });

  // Map picker click
  document.getElementById('map-picker')?.addEventListener('click', () => {
    const lat = prompt('Enter Latitude:', (document.getElementById('locationLat') as HTMLInputElement)?.value || '-8.5569');
    const lng = prompt('Enter Longitude:', (document.getElementById('locationLng') as HTMLInputElement)?.value || '125.5603');
    if (lat && lng) {
      (document.getElementById('locationLat') as HTMLInputElement).value = lat;
      (document.getElementById('locationLng') as HTMLInputElement).value = lng;
    }
  });

  async function submitForm(publish: boolean) {
    if (!form || !entityTypeInput) return;

    // Validation
    const requiredFields = ['title', 'slug', 'categoryId', 'aboutUs', 'contactName', 'contactNumber', 'email', 'address', 'locationLat', 'locationLng'];
    for (const field of requiredFields) {
      const el = document.getElementById(field) as HTMLInputElement;
      if (!el?.value.trim()) {
        el?.focus();
        alert(`Please fill in the required field: ${field}`);
        return;
      }
    }

    // Build opening hours object
    const openingHours: Record<string, { open: string; close: string } | { open: string; close: string }> = {};
    ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'].forEach(day => {
      const closed = (document.querySelector(`.day-closed[data-day="${day}"]`) as HTMLInputElement)?.checked;
      const openTime = (document.querySelector(`.day-open[data-day="${day}"]`) as HTMLInputElement)?.value || '09:00';
      const closeTime = (document.querySelector(`.day-close[data-day="${day}"]`) as HTMLInputElement)?.value || '17:00';
      openingHours[day] = closed ? { open: 'closed', close: 'closed' } : { open: openTime, close: closeTime };
    });

    // Parse tags
    const tagsInput = (document.getElementById('tags') as HTMLInputElement)?.value || '';
    const tags = tagsInput.split(',').map(t => t.trim()).filter(t => t).slice(0, 10);

    // Build social links
    const socialLinks: Record<string, string | null> = {
      facebook: (document.getElementById('facebook') as HTMLInputElement)?.value || null,
      instagram: (document.getElementById('instagram') as HTMLInputElement)?.value || null,
      tiktok: (document.getElementById('tiktok') as HTMLInputElement)?.value || null,
    };

    // Handle images (file inputs)
    const bannerFile = (document.getElementById('bannerImage') as HTMLInputElement)?.files?.[0];
    const profileFile = (document.getElementById('profileImage') as HTMLInputElement)?.files?.[0];
    const galleryFiles = (document.getElementById('galleryImages') as HTMLInputElement)?.files;

    const data = {
      entityType: entityTypeInput.value,
      title: (document.getElementById('title') as HTMLInputElement).value,
      slug: (document.getElementById('slug') as HTMLInputElement).value,
      categoryId: (document.getElementById('categoryId') as HTMLSelectElement).value,
      aboutUs: (document.getElementById('aboutUs') as HTMLTextAreaElement).value,
      yearOfEstablishment: (document.getElementById('yearOfEstablishment') as HTMLInputElement).value || null,
      contactName: (document.getElementById('contactName') as HTMLInputElement).value,
      countryCode: (document.getElementById('countryCode') as HTMLSelectElement).value,
      contactNumber: (document.getElementById('contactNumber') as HTMLInputElement).value,
      email: (document.getElementById('email') as HTMLInputElement).value,
      address: (document.getElementById('address') as HTMLTextAreaElement).value,
      locationLat: parseFloat((document.getElementById('locationLat') as HTMLInputElement).value),
      locationLng: parseFloat((document.getElementById('locationLng') as HTMLInputElement).value),
      openingHours: JSON.stringify(openingHours),
      tags: JSON.stringify(tags),
      socialLinks: JSON.stringify(socialLinks),
      publishNow: publish,
    };

    try {
      // Create FormData for file upload
      const formData = new FormData();
      Object.entries(data).forEach(([key, value]) => {
        formData.append(key, String(value));
      });

      if (bannerFile) formData.append('bannerImage', bannerFile);
      if (profileFile) formData.append('profileImage', profileFile);
      if (galleryFiles) {
        for (let i = 0; i < Math.min(galleryFiles.length, 6); i++) {
          formData.append('galleryImages', galleryFiles[i]);
        }
      }

      const res = await fetch('/api/businesses/create', {
        method: 'POST',
        body: formData,
      });

      const result = await res.json();

      if (result.success && result.data?.slug) {
        window.location.href = `/business/${result.data.slug}`;
      } else {
        alert(result.error?.message || 'Failed to create listing');
      }
    } catch (err) {
      console.error('Submit error:', err);
      alert('Failed to create listing');
    }
  }

  saveDraftBtn?.addEventListener('click', () => submitForm(false));
  publishBtn?.addEventListener('click', () => submitForm(true));
  subscribeBtn?.addEventListener('click', () => {
    window.location.href = '/pricing';
  });
</script>