---
// Organization page with SSR
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import { getDb } from '@/lib/db';
const db = await getDb();
import { businessPages } from '@/db/schema';
import { eq } from 'drizzle-orm';

const { slug } = Astro.params;
const siteUrl = import.meta.env.SITE || 'https://timorlist.com';
const canonicalUrl = `${siteUrl}/organization/${slug}`;

// SSR: Load organization data
const org = await db.select()
  .from(businessPages)
  .where(eq(businessPages.slug, slug ?? ''))
  .get();

// Redirect if not found or not an organization
if (!org || org.entityType !== 'organization') {
  return Astro.redirect('/organization');
}

// Type labels
const typeLabels: Record<string, string> = {
  government: 'Government',
  ngo: 'NGO',
  nonprofit: 'Non-Profit',
  foundation: 'Foundation',
};

// Parse opening hours
const openingHours = org.openingHours ? JSON.parse(org.openingHours) : null;

// Title & description
const pageTitle = `${org.title} - TIMORLIST`;
const pageDesc = org.aboutUs?.substring(0, 160) || `${org.title} - ${typeLabels[org.organizationType || ''] || 'Organization'} in Timor-Leste`;
---

<Layout title={pageTitle} description={pageDesc} canonical={canonicalUrl}>
  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "GovernmentOrganization",
    "name": org.title,
    "description": org.aboutUs,
    "url": canonicalUrl,
    "image": org.profileImageId ? `/api/media/${org.profileImageId}` : undefined,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": org.address,
      "addressLocality": "Dili",
      "addressCountry": "TL"
    },
    "telephone": org.contactNumber ? `${org.countryCode} ${org.contactNumber}` : undefined,
  })} />

  <div class="bg-background min-h-screen">
    <!-- Banner -->
    <div class="relative h-48 md:h-64 bg-gradient-to-br from-blue-100 to-blue-200 dark:from-blue-900/30 dark:to-blue-800/30">
      {org.bannerImageId && (
        <img src={`/api/media/${org.bannerImageId}`} class="w-full h-full object-cover" alt="" />
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
    </div>

    <div class="container max-w-6xl mx-auto px-4 md:px-6 -mt-16 relative z-10">
      <!-- Profile Header -->
      <div class="flex flex-col md:flex-row gap-6 mb-8">
        <!-- Main Content -->
        <div class="flex-1">
          <!-- Profile Card -->
          <div class="bg-card border rounded-xl shadow p-6 mb-6">
            <div class="flex flex-col md:flex-row gap-6">
              <!-- Profile Image -->
              <div class="w-24 h-24 md:w-32 md:h-32 rounded-full overflow-hidden bg-muted flex-shrink-0 border-4 border-background shadow-lg">
                {org.profileImageId ? (
                  <img src={`/api/media/${org.profileImageId}`} class="w-full h-full object-cover" alt={org.title} />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-4xl font-bold text-white bg-blue-600">
                    {org.title.split(' ').map((w: string) => w[0]).join('').substring(0, 2)}
                  </div>
                )}
              </div>

              <!-- Info -->
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <h1 class="text-2xl md:text-3xl font-bold">{org.title}</h1>
                  {org.verifiedBadge && (
                    <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400 flex items-center gap-1">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      Verified
                    </span>
                  )}
                </div>

                <!-- Type Badge -->
                <div class="flex items-center gap-2 mb-2">
                  <span class={`px-2 py-1 text-xs font-medium rounded-full ${
                    org.organizationType === 'government' ? 'bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400' :
                    org.organizationType === 'ngo' ? 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400' :
                    'bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-400'
                  }`}>
                    {typeLabels[org.organizationType || ''] || 'Organization'}
                  </span>
                </div>

                <!-- Contact -->
                <div class="space-y-1 mt-4">
                  {org.contactName && (
                    <p class="font-medium">{org.contactName}</p>
                  )}
                  {org.contactNumber && (
                    <p class="text-sm text-muted-foreground">
                      <a href={`tel:${org.countryCode}${org.contactNumber}`} class="hover:text-primary">
                        {org.countryCode} {org.contactNumber}
                      </a>
                    </p>
                  )}
                  {org.email && (
                    <p class="text-sm text-muted-foreground">
                      <a href={`mailto:${org.email}`} class="hover:text-primary">{org.email}</a>
                    </p>
                  )}
                  {org.address && (
                    <p class="text-sm text-muted-foreground">{org.address}</p>
                  )}
                </div>

                <!-- Registration Link -->
                {org.registrationUrl && (
                  <div class="mt-4">
                    <a href={org.registrationUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-primary hover:underline">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                      </svg>
                      View Official Registration
                    </a>
                  </div>
                )}
              </div>

              <!-- Actions -->
              <div class="flex gap-2 flex-shrink-0">
                <Button id="share-btn" size="sm" variant="outline">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
                  </svg>
                  Share
                </Button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Main Grid -->
      <div class="grid md:grid-cols-3 gap-6 pb-12">
        <!-- Left Sidebar -->
        <div class="space-y-6">
          <!-- About -->
          <Card>
            <div class="p-4">
              <h3 class="font-semibold mb-2 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                About
              </h3>
              {org.aboutUs ? (
                <p class="text-sm text-muted-foreground whitespace-pre-line">{org.aboutUs}</p>
              ) : (
                <p class="text-sm text-muted-foreground italic">No description available.</p>
              )}
            </div>
          </Card>

          <!-- Hours -->
          <Card>
            <div class="p-4">
              <h3 class="font-semibold mb-2 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Hours
              </h3>
              {openingHours ? (
                <div class="space-y-1 text-sm">
                  {['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'].map(day => {
                    const dayData = openingHours[day];
                    const dayName = day.charAt(0).toUpperCase() + day.slice(1);
                    if (dayData?.open === 'closed') {
                      return <div class="flex justify-between"><span>{dayName}</span><span class="text-red-500">Closed</span></div>;
                    }
                    if (dayData?.open && dayData?.close) {
                      return <div class="flex justify-between"><span>{dayName}</span><span>{dayData.open} - {dayData.close}</span></div>;
                    }
                    return null;
                  })}
                </div>
              ) : (
                <p class="text-sm text-muted-foreground italic">Hours not available.</p>
              )}
            </div>
          </Card>

          <!-- Location -->
          <Card>
            <div class="p-4">
              <h3 class="font-semibold mb-2 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                Location
              </h3>
              {org.address ? (
                <div>
                  <p class="text-sm text-muted-foreground">{org.address}</p>
                  {org.locationLat && org.locationLng && (
                    <a href={`https://www.openstreetmap.org/?mlat=${org.locationLat}&mlon=${org.locationLng}#map=15/${org.locationLat}/${org.locationLng}`} target="_blank" class="text-sm text-primary hover:underline mt-2 inline-block">
                      View on Map →
                    </a>
                  )}
                </div>
              ) : (
                <p class="text-sm text-muted-foreground italic">Location not available.</p>
              )}
            </div>
          </Card>
        </div>

        <!-- Right Content: Info -->
        <div class="md:col-span-2">
          <Card>
            <div class="p-4 border-b">
              <h2 class="text-xl font-semibold">Organization Information</h2>
            </div>
            <div class="p-6">
              {org.aboutUs ? (
                <div class="space-y-4">
                  <div>
                    <h4 class="font-medium mb-2">Overview</h4>
                    <p class="text-muted-foreground">{org.aboutUs}</p>
                  </div>

                  {org.contactName && (
                    <div>
                      <h4 class="font-medium mb-2">Contact Person</h4>
                      <p class="text-muted-foreground">{org.contactName}</p>
                    </div>
                  )}

                  {org.yearOfEstablishment && (
                    <div>
                      <h4 class="font-medium mb-2">Established</h4>
                      <p class="text-muted-foreground">{org.yearOfEstablishment}</p>
                    </div>
                  )}
                </div>
              ) : (
                <div class="text-center py-8">
                  <svg class="w-12 h-12 mx-auto text-muted-foreground mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0H3"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 21v-4m0 0h6a2 2 0 012 2v4m-8-6H7a2 2 0 00-2 2v4m0-6v6"/>
                  </svg>
                  <p class="text-muted-foreground">No detailed information available.</p>
                </div>
              )}
            </div>
          </Card>

          <!-- CTA -->
          <Card class="mt-6 bg-primary/5 border-primary/20">
            <div class="p-6 text-center">
              <h3 class="font-semibold mb-2">Is your organization missing?</h3>
              <p class="text-sm text-muted-foreground mb-4">Register your government agency, NGO, or nonprofit on TIMORLIST.</p>
              <a href="/register?type=organization">
                <Button>Add Your Organization</Button>
              </a>
            </div>
          </Card>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Share button
  document.getElementById('share-btn')?.addEventListener('click', () => {
    if (navigator.share) {
      navigator.share({
        title: document.title,
        text: 'Check out this organization on TimorLIST',
        url: window.location.href,
      });
    } else {
      navigator.clipboard.writeText(window.location.href);
      alert('Link copied to clipboard!');
    }
  });
</script>
