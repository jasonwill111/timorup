---
// Non-profit listing page - SSR
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/ui/Card.astro';
import CardContent from '../../components/ui/CardContent.astro';
import Button from '../../components/ui/Button.astro';
import { getDb } from '../../lib/db';
import { businessPages } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { escapeHtml } from '../../lib/utils';

const db = await getDb();

// Get all non-profit organizations (government and NGO)
const nonprofits = await db.select()
  .from(businessPages)
  .where(eq(businessPages.entityType, 'nonprofit'))
  .limit(50);
---

<Layout title="Non-Profit Organizations - TimorList">
  <div class="container max-w-6xl py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold">Non-Profit Organizations</h1>
      <p class="text-muted-foreground mt-2">Government agencies, NGOs, and non-profit organizations in Timor-Leste</p>
    </div>

    {nonprofits.length > 0 ? (
      <div class="grid sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {nonprofits.map((org) => (
          <a href={`/non-profit/${escapeHtml(org.slug || '')}`} class="block group">
            <Card class="overflow-hidden transition-shadow hover:shadow-lg">
              <div class="aspect-[3/2] bg-muted relative">
                {org.bannerImageId ? (
                  <img src={`/api/media/${org.bannerImageId}`} alt={escapeHtml(org.name || '')} class="w-full h-full object-cover" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-4xl font-bold text-muted-foreground">
                    {escapeHtml(org.name?.charAt(0) || 'N')}
                  </div>
                )}
              </div>
              <CardContent class="p-4">
                <h3 class="font-semibold group-hover:text-primary transition-colors">{escapeHtml(org.name || '')}</h3>
                {org.address && <p class="text-sm text-muted-foreground mt-1">{escapeHtml(org.address)}</p>}
                {org.organizationType && (
                  <span class="inline-block mt-2 text-xs px-2 py-1 bg-secondary rounded">
                    {org.organizationType === 'government' ? 'Government' : 'NGO'}
                  </span>
                )}
              </CardContent>
            </Card>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-lg text-muted-foreground">No non-profit organizations found.</p>
        <a href="/businesses" class="inline-block mt-4">
          <Button variant="outline">Browse Businesses</Button>
        </a>
      </div>
    )}
  </div>
</Layout>
