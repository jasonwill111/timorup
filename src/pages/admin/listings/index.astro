---
// Admin listing management page - API driven (listings table)
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import Button from '../../../components/ui/Button.astro';
---

<AdminLayout title="Listing Management">
  <div class="container py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold">Listing Management</h1>
        <p class="text-sm text-muted-foreground">Manage classified listings</p>
      </div>
      <a href="/admin/listings/new">
        <Button>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          New Listing
        </Button>
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <div class="bg-card rounded-lg border p-4">
        <div class="text-2xl font-bold" id="stat-total">-</div>
        <div class="text-xs text-muted-foreground">Total</div>
      </div>
      <div class="bg-card rounded-lg border p-4">
        <div class="text-2xl font-bold text-green-600" id="stat-published">-</div>
        <div class="text-xs text-muted-foreground">Published</div>
      </div>
      <div class="bg-card rounded-lg border p-4">
        <div class="text-2xl font-bold text-gray-600" id="stat-draft">-</div>
        <div class="text-xs text-muted-foreground">Draft</div>
      </div>
      <div class="bg-card rounded-lg border p-4">
        <div class="text-2xl font-bold text-red-600" id="stat-expired">-</div>
        <div class="text-xs text-muted-foreground">Expired</div>
      </div>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-4 mb-6">
      <select id="filter-type" class="h-10 px-3 rounded-md border border-input bg-background">
        <option value="">All Types</option>
        <option value="product">Product</option>
        <option value="vehicle">Vehicle</option>
        <option value="property">Property</option>
        <option value="job">Job</option>
        <option value="service">Service</option>
        <option value="wanted">Wanted</option>
      </select>
      <select id="filter-status" class="h-10 px-3 rounded-md border border-input bg-background">
        <option value="">All Status</option>
        <option value="draft">Draft</option>
        <option value="published">Published</option>
      </select>
      <input
        id="search"
        type="search"
        placeholder="Search listings..."
        class="h-10 px-3 rounded-md border border-input bg-background w-64"
      />
    </div>

    <!-- Listings Table -->
    <div class="bg-card rounded-lg border overflow-hidden">
      <table class="w-full">
        <thead class="bg-muted/50">
          <tr>
            <th class="text-left px-4 py-3 text-sm font-medium">Title</th>
            <th class="text-left px-4 py-3 text-sm font-medium">Type</th>
            <th class="text-left px-4 py-3 text-sm font-medium">Status</th>
            <th class="text-left px-4 py-3 text-sm font-medium">Price</th>
            <th class="text-right px-4 py-3 text-sm font-medium">Actions</th>
          </tr>
        </thead>
        <tbody id="listings-body" class="divide-y">
          <tr>
            <td colspan="5" class="text-center py-8 text-muted-foreground">
              <div class="flex justify-center">
                <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-primary"></div>
              </div>
            </td>
          </tr>
        </tbody>
      </table>

      <div id="no-results" class="hidden text-center py-12 text-muted-foreground">
        No listings found
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // Auth fetch helper
  async function authFetch(url, options = {}) {
    return fetch(url, {
      ...options,
      credentials: 'include',
      headers: {
        ...(options.body ? { 'Content-Type': 'application/json' } : {}),
        ...options.headers,
      },
    });
  }

  interface Listing {
    id: string;
    title: string;
    slug: string;
    categoryId: string | null;
    status: string;
    price: string | null;
    createdAt: number;
    expiresAt: number | null;
  }

  let listings: Listing[] = [];

  const typeFilter = document.getElementById('filter-type') as HTMLSelectElement;
  const statusFilter = document.getElementById('filter-status') as HTMLSelectElement;
  const searchInput = document.getElementById('search') as HTMLInputElement;
  const tbody = document.getElementById('listings-body') as HTMLTableSectionElement;
  const noResults = document.getElementById('no-results') as HTMLDivElement;

  const statusColors: Record<string, string> = {
    draft: 'bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300',
    published: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
  };

  async function loadListings() {
    try {
      const res = await authFetch('/api/admin/listing');
      const data = await res.json();

      if (data.success) {
        listings = data.data || [];
        updateStats();
        renderListings();
      } else {
        console.error('API error:', data.error);
        tbody.innerHTML = '<tr><td colspan="5" class="text-center py-8 text-red-500">Failed to load listings</td></tr>';
      }
    } catch (err) {
      console.error('Failed to load listings:', err);
      tbody.innerHTML = '<tr><td colspan="5" class="text-center py-8 text-red-500">Failed to load listings</td></tr>';
    }
  }

  function updateStats() {
    const now = Date.now() / 1000;
    const total = listings.length;
    const published = listings.filter(l => l.status === 'published').length;
    const draft = listings.filter(l => l.status === 'draft').length;
    const expired = listings.filter(l => l.expiresAt && l.expiresAt < now).length;

    document.getElementById('stat-total')!.textContent = String(total);
    document.getElementById('stat-published')!.textContent = String(published);
    document.getElementById('stat-draft')!.textContent = String(draft);
    document.getElementById('stat-expired')!.textContent = String(expired);
  }

  function renderListings() {
    const search = searchInput?.value.toLowerCase() || '';
    const type = typeFilter?.value || '';
    const status = statusFilter?.value || '';

    const filtered = listings.filter(l => {
      if (search && !l.title.toLowerCase().includes(search)) return false;
      if (status && l.status !== status) return false;
      return true;
    });

    if (filtered.length === 0) {
      tbody.innerHTML = '';
      noResults.classList.remove('hidden');
      return;
    }

    noResults.classList.add('hidden');

    tbody.innerHTML = filtered.map(listing => `
      <tr class="hover:bg-muted/30">
        <td class="px-4 py-3">
          <div class="font-medium">${escapeHtml(listing.title)}</div>
          <div class="text-xs text-muted-foreground">
            Created ${formatDate(listing.createdAt)}
          </div>
        </td>
        <td class="px-4 py-3">
          <span class="px-2 py-0.5 text-xs rounded-full bg-muted">
            {listing.categoryId || '-'}
          </span>
        </td>
        <td class="px-4 py-3">
          <span class="px-2 py-0.5 text-xs rounded-full ${statusColors[listing.status] || statusColors.draft}">
            ${listing.status || 'draft'}
          </span>
        </td>
        <td class="px-4 py-3">
          ${listing.price || '-'}
        </td>
        <td class="px-4 py-3 text-right">
          <div class="flex items-center justify-end gap-2">
            <button
              data-id="${listing.id}"
              class="edit-listing text-sm text-primary hover:underline"
            >
              Edit
            </button>
            <button
              data-id="${listing.id}"
              data-status="${listing.status}"
              class="toggle-status text-sm text-primary hover:underline"
            >
              ${listing.status === 'published' ? 'Unpublish' : 'Publish'}
            </button>
            <button
              data-id="${listing.id}"
              class="delete-listing text-sm text-red-500 hover:underline"
            >
              Delete
            </button>
            <a href="/listing/${listing.slug}" target="_blank" class="text-sm text-muted-foreground hover:text-foreground">
              View →
            </a>
          </div>
        </td>
      </tr>
    `).join('');

    // Add event listeners for buttons
    tbody.querySelectorAll('.toggle-status').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = (e.target as HTMLElement).dataset.id!;
        const currentStatus = (e.target as HTMLElement).dataset.status!;
        const newStatus = currentStatus === 'published' ? 'draft' : 'published';

        try {
          const res = await authFetch('/api/admin/listing', {
            method: 'PUT',
            body: JSON.stringify({ id, status: newStatus }),
          });
          const data = await res.json();
          if (data.success) {
            loadListings();
          }
        } catch (err) {
          console.error('Failed to toggle status:', err);
        }
      });
    });

    tbody.querySelectorAll('.delete-listing').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = (e.target as HTMLElement).dataset.id!;
        if (!confirm('Delete this listing?')) return;

        try {
          const res = await authFetch('/api/admin/listing?id=' + id, { method: 'DELETE' });
          const data = await res.json();
          if (data.success) {
            loadListings();
          }
        } catch (err) {
          console.error('Failed to delete:', err);
        }
      });
    });
  }

  function escapeHtml(str: string) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function formatDate(value: string | number | null | undefined): string {
    if (!value) return '-';
    try {
      // Handle Unix timestamp (number) or ISO string
      const date = typeof value === 'number'
        ? new Date(value * 1000)
        : new Date(value);
      if (isNaN(date.getTime())) return '-';
      return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    } catch {
      return '-';
    }
  }

  // Event listeners
  typeFilter?.addEventListener('change', renderListings);
  statusFilter?.addEventListener('change', renderListings);
  searchInput?.addEventListener('input', renderListings);

  // Edit button handler
  tbody?.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('.edit-listing') as HTMLButtonElement | null;
    if (!btn) return;

    const id = btn.dataset.id;
    if (!id) return;

    const listing = listings.find(l => l.id === id);
    if (!listing) return;

    alert('Edit functionality: Redirect to /admin/listings/edit/' + id);
    // TODO: Implement full edit page redirect or inline edit modal
  });

  // Init
  loadListings();
</script>