---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import Button from '@components/ui/Button.astro';
import { getDb } from '@/lib/db';
const db = await getDb();
import { businesses } from '@/db/schema';
import { SKU_SERVICE_TYPES, SPECIFICATION_FIELDS } from '@/lib/constants';

// Get all businesses for dropdown
const allBusinesses = await db.select({
  id: businesses.id,
  title: businesses.title,
}).from(businesses).all();

const businessOptions = allBusinesses.map(b => ({
  value: b.id,
  label: b.title,
}));

const businessOptionsJson = JSON.stringify(businessOptions);
---

<AdminLayout title="SKUs / Products">
  <!-- Hidden data for client script -->
  <script id="business-data" type="application/json" set:html={businessOptionsJson}></script>

  <div class="container py-4 px-2 md:py-6">
    <!-- Page Header -->
    <div class="mb-4 md:mb-6 flex items-start justify-between gap-2">
      <div class="min-w-0">
        <h1 class="text-lg md:text-2xl font-bold truncate">SKUs / Products</h1>
        <p class="text-xs md:text-sm text-muted-foreground hidden sm:block">Manage products and services with flexible pricing</p>
      </div>
      <Button id="add-sku-btn" class="text-xs px-2 py-1 h-7 flex-shrink-0 whitespace-nowrap md:text-sm md:px-4 md:h-9">+ Add SKU</Button>
    </div>

    <!-- Search and Filters -->
    <div class="bg-card border rounded-lg p-3 md:p-4 mb-4">
      <div class="flex flex-col md:flex-row gap-3">
        <div class="flex-1">
          <input
            type="text"
            id="search-input"
            placeholder="Search by title..."
            class="w-full px-3 py-2 border rounded-lg text-sm"
          />
        </div>
        <div class="flex gap-2">
          <select id="business-filter" class="px-3 py-2 border rounded-lg text-sm bg-background">
            <option value="">All Businesses</option>
          </select>
          <select id="type-filter" class="px-3 py-2 border rounded-lg text-sm bg-background">
            <option value="">All Types</option>
            <option value="product">Product</option>
            <option value="service">Service</option>
            <option value="subscription">Subscription</option>
          </select>
        </div>
      </div>
    </div>

    <!-- SKUs List -->
    <div class="bg-card border rounded-lg p-3 md:p-4">
      <div class="flex items-center justify-between mb-4">
        <span id="skus-count" class="text-xs text-muted-foreground">Loading...</span>
      </div>
      <div id="skus-list" class="space-y-2">
        <p class="text-center text-muted-foreground py-4 text-sm">Loading...</p>
      </div>
    </div>
  </div>

  <!-- Create/Edit SKU Modal -->
  <div id="sku-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
    <div class="bg-card border rounded-lg w-full max-w-lg max-h-[90vh] overflow-y-auto">
      <div class="p-4 border-b flex items-center justify-between sticky top-0 bg-card">
        <h2 id="modal-title" class="text-lg font-bold">Create SKU</h2>
        <button id="close-modal" class="p-1 hover:bg-muted rounded">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <form id="sku-form" class="p-4 space-y-4">
        <input type="hidden" id="sku-id" name="id" value="" />

        <!-- Business -->
        <div>
          <label for="sku-business" class="block text-sm font-medium mb-1">Business *</label>
          <select id="sku-business" name="businessId" required class="w-full px-3 py-2 border rounded-md text-sm bg-background">
            <option value="">Select a business...</option>
          </select>
        </div>

        <!-- Title -->
        <div>
          <label for="sku-title" class="block text-sm font-medium mb-1">Product/Service Name *</label>
          <input type="text" id="sku-title" name="title" required class="w-full px-3 py-2 border rounded-md text-sm" placeholder="e.g., Hourly Massage Service" />
        </div>

        <!-- Service Type -->
        <div>
          <label for="sku-service-type" class="block text-sm font-medium mb-1">Service Type</label>
          <select id="sku-service-type" name="productType" class="w-full px-3 py-2 border rounded-md text-sm bg-background">
            {SKU_SERVICE_TYPES.map(type => (
              <option value={type.value}>{type.icon} {type.label}</option>
            ))}
          </select>
        </div>

        <!-- Price Fields -->
        <div id="price-fields-container" data-field-count="1">
          <label class="block text-sm font-medium mb-2">Pricing Options</label>
          <div id="price-fields" class="space-y-2">
            <!-- Price fields will be added dynamically -->
          </div>
          <button type="button" id="add-price-field" class="mt-2 text-xs text-primary hover:underline">
            + Add another price option
          </button>
        </div>

        <!-- Industry Specifications -->
        <div id="specifications-container" class="hidden">
          <label class="block text-sm font-medium mb-2">Industry Specifications</label>
          <p class="text-xs text-muted-foreground mb-2">Fill in relevant details based on the service type</p>
          <div id="specifications-fields" class="space-y-3">
            <!-- Specification fields will be added dynamically -->
          </div>
        </div>

        <!-- Image/Video Upload -->
        <div>
          <label class="block text-sm font-medium mb-1">Product Images</label>
          <div id="sku-image-upload" class="border-2 border-dashed border-muted-foreground/25 rounded-lg p-4 text-center hover:border-muted-foreground/50 transition-colors cursor-pointer">
            <p class="text-sm text-muted-foreground">Click or drag to upload images/videos</p>
            <input type="file" id="sku-image-file" accept="image/*,video/mp4,video/webm,video/quicktime" multiple class="hidden" />
          </div>
          <div id="sku-image-preview" class="mt-2 grid grid-cols-4 gap-2 hidden"></div>
          <input type="hidden" id="sku-media-ids" name="mediaIds" value="" />
        </div>

        <!-- Description - TipTap Editor -->
        <div>
          <label class="block text-sm font-medium mb-1">Description</label>
          <div id="editor-toolbar" class="flex flex-wrap gap-1 p-2 border border-b-0 rounded-t-md bg-muted/30">
            <button type="button" data-command="toggleBold" class="toolbar-btn" title="Bold">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/></svg>
            </button>
            <button type="button" data-command="toggleItalic" class="toolbar-btn" title="Italic">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 4h-9 M14 20H5 M15 4L9 20"/></svg>
            </button>
            <button type="button" data-command="toggleUnderline" class="toolbar-btn" title="Underline">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 4v6a6 6 0 0 0 12 0V4 M4 20h16"/></svg>
            </button>
            <div class="w-px bg-border mx-1"></div>
            <button type="button" data-command="toggleHeading" data-level="1" class="toolbar-btn" title="Heading 1">H1</button>
            <button type="button" data-command="toggleHeading" data-level="2" class="toolbar-btn" title="Heading 2">H2</button>
            <div class="w-px bg-border mx-1"></div>
            <button type="button" data-command="toggleBulletList" class="toolbar-btn" title="Bullet List">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 6h13 M8 12h13 M8 18h13 M3 6h.01 M3 12h.01 M3 18h.01"/></svg>
            </button>
            <button type="button" data-command="toggleOrderedList" class="toolbar-btn" title="Ordered List">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6h11 M10 12h11 M10 18h11 M4 6h1v4 M4 10h2 M4 14h2l-2 4h2"/></svg>
            </button>
            <button type="button" data-command="toggleBlockquote" class="toolbar-btn" title="Quote">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21z M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
            </button>
            <div class="w-px bg-border mx-1"></div>
            <button type="button" data-command="undo" class="toolbar-btn" title="Undo">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a5 5 0 0 1 5 5v0a5 5 0 0 1-5 5H3"/></svg>
            </button>
            <button type="button" data-command="redo" class="toolbar-btn" title="Redo">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 10h-10a5 5 0 0 0-5 5v0a5 5 0 0 0 5 5h10"/></svg>
            </button>
          </div>
          <div id="tiptap-editor" class="prose-editor border rounded-b-md" data-placeholder="Brief description..."></div>
          <input type="hidden" id="sku-description" name="description" value="" />
        </div>

        <!-- Actions -->
        <div class="flex gap-2 justify-end pt-2">
          <Button type="button" id="cancel-btn" variant="outline" class="text-xs py-1 h-8">Cancel</Button>
          <Button type="submit" class="text-xs py-1 h-8">Save</Button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  import { getPriceUnitsForServiceType, SPECIFICATION_FIELDS } from '../../lib/constants';
  import { Editor } from '@tiptap/core';
  import StarterKit from '@tiptap/starter-kit';
  import Underline from '@tiptap/extension-underline';
  import Placeholder from '@tiptap/extension-placeholder';
  import { actions } from 'astro:actions';

  // Read business options from hidden JSON element
  const businessDataEl = document.getElementById('business-data');
  const businessOptions = businessDataEl ? JSON.parse(businessDataEl.textContent || '[]') : [];

  let editingId = null;
  let editor = null;
  let skuMediaIds: string[] = [];

  // Image/video upload
  const MAX_IMAGE_SIZE = 2 * 1024 * 1024;
  const MAX_VIDEO_SIZE = 8 * 1024 * 1024;
  const IMAGE_TYPES = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
  const VIDEO_TYPES = ['video/mp4', 'video/webm', 'video/quicktime'];

  // Preload video processor
  import('@/lib/video-compress').then(({ preloadFFmpeg }) => preloadFFmpeg());

  async function handleSkuImageUpload(files: FileList) {
    const preview = document.getElementById('sku-image-preview')!;
    const uploadArea = document.getElementById('sku-image-upload')!;

    for (const file of files) {
      if (skuMediaIds.length >= 4) break;

      const isImage = IMAGE_TYPES.includes(file.type);
      const isVideo = VIDEO_TYPES.includes(file.type);

      if (!isImage && !isVideo) continue;

      if (isImage && file.size > MAX_IMAGE_SIZE) {
        alert(`Image too large: ${(file.size / 1024 / 1024).toFixed(1)}MB. Max: 2MB`);
        continue;
      }
      if (isVideo && file.size > MAX_VIDEO_SIZE) {
        alert(`Video too large: ${(file.size / 1024 / 1024).toFixed(1)}MB. Max: 8MB`);
        continue;
      }

      let fileToUpload = file;

      // Compress video
      if (isVideo) {
        const statusDiv = document.createElement('div');
        statusDiv.className = 'absolute inset-0 bg-black/50 flex items-center justify-center text-white text-xs rounded-lg z-10';
        statusDiv.textContent = 'Processing...';
        uploadArea.style.position = 'relative';
        uploadArea.appendChild(statusDiv);

        try {
          const { compressVideo } = await import('@/lib/video-compress');
          const result = await compressVideo(file, {
            maxSize: MAX_VIDEO_SIZE,
            onProgress: (p) => { statusDiv.textContent = p.message; }
          });

          if (!result.withinLimit) {
            alert('Video still too large after compression');
            statusDiv.remove();
            continue;
          }
          fileToUpload = result.file;
          statusDiv.textContent = 'Uploading...';
        } catch (err) {
          console.error('Video compression error:', err);
          statusDiv.remove();
          alert('Video processing failed');
          continue;
        }
      }

      try {
        const result = await actions.media.uploadMedia({ file: fileToUpload, category: 'sku' });
        const data = { success: result.success, data: result.data };

        if (data.success && data.data?.id) {
          skuMediaIds.push(data.data.id);
          const mediaId = data.data.id;
          const mediaUrl = data.data.url;
          const mediaType = isVideo ? 'video' : 'image';

          const div = document.createElement('div');
          div.className = 'relative aspect-square rounded-lg overflow-hidden bg-muted';
          div.innerHTML = mediaType === 'video'
            ? `<video src="${mediaUrl}" class="w-full h-full object-cover" muted /><div class="absolute inset-0 flex items-center justify-center"><svg class="w-6 h-6 text-white" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></div>`
            : `<img src="${mediaUrl}" class="w-full h-full object-cover" />`;
          div.innerHTML += `<button type="button" data-remove="${mediaId}" class="absolute top-1 right-1 w-5 h-5 bg-red-500 text-white rounded-full text-xs">×</button>`;
          div.querySelector('[data-remove]')?.addEventListener('click', () => {
            skuMediaIds = skuMediaIds.filter(id => id !== mediaId);
            div.remove();
            document.getElementById('sku-media-ids')!.value = skuMediaIds.join(',');
          });
          preview.appendChild(div);
          preview.classList.remove('hidden');
          document.getElementById('sku-media-ids')!.value = skuMediaIds.join(',');
        }
      } catch (err) {
        console.error('Upload error:', err);
      }
    }
  }

  // Setup upload handlers
  document.getElementById('sku-image-upload')?.addEventListener('click', () => {
    document.getElementById('sku-image-file')?.click();
  });
  document.getElementById('sku-image-file')?.addEventListener('change', (e) => {
    const files = (e.target as HTMLInputElement).files;
    if (files) handleSkuImageUpload(files);
    (e.target as HTMLInputElement).value = '';
  });
  function initEditor(initialContent = '') {
    const element = document.querySelector('#tiptap-editor');
    if (!element) return null;

    // Destroy existing editor
    if (editor) {
      editor.destroy();
    }

    editor = new Editor({
      element,
      extensions: [
        StarterKit,
        Underline,
        Placeholder.configure({
          placeholder: element.dataset.placeholder || 'Start writing...',
        }),
      ],
      content: initialContent,
      immediatelyRender: false,
      onUpdate: ({ editor }) => {
        // Sync to hidden input
        const hiddenInput = document.getElementById('sku-description');
        if (hiddenInput) {
          hiddenInput.value = editor.getHTML();
        }
      },
    });

    // Initial sync
    const hiddenInput = document.getElementById('sku-description');
    if (hiddenInput) {
      hiddenInput.value = initialContent;
    }

    return editor;
  }

  // Toolbar button handler
  function setupToolbar() {
    document.querySelectorAll('[data-command]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!editor) return;
        const command = btn.dataset.command;
        const level = btn.dataset.level;

        if (command === 'toggleHeading' && level) {
          editor.chain().focus().toggleHeading({ level: parseInt(level) }).run();
        } else if (command === 'undo') {
          editor.chain().focus().undo().run();
        } else if (command === 'redo') {
          editor.chain().focus().redo().run();
        } else if (command) {
          const cmd = editor.chain().focus()[command];
          if (typeof cmd.run === 'function') {
            cmd.run();
          }
        }
      });
    });
  }

  // Update toolbar button active states
  function updateToolbarState() {
    if (!editor) return;
    document.querySelectorAll('[data-command]').forEach(btn => {
      const command = btn.dataset.command;
      const level = btn.dataset.level;
      let isActive = false;

      if (command === 'toggleHeading' && level) {
        isActive = editor.isActive('heading', { level: parseInt(level) });
      } else if (['toggleBold', 'toggleItalic', 'toggleUnderline', 'toggleBulletList', 'toggleOrderedList', 'toggleBlockquote'].includes(command)) {
        isActive = editor.isActive(command.replace('toggle', '').toLowerCase());
      }

      btn.classList.toggle('active', isActive);
    });
  }

  // Populate business dropdown
  function populateBusinesses(selectedId = '') {
    const select = document.getElementById('sku-business');
    if (!select) return;
    select.innerHTML = '<option value="">Select a business...</option>' +
      businessOptions.map(b => `<option value="${b.value}" ${b.value === selectedId ? 'selected' : ''}>${b.label}</option>`).join('');
  }

  // Render price fields based on service type
  function renderPriceFields(productType = 'product', existingFields = []) {
    const container = document.getElementById('price-fields');
    if (!container) return;

    const units = getPriceUnitsForServiceType(productType);

    // Add first field if empty
    if (existingFields.length === 0) {
      existingFields.push({ label: '', value: '', unit: '' });
    }

    container.innerHTML = existingFields.map((field, idx) => `
      <div class="flex gap-2 items-center price-field-row" data-index="${idx}">
        <input type="text" name="priceLabel_${idx}" value="${field.label}" placeholder="Label (e.g., Hourly Rate)" class="flex-1 px-2 py-1 border rounded text-xs" />
        <input type="number" name="priceValue_${idx}" value="${field.value}" placeholder="${field.unit ? '0.00' : 'Ask for price'}" class="w-20 px-2 py-1 border rounded text-xs" step="0.01" />
        <select name="priceUnit_${idx}" class="px-2 py-1 border rounded text-xs bg-background">
          ${units.map(u => `<option value="${u.value}" ${u.value === field.unit ? 'selected' : ''}>${u.label}</option>`).join('')}
        </select>
        <button type="button" class="remove-price-field text-red-500 hover:text-red-600 p-1" ${idx === 0 ? 'style="visibility:hidden"' : ''}>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    `).join('');

    // Store field count
    document.getElementById('price-fields-container').dataset.fieldCount = existingFields.length;
  }

  // Add new price field
  document.getElementById('add-price-field')?.addEventListener('click', () => {
    const container = document.getElementById('price-fields-container');
    const count = parseInt(container.dataset.fieldCount || '1') + 1;
    const productType = document.getElementById('sku-service-type')?.value || 'product';
    const units = getPriceUnitsForServiceType(productType);

    const row = document.createElement('div');
    row.className = 'flex gap-2 items-center price-field-row';
    row.dataset.index = String(count - 1);
    row.innerHTML = `
      <input type="text" name="priceLabel_${count - 1}" placeholder="Label (e.g., Weekend Rate)" class="flex-1 px-2 py-1 border rounded text-xs" />
      <input type="number" name="priceValue_${count - 1}" placeholder="0.00" class="w-20 px-2 py-1 border rounded text-xs" step="0.01" />
      <select name="priceUnit_${count - 1}" class="px-2 py-1 border rounded text-xs bg-background">
        ${units.map(u => `<option value="${u.value}">${u.label}</option>`).join('')}
      </select>
      <button type="button" class="remove-price-field text-red-500 hover:text-red-600 p-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    `;
    document.getElementById('price-fields').appendChild(row);
    container.dataset.fieldCount = String(count);
  });

  // Remove price field (event delegation)
  document.getElementById('price-fields')?.addEventListener('click', (e) => {
    const btn = e.target.closest('.remove-price-field');
    if (btn) {
      const row = btn.closest('.price-field-row');
      row.remove();
    }
  });

  // Service type change
  document.getElementById('sku-service-type')?.addEventListener('change', (e) => {
    const productType = e.target.value;
    renderPriceFields(productType);
    renderSpecificationFields(productType);
  });

  // Render specification fields based on service type
  function renderSpecificationFields(productType = 'product', existingSpecs = {}) {
    const container = document.getElementById('specifications-container');
    const fieldsContainer = document.getElementById('specifications-fields');
    if (!container || !fieldsContainer) return;

    const fields = SPECIFICATION_FIELDS[productType] || [];

    if (fields.length === 0) {
      container.classList.add('hidden');
      return;
    }

    container.classList.remove('hidden');

    fieldsContainer.innerHTML = fields.map(field => {
      const value = existingSpecs[field.key] || '';
      const id = `spec-${field.key}`;

      if (field.type === 'text') {
        return `
          <div>
            <label for="${id}" class="block text-xs font-medium text-muted-foreground mb-1">${field.label}</label>
            <input type="text" id="${id}" name="spec_${field.key}" value="${value}"
              placeholder="${field.placeholder || ''}"
              class="w-full px-3 py-2 border rounded-md text-sm" />
          </div>
        `;
      }

      if (field.type === 'number') {
        return `
          <div>
            <label for="${id}" class="block text-xs font-medium text-muted-foreground mb-1">${field.label}</label>
            <input type="number" id="${id}" name="spec_${field.key}" value="${value}"
              placeholder="${field.placeholder || ''}"
              class="w-full px-3 py-2 border rounded-md text-sm" />
          </div>
        `;
      }

      if (field.type === 'select') {
        return `
          <div>
            <label for="${id}" class="block text-xs font-medium text-muted-foreground mb-1">${field.label}</label>
            <select id="${id}" name="spec_${field.key}" class="w-full px-3 py-2 border rounded-md text-sm bg-background">
              <option value="">Select...</option>
              ${field.options.map(opt => `<option value="${opt}" ${value === opt ? 'selected' : ''}>${opt.charAt(0).toUpperCase() + opt.slice(1).replace('_', ' ')}</option>`).join('')}
            </select>
          </div>
        `;
      }

      if (field.type === 'checkbox') {
        return `
          <div class="flex items-center gap-2">
            <input type="checkbox" id="${id}" name="spec_${field.key}" value="true" ${value ? 'checked' : ''} class="w-4 h-4" />
            <label for="${id}" class="text-sm">${field.label}</label>
          </div>
        `;
      }

      if (field.type === 'tags') {
        const tagsValue = Array.isArray(value) ? value.join(', ') : value;
        return `
          <div>
            <label for="${id}" class="block text-xs font-medium text-muted-foreground mb-1">${field.label}</label>
            <input type="text" id="${id}" name="spec_${field.key}" value="${tagsValue}"
              placeholder="${field.placeholder || 'Comma separated values'}"
              class="w-full px-3 py-2 border rounded-md text-sm" />
            <p class="text-xs text-muted-foreground mt-1">Separate with commas</p>
          </div>
        `;
      }

      return '';
    }).join('');
  }

  // Auth fetch helper
  async function authFetch(url, options = {}) {
    return fetch(url, {
      ...options,
      credentials: 'include',
      headers: {
        ...(options.body ? { 'Content-Type': 'application/json' } : {}),
        ...options.headers,
      },
    });
  }

  // Global SKUs storage
  (window as SkuData).allSkus = [];

  // Load SKUs
  async function loadSKUs() {
    const container = document.getElementById('skus-list');
    const countEl = document.getElementById('skus-count');
    const businessFilter = document.getElementById('business-filter') as HTMLSelectElement;
    if (!container) return;

    // Populate business filter options
    if (businessFilter) {
      businessFilter.innerHTML = '<option value="">All Businesses</option>' +
        businessOptions.map(b => `<option value="${b.value}">${escapeHtml(b.label)}</option>`).join('');
    }

    try {
      const res = await authFetch('/api/admin/skus');
      const data = await res.json();

      if (!data.success) {
        container.innerHTML = '<p class="text-center text-muted-foreground py-4 text-sm">Failed to load SKUs</p>';
        return;
      }

      (window as SkuData).allSkus = data.data || [];
      renderSkus();
    } catch (err) {
      console.error('Error loading SKUs:', err);
      container.innerHTML = '<p class="text-center text-muted-foreground py-4 text-sm">Error loading SKUs</p>';
    }
  }

  // Render SKUs with filters
  function renderSkus() {
    const container = document.getElementById('skus-list');
    const countEl = document.getElementById('skus-count');
    if (!container || !(window as SkuData).allSkus) return;

    const search = (document.getElementById('search-input') as HTMLInputElement)?.value.toLowerCase() || '';
    const businessFilter = (document.getElementById('business-filter') as HTMLSelectElement)?.value || '';
    const typeFilter = (document.getElementById('type-filter') as HTMLSelectElement)?.value || '';

    const bizMap = new Map(businessOptions.map(b => [b.value, b.label]));

    const filtered = (window as SkuData).allSkus.filter((sku: SkuData) => {
      const matchesSearch = !search || sku.title?.toLowerCase().includes(search);
      const matchesBusiness = !businessFilter || sku.businessId === businessFilter;
      const matchesType = !typeFilter || sku.productType === typeFilter;
      return matchesSearch && matchesBusiness && matchesType;
    });

    if (countEl) countEl.textContent = `${filtered.length} of ${(window as SkuData).allSkus.length} SKUs`;

    if (filtered.length === 0) {
      container.innerHTML = '<p class="text-center text-muted-foreground py-8">No SKUs found</p>';
      return;
    }

    container.innerHTML = filtered.map((sku: SkuData) => {
      let priceDisplay = 'Ask for price';
      try {
        const fields = sku.priceFields ? JSON.parse(sku.priceFields) : [];
        if (fields.length > 0 && fields[0].value) {
          const unit = fields[0].unit ? ` / ${fields[0].unit.replace('/', '')}` : '';
          priceDisplay = `$${fields[0].value}${unit}`;
        }
      } catch (e) {
        // ignore
      }

      return `
        <div class="flex items-center justify-between p-2 md:p-3 border rounded text-sm hover:bg-muted/30">
          <div class="min-w-0 flex-1">
            <p class="font-medium truncate">${escapeHtml(sku.title)}</p>
            <p class="text-xs text-muted-foreground">
              ${priceDisplay} - ${bizMap.get(sku.businessId) || 'Unknown'}
            </p>
          </div>
          <div class="flex items-center gap-2">
            <span class="px-2 py-0.5 text-xs rounded-full ${sku.productType === 'product' ? 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200' : 'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200'}">${sku.productType || 'product'}</span>
            <button class="edit-sku text-primary hover:text-primary/80 text-xs px-2 py-1" data-id="${sku.id}">Edit</button>
            <button class="delete-sku text-red-500 hover:text-red-600 text-xs px-2 py-1" data-id="${sku.id}">Del</button>
          </div>
        </div>
      `;
    }).join('');

    // Edit handlers
    container.querySelectorAll('.edit-sku').forEach(btn => {
      btn.addEventListener('click', () => editSKU(btn.dataset.id));
    });

    // Delete handlers
    container.querySelectorAll('.delete-sku').forEach(btn => {
      btn.addEventListener('click', () => deleteSKU(btn.dataset.id));
    });
  }

  // Edit SKU
  async function editSKU(id) {
    try {
      const res = await fetch(`/api/products/${id}`);
      const data = await res.json();

      if (!data.id) {
        alert('SKU not found');
        return;
      }

      editingId = id;
      document.getElementById('modal-title').textContent = 'Edit SKU';
      document.getElementById('sku-id').value = id;
      document.getElementById('sku-title').value = data.title || '';
      document.getElementById('sku-business').value = data.businessId || '';
      document.getElementById('sku-service-type').value = data.productType || 'product';

      // Parse price fields
      let priceFields = [];
      try {
        priceFields = data.priceFields ? JSON.parse(data.priceFields) : [];
      } catch (e) {
        // ignore
      }
      renderPriceFields(data.productType || 'product', priceFields);

      // Parse and render specification fields
      let specifications = {};
      try {
        specifications = data.specifications ? JSON.parse(data.specifications) : {};
      } catch (e) {
        // ignore
      }

      // Initialize editor with existing content
      initEditor(data.description || '');

      openModal();
      setupToolbar();
    } catch (err) {
      console.error('Error loading SKU:', err);
      alert('Failed to load SKU');
    }
  }

  // Delete SKU
  async function deleteSKU(id) {
    if (!confirm('Are you sure you want to delete this SKU?')) return;

    try {
      const res = await fetch(`/api/products/${id}`, { method: 'DELETE' });
      if (res.ok) {
        loadSKUs();
      } else {
        alert('Failed to delete SKU');
      }
    } catch (err) {
      alert('Failed to delete SKU');
    }
  }

  // Modal controls
  function openModal() {
    const modal = document.getElementById('sku-modal');
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
    // Focus editor after modal opens
    setTimeout(() => editor?.commands.focus(), 100);
  }

  function closeModal() {
    const modal = document.getElementById('sku-modal');
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    editingId = null;
    document.getElementById('sku-form').reset();
    document.getElementById('sku-id').value = '';
    document.getElementById('modal-title').textContent = 'Create SKU';
    // Clear editor
    if (editor) {
      editor.commands.clearContent();
    }
    const hiddenInput = document.getElementById('sku-description');
    if (hiddenInput) {
      hiddenInput.value = '';
    }
  }

  document.getElementById('add-sku-btn')?.addEventListener('click', () => {
    populateBusinesses();
    renderPriceFields('product');
    renderSpecificationFields('product');
    editingId = null;
    document.getElementById('modal-title').textContent = 'Create SKU';
    initEditor('');
    setupToolbar();
    openModal();
  });

  document.getElementById('close-modal')?.addEventListener('click', closeModal);
  document.getElementById('cancel-btn')?.addEventListener('click', closeModal);

  document.getElementById('sku-modal')?.addEventListener('click', (e) => {
    if (e.target.id === 'sku-modal') closeModal();
  });

  // Form submission
  document.getElementById('sku-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);

    // Collect price fields
    const fieldCount = parseInt(document.getElementById('price-fields-container').dataset.fieldCount || '1');
    const priceFields = [];
    for (let i = 0; i < fieldCount; i++) {
      const label = formData.get(`priceLabel_${i}`);
      const value = formData.get(`priceValue_${i}`);
      const unit = formData.get(`priceUnit_${i}`);
      if (label || value) {
        priceFields.push({ label, value: value || '', unit: unit || '' });
      }
    }

    // Collect specification fields
    const productType = formData.get('productType');
    const specFields = SPECIFICATION_FIELDS[productType] || [];
    const specifications = {};
    specFields.forEach(field => {
      const key = `spec_${field.key}`;
      if (field.type === 'checkbox') {
        specifications[field.key] = formData.get(key) === 'true';
      } else if (field.type === 'tags') {
        const val = formData.get(key);
        specifications[field.key] = val ? val.split(',').map(v => v.trim()).filter(v => v) : [];
      } else {
        const val = formData.get(key);
        if (val) specifications[field.key] = field.type === 'number' ? Number(val) : val;
      }
    });

    // Get description from hidden input (synced from TipTap)
    const descriptionInput = document.getElementById('sku-description');
    const description = descriptionInput?.value || '';

    const skuData = {
      title: formData.get('title'),
      businessId: formData.get('businessId'),
      productType,
      priceFields: priceFields.length > 0 ? JSON.stringify(priceFields) : null,
      specifications: Object.keys(specifications).length > 0 ? specifications : null,
      description,
      isAdmin: true,
    };

    if (!skuData.businessId) {
      alert('Please select a business');
      return;
    }

    if (!skuData.title) {
      alert('Please enter a title');
      return;
    }

    try {
      const url = editingId ? `/api/products/${editingId}` : '/api/products';
      const method = editingId ? 'PUT' : 'POST';

      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(skuData),
      });

      if (res.ok) {
        closeModal();
        loadSKUs();
      } else {
        const error = await res.json();
        alert('Failed to save SKU: ' + (error.message || 'Unknown error'));
      }
    } catch (err) {
      alert('Failed to save SKU');
    }
  });

  function escapeHtml(str: string) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // Init
  populateBusinesses();
  renderPriceFields('product');
  renderSpecificationFields('product');
  loadSKUs();
  // Initialize editor for create mode (will be reset on modal open)
  initEditor('');
  setupToolbar();

  // Event listeners for search and filters
  document.getElementById('search-input')?.addEventListener('input', renderSkus);
  document.getElementById('business-filter')?.addEventListener('change', renderSkus);
  document.getElementById('type-filter')?.addEventListener('change', renderSkus);
</script>

