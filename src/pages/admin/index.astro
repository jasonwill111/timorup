      <!-- Categories -->
      <a href="/admin/categories" class="bg-gradient-to-br from-cyan-50 to-cyan-100 dark:from-cyan-950/50 dark:to-cyan-900/50 border-cyan-200 dark:border-cyan-800 rounded-xl p-3 border hover:shadow-md transition-shadow cursor-pointer">
