---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard">
<script>
  // Auth fetch helper
  async function authFetch(url, options = {}) {
    return fetch(url, {
      ...options,
      credentials: 'include',
      headers: {
        ...(options.body ? { 'Content-Type': 'application/json' } : {}),
        ...options.headers,
      },
    });
  }

  // Check authentication on page load
  async function checkAuth() {
    try {
      const res = await authFetch('/api/auth/session');
      const data = await res.json();
      if (!data.user || !['admin', 'super_admin', 'editor'].includes(data.user.role)) {
        window.location.href = '/admin/login?redirect=/admin';
      }
    } catch (e) {
      window.location.href = '/admin/login?redirect=/admin';
    }
  }
  checkAuth();
</script>
  <div class="container py-4 px-2 md:py-6 max-w-7xl">
    <!-- Page Header -->
    <div class="mb-4 md:mb-6 flex items-center justify-between">
      <div>
        <h1 class="text-xl md:text-2xl font-bold">Dashboard</h1>
        <p class="text-xs md:text-sm text-muted-foreground">Overview of your platform</p>
      </div>
      <a href="/admin/businesses" class="text-xs px-2 py-1 border rounded hover:bg-muted md:text-sm md:px-3">
        View All →
      </a>
    </div>

    <!-- Stats Cards - 2x3 Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4 mb-6">
      <!-- Users -->
      <div class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-950/50 dark:to-blue-900/50 border-blue-200 dark:border-blue-800 rounded-xl p-4 border">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-bold text-blue-700 dark:text-blue-300" id="stat-users">-</p>
            <p class="text-xs text-blue-600 dark:text-blue-400">Users</p>
          </div>
        </div>
      </div>

      <!-- Businesses -->
      <div class="bg-gradient-to-br from-emerald-50 to-emerald-100 dark:from-emerald-950/50 dark:to-emerald-900/50 border-emerald-200 dark:border-emerald-800 rounded-xl p-4 border">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-emerald-500 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-bold text-emerald-700 dark:text-emerald-300" id="stat-businesses">-</p>
            <p class="text-xs text-emerald-600 dark:text-emerald-400">Businesses</p>
          </div>
        </div>
      </div>

      <!-- Subscriptions -->
      <div class="bg-gradient-to-br from-purple-50 to-purple-100 dark:from-purple-950/50 dark:to-purple-900/50 border-purple-200 dark:border-purple-800 rounded-xl p-4 border">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-purple-500 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-bold text-purple-700 dark:text-purple-300" id="stat-subscriptions">-</p>
            <p class="text-xs text-purple-600 dark:text-purple-400">Subscriptions</p>
          </div>
        </div>
      </div>

      <!-- Revenue -->
      <div class="bg-gradient-to-br from-amber-50 to-amber-100 dark:from-amber-950/50 dark:to-amber-900/50 border-amber-200 dark:border-amber-800 rounded-xl p-4 border">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-amber-500 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-bold text-amber-700 dark:text-amber-300" id="stat-revenue">$0</p>
            <p class="text-xs text-amber-600 dark:text-amber-400">Revenue</p>
          </div>
        </div>
      </div>

      <!-- Products -->
      <div class="bg-gradient-to-br from-rose-50 to-rose-100 dark:from-rose-950/50 dark:to-rose-900/50 border-rose-200 dark:border-rose-800 rounded-xl p-4 border">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-rose-500 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-bold text-rose-700 dark:text-rose-300" id="stat-products">-</p>
            <p class="text-xs text-rose-600 dark:text-rose-400">Products</p>
          </div>
        </div>
      </div>

      <!-- Categories -->
      <div class="bg-gradient-to-br from-cyan-50 to-cyan-100 dark:from-cyan-950/50 dark:to-cyan-900/50 border-cyan-200 dark:border-cyan-800 rounded-xl p-4 border">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-cyan-500 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
            </svg>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-bold text-cyan-700 dark:text-cyan-300" id="stat-categories">-</p>
            <p class="text-xs text-cyan-600 dark:text-cyan-400">Categories</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Actions & Recent Activity -->
    <div class="grid md:grid-cols-2 gap-4 md:gap-6">
      <!-- Recent Subscriptions -->
      <div class="bg-card border rounded-xl p-4">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-semibold">Recent Subscriptions</h3>
          <a href="/admin/subscriptions" class="text-xs text-primary hover:underline">View All</a>
        </div>
        <div id="orders-list" class="space-y-2">
          <p class="text-center text-muted-foreground py-8 text-sm">Loading...</p>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="bg-card border rounded-xl p-4">
        <h3 class="font-semibold mb-4">Quick Actions</h3>
        <div class="grid grid-cols-2 gap-2">
          <a href="/admin/businesses" class="flex items-center gap-2 p-3 rounded-lg bg-blue-50 dark:bg-blue-950/30 hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
            </svg>
            <span class="text-sm font-medium">Add Business</span>
          </a>
          <a href="/admin/skus" class="flex items-center gap-2 p-3 rounded-lg bg-emerald-50 dark:bg-emerald-950/30 hover:bg-emerald-100 dark:hover:bg-emerald-900/50 transition-colors">
            <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
            <span class="text-sm font-medium">Add Product</span>
          </a>
          <a href="/admin/blogs" class="flex items-center gap-2 p-3 rounded-lg bg-purple-50 dark:bg-purple-950/30 hover:bg-purple-100 dark:hover:bg-purple-900/50 transition-colors">
            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828l3.586 3.586a2 2 0 010 2.828l-3.586 3.586a2 2 0 01-2.828 0l-3.586-3.586a2 2 0 010-2.828L9.414 5.414A2 2 0 0112 3.586z"/>
            </svg>
            <span class="text-sm font-medium">Write Blog</span>
          </a>
          <a href="/admin/media" class="flex items-center gap-2 p-3 rounded-lg bg-amber-50 dark:bg-amber-950/30 hover:bg-amber-100 dark:hover:bg-amber-900/50 transition-colors">
            <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <span class="text-sm font-medium">Upload Media</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // Auth fetch helper
  async function authFetch(url, options = {}) {
    return fetch(url, {
      ...options,
      credentials: 'include',
      headers: {
        ...(options.body ? { 'Content-Type': 'application/json' } : {}),
        ...options.headers,
      },
    });
  }

  // Load dashboard stats
  async function loadStats() {
    try {
      const res = await authFetch('/api/admin/stats');
      const data = await res.json();
      
      if (data.success) {
        document.getElementById('stat-users')!.textContent = String(data.data.totalUsers);
        document.getElementById('stat-businesses')!.textContent = String(data.data.totalBusinesses);
        document.getElementById('stat-subscriptions')!.textContent = String(data.data.totalSubscriptions);
        document.getElementById('stat-revenue')!.textContent = '$' + String(data.data.totalRevenue || 0);
        document.getElementById('stat-products')!.textContent = String(data.data.totalProducts);
        document.getElementById('stat-categories')!.textContent = String(data.data.totalCategories);
      }
    } catch (err) {
      console.error('Error loading stats:', err);
    }
  }
  
  // Load recent subscriptions (orders are now subscriptions)
  async function loadOrders() {
    try {
      const res = await authFetch('/api/admin/subscriptions');
      const data = await res.json();

      const container = document.getElementById('orders-list');
      if (!container) return;

      if (!data.success || !data.subscriptions || data.subscriptions.length === 0) {
        container.innerHTML = '<p class="text-center text-muted-foreground py-8 text-sm">No subscriptions yet</p>';
        return;
      }

      container.innerHTML = data.subscriptions.slice(0, 5).map((sub: any) => `
        <div class="flex items-center justify-between p-2 md:p-3 border rounded text-sm">
          <div class="min-w-0 flex-1">
            <p class="font-medium truncate">#${sub.id.slice(0, 8)}</p>
            <p class="text-xs text-muted-foreground truncate">${sub.planType || 'Subscription'} - $${sub.amount}</p>
          </div>
          <div class="flex items-center gap-2 ml-2">
            <span class="px-2 py-0.5 text-xs rounded-full ${sub.status === 'paid' ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200' : 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200'}">${sub.status}</span>
          </div>
        </div>
      `).join('');
    } catch (err) {
      console.error('Error loading subscriptions:', err);
    }
  }
  
  // Initialize
  loadStats();
  loadOrders();
</script>
