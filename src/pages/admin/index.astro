            </svg>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-bold text-purple-700 dark:text-purple-300" id="mtd-subs">0</p>
            <p class="text-xs text-purple-600 dark:text-purple-400">MTD Subscriptions</p>
          </div>
        </div>
      </div>

      <!-- MTD New Users -->
      <div class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-950/50 dark:to-blue-900/50 border-blue-200 dark:border-blue-800 rounded-xl p-4 border">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
            </svg>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-bold text-blue-700 dark:text-blue-300" id="mtd-users">0</p>
            <p class="text-xs text-blue-600 dark:text-blue-400">MTD New Users</p>
          </div>
        </div>
      </div>

      <!-- Expiring Soon (Alert) -->
      <a href="/admin/subscriptions?filter=expiring" class="bg-gradient-to-br from-red-50 to-red-100 dark:from-red-950/50 dark:to-red-900/50 border-red-200 dark:border-red-800 rounded-xl p-4 border hover:shadow-md transition-shadow cursor-pointer">
