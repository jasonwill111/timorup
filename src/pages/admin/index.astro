            </svg>
          </div>
          <div>
            <p class="text-2xl md:text-3xl font-bold text-red-700 dark:text-red-300" id="stat-expiring">0</p>
            <p class="text-xs text-red-600 dark:text-red-400">Expiring Soon</p>
          </div>
        </div>
      </a>
    </div>

    <!-- Charts Section -->
    <div class="grid md:grid-cols-2 gap-4 md:gap-6 mb-6">
      <!-- Revenue Bar Chart -->
      <div class="bg-card border rounded-xl p-4">
        <h3 class="font-semibold mb-2">Revenue (6 Months)</h3>
        <div id="revenue-chart" class="flex items-end justify-between gap-1 h-32"></div>
      </div>

      <!-- Subscriptions Line Chart -->
      <div class="bg-card border rounded-xl p-4">
        <h3 class="font-semibold mb-2">New Subscriptions (6 Months)</h3>
        <div id="subscriptions-chart" class="h-32 relative">
          <svg class="w-full h-full" id="subscriptions-svg"></svg>
        </div>
      </div>
    </div>

    <div class="bg-card border rounded-xl p-4 mb-6">
      <h3 class="font-semibold mb-2">New Users (6 Months)</h3>
      <div id="users-chart" class="h-32 relative">
        <svg class="w-full h-full" id="users-svg"></svg>
      </div>
    </div>

    <!-- Quick Actions & Recent Activity -->
    <div class="grid md:grid-cols-2 gap-4 md:gap-6">
      <!-- Recent Subscriptions -->
      <div class="bg-card border rounded-xl p-4">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-semibold">Recent Subscriptions</h3>
          <a href="/admin/subscriptions" class="text-xs text-primary hover:underline">View All</a>
        </div>
        <div id="orders-list" class="space-y-2">
          <p class="text-center text-muted-foreground py-8 text-sm">Loading...</p>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="bg-card border rounded-xl p-4">
        <h3 class="font-semibold mb-4">Quick Actions</h3>
        <div class="grid grid-cols-2 gap-2">
          <a href="/admin/businesses" class="flex items-center gap-2 p-3 rounded-lg bg-blue-50 dark:bg-blue-950/30 hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
            </svg>
            <span class="text-sm font-medium">Add Business</span>
          </a>
          <a href="/admin/skus" class="flex items-center gap-2 p-3 rounded-lg bg-emerald-50 dark:bg-emerald-950/30 hover:bg-emerald-100 dark:hover:bg-emerald-900/50 transition-colors">
            <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
            <span class="text-sm font-medium">Add Product</span>
          </a>
          <a href="/admin/blogs" class="flex items-center gap-2 p-3 rounded-lg bg-purple-50 dark:bg-purple-950/30 hover:bg-purple-100 dark:hover:bg-purple-900/50 transition-colors">
            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828l3.586 3.586a2 2 0 010 2.828l-3.586 3.586a2 2 0 01-2.828 0l-3.586-3.586a2 2 0 010-2.828L9.414 5.414A2 2 0 0112 3.586z"/>
            </svg>
            <span class="text-sm font-medium">Write Blog</span>
          </a>
          <a href="/admin/media" class="flex items-center gap-2 p-3 rounded-lg bg-amber-50 dark:bg-amber-950/30 hover:bg-amber-100 dark:hover:bg-amber-900/50 transition-colors">
            <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <span class="text-sm font-medium">Upload Media</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // Auth fetch helper
  async function authFetch(url, options = {}) {
    return fetch(url, {
      ...options,
      credentials: 'include',
      headers: {
        ...(options.body ? { 'Content-Type': 'application/json' } : {}),
        ...options.headers,
      },
    });
  }

  // Load dashboard stats
  async function loadStats() {
    try {
      const res = await authFetch('/api/admin/stats');
      const data = await res.json();

      if (data.success) {
        document.getElementById('stat-users')!.textContent = String(data.data.totalUsers);
        document.getElementById('stat-businesses')!.textContent = String(data.data.totalBusinesses - data.data.totalNonProfits);
        document.getElementById('stat-nonprofits')!.textContent = String(data.data.totalNonProfits);
        document.getElementById('stat-subscriptions')!.textContent = String(data.data.totalSubscriptions);
        document.getElementById('stat-revenue')!.textContent = '$' + String(data.data.totalRevenue || 0);
        document.getElementById('stat-products')!.textContent = String(data.data.totalProducts);
        document.getElementById('stat-categories')!.textContent = String(data.data.totalCategories);
        document.getElementById('stat-expiring')!.textContent = String(data.data.expiringSoon || 0);

        // MTD Stats
        if (data.data.mtd) {
          document.getElementById('mtd-revenue')!.textContent = '$' + String(data.data.mtd.revenue || 0);
          document.getElementById('mtd-subs')!.textContent = String(data.data.mtd.newSubscriptions || 0);
          document.getElementById('mtd-users')!.textContent = String(data.data.mtd.newUsers || 0);
        }

        // Monthly Chart
        if (data.data.monthly && data.data.monthly.length > 0) {
          renderMonthlyChart(data.data.monthly);
        }
      }
    } catch (err) {
      console.error('Error loading stats:', err);
    }
  }

  // Render revenue bar chart
  function renderRevenueChart(monthlyData: { month: string; revenue: number }[]) {
    const chart = document.getElementById('revenue-chart');
    if (!chart) return;

    const maxRevenue = Math.max(...monthlyData.map(m => m.revenue), 1);
    const chartHeight = 120;

    chart.innerHTML = monthlyData.map(m => {
      const heightPercent = (m.revenue / maxRevenue) * 100;
      const heightPx = Math.max((heightPercent / 100) * chartHeight, 4);
      return `
        <div class="flex-1 flex flex-col items-center gap-1">
          <div class="w-full bg-gradient-to-t from-amber-400 to-amber-300 rounded-t transition-all hover:opacity-80 cursor-help relative group" style="height: ${heightPx}px">
            <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-gray-800 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 whitespace-nowrap z-10">
              $${m.revenue}
            </div>
          </div>
          <span class="text-xs text-muted-foreground">${m.month}</span>
        </div>
      `;
    }).join('');
  }

  // Render SVG line chart
  function renderLineChart(svgId: string, data: number[], labels: string[], color: string) {
    const svg = document.getElementById(svgId) as unknown as SVGSVGElement;
    if (!svg) return;

    const width = svg.clientWidth || 400;
    const height = svg.clientHeight || 128;
    const padding = { top: 10, right: 10, bottom: 30, left: 10 };
    const chartWidth = width - padding.left - padding.right;
    const chartHeight = height - padding.top - padding.bottom;

    const maxVal = Math.max(...data, 1);
    const minVal = 0;
    const range = maxVal - minVal || 1;

    // Create points
    const points = data.map((val, i) => ({
      x: padding.left + (i / (data.length - 1)) * chartWidth,
      y: padding.top + chartHeight - ((val - minVal) / range) * chartHeight
    }));

    // Create path
    const pathD = points.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x} ${p.y}`).join(' ');

    // Create area path
    const areaD = pathD + ` L ${points[points.length - 1].x} ${height - padding.bottom} L ${padding.left} ${height - padding.bottom} Z`;

    svg.innerHTML = `
      <defs>
        <linearGradient id="${svgId}-gradient" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="${color}" stop-opacity="0.3"/>
          <stop offset="100%" stop-color="${color}" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <!-- Area fill -->
      <path d="${areaD}" fill="url(#${svgId}-gradient)"/>
      <!-- Line -->
      <path d="${pathD}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <!-- Points and labels -->
      ${points.map((p, i) => `
        <circle cx="${p.x}" cy="${p.y}" r="4" fill="${color}" class="hover:r-6 transition-all cursor-pointer">
          <title>${labels[i]}: ${data[i]}</title>
        </circle>
        <text x="${p.x}" y="${height - 8}" text-anchor="middle" class="fill-muted-foreground text-xs">${labels[i]}</text>
      `).join('')}
    `;
  }

  </script>
