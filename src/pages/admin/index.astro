---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard">
<script>
  // Auth fetch helper
  async function authFetch(url, options = {}) {
    return fetch(url, {
      ...options,
      credentials: 'include',
      headers: {
        ...(options.body ? { 'Content-Type': 'application/json' } : {}),
        ...options.headers,
      },
    });
  }

  // Check authentication on page load
  async function checkAuth() {
    try {
      const res = await authFetch('/api/auth/session');
      const data = await res.json();
      if (!data.user || !['admin', 'super_admin', 'editor'].includes(data.user.role)) {
        window.location.href = '/admin/login?redirect=/admin';
      }
    } catch (e) {
      window.location.href = '/admin/login?redirect=/admin';
    }
  }

  // Render revenue bar chart
  function renderRevenueChart(monthlyData: { month: string; revenue: number }[]) {
    const chart = document.getElementById('revenue-chart');
    if (!chart) return;

    const maxRevenue = Math.max(...monthlyData.map(m => m.revenue), 1);
    const chartHeight = 120;

    chart.innerHTML = monthlyData.map(m => {
      const heightPercent = (m.revenue / maxRevenue) * 100;
      const heightPx = Math.max((heightPercent / 100) * chartHeight, 4);
      return `
        <div class="flex-1 flex flex-col items-center gap-1">
          <div class="w-full bg-gradient-to-t from-amber-400 to-amber-300 rounded-t transition-all hover:opacity-80 cursor-help relative group" style="height: ${heightPx}px">
            <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-gray-800 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 whitespace-nowrap z-10">
              $${m.revenue}
            </div>
          </div>
          <span class="text-xs text-muted-foreground">${m.month}</span>
        </div>
      `;
    }).join('');
  }

  // Render SVG line chart
  function renderLineChart(svgId: string, data: number[], labels: string[], color: string) {
    const svg = document.getElementById(svgId) as unknown as SVGSVGElement;
    if (!svg) return;

    const width = svg.clientWidth || 400;
    const height = svg.clientHeight || 128;
    const padding = { top: 10, right: 10, bottom: 30, left: 10 };
    const chartWidth = width - padding.left - padding.right;
    const chartHeight = height - padding.top - padding.bottom;

    const maxVal = Math.max(...data, 1);
    const minVal = 0;
    const range = maxVal - minVal || 1;

    // Create points
    const points = data.map((val, i) => ({
      x: padding.left + (i / (data.length - 1)) * chartWidth,
      y: padding.top + chartHeight - ((val - minVal) / range) * chartHeight
    }));

    // Create path
    const pathD = points.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x} ${p.y}`).join(' ');

    // Create area path
    const areaD = pathD + ` L ${points[points.length - 1].x} ${height - padding.bottom} L ${padding.left} ${height - padding.bottom} Z`;

    svg.innerHTML = `
      <defs>
        <linearGradient id="${svgId}-gradient" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="${color}" stop-opacity="0.3"/>
          <stop offset="100%" stop-color="${color}" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <path d="${areaD}" fill="url(#${svgId}-gradient)"/>
      <path d="${pathD}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      ${points.map((p, i) => `
        <circle cx="${p.x}" cy="${p.y}" r="4" fill="${color}">
          <title>${labels[i]}: ${data[i]}</title>
        </circle>
        <text x="${p.x}" y="${height - 8}" text-anchor="middle" class="fill-muted-foreground text-xs">${labels[i]}</text>
      `).join('')}
    `;
  }

  // Load dashboard stats
  async function loadStats() {
    try {
      const res = await authFetch('/api/admin/stats');
      const data = await res.json();

      if (data.success) {
        document.getElementById('stat-users')!.textContent = String(data.data.totalUsers);
        document.getElementById('stat-businesses')!.textContent = String(data.data.totalBusinesses - data.data.totalNonProfits);
        document.getElementById('stat-nonprofits')!.textContent = String(data.data.totalNonProfits);
        document.getElementById('stat-products')!.textContent = String(data.data.totalProducts);
        document.getElementById('stat-categories')!.textContent = String(data.data.totalCategories);

        if (data.data.mtd) {
          document.getElementById('mtd-revenue')!.textContent = '$' + String(data.data.mtd.revenue || 0);
          document.getElementById('mtd-subs')!.textContent = String(data.data.mtd.newSubscriptions || 0);
          document.getElementById('mtd-users')!.textContent = String(data.data.mtd.newUsers || 0);
        }

        document.getElementById('stat-expiring')!.textContent = String(data.data.expiringSoon || 0);

        if (data.data.monthly && data.data.monthly.length > 0) {
          renderRevenueChart(data.data.monthly);
          renderLineChart('subscriptions-svg', data.data.monthly.map((m: any) => m.subscriptions), data.data.monthly.map((m: any) => m.month), '#8b5cf6');
          const usersData = data.data.monthlyUsers || data.data.monthly.map((m: any) => 0);
          renderLineChart('users-svg', usersData, data.data.monthly.map((m: any) => m.month), '#3b82f6');
        }
      }
    } catch (err) {
      console.error('Error loading stats:', err);
    }
  }

  // Initialize
  checkAuth();
  loadStats();
</script>
  <div class="container py-4 px-2 md:py-6 max-w-7xl">
    <!-- Page Header -->
    <div class="mb-4 md:mb-6">
      <h1 class="text-xl md:text-2xl font-bold">Dashboard</h1>
      <p class="text-xs md:text-sm text-muted-foreground">Overview of your platform</p>
    </div>

    <!-- Stats Cards - Total Counts (Cumulative) -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-3 md:gap-4 mb-4">
      <!-- Users -->
      <a href="/admin/users" class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-950/50 dark:to-blue-900/50 border-blue-200 dark:border-blue-800 rounded-xl p-3 border hover:shadow-md transition-shadow cursor-pointer">
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-bold text-blue-700 dark:text-blue-300" id="stat-users">-</p>
          <p class="text-xs text-blue-600 dark:text-blue-400">Users</p>
        </div>
      </a>

      <!-- Businesses -->
      <a href="/admin/businesses?type=business" class="bg-gradient-to-br from-emerald-50 to-emerald-100 dark:from-emerald-950/50 dark:to-emerald-900/50 border-emerald-200 dark:border-emerald-800 rounded-xl p-3 border hover:shadow-md transition-shadow cursor-pointer">
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-bold text-emerald-700 dark:text-emerald-300" id="stat-businesses">-</p>
          <p class="text-xs text-emerald-600 dark:text-emerald-400">Businesses</p>
        </div>
      </a>

      <!-- Non-Profits -->
      <a href="/admin/businesses?type=nonprofit" class="bg-gradient-to-br from-teal-50 to-teal-100 dark:from-teal-950/50 dark:to-teal-900/50 border-teal-200 dark:border-teal-800 rounded-xl p-3 border hover:shadow-md transition-shadow cursor-pointer">
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-bold text-teal-700 dark:text-teal-300" id="stat-nonprofits">-</p>
          <p class="text-xs text-teal-600 dark:text-teal-400">Non-Profits</p>
        </div>
      </a>

      <!-- Products -->
      <a href="/admin/skus" class="bg-gradient-to-br from-rose-50 to-rose-100 dark:from-rose-950/50 dark:to-rose-900/50 border-rose-200 dark:border-rose-800 rounded-xl p-3 border hover:shadow-md transition-shadow cursor-pointer">
        <div class="text-center">
          <p class="text-2xl md:text-3xl font-bold text-rose-700 dark:text-rose-300" id="stat-products">-</p>
          <p class="text-xs text-rose-600 dark:text-rose-400">Products</p>
        </div>
