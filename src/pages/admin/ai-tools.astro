---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import { actions } from 'astro:actions';
---

<AdminLayout title="AI Tools">
  <div class="container py-6 px-4">
    <!-- Page Header -->
    <div class="mb-6">
      <h1 class="text-2xl font-bold">AI Tools</h1>
      <p class="text-sm text-muted-foreground">Generate listings, products, blog posts, and landing pages with AI</p>
    </div>

    <!-- Tab Navigation -->
    <div class="mb-6 border-b border-border">
      <nav class="-mb-px flex space-x-6">
        <button
          id="tab-listing"
          class="tab-btn py-3 px-1 border-b-2 font-medium text-sm border-primary text-primary"
          data-tab="listing"
        >
          Listing Generator
        </button>
        <button
          id="tab-sku"
          class="tab-btn py-3 px-1 border-b-2 font-medium text-sm border-transparent text-muted-foreground hover:text-foreground"
          data-tab="sku"
        >
          Product/SKU Generator
        </button>
        <button
          id="tab-blog"
          class="tab-btn py-3 px-1 border-b-2 font-medium text-sm border-transparent text-muted-foreground hover:text-foreground"
          data-tab="blog"
        >
          Blog Article Generator
        </button>
        <button
          id="tab-landing"
          class="tab-btn py-3 px-1 border-b-2 font-medium text-sm border-transparent text-muted-foreground hover:text-foreground"
          data-tab="landing"
        >
          Landing Page Generator
        </button>
      </nav>
    </div>

    <!-- Listing Generator -->
    <div id="listing-section" class="tab-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-card border rounded-lg p-6">
          <h2 class="text-lg font-semibold mb-4">Create New Listing</h2>
          <form id="listing-form" class="space-y-4">
            <div>
              <label class="block text-sm font-medium mb-1">Business Name *</label>
              <input type="text" id="listing-title" required class="w-full px-3 py-2 border rounded-md text-sm" placeholder="e.g. Timor Coffee Shop" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Entity Type *</label>
              <select id="listing-entity-type" required class="w-full px-3 py-2 border rounded-md text-sm bg-background">
                <option value="business">Business</option>
                <option value="nonprofit">Non-Profit</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Category</label>
              <select id="listing-category" class="w-full px-3 py-2 border rounded-md text-sm bg-background">
                <option value="">Select category...</option>
                <option value="cat-1">Restaurants & Cafes</option>
                <option value="cat-2">Hotels & Accommodation</option>
                <option value="cat-3">Shopping</option>
                <option value="cat-4">Health & Beauty</option>
                <option value="cat-5">Automotive</option>
                <option value="cat-6">Professional Services</option>
                <option value="cat-7">Education</option>
                <option value="cat-8">Entertainment</option>
                <option value="cat-9">Travel & Tours</option>
                <option value="cat-10">Construction</option>
              </select>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium mb-1">Contact Name</label>
                <input type="text" id="listing-contact" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="Contact person" />
              </div>
              <div>
                <label class="block text-sm font-medium mb-1">Phone</label>
                <input type="text" id="listing-phone" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="77000000" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Email</label>
              <input type="email" id="listing-email" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="info@example.tl" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Address</label>
              <input type="text" id="listing-address" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="Avenida Principal, Dili" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">About Us</label>
              <textarea id="listing-about" rows="3" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="Tell customers about your business..."></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Tags (comma-separated)</label>
              <input type="text" id="listing-tags" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="coffee, wifi, local" />
            </div>
            <button type="submit" class="w-full py-2 px-4 bg-primary text-primary-foreground rounded-md font-medium hover:opacity-90">
              Generate Listing
            </button>
          </form>
        </div>

        <!-- Preview Panel -->
        <div class="bg-card border rounded-lg p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold">Generated Preview</h2>
            <span id="listing-status" class="px-2 py-1 text-xs rounded-full bg-muted">Ready</span>
          </div>
          <div id="listing-loading" class="hidden py-12 text-center">
            <div class="animate-spin w-10 h-10 border-4 border-primary border-t-transparent rounded-full mx-auto mb-4"></div>
            <p class="text-muted-foreground">Generating listing...</p>
          </div>
          <div id="listing-preview" class="hidden space-y-4">
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Title</span>
              <p id="preview-listing-title" class="font-medium"></p>
            </div>
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Entity Type</span>
              <p id="preview-listing-type" class="font-medium"></p>
            </div>
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Contact</span>
              <p id="preview-listing-contact" class="text-sm"></p>
            </div>
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Address</span>
              <p id="preview-listing-address" class="text-sm"></p>
            </div>
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Tags</span>
              <p id="preview-listing-tags" class="text-sm"></p>
            </div>
            <div class="flex gap-2 pt-4">
              <button id="listing-preview-btn" class="flex-1 py-2 px-4 bg-blue-600 text-white rounded-md font-medium hover:opacity-90">
                Preview
              </button>
              <button id="listing-save-btn" class="flex-1 py-2 px-4 bg-green-600 text-white rounded-md font-medium hover:opacity-90">
                Save Listing
              </button>
              <button id="listing-copy-btn" class="py-2 px-4 border rounded-md font-medium hover:bg-muted">
                Copy
              </button>
            </div>
          </div>
          <div id="listing-empty" class="py-12 text-center text-muted-foreground">
            <svg class="w-16 h-16 mx-auto mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
            <p>Fill the form and click Generate</p>
          </div>
        </div>
      </div>
    </div>

    <!-- SKU Generator -->
    <div id="sku-section" class="tab-content hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-card border rounded-lg p-6">
          <h2 class="text-lg font-semibold mb-4">Create Product/Service</h2>
          <form id="sku-form" class="space-y-4">
            <div>
              <label class="block text-sm font-medium mb-1">Product/Service Title *</label>
              <input type="text" id="sku-title" required class="w-full px-3 py-2 border rounded-md text-sm" placeholder="e.g. Wireless Headphones" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Service Type *</label>
              <select id="sku-type" required class="w-full px-3 py-2 border rounded-md text-sm bg-background">
                <option value="product">Product</option>
                <option value="service">Service</option>
                <option value="rental">Rental</option>
                <option value="food">Food</option>
                <option value="accommodation">Accommodation</option>
                <option value="project">Project</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Description</label>
              <textarea id="sku-description" rows="3" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="Product description..."></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Price Label</label>
              <input type="text" id="sku-price-label" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="e.g. Hourly Rate, Per Day" />
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium mb-1">Price Value</label>
                <input type="text" id="sku-price-value" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="25.00" />
              </div>
              <div>
                <label class="block text-sm font-medium mb-1">Unit</label>
                <input type="text" id="sku-price-unit" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="/hour, /day" />
              </div>
            </div>
            <button type="submit" class="w-full py-2 px-4 bg-primary text-primary-foreground rounded-md font-medium hover:opacity-90">
              Generate SKU
            </button>
          </form>
        </div>

        <!-- Preview Panel -->
        <div class="bg-card border rounded-lg p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold">Generated Preview</h2>
            <span id="sku-status" class="px-2 py-1 text-xs rounded-full bg-muted">Ready</span>
          </div>
          <div id="sku-loading" class="hidden py-12 text-center">
            <div class="animate-spin w-10 h-10 border-4 border-primary border-t-transparent rounded-full mx-auto mb-4"></div>
            <p class="text-muted-foreground">Generating SKU...</p>
          </div>
          <div id="sku-preview" class="hidden space-y-4">
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Title</span>
              <p id="preview-sku-title" class="font-medium"></p>
            </div>
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Service Type</span>
              <p id="preview-sku-type" class="font-medium"></p>
            </div>
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Price</span>
              <p id="preview-sku-price" class="font-medium"></p>
            </div>
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Description</span>
              <p id="preview-sku-desc" class="text-sm"></p>
            </div>
            <div class="flex gap-2 pt-4">
              <button id="sku-save-btn" class="flex-1 py-2 px-4 bg-green-600 text-white rounded-md font-medium hover:opacity-90">
                Save SKU
              </button>
              <button id="sku-copy-btn" class="py-2 px-4 border rounded-md font-medium hover:bg-muted">
                Copy JSON
              </button>
            </div>
          </div>
          <div id="sku-empty" class="py-12 text-center text-muted-foreground">
            <p>Fill the form and click Generate</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Blog Generator -->
    <div id="blog-section" class="tab-content hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-card border rounded-lg p-6">
          <h2 class="text-lg font-semibold mb-4">Generate Blog Article</h2>
          <form id="blog-form" class="space-y-4">
            <div>
              <label class="block text-sm font-medium mb-1">Topic *</label>
              <input type="text" id="blog-topic" required class="w-full px-3 py-2 border rounded-md text-sm" placeholder="e.g. Best Coffee Shops in Dili" />
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium mb-1">Article Type</label>
                <select id="blog-type" class="w-full px-3 py-2 border rounded-md text-sm bg-background">
                  <option value="business-introduction">Business Introduction</option>
                  <option value="local-highlight">Local Highlight</option>
                  <option value="event-announcement">Event Announcement</option>
                  <option value="how-to-guide">How-To Guide</option>
                  <option value="industry-news">Industry News</option>
                  <option value="community-story">Community Story</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium mb-1">Length</label>
                <select id="blog-length" class="w-full px-3 py-2 border rounded-md text-sm bg-background">
                  <option value="short">Short (~300 words)</option>
                  <option value="medium" selected>Medium (~600 words)</option>
                  <option value="long">Long (~1200 words)</option>
                </select>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Additional Requirements</label>
              <textarea id="blog-prompt" rows="4" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="Key points to cover, specific businesses to mention..."></textarea>
            </div>
            <button type="submit" class="w-full py-2 px-4 bg-primary text-primary-foreground rounded-md font-medium hover:opacity-90">
              Generate Article
            </button>
          </form>
        </div>

        <!-- Preview Panel -->
        <div class="bg-card border rounded-lg p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold">Generated Article</h2>
            <span id="blog-status" class="px-2 py-1 text-xs rounded-full bg-muted">Ready</span>
          </div>
          <div id="blog-loading" class="hidden py-12 text-center">
            <div class="animate-spin w-10 h-10 border-4 border-primary border-t-transparent rounded-full mx-auto mb-4"></div>
            <p class="text-muted-foreground">Generating article...</p>
          </div>
          <div id="blog-preview" class="hidden space-y-4">
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Title</span>
              <p id="preview-blog-title" class="font-medium"></p>
            </div>
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Excerpt</span>
              <p id="preview-blog-excerpt" class="text-sm"></p>
            </div>
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Content</span>
              <div id="preview-blog-content" class="text-sm max-h-64 overflow-y-auto"></div>
            </div>
            <div class="flex gap-2 pt-4">
              <button id="blog-preview-btn" class="flex-1 py-2 px-4 bg-blue-600 text-white rounded-md font-medium hover:opacity-90">
                Preview
              </button>
              <button id="blog-save-btn" class="flex-1 py-2 px-4 bg-green-600 text-white rounded-md font-medium hover:opacity-90">
                Save Draft
              </button>
              <button id="blog-copy-btn" class="py-2 px-4 border rounded-md font-medium hover:bg-muted">
                Copy
              </button>
            </div>
          </div>
          <div id="blog-empty" class="py-12 text-center text-muted-foreground">
            <p>Fill the form and click Generate</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Landing Page Generator -->
    <div id="landing-section" class="tab-content hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-card border rounded-lg p-6">
          <h2 class="text-lg font-semibold mb-4">Create Landing Page</h2>
          <form id="landing-form" class="space-y-4">
            <div>
              <label class="block text-sm font-medium mb-1">Page Title *</label>
              <input type="text" id="landing-title" required class="w-full px-3 py-2 border rounded-md text-sm" placeholder="e.g. Summer Sale 2026" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Page Type</label>
              <select id="landing-type" class="w-full px-3 py-2 border rounded-md text-sm bg-background">
                <option value="promotion">Promotion / Sale</option>
                <option value="product-showcase">Product Showcase</option>
                <option value="event">Event</option>
                <option value="seasonal">Seasonal Campaign</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Description</label>
              <textarea id="landing-description" rows="2" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="Brief description..."></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Requirements for AI</label>
              <textarea id="landing-prompt" rows="4" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="Key message, target audience, specific products..."></textarea>
            </div>
            <button type="submit" class="w-full py-2 px-4 bg-primary text-primary-foreground rounded-md font-medium hover:opacity-90">
              Generate Landing Page
            </button>
          </form>
        </div>

        <!-- Preview Panel -->
        <div class="bg-card border rounded-lg p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold">Generated Page</h2>
            <span id="landing-status" class="px-2 py-1 text-xs rounded-full bg-muted">Ready</span>
          </div>
          <div id="landing-loading" class="hidden py-12 text-center">
            <div class="animate-spin w-10 h-10 border-4 border-primary border-t-transparent rounded-full mx-auto mb-4"></div>
            <p class="text-muted-foreground">Generating landing page...</p>
          </div>
          <div id="landing-preview" class="hidden space-y-4">
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Hero Title</span>
              <p id="preview-landing-hero-title" class="font-medium"></p>
            </div>
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Hero Subtitle</span>
              <p id="preview-landing-hero-subtitle" class="text-sm"></p>
            </div>
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Description</span>
              <p id="preview-landing-desc" class="text-sm"></p>
            </div>
            <div class="p-4 bg-muted rounded-lg">
              <span class="text-xs text-muted-foreground">Features</span>
              <ul id="preview-landing-features" class="text-sm list-disc pl-4"></ul>
            </div>
            <div class="flex gap-2 pt-4">
              <button id="landing-preview-btn" class="flex-1 py-2 px-4 bg-blue-600 text-white rounded-md font-medium hover:opacity-90">
                Preview
              </button>
              <button id="landing-save-btn" class="flex-1 py-2 px-4 bg-green-600 text-white rounded-md font-medium hover:opacity-90">
                Save Page
              </button>
              <button id="landing-copy-btn" class="py-2 px-4 border rounded-md font-medium hover:bg-muted">
                Copy
              </button>
            </div>
          </div>
          <div id="landing-empty" class="py-12 text-center text-muted-foreground">
            <p>Fill the form and click Generate</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { actions } from 'astro:actions';
  import DOMPurify from 'dompurify';

  // AI Generator interfaces
  interface PriceField {
    label: string;
    value: string;
    unit: string;
  }

  interface GeneratedListing {
    title: string;
    entityType: string;
    categoryId: string | null;
    contactName: string | null;
    contactNumber: string | null;
    countryCode: string;
    email: string | null;
    address: string | null;
    aboutUs: string | null;
    tags: string[];
  }

  interface GeneratedSku {
    title: string;
    productType: string;
    skuDescription: string;
    priceFields: PriceField[];
  }

  interface GeneratedBlog {
    title: string;
    excerpt: string;
    content: string;
    tags: string[];
    slug: string;
    status: string;
  }

  interface GeneratedLanding {
    heroTitle: string;
    heroSubtitle: string;
    features: string[];
    ctaText: string;
  }

  // Action result type helper
  type ActionResult<T = unknown> = { success: boolean; data?: T; error?: { message?: string } } | { data?: { success: boolean; error?: { message?: string } } };

  function unwrapActionResult<T>(result: ActionResult<T>): T {
    if (result && typeof result === 'object') {
      if ('data' in result && result.data) {
        return result.data as T;
      }
      if ('success' in result) {
        return result as unknown as T;
      }
    }
    return result as unknown as T;
  }

  // Tab switching
  const tabBtns = document.querySelectorAll('.tab-btn');
  const sections = {
    listing: document.getElementById('listing-section'),
    sku: document.getElementById('sku-section'),
    blog: document.getElementById('blog-section'),
    landing: document.getElementById('landing-section'),
  };

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.getAttribute('data-tab');

      tabBtns.forEach(b => {
        b.classList.remove('border-primary', 'text-primary');
        b.classList.add('border-transparent', 'text-muted-foreground');
      });
      btn.classList.remove('border-transparent', 'text-muted-foreground');
      btn.classList.add('border-primary', 'text-primary');

      Object.values(sections).forEach(s => s?.classList.add('hidden'));
      sections[tab as keyof typeof sections]?.classList.remove('hidden');
    });
  });

  // ============== LISTING GENERATOR ==============
  let generatedListing: GeneratedListing | null = null;

  document.getElementById('listing-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const title = (document.getElementById('listing-title') as HTMLInputElement).value;
    const entityType = (document.getElementById('listing-entity-type') as HTMLSelectElement).value;
    const categoryId = (document.getElementById('listing-category') as HTMLSelectElement).value;
    const contactName = (document.getElementById('listing-contact') as HTMLInputElement).value;
    const phone = (document.getElementById('listing-phone') as HTMLInputElement).value;
    const email = (document.getElementById('listing-email') as HTMLInputElement).value;
    const address = (document.getElementById('listing-address') as HTMLInputElement).value;
    const about = (document.getElementById('listing-about') as HTMLTextAreaElement).value;
    const tags = (document.getElementById('listing-tags') as HTMLInputElement).value;

    document.getElementById('listing-loading')?.classList.remove('hidden');
    document.getElementById('listing-preview')?.classList.add('hidden');
    document.getElementById('listing-empty')?.classList.add('hidden');
    const statusEl = document.getElementById('listing-status');
    if (statusEl) { statusEl.textContent = 'Generating...'; statusEl.className = 'px-2 py-1 text-xs rounded-full bg-yellow-100'; }

    try {
      const result = await actions.admin.aiGenerate({
        type: 'listing',
        data: { title, entityType, categoryId, contactName, phone, email, address, about, tags }
      });

      // Astro Actions wraps result in data property
      const actionResult = unwrapActionResult<{ success: boolean; error?: { message?: string }; object?: GeneratedListing }>(result);
      if (!actionResult.success) {
        throw new Error(actionResult.error?.message || 'Generation failed');
      }

      // Use AI structured output
      const aiData = actionResult.object || {};
      generatedListing = {
        ...aiData,
        title: aiData.title || title,
        entityType: aiData.entityType || entityType,
        categoryId: categoryId || null,
        contactName: aiData.contactName || contactName,
        contactNumber: aiData.contactNumber || phone,
        countryCode: '+670',
        email: aiData.email || email,
        address: aiData.address || address,
        aboutUs: aiData.aboutUs || about,
        tags: aiData.tags || (tags ? tags.split(',').map((t: string) => t.trim()) : []),
      };

      document.getElementById('preview-listing-title')!.textContent = generatedListing.title;
      document.getElementById('preview-listing-type')!.textContent = generatedListing.entityType;
      document.getElementById('preview-listing-contact')!.textContent = `${generatedListing.contactName || '-'} | ${generatedListing.contactNumber || '-'} | ${generatedListing.email || '-'}`;
      document.getElementById('preview-listing-address')!.textContent = generatedListing.address || '-';
      document.getElementById('preview-listing-tags')!.textContent = Array.isArray(generatedListing.tags) ? generatedListing.tags.join(', ') : '-';

      document.getElementById('listing-preview')?.classList.remove('hidden');
      if (statusEl) { statusEl.textContent = 'Generated'; statusEl.className = 'px-2 py-1 text-xs rounded-full bg-green-100'; }
    } catch (err) {
      const error = err instanceof Error ? err : new Error(String(err));
      console.error('Listing generation error:', error);
      const errorMsg = error.message?.includes('permission') || error.message?.includes('unauthorized')
        ? 'MiniMax API权限被拒绝。请检查API密钥和配额。'
        : 'Failed to generate listing: ' + (error.message || 'Unknown error');
      alert(errorMsg);
      if (statusEl) { statusEl.textContent = 'Error'; statusEl.className = 'px-2 py-1 text-xs rounded-full bg-red-100'; }
      document.getElementById('listing-empty')?.classList.remove('hidden');
    } finally {
      document.getElementById('listing-loading')?.classList.add('hidden');
    }
  });

  document.getElementById('listing-copy-btn')?.addEventListener('click', () => {
    if (generatedListing) {
      navigator.clipboard.writeText(JSON.stringify(generatedListing, null, 2));
      alert('Copied to clipboard!');
    }
  });

  // Preview button - opens full preview in new tab
  document.getElementById('listing-preview-btn')?.addEventListener('click', () => {
    if (generatedListing) {
      const previewWindow = window.open('', '_blank');
      if (previewWindow) {
        previewWindow.document.write(`
          <!DOCTYPE html>
          <html>
          <head>
            <title>Listing Preview - ${generatedListing.title || 'Draft'}</title>
            <style>
              body { font-family: system-ui, sans-serif; max-width: 800px; margin: 40px auto; padding: 20px; }
              .field { margin-bottom: 20px; padding: 15px; background: #f5f5f5; border-radius: 8px; }
              .label { font-size: 12px; color: #666; margin-bottom: 5px; }
              .value { font-size: 16px; font-weight: 500; }
              h1 { margin-bottom: 30px; }
              pre { background: #1a1a1a; color: #fff; padding: 20px; border-radius: 8px; overflow-x: auto; }
            </style>
          </head>
          <body>
            <h1>📋 Listing Preview</h1>
            <div class="field"><div class="label">Title</div><div class="value">${generatedListing.title || '-'}</div></div>
            <div class="field"><div class="label">Entity Type</div><div class="value">${generatedListing.entityType || '-'}</div></div>
            <div class="field"><div class="label">Contact</div><div class="value">${generatedListing.contactName || '-'} | ${generatedListing.contactNumber || '-'} | ${generatedListing.email || '-'}</div></div>
            <div class="field"><div class="label">Address</div><div class="value">${generatedListing.address || '-'}</div></div>
            <div class="field"><div class="label">About Us</div><div class="value">${(generatedListing.aboutUs || '-').substring(0, 300)}</div></div>
            <div class="field"><div class="label">Tags</div><div class="value">${Array.isArray(generatedListing.tags) ? generatedListing.tags.join(', ') : '-'}</div></div>
            <h2 style="margin-top:30px">Raw JSON</h2>
            <pre>${JSON.stringify(generatedListing, null, 2)}</pre>
          </body>
          </html>
        `);
        previewWindow.document.close();
      }
    }
  });

  document.getElementById('listing-save-btn')?.addEventListener('click', async () => {
    if (!generatedListing) return;

    try {
      const result = await actions.admin.listings.create(generatedListing);
      if (result.success) {
        alert('Listing created! ID: ' + result.data?.id);
      } else {
        alert('Failed to save: ' + (result.error?.message || 'Unknown error'));
      }
    } catch (err) {
      alert('Failed to save listing');
    }
  });

  // ============== SKU GENERATOR ==============
  let generatedSku: GeneratedSku | null = null;

  document.getElementById('sku-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const title = (document.getElementById('sku-title') as HTMLInputElement).value;
    const productType = (document.getElementById('sku-type') as HTMLSelectElement).value;
    const description = (document.getElementById('sku-description') as HTMLTextAreaElement).value;
    const priceLabel = (document.getElementById('sku-price-label') as HTMLInputElement).value;
    const priceValue = (document.getElementById('sku-price-value') as HTMLInputElement).value;
    const priceUnit = (document.getElementById('sku-price-unit') as HTMLInputElement).value;

    document.getElementById('sku-loading')?.classList.remove('hidden');
    document.getElementById('sku-preview')?.classList.add('hidden');
    document.getElementById('sku-empty')?.classList.add('hidden');
    const statusEl = document.getElementById('sku-status');
    if (statusEl) { statusEl.textContent = 'Generating...'; statusEl.className = 'px-2 py-1 text-xs rounded-full bg-yellow-100'; }

    try {
      const result = await actions.admin.aiGenerate({
        type: 'sku',
        data: { title, productType, description, priceFields: priceValue ? [{ label: priceLabel || 'Price', value: priceValue, unit: priceUnit || '' }] : [] }
      });

      // Astro Actions wraps result in data property
      const actionResult = unwrapActionResult<{ success: boolean; error?: { message?: string }; object?: GeneratedSku }>(result);
      if (!actionResult.success) {
        throw new Error(actionResult.error?.message || 'Generation failed');
      }

      const aiData = actionResult.object || {};
      generatedSku = {
        title: aiData.title || title,
        productType: aiData.productType || productType,
        skuDescription: aiData.description || description,
        priceFields: aiData.priceFields || (priceValue ? [{ label: priceLabel || 'Price', value: priceValue, unit: priceUnit || '' }] : []),
      };

      document.getElementById('preview-sku-title')!.textContent = generatedSku.title;
      document.getElementById('preview-sku-type')!.textContent = generatedSku.productType;
      document.getElementById('preview-sku-price')!.textContent = generatedSku.priceFields.map((p: PriceField) => `${p.label}: $${p.value}${p.unit}`).join(', ');
      document.getElementById('preview-sku-desc')!.textContent = generatedSku.skuDescription;

      document.getElementById('sku-preview')?.classList.remove('hidden');
      if (statusEl) { statusEl.textContent = 'Generated'; statusEl.className = 'px-2 py-1 text-xs rounded-full bg-green-100'; }
    } catch (err) {
      const error = err instanceof Error ? err : new Error(String(err));
      console.error('SKU generation error:', error);
      const errorMsg = error.message?.includes('permission') || error.message?.includes('unauthorized')
        ? 'MiniMax API权限被拒绝。请检查API密钥和配额。'
        : 'Failed to generate SKU: ' + (error.message || 'Unknown error');
      alert(errorMsg);
      if (statusEl) { statusEl.textContent = 'Error'; statusEl.className = 'px-2 py-1 text-xs rounded-full bg-red-100'; }
      document.getElementById('sku-empty')?.classList.remove('hidden');
    } finally {
      document.getElementById('sku-loading')?.classList.add('hidden');
    }
  });

  document.getElementById('sku-copy-btn')?.addEventListener('click', () => {
    if (generatedSku) {
      navigator.clipboard.writeText(JSON.stringify(generatedSku, null, 2));
      alert('Copied to clipboard!');
    }
  });

  // ============== BLOG GENERATOR ==============
  let generatedBlog: GeneratedBlog | null = null;

  document.getElementById('blog-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const topic = (document.getElementById('blog-topic') as HTMLInputElement).value;
    const type = (document.getElementById('blog-type') as HTMLSelectElement).value;
    const length = (document.getElementById('blog-length') as HTMLSelectElement).value;
    const prompt = (document.getElementById('blog-prompt') as HTMLTextAreaElement).value;

    document.getElementById('blog-loading')?.classList.remove('hidden');
    document.getElementById('blog-preview')?.classList.add('hidden');
    document.getElementById('blog-empty')?.classList.add('hidden');
    const statusEl = document.getElementById('blog-status');
    if (statusEl) { statusEl.textContent = 'Generating...'; statusEl.className = 'px-2 py-1 text-xs rounded-full bg-yellow-100'; }

    try {
      const result = await actions.admin.aiGenerate({
        type: 'blog',
        data: { topic, type, length, prompt }
      });

      // Debug logs removed for production

      // Astro Actions wraps result in data property
      const actionResult = unwrapActionResult<{ success: boolean; error?: { message?: string }; object?: GeneratedBlog }>(result);
      if (!actionResult.success) {
        const errMsg = actionResult.error?.message || 'Generation failed';
        console.error('[Blog] Action failed:', errMsg);
        throw new Error(errMsg);
      }

      // Use AI structured output - object is directly in actionResult
      const aiData = actionResult.object || {};
      generatedBlog = {
        title: aiData.title || topic,
        excerpt: aiData.excerpt || '',
        content: aiData.content || '',
        tags: aiData.tags || [],
        slug: aiData.slug || '',
        status: aiData.status || 'draft',
        topic,
        type,
        length,
      };

      document.getElementById('preview-blog-title')!.textContent = generatedBlog.title;
      document.getElementById('preview-blog-excerpt')!.textContent = (generatedBlog.excerpt || generatedBlog.content || '').substring(0, 200);
      document.getElementById('preview-blog-content')!.innerHTML = DOMPurify.sanitize((generatedBlog.content || '').replace(/\n/g, '<br>'), { ALLOWED_TAGS: ['br'] });

      document.getElementById('blog-preview')?.classList.remove('hidden');
      if (statusEl) { statusEl.textContent = 'Generated'; statusEl.className = 'px-2 py-1 text-xs rounded-full bg-green-100'; }
    } catch (err) {
      const error = err instanceof Error ? err : new Error(String(err));
      console.error('Blog generation error:', error);
      const errorMsg = error.message?.includes('permission') || error.message?.includes('unauthorized')
        ? 'MiniMax API权限被拒绝。请检查API密钥和配额。'
        : 'Failed to generate blog: ' + (error.message || 'Unknown error');
      alert(errorMsg);
      if (statusEl) { statusEl.textContent = 'Error'; statusEl.className = 'px-2 py-1 text-xs rounded-full bg-red-100'; }
      document.getElementById('blog-empty')?.classList.remove('hidden');
    } finally {
      document.getElementById('blog-loading')?.classList.add('hidden');
    }
  });

  // Blog Preview button
  document.getElementById('blog-preview-btn')?.addEventListener('click', () => {
    if (generatedBlog) {
      const previewWindow = window.open('', '_blank');
      if (previewWindow) {
        previewWindow.document.write(`
          <!DOCTYPE html>
          <html>
          <head>
            <title>Blog Preview - ${DOMPurify.escape(generatedBlog.title || 'Draft')}</title>
            <style>
              body { font-family: system-ui, sans-serif; max-width: 800px; margin: 40px auto; padding: 20px; line-height: 1.6; }
              h1 { margin-bottom: 10px; }
              .meta { color: #666; margin-bottom: 30px; }
              .content { font-size: 18px; }
              pre { background: #1a1a1a; color: #fff; padding: 20px; border-radius: 8px; overflow-x: auto; }
            </style>
          </head>
          <body>
            <h1>${DOMPurify.escape(generatedBlog.title || 'Untitled')}</h1>
            <div class="meta">${DOMPurify.escape(generatedBlog.excerpt || '')}</div>
            <div class="content">${DOMPurify.sanitize((generatedBlog.content || '').replace(/\n/g, '<br>'), { ALLOWED_TAGS: ['br'] })}</div>
            <h2 style="margin-top:50px">Raw JSON</h2>
            <pre>${DOMPurify.escape(JSON.stringify(generatedBlog, null, 2))}</pre>
          </body>
          </html>
        `);
        previewWindow.document.close();
      }
    }
  });

  document.getElementById('blog-copy-btn')?.addEventListener('click', () => {
    if (generatedBlog) {
      navigator.clipboard.writeText(JSON.stringify(generatedBlog, null, 2));
      alert('Copied to clipboard!');
    }
  });

  // ============== LANDING PAGE GENERATOR ==============
  let generatedLanding: GeneratedLanding | null = null;

  document.getElementById('landing-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const title = (document.getElementById('landing-title') as HTMLInputElement).value;
    const type = (document.getElementById('landing-type') as HTMLSelectElement).value;
    const description = (document.getElementById('landing-description') as HTMLTextAreaElement).value;
    const prompt = (document.getElementById('landing-prompt') as HTMLTextAreaElement).value;

    document.getElementById('landing-loading')?.classList.remove('hidden');
    document.getElementById('landing-preview')?.classList.add('hidden');
    document.getElementById('landing-empty')?.classList.add('hidden');
    const statusEl = document.getElementById('landing-status');
    if (statusEl) { statusEl.textContent = 'Generating...'; statusEl.className = 'px-2 py-1 text-xs rounded-full bg-yellow-100'; }

    try {
      const result = await actions.admin.aiGenerate({
        type: 'landing',
        data: { title, type, description, prompt }
      });

      // Astro Actions wraps result in data property
      const actionResult = unwrapActionResult<{ success: boolean; error?: { message?: string }; object?: GeneratedLanding }>(result);
      if (!actionResult.success) {
        throw new Error(actionResult.error?.message || 'Generation failed');
      }

      // Use AI structured output
      const aiData = actionResult.object || {};
      generatedLanding = {
        hero: aiData.hero || { title: title, subtitle: description },
        landingDescription: aiData.description || '',
        features: aiData.features || [],
        cta: aiData.cta || {},
        type,
        title,
        prompt,
      };

      document.getElementById('preview-landing-hero-title')!.textContent = generatedLanding.hero?.title || title;
      document.getElementById('preview-landing-hero-subtitle')!.textContent = generatedLanding.hero?.subtitle || description;

      const featuresEl = document.getElementById('preview-landing-features')!;
      const escapeHtml = (str: string) => str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      featuresEl.innerHTML = (generatedLanding.features || []).map((f: GeneratedSku) => `<li><strong>${escapeHtml(f.title || '')}</strong>: ${escapeHtml(f.description || '')}</li>`).join('') || '<li>No features generated</li>';

      document.getElementById('preview-landing-desc')!.textContent = generatedLanding.landingDescription;

      document.getElementById('landing-preview')?.classList.remove('hidden');
      if (statusEl) { statusEl.textContent = 'Generated'; statusEl.className = 'px-2 py-1 text-xs rounded-full bg-green-100'; }
    } catch (err) {
      const error = err instanceof Error ? err : new Error(String(err));
      console.error('Landing page generation error:', error);
      const errorMsg = error.message?.includes('permission') || error.message?.includes('unauthorized')
        ? 'MiniMax API权限被拒绝。请检查API密钥和配额。'
        : 'Failed to generate landing page: ' + (error.message || 'Unknown error');
      alert(errorMsg);
      if (statusEl) { statusEl.textContent = 'Error'; statusEl.className = 'px-2 py-1 text-xs rounded-full bg-red-100'; }
      document.getElementById('landing-empty')?.classList.remove('hidden');
    } finally {
      document.getElementById('landing-loading')?.classList.add('hidden');
    }
  });

  // Landing Preview button
  document.getElementById('landing-preview-btn')?.addEventListener('click', () => {
    if (generatedLanding) {
      const previewWindow = window.open('', '_blank');
      if (previewWindow) {
        previewWindow.document.write(`
          <!DOCTYPE html>
          <html>
          <head>
            <title>Landing Page Preview - ${generatedLanding.hero?.title || 'Draft'}</title>
            <style>
              body { font-family: system-ui, sans-serif; max-width: 900px; margin: 0 auto; padding: 40px 20px; }
              .hero { background: linear-gradient(135deg, #FFD150, #FFA500); padding: 60px 40px; border-radius: 16px; margin-bottom: 40px; text-align: center; }
              .hero h1 { font-size: 48px; margin: 0 0 20px; color: #1a1a1a; }
              .hero p { font-size: 24px; color: #333; margin: 0; }
              .features { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin: 40px 0; }
              .feature { background: #f5f5f5; padding: 30px; border-radius: 12px; }
              .feature h3 { margin: 0 0 10px; }
              .feature p { color: #666; margin: 0; }
              .cta { background: #1a1a1a; color: white; padding: 40px; border-radius: 12px; text-align: center; }
              pre { background: #1a1a1a; color: #fff; padding: 20px; border-radius: 8px; overflow-x: auto; margin-top: 40px; }
            </style>
          </head>
          <body>
            <div class="hero">
              <h1>${generatedLanding.hero?.title || 'Untitled'}</h1>
              <p>${generatedLanding.hero?.subtitle || generatedLanding.description || ''}</p>
            </div>
            <div class="features">
              ${(generatedLanding.features || []).map((f: GeneratedSku) => `
                <div class="feature">
                  <h3>${f.icon || ''} ${f.title || ''}</h3>
                  <p>${f.description || ''}</p>
                </div>
              `).join('')}
            </div>
            <div class="cta">
              <h2>${generatedLanding.cta?.title || 'Call to Action'}</h2>
              <p>${generatedLanding.cta?.description || ''}</p>
              <button style="background:#FFD150;color:#1a1a1a;padding:15px 30px;border:none;border-radius:8px;font-size:18px;cursor:pointer">${generatedLanding.cta?.buttonText || 'Get Started'}</button>
            </div>
            <h2 style="margin-top:50px">Raw JSON</h2>
            <pre>${JSON.stringify(generatedLanding, null, 2)}</pre>
          </body>
          </html>
        `);
        previewWindow.document.close();
      }
    }
  });

  document.getElementById('landing-copy-btn')?.addEventListener('click', () => {
    if (generatedLanding) {
      navigator.clipboard.writeText(JSON.stringify(generatedLanding, null, 2));
      alert('Copied to clipboard!');
    }
  });
</script>
