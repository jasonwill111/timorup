---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import Button from '@components/ui/Button.astro';
---

<AdminLayout title="Plans">
  <div class="container py-4 px-2 md:py-6">
    <!-- Page Header -->
    <div class="mb-4 md:mb-6 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
      <div class="min-w-0">
        <h1 class="text-lg md:text-2xl font-bold truncate">Subscription Plans</h1>
        <p class="text-xs md:text-sm text-muted-foreground hidden sm:block">Manage subscription plan pricing and limits</p>
      </div>
      <Button id="add-plan-btn" class="text-xs px-2 py-1 h-7 flex-shrink-0 whitespace-nowrap md:text-sm md:px-4 md:h-9 hidden">+ Add Plan</Button>
    </div>

    <!-- Important Notice - Prominent Warning -->
    <div class="mb-4 bg-amber-50 dark:bg-amber-900/30 border-2 border-amber-400 dark:border-amber-600 rounded-lg p-3">
      <div class="flex items-start gap-2">
        <svg class="w-5 h-5 text-amber-600 dark:text-amber-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <p class="text-amber-800 dark:text-amber-300 text-xs md:text-sm">
          <span class="font-semibold">Note:</span> Changes to plan limits apply to new subscriptions only. Existing subscriptions retain their original limits.
        </p>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-4 mb-4">
      <div class="bg-card border rounded-lg p-3 text-center">
        <p class="text-xl md:text-2xl font-bold" id="stat-total">-</p>
        <p class="text-xs text-muted-foreground">Total Plans</p>
      </div>
      <div class="bg-card border rounded-lg p-3 text-center">
        <p class="text-xl md:text-2xl font-bold text-green-600" id="stat-monthly">-</p>
        <p class="text-xs text-muted-foreground">Monthly</p>
      </div>
      <div class="bg-card border rounded-lg p-3 text-center">
        <p class="text-xl md:text-2xl font-bold text-blue-600" id="stat-yearly">-</p>
        <p class="text-xs text-muted-foreground">Yearly</p>
      </div>
      <div class="bg-card border rounded-lg p-3 text-center">
        <p class="text-xl md:text-2xl font-bold text-amber-600" id="stat-active">-</p>
        <p class="text-xs text-muted-foreground">Active</p>
      </div>
    </div>

    <!-- Plans Table -->
    <div class="bg-card border rounded-lg">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-muted/50">
            <tr>
              <th class="text-left p-3 font-medium">Plan</th>
              <th class="text-left p-3 font-medium hidden md:table-cell">Period</th>
              <th class="text-left p-3 font-medium">Price</th>
              <th class="text-left p-3 font-medium hidden lg:table-cell">SKU Limit</th>
              <th class="text-left p-3 font-medium hidden lg:table-cell">Images</th>
              <th class="text-left p-3 font-medium hidden lg:table-cell">Videos</th>
              <th class="text-center p-3 font-medium">Status</th>
              <th class="text-right p-3 font-medium">Actions</th>
            </tr>
          </thead>
          <tbody id="plans-list">
            <tr>
              <td colspan="8" class="text-center p-8 text-muted-foreground">Loading...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Edit Plan Modal -->
  <div id="plan-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4 overflow-y-auto">
    <div class="bg-card border rounded-lg w-full max-w-lg my-8">
      <div class="p-4 border-b flex items-center justify-between">
        <h2 class="text-lg font-semibold" id="modal-title">Edit Plan</h2>
        <button id="close-modal" class="text-muted-foreground hover:text-foreground">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form id="plan-form" class="p-4 space-y-4">
        <input type="hidden" id="plan-id" name="id" />

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium mb-1">Plan Name</label>
            <input type="text" id="plan-name" name="name" required class="w-full h-9 px-3 rounded-md border bg-background text-sm" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Period</label>
            <select id="plan-period" name="period" required class="w-full h-9 px-3 rounded-md border bg-background text-sm">
              <option value="monthly">Monthly</option>
              <option value="yearly">Yearly</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium mb-1">Price (USD)</label>
            <input type="number" id="plan-amount" name="amount" required min="0" class="w-full h-9 px-3 rounded-md border bg-background text-sm" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">SKU Limit</label>
            <input type="number" id="plan-skuLimit" name="skuLimit" required min="0" class="w-full h-9 px-3 rounded-md border bg-background text-sm" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium mb-1">Max Images</label>
            <input type="number" id="plan-maxImages" name="maxImages" required min="0" class="w-full h-9 px-3 rounded-md border bg-background text-sm" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Max Videos</label>
            <input type="number" id="plan-maxVideos" name="maxVideos" required min="0" class="w-full h-9 px-3 rounded-md border bg-background text-sm" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium mb-1">Description</label>
          <textarea id="plan-description" name="description" rows="2" class="w-full px-3 py-2 rounded-md border bg-background text-sm"></textarea>
        </div>

        <div>
          <label class="block text-sm font-medium mb-1">Features (one per line)</label>
          <textarea id="plan-features" name="features" rows="4" placeholder="Feature 1&#10;Feature 2&#10;Feature 3" class="w-full px-3 py-2 rounded-md border bg-background text-sm"></textarea>
        </div>

        <div class="flex items-center gap-2">
          <input type="checkbox" id="plan-active" name="active" class="w-4 h-4 rounded border-gray-300" />
          <label for="plan-active" class="text-sm">Active</label>
        </div>

        <div class="flex justify-end gap-2 pt-2">
          <Button type="button" id="cancel-btn" variant="outline">Cancel</Button>
          <Button type="submit">Save Changes</Button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  interface Plan {
    id: string;
    name: string;
    period: string;
    amount: number;
    skuLimit: number;
    maxImages: number;
    maxVideos: number;
    features: string[];
    description: string;
    active: boolean;
    sortOrder: number;
  }

  let plans: Plan[] = [];
  let currentUserRole: string = '';

  // Check auth and role
  async function checkAuth() {
    try {
      const res = await fetch('/api/auth/session', { credentials: 'include' });
      const data = await res.json();
      if (data.user) {
        currentUserRole = data.user.role || '';
      }
    } catch (e) {
      console.error('Auth check failed:', e);
    }
  }

  async function loadPlans() {
    try {
      const res = await fetch('/api/admin/plans');
      const data = await res.json();

      if (data.success && data.data) {
        plans = data.data;
        renderPlans();
        updateStats();
      } else {
        showError(data.error?.message || 'Failed to load plans');
      }
    } catch (e) {
      console.error('Failed to load plans:', e);
      showError('Failed to load plans');
    }
  }

  function renderPlans() {
    const tbody = document.getElementById('plans-list');
    if (!tbody) return;

    if (plans.length === 0) {
      tbody.innerHTML = '<tr><td colspan="8" class="text-center p-8 text-muted-foreground">No plans found</td></tr>';
      return;
    }

    const canEdit = currentUserRole === 'super_admin';

    tbody.innerHTML = plans.map(plan => `
      <tr class="border-t hover:bg-muted/50">
        <td class="p-3">
          <div class="font-medium">${escapeHtml(plan.name)}</div>
          <div class="text-xs text-muted-foreground">${escapeHtml(plan.id)}</div>
        </td>
        <td class="p-3 hidden md:table-cell">
          <span class="px-2 py-1 text-xs rounded-full ${plan.period === 'yearly' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' : 'bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300'}">
            ${plan.period}
          </span>
        </td>
        <td class="p-3 font-semibold">$${plan.amount}</td>
        <td class="p-3 hidden lg:table-cell">${plan.skuLimit}</td>
        <td class="p-3 hidden lg:table-cell">${plan.maxImages}</td>
        <td class="p-3 hidden lg:table-cell">${plan.maxVideos}</td>
        <td class="p-3 text-center">
          <span class="px-2 py-1 text-xs rounded-full ${plan.active ? 'bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300' : 'bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300'}">
            ${plan.active ? 'Active' : 'Inactive'}
          </span>
        </td>
        <td class="p-3 text-right">
          ${canEdit ? `<button onclick="window.editPlan('${plan.id}')" class="text-blue-600 hover:text-blue-800 text-sm">Edit</button>` : '<span class="text-xs text-muted-foreground">View only</span>'}
        </td>
      </tr>
    `).join('');
  }

  function updateStats() {
    const total = plans.length;
    const monthly = plans.filter(p => p.period === 'monthly').length;
    const yearly = plans.filter(p => p.period === 'yearly').length;
    const active = plans.filter(p => p.active).length;

    const statTotal = document.getElementById('stat-total');
    const statMonthly = document.getElementById('stat-monthly');
    const statYearly = document.getElementById('stat-yearly');
    const statActive = document.getElementById('stat-active');

    if (statTotal) statTotal.textContent = String(total);
    if (statMonthly) statMonthly.textContent = String(monthly);
    if (statYearly) statYearly.textContent = String(yearly);
    if (statActive) statActive.textContent = String(active);
  }

  (window as PlanData).editPlan = function(planId: string) {
    const plan = plans.find(p => p.id === planId);
    if (!plan) return;

    const modal = document.getElementById('plan-modal');
    const title = document.getElementById('modal-title');
    const form = document.getElementById('plan-form') as HTMLFormElement;

    if (title) title.textContent = `Edit ${plan.name} (${plan.period})`;
    if (form) {
      (document.getElementById('plan-id') as HTMLInputElement).value = plan.id;
      (document.getElementById('plan-name') as HTMLInputElement).value = plan.name;
      (document.getElementById('plan-period') as HTMLSelectElement).value = plan.period;
      (document.getElementById('plan-amount') as HTMLInputElement).value = String(plan.amount);
      (document.getElementById('plan-skuLimit') as HTMLInputElement).value = String(plan.skuLimit);
      (document.getElementById('plan-maxImages') as HTMLInputElement).value = String(plan.maxImages);
      (document.getElementById('plan-maxVideos') as HTMLInputElement).value = String(plan.maxVideos);
      (document.getElementById('plan-description') as HTMLTextAreaElement).value = plan.description || '';
      (document.getElementById('plan-features') as HTMLTextAreaElement).value = (plan.features || []).join('\n');
      (document.getElementById('plan-active') as HTMLInputElement).checked = plan.active;
    }

    if (modal) {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }
  };

  function closeModal() {
    const modal = document.getElementById('plan-modal');
    if (modal) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }
  }

  async function savePlan(formData: FormData) {
    const id = formData.get('id') as string;
    const featuresText = formData.get('features') as string;
    const features = featuresText.split('\n').filter(f => f.trim());

    const payload = {
      name: formData.get('name'),
      period: formData.get('period'),
      amount: parseInt(formData.get('amount') as string),
      skuLimit: parseInt(formData.get('skuLimit') as string),
      maxImages: parseInt(formData.get('maxImages') as string),
      maxVideos: parseInt(formData.get('maxVideos') as string),
      description: formData.get('description'),
      features: features,
      active: formData.get('active') === 'on',
    };

    try {
      const res = await fetch(`/api/admin/plans/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await res.json();

      if (data.success) {
        closeModal();
        loadPlans();
      } else {
        showError(data.error?.message || 'Failed to save plan');
      }
    } catch (e) {
      console.error('Failed to save plan:', e);
      showError('Failed to save plan');
    }
  }

  function showError(message: string) {
    alert(message);
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // Event listeners
  document.addEventListener('DOMContentLoaded', async () => {
    await checkAuth();
    loadPlans();

    document.getElementById('close-modal')?.addEventListener('click', closeModal);
    document.getElementById('cancel-btn')?.addEventListener('click', closeModal);

    document.getElementById('plan-modal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) closeModal();
    });

    document.getElementById('plan-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const formData = new FormData(form);
      await savePlan(formData);
    });
  });
</script>
