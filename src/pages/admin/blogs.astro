---
import AdminLayout from '@layouts/AdminLayout.astro';
import { Button } from '@components/ui/button';
---

<AdminLayout title="Blog Posts">
  <div class="container py-4 px-2 md:py-6">
    <!-- Page Header -->
    <div class="mb-4 md:mb-6">
      <h1 class="text-xl md:text-2xl font-bold">Blog Posts</h1>
      <p class="text-sm text-muted-foreground mt-1">Manage blog posts and articles</p>
    </div>
    
    <!-- Info Card -->
    <div class="bg-card border rounded-lg p-4">
      <div class="flex items-start gap-3">
        <div class="text-2xl">📝</div>
        <div>
          <h3 class="font-semibold mb-1">Blog Posts Not Available</h3>
          <p class="text-sm text-muted-foreground mb-3">The blog/posts feature is not yet implemented in the database schema. This feature requires adding a new database table for blog posts.</p>
          <p class="text-xs text-muted-foreground">To add this feature, you would need to:</p>
          <ol class="text-xs text-muted-foreground list-decimal list-inside mt-1 space-y-0.5">
            <li>Add a blog_posts table to the database schema</li>
            <li>Create API routes for CRUD operations</li>
            <li>Build the admin UI for managing posts</li>
          </ol>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
