---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import Button from '@components/ui/Button.astro';
import { actions } from 'astro:actions';

const userId = Astro.locals.user?.id || 'system';
---

<AdminLayout title="Blog Posts">
  <span id="current-user-id" data-user-id={userId} class="hidden" aria-hidden="true"></span>
  <div class="container py-4 px-2 md:py-6">
    <!-- Page Header -->
    <div class="mb-4 md:mb-6 flex items-center justify-between">
      <div>
        <h1 class="text-xl md:text-2xl font-bold">Blog Posts</h1>
        <p class="text-sm text-muted-foreground mt-1">Create and manage blog posts</p>
      </div>
      <Button id="new-post-btn" class="text-xs py-1 h-7 md:text-sm md:h-9">+ New Post</Button>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-2 mb-4">
      <input
        type="text" id="search-input"
        placeholder="Search posts..."
        class="px-3 py-1.5 text-sm border rounded-md focus:outline-none focus:ring-1 focus:ring-primary w-48"
      />
      <select id="status-filter"
        class="px-3 py-1.5 text-sm border rounded-md focus:outline-none focus:ring-1 focus:ring-primary bg-background">
        <option value="">All statuses</option>
        <option value="draft">Draft</option>
        <option value="published">Published</option>
        <option value="archived">Archived</option>
      </select>
    </div>

    <!-- Posts List -->
    <div class="bg-card border rounded-lg divide-y">
      <div id="posts-list" class="divide-y divide-border">
        <p class="text-center text-muted-foreground py-8 text-sm">Loading...</p>
      </div>
    </div>
  </div>

  <!-- Create/Edit Modal -->
  <div id="post-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4" aria-modal="true">
    <div class="bg-card border rounded-lg w-full max-w-3xl max-h-[90vh] overflow-y-auto">
      <div class="p-4 border-b flex items-center justify-between">
        <h2 class="text-lg font-bold" id="modal-title">New Blog Post</h2>
        <button id="close-modal" class="p-1 hover:bg-muted rounded">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <form id="post-form" class="p-4 space-y-4">
        <input type="hidden" id="post-id" />
        <input type="hidden" id="featured-image-id" />
        <input type="hidden" id="thumbnail-id" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="md:col-span-2">
            <label class="block text-sm font-medium mb-1">Title *</label>
            <input type="text" id="post-title" required
              class="w-full px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
              placeholder="Post title" />
          </div>

          <div class="md:col-span-2">
            <label class="block text-sm font-medium mb-1">Slug *</label>
            <div class="flex gap-2">
              <input type="text" id="post-slug" required
                class="flex-1 px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
                placeholder="post-url-slug" />
              <button type="button" id="generate-slug-btn"
                class="px-3 py-2 text-sm border rounded-md hover:bg-muted whitespace-nowrap">
                Auto
              </button>
            </div>
          </div>

          <div class="md:col-span-2">
            <label class="block text-sm font-medium mb-1">Excerpt</label>
            <textarea id="post-excerpt" rows="2"
              class="w-full px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-primary resize-none"
              placeholder="Short summary (optional)"></textarea>
          </div>

          <div class="md:col-span-2">
            <label class="block text-sm font-medium mb-1">Content</label>
            <div id="editor-container"></div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1">Status</label>
            <select id="post-status"
              class="w-full px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-primary bg-background">
              <option value="draft">Draft</option>
              <option value="published">Published</option>
              <option value="archived">Archived</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1">Tags (comma-separated)</label>
            <input type="text" id="post-tags"
              class="w-full px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
              placeholder="news, update, tips" />
          </div>

          <div>
            <label class="block text-sm font-medium mb-1">Featured Image</label>
            <div id="featured-image-upload" class="border-2 border-dashed border-muted-foreground/25 rounded-lg p-4 text-center hover:border-muted-foreground/50 transition-colors cursor-pointer">
              <p class="text-sm text-muted-foreground">Click or drag to upload image</p>
              <input type="file" id="featured-image-file" accept="image/*,video/mp4,video/webm,video/quicktime" class="hidden" />
            </div>
            <div id="featured-image-preview" class="mt-2 hidden">
              <div class="relative inline-block">
                <img id="featured-preview-img" class="w-full max-h-40 rounded-lg object-cover" />
                <button type="button" id="remove-featured-image" class="absolute top-1 right-1 w-6 h-6 bg-red-500 text-white rounded-full text-xs">×</button>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1">Thumbnail</label>
            <div id="thumbnail-upload" class="border-2 border-dashed border-muted-foreground/25 rounded-lg p-4 text-center hover:border-muted-foreground/50 transition-colors cursor-pointer">
              <p class="text-sm text-muted-foreground">Click or drag to upload</p>
              <input type="file" id="thumbnail-file" accept="image/*,video/mp4,video/webm,video/quicktime" class="hidden" />
            </div>
            <div id="thumbnail-preview" class="mt-2 hidden">
              <div class="relative inline-block">
                <img id="thumbnail-preview-img" class="w-24 h-24 rounded-lg object-cover" />
                <button type="button" id="remove-thumbnail" class="absolute top-0 right-0 w-5 h-5 bg-red-500 text-white rounded-full text-xs">×</button>
              </div>
            </div>
          </div>
        </div>

        <div class="flex gap-2 pt-2">
          <button type="submit"
            class="flex-1 bg-primary text-primary-foreground py-2 rounded-md hover:opacity-90 transition-opacity">
            Save Post
          </button>
          <button type="button" id="cancel-btn"
            class="px-4 py-2 border rounded-md hover:bg-muted transition-colors">
            Cancel
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Confirm Modal -->
  <div id="delete-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
    <div class="bg-card border rounded-lg w-full max-w-sm p-6 text-center">
      <h3 class="text-lg font-bold mb-2">Delete Post?</h3>
      <p class="text-sm text-muted-foreground mb-4">This action cannot be undone.</p>
      <div class="flex gap-2">
        <button id="confirm-delete-btn"
          class="flex-1 bg-red-500 text-white py-2 rounded-md hover:opacity-90 transition-opacity">
          Delete
        </button>
        <button id="cancel-delete-btn"
          class="flex-1 border py-2 rounded-md hover:bg-muted transition-colors">
          Cancel
        </button>
      </div>
    </div>
  </div>
</AdminLayout>

<!-- TipTap CSS -->
<link rel="stylesheet" href="https://unpkg.com/@tiptap/core@3.22.3/dist/tiptap.min.css" />

<script>
  import { actions } from 'astro:actions';

  // ── TipTap Editor Helper ─────────────────────────────────────────────────────
  // Using dynamic import to avoid SSR build issues
  async function initTipTapEditor(element: HTMLElement, options: { placeholder?: string; content?: string } = {}) {
    const textareaId = `${element.id}-content`;

    // Create hidden textarea for form submission
    const textarea = document.createElement('textarea');
    textarea.id = textareaId;
    textarea.name = element.id.replace('-editor', '');
    textarea.className = 'hidden';
    element.insertAdjacentElement('afterend', textarea);

    // Dynamic imports for TipTap
    const [tiptapCore, tiptapStarterKit, tiptapLink, tiptapPlaceholder] = await Promise.all([
      import('https://esm.sh/@tiptap/core@3.22.3'),
      import('https://esm.sh/@tiptap/starter-kit@3.22.3'),
      import('https://esm.sh/@tiptap/extension-link@3.22.3'),
      import('https://esm.sh/@tiptap/extension-placeholder@3.22.3'),
    ]);

    const { Editor } = tiptapCore;
    const { default: StarterKit } = tiptapStarterKit;
    const { default: Link } = tiptapLink;
    const { default: Placeholder } = tiptapPlaceholder;

    const editor = new Editor({
      element,
      extensions: [
        StarterKit.configure({
          heading: { levels: [2, 3] },
        }),
        Link.configure({
          openOnClick: false,
          HTMLAttributes: { class: 'text-primary underline' },
        }),
        Placeholder.configure({
          placeholder: options.placeholder || 'Start typing...',
          emptyEditorClass: 'is-editor-empty',
        }),
      ],
      content: options.content || '',
      onUpdate: ({ editor }) => {
        textarea.value = editor.getHTML();
      },
      editorProps: {
        attributes: {
          class: 'prose prose-sm dark:prose-invert max-w-none focus:outline-none min-h-[150px] px-3 py-2',
        },
      },
    });

    // Initial sync
    textarea.value = editor.getHTML();

    return editor;
  }

  // ── State ──────────────────────────────────────────────────────────────────
  let posts: BlogData = [];
  let deleteTargetId: string | null = null;
  let editorInstance: BlogData = null;

  // Image/video upload state
  let featuredImageId: string | null = null;
  let thumbnailId: string | null = null;
  const MAX_IMAGE_SIZE = 2 * 1024 * 1024;
  const MAX_VIDEO_SIZE = 8 * 1024 * 1024;
  const IMAGE_TYPES = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
  const VIDEO_TYPES = ['video/mp4', 'video/webm', 'video/quicktime'];

  // Preload video processor
  import('@/lib/video-compress').then(({ preloadFFmpeg }) => preloadFFmpeg());

  // ── Upload handlers ─────────────────────────────────────────────────────────
  async function handleImageUpload(inputId: string, type: 'featured' | 'thumbnail') {
    const input = document.getElementById(inputId) as HTMLInputElement;
    if (!input?.files?.length) return;

    const file = input.files[0];
    const isImage = IMAGE_TYPES.includes(file.type);
    const isVideo = VIDEO_TYPES.includes(file.type);

    if (!isImage && !isVideo) {
      alert('Unsupported file type');
      return;
    }

    if (isImage && file.size > MAX_IMAGE_SIZE) {
      alert(`Image too large: ${(file.size / 1024 / 1024).toFixed(1)}MB. Max: 2MB`);
      return;
    }
    if (isVideo && file.size > MAX_VIDEO_SIZE) {
      alert(`Video too large: ${(file.size / 1024 / 1024).toFixed(1)}MB. Max: 8MB`);
      return;
    }

    let fileToUpload: File = file;

    // Compress video
    if (isVideo) {
      const uploadEl = document.getElementById(type === 'featured' ? 'featured-image-upload' : 'thumbnail-upload');
      const statusDiv = document.createElement('div');
      statusDiv.className = 'absolute inset-0 bg-black/50 flex items-center justify-center text-white text-xs rounded-lg';
      statusDiv.textContent = 'Processing...';
      uploadEl?.appendChild(statusDiv);

      try {
        const { compressVideo } = await import('@/lib/video-compress');
        const result = await compressVideo(file, {
          maxSize: MAX_VIDEO_SIZE,
          onProgress: (p) => { statusDiv.textContent = p.message; }
        });

        if (!result.withinLimit) {
          alert('Video still too large after compression');
          statusDiv.remove();
          return;
        }
        fileToUpload = result.file;
        statusDiv.textContent = 'Uploading...';
      } catch (err) {
        console.error('Video compression error:', err);
        statusDiv.remove();
        alert('Video processing failed');
        return;
      }
    }

    try {
      const result = await actions.media.uploadMedia({
        file: fileToUpload,
        entityType: 'blog',
      });

      if (result.success && result.data?.id) {
        if (type === 'featured') {
          featuredImageId = result.data.id;
          const hiddenInput = document.getElementById('featured-image-id') as HTMLInputElement;
          if (hiddenInput) hiddenInput.value = result.data.id;
          document.getElementById('featured-preview-img')!.src = result.data.url;
          document.getElementById('featured-image-preview')!.classList.remove('hidden');
          document.getElementById('featured-image-upload')!.classList.add('hidden');
        } else {
          thumbnailId = result.data.id;
          const hiddenInput = document.getElementById('thumbnail-id') as HTMLInputElement;
          if (hiddenInput) hiddenInput.value = result.data.id;
          document.getElementById('thumbnail-preview-img')!.src = result.data.url;
          document.getElementById('thumbnail-preview')!.classList.remove('hidden');
          document.getElementById('thumbnail-upload')!.classList.add('hidden');
        }
      }
    } catch (err) {
      console.error('Upload error:', err);
    }
  }

  // Setup upload handlers
  document.getElementById('featured-image-upload')?.addEventListener('click', () => {
    document.getElementById('featured-image-file')?.click();
  });
  document.getElementById('featured-image-file')?.addEventListener('change', () => {
    handleImageUpload('featured-image-file', 'featured');
  });
  document.getElementById('remove-featured-image')?.addEventListener('click', () => {
    featuredImageId = null;
    document.getElementById('featured-image-preview')?.classList.add('hidden');
    document.getElementById('featured-image-upload')?.classList.remove('hidden');
  });

  document.getElementById('thumbnail-upload')?.addEventListener('click', () => {
    document.getElementById('thumbnail-file')?.click();
  });
  document.getElementById('thumbnail-file')?.addEventListener('change', () => {
    handleImageUpload('thumbnail-file', 'thumbnail');
  });
  document.getElementById('remove-thumbnail')?.addEventListener('click', () => {
    thumbnailId = null;
    document.getElementById('thumbnail-preview')?.classList.add('hidden');
    document.getElementById('thumbnail-upload')?.classList.remove('hidden');
  });

  // ── DOM refs ────────────────────────────────────────────────────────────────
  const $ = (id: string) => document.getElementById(id)!;
  const modal = $<HTMLDivElement>('post-modal');
  const deleteModal = $<HTMLDivElement>('delete-modal');
  const form = $<HTMLFormElement>('post-form');
  const listEl = $<HTMLDivElement>('posts-list');
  const searchInput = $<HTMLInputElement>('search-input');
  const statusFilter = $<HTMLSelectElement>('status-filter');
  const postIdInput = $<HTMLInputElement>('post-id') as HTMLInputElement;
  const titleInput = $<HTMLInputElement>('post-title') as HTMLInputElement;
  const slugInput = $<HTMLInputElement>('post-slug') as HTMLInputElement;
  const excerptInput = $<HTMLTextAreaElement>('post-excerpt') as HTMLTextAreaElement;
  const statusSelect = $<HTMLSelectElement>('post-status') as HTMLSelectElement;
  const tagsInput = $<HTMLInputElement>('post-tags') as HTMLInputElement;
  const modalTitle = $<HTMLHeadingElement>('modal-title');

  // ── Fetch posts ─────────────────────────────────────────────────────────────
  async function fetchPosts() {
    try {
      const res = await fetch("/api/admin/blogs", { credentials: "include" }); const result = await res.json();;
      posts = result.success ? result.data : [];
      renderList();
    } catch {
      listEl.innerHTML = '<p class="text-center text-red-500 py-8">Failed to load posts</p>';
    }
  }

  // ── Render list ─────────────────────────────────────────────────────────────
  function renderList() {
    if (posts.length === 0) {
      listEl.innerHTML = '<p class="text-center text-muted-foreground py-8 text-sm">No posts found</p>';
      return;
    }
    listEl.innerHTML = posts.map(post => `
      <div class="p-3 md:p-4 flex items-start justify-between gap-3 hover:bg-muted/30 transition-colors">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 flex-wrap">
            <h3 class="font-medium text-sm truncate">${escapeHtml(post.title)}</h3>
            ${statusBadge(post.status)}
          </div>
          <p class="text-xs text-muted-foreground mt-0.5 truncate">${escapeHtml(post.excerpt || '')}</p>
          <p class="text-xs text-muted-foreground mt-0.5">
            ${post.publishedAt ? formatDate(post.publishedAt) : 'Not published'}
            ${post.tags ? ` · ${JSON.parse(post.tags || '[]').join(', ')}` : ''}
          </p>
        </div>
        <div class="flex gap-1 shrink-0">
          <button onclick="window.editPost('${post.id}')" class="px-2 py-1 text-xs border rounded hover:bg-muted">Edit</button>
          <button onclick="window.deletePost('${post.id}')" class="px-2 py-1 text-xs border rounded hover:bg-red-50 hover:text-red-500">Delete</button>
        </div>
      </div>
    `).join('');
  }

  (window as BlogData).editPost = async function(id: string) {
    const post = posts.find(p => p.id === id);
    if (!post) return;

    postIdInput.value = id;
    titleInput.value = post.title;
    slugInput.value = post.slug;
    excerptInput.value = post.excerpt || '';
    statusSelect.value = post.status || 'draft';
    tagsInput.value = post.tags ? JSON.parse(post.tags).join(', ') : '';
    modalTitle.textContent = 'Edit Blog Post';

    openModal();
    renderEditor(post.content || '');
  };

  (window as BlogData).deletePost = function(id: string) {
    deleteTargetId = id;
    deleteModal.classList.remove('hidden');
    deleteModal.classList.add('flex');
  };

  // ── Modal helpers ───────────────────────────────────────────────────────────
  function openModal() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  function closeDeleteModal() {
    deleteModal.classList.add('hidden');
    deleteModal.classList.remove('flex');
    deleteTargetId = null;
  }

  // ── Editor ───────────────────────────────────────────────────────────────────
  async function renderEditor(initialContent = '') {
    const container = document.getElementById('editor-container')!;
    container.innerHTML = '<div id="content-editor"></div>';

    editorInstance = await initTipTapEditor(
      document.getElementById('content-editor')!,
      {
        placeholder: 'Write your blog post...',
        content: initialContent,
      }
    );
  }

  // ── Save ─────────────────────────────────────────────────────────────────────
  async function savePost() {
    const id = postIdInput.value;

    // Get content from hidden textarea synced by TipTap editor
    const contentTextarea = document.getElementById('content-editor-content') as HTMLTextAreaElement;
    const finalContent = contentTextarea?.value || '';

    const tags = tagsInput.value
      .split(',').map(t => t.trim()).filter(Boolean);

    const payload = {
      title: titleInput.value,
      slug: slugInput.value,
      excerpt: excerptInput.value,
      content: finalContent,
      status: statusSelect.value,
      tags,
      authorId: getCurrentUserId(),
    };

    try {
      let result;
      if (id) {
        result = await actions.admin.blogs.update(payload);
      } else {
        result = await actions.admin.blogs.create(payload);
      }
      if (result.success) {
        closeModal();
        fetchPosts();
      } else {
        alert(result.error?.message || 'Save failed');
      }
    } catch {
      alert('Save failed');
    }
  }

  // ── Delete ───────────────────────────────────────────────────────────────────
  async function handleDelete() {
    if (!deleteTargetId) return;
    try {
      const result = await actions.admin.blogs.delete({ id: deleteTargetId });
      if (result.success) {
        closeDeleteModal();
        fetchPosts();
      } else {
        alert(result.error?.message || 'Delete failed');
      }
    } catch {
      alert('Delete failed');
    }
  }

  // ── Helpers ──────────────────────────────────────────────────────────────────
  function getCurrentUserId() {
    // Server provides userId in data attribute
    const el = document.getElementById('current-user-id');
    return el?.dataset.userId || 'system';
  }

  function escapeHtml(str: string) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function formatDate(date: string | Date) {
    return new Date(date).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' });
  }

  function statusBadge(status: string) {
    const map: Record<string, string> = {
      published: 'bg-green-100 text-green-700',
      draft: 'bg-yellow-100 text-yellow-700',
      archived: 'bg-gray-100 text-gray-600',
    };
    const cls = map[status] || 'bg-gray-100 text-gray-600';
    return `<span class="px-1.5 py-0.5 text-xs rounded ${cls} capitalize">${status}</span>`;
  }

  function slugify(text: string) {
    return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  }

  // ── Event listeners ───────────────────────────────────────────────────────────
  $('new-post-btn').addEventListener('click', () => {
    postIdInput.value = '';
    titleInput.value = '';
    slugInput.value = '';
    excerptInput.value = '';
    statusSelect.value = 'draft';
    tagsInput.value = '';
    modalTitle.textContent = 'New Blog Post';
    openModal();
    renderEditor();
  });

  $('close-modal').addEventListener('click', closeModal);
  $('cancel-btn').addEventListener('click', closeModal);

  $('generate-slug-btn').addEventListener('click', () => {
    slugInput.value = slugify(titleInput.value);
  });

  // Auto-generate slug on title change if slug is empty
  titleInput.addEventListener('input', () => {
    if (!slugInput.value) slugInput.value = slugify(titleInput.value);
  });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    savePost();
  });

  $('confirm-delete-btn').addEventListener('click', handleDelete);
  $('cancel-delete-btn').addEventListener('click', closeDeleteModal);

  searchInput.addEventListener('input', () => fetchPosts());
  statusFilter.addEventListener('change', () => fetchPosts());

  // Close modal on backdrop click
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  deleteModal.addEventListener('click', (e) => { if (e.target === deleteModal) closeDeleteModal(); });

  // ── Init ─────────────────────────────────────────────────────────────────────
  fetchPosts();
</script>

<style is:global>
  /* TipTap editor styling */
  .ProseMirror {
    outline: none;
    min-height: 150px;
  }

  .ProseMirror p.is-editor-empty:first-child::before {
    content: attr(data-placeholder);
    color: #9ca3af;
    float: left;
    height: 0;
    pointer-events: none;
  }

  .ProseMirror h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  .ProseMirror h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .ProseMirror ul, .ProseMirror ol {
    padding-left: 1.5rem;
    margin: 0.5rem 0;
  }

  .ProseMirror a {
    color: var(--color-primary);
    text-decoration: underline;
  }
</style>
