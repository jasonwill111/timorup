---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
---

<AdminLayout title="Subscriptions">
  <div class="container py-4 px-2 md:py-6">
    <!-- Page Header -->
    <div class="mb-4 md:mb-6">
      <h1 class="text-xl md:text-2xl font-bold">Subscriptions</h1>
      <p class="text-sm text-muted-foreground mt-1">Manage subscription orders and payments</p>
    </div>

    <!-- Filter Tabs -->
    <div class="flex gap-2 mb-4 overflow-x-auto">
      <button class="filter-btn px-3 py-1.5 text-xs rounded-full border bg-primary text-primary-foreground" data-status="all">All</button>
      <button class="filter-btn px-3 py-1.5 text-xs rounded-full border" data-status="unpaid">Unpaid</button>
      <button class="filter-btn px-3 py-1.5 text-xs rounded-full border" data-status="paid">Paid</button>
    </div>

    <!-- Orders List -->
    <div class="bg-card border rounded-lg p-3 md:p-4">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-semibold text-sm md:text-base">Orders</h3>
        <span id="orders-count" class="text-xs text-muted-foreground">Loading...</span>
      </div>
      <div id="orders-list" class="space-y-2">
        <p class="text-center text-muted-foreground py-4 text-sm">Loading...</p>
      </div>
    </div>
  </div>

  <!-- Order Details Modal -->
  <div id="order-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
    <div class="bg-card border rounded-lg w-full max-w-lg">
      <div class="p-4 border-b flex items-center justify-between">
        <h2 class="text-lg font-bold">Order Details</h2>
        <button id="close-modal" class="p-1 hover:bg-muted rounded">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <form id="order-form" class="p-4 space-y-4">
        <input type="hidden" id="order-id" name="orderId" />

        <!-- Plan Type -->
        <div>
          <label for="plan-type" class="block text-sm font-medium mb-1">Plan Type</label>
          <select id="plan-type" name="planType" class="w-full px-3 py-2 border rounded-lg bg-background">
            <option value="basic-monthly">Basic Monthly - $29</option>
            <option value="basic-yearly">Basic Yearly - $290</option>
            <option value="pro-monthly">Pro Monthly - $59</option>
            <option value="pro-yearly">Pro Yearly - $590</option>
            <option value="max-monthly">Max Monthly - $89</option>
            <option value="max-yearly">Max Yearly - $890</option>
          </select>
        </div>

        <!-- Actual Amount -->
        <div>
          <label for="amount" class="block text-sm font-medium mb-1">Actual Amount (USD)</label>
          <input type="number" id="amount" name="amount" step="0.01" min="0" class="w-full px-3 py-2 border rounded-lg bg-background" />
          <p class="text-xs text-muted-foreground mt-1">Leave empty to use plan default</p>
        </div>

        <!-- Status -->
        <div>
          <label for="status" class="block text-sm font-medium mb-1">Payment Status</label>
          <select id="status" name="status" class="w-full px-3 py-2 border rounded-lg bg-background">
            <option value="unpaid">Unpaid</option>
            <option value="paid">Paid</option>
            <option value="cancelled">Cancelled</option>
            <option value="refunded">Refunded</option>
          </select>
        </div>

        <!-- Expiry Date -->
        <div>
          <label for="expiry-date" class="block text-sm font-medium mb-1">Expiry Date</label>
          <input type="date" id="expiry-date" name="expiryDate" class="w-full px-3 py-2 border rounded-lg bg-background" />
        </div>

        <!-- Admin Notes -->
        <div>
          <label for="admin-notes" class="block text-sm font-medium mb-1">Admin Notes</label>
          <textarea id="admin-notes" name="adminNotes" rows="3" class="w-full px-3 py-2 border rounded-lg bg-background" placeholder="Discount applied, special arrangement, etc."></textarea>
        </div>

        <!-- Info Display -->
        <div class="bg-muted/50 rounded-lg p-3 text-sm space-y-1">
          <div class="flex justify-between">
            <span class="text-muted-foreground">Order ID:</span>
            <span id="modal-order-id" class="font-mono text-xs"></span>
          </div>
          <div class="flex justify-between">
            <span class="text-muted-foreground">Business:</span>
            <span id="modal-business-title"></span>
          </div>
          <div class="flex justify-between">
            <span class="text-muted-foreground">Created:</span>
            <span id="modal-created-date"></span>
          </div>
          <div class="flex justify-between">
            <span class="text-muted-foreground">Paid Date:</span>
            <span id="modal-paid-date"></span>
          </div>
        </div>
      </form>

      <div class="p-4 border-t flex gap-2 justify-between">
        <button id="delete-order-btn" class="px-4 py-2 bg-red-600 text-white text-sm rounded-md hover:bg-red-700">Delete</button>
        <div class="flex gap-2">
          <button id="cancel-modal-btn" class="px-4 py-2 border text-sm rounded-md hover:bg-muted">Cancel</button>
          <button id="save-order-btn" class="px-4 py-2 bg-primary text-black text-sm rounded-md hover:bg-primary/90">Save Changes</button>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { toast } from '../../stores/toast';

  let currentFilter = 'all';
  let selectedOrderId = '';
  let currentOrderData: any = null;

  // Load orders
  async function loadOrders() {
    try {
      const url = currentFilter === 'all'
        ? '/api/admin/orders'
        : `/api/admin/orders?status=${currentFilter}`;
      const res = await fetch(url);
      const data = await res.json();

      const container = document.getElementById('orders-list');
      const countEl = document.getElementById('orders-count');
      if (!container || !countEl) return;

      if (!data.success || data.data.length === 0) {
        container.innerHTML = '<p class="text-center text-muted-foreground py-8">No orders found</p>';
        countEl.textContent = '0 orders';
        return;
      }

      countEl.textContent = `${data.data.length} order${data.data.length !== 1 ? 's' : ''}`;

      container.innerHTML = data.data.map((order: any) => `
        <div class="flex items-center justify-between p-3 border rounded text-sm cursor-pointer hover:bg-muted/50" onclick="showOrderDetails('${order.id}')">
          <div class="min-w-0 flex-1">
            <p class="font-medium truncate">#${order.id.slice(0, 8)}</p>
            <p class="text-xs text-muted-foreground truncate">${order.planType} - $${order.amount}</p>
            <p class="text-xs text-muted-foreground">${order.businessTitle || order.userEmail || 'N/A'}</p>
          </div>
          <div class="flex items-center gap-2 ml-2">
            <span class="px-2 py-0.5 text-xs rounded-full ${order.status === 'paid' ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200' : 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200'}">${order.status}</span>
          </div>
        </div>
      `).join('');
    } catch (err) {
      console.error('Error loading orders:', err);
      toast.error('Failed to load orders');
    }
  }

  // Filter buttons
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('bg-primary', 'text-primary-foreground');
      });
      btn.classList.add('bg-primary', 'text-primary-foreground');
      currentFilter = (btn as HTMLElement).dataset.status || 'all';
      loadOrders();
    });
  });

  // Show order details
  (window as any).showOrderDetails = async function(id: string) {
    selectedOrderId = id;
    const modal = document.getElementById('order-modal');
    const form = document.getElementById('order-form') as HTMLFormElement;

    if (!modal || !form) return;

    try {
      const res = await fetch(`/api/admin/orders/${id}`);
      const data = await res.json();

      if (!data.success) {
        toast.error('Failed to load order details');
        return;
      }

      const order = data.data;
      currentOrderData = order;

      // Fill form
      (document.getElementById('order-id') as HTMLInputElement).value = order.id;
      (document.getElementById('plan-type') as HTMLSelectElement).value = order.planType;
      (document.getElementById('amount') as HTMLInputElement).value = order.amount;
      (document.getElementById('status') as HTMLSelectElement).value = order.status;
      (document.getElementById('expiry-date') as HTMLInputElement).value = order.expiryDate ? new Date(order.expiryDate).toISOString().split('T')[0] : '';
      (document.getElementById('admin-notes') as HTMLTextAreaElement).value = order.adminNotes || '';

      // Info display
      document.getElementById('modal-order-id')!.textContent = order.id.slice(0, 12) + '...';
      document.getElementById('modal-business-title')!.textContent = order.businessTitle || 'N/A';
      document.getElementById('modal-created-date')!.textContent = order.createdAt ? new Date(order.createdAt).toLocaleDateString() : 'N/A';
      document.getElementById('modal-paid-date')!.textContent = order.paidDate ? new Date(order.paidDate).toLocaleDateString() : 'Not paid';

      modal.classList.remove('hidden');
      modal.classList.add('flex');
    } catch (err) {
      console.error('Error loading order:', err);
      toast.error('Error loading order details');
    }
  };

  // Save order
  document.getElementById('save-order-btn')?.addEventListener('click', async () => {
    if (!selectedOrderId) return;

    const planType = (document.getElementById('plan-type') as HTMLSelectElement).value;
    const amount = (document.getElementById('amount') as HTMLInputElement).value;
    const status = (document.getElementById('status') as HTMLSelectElement).value;
    const expiryDate = (document.getElementById('expiry-date') as HTMLInputElement).value;
    const adminNotes = (document.getElementById('admin-notes') as HTMLTextAreaElement).value;

    try {
      const res = await fetch(`/api/admin/orders/${selectedOrderId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          planType,
          amount: amount ? parseFloat(amount) : null,
          status,
          expiryDate: expiryDate || null,
          adminNotes: adminNotes || null,
        }),
      });

      const data = await res.json();

      if (data.success) {
        toast.success('Order updated successfully!');
        closeModal();
        loadOrders();
      } else {
        toast.error(data.error?.message || 'Failed to update order');
      }
    } catch (err) {
      console.error('Error saving order:', err);
      toast.error('Error saving order');
    }
  });

  // Delete order
  document.getElementById('delete-order-btn')?.addEventListener('click', async () => {
    if (!selectedOrderId) return;
    if (!confirm('Are you sure you want to delete this order?')) return;

    try {
      const res = await fetch(`/api/admin/orders/${selectedOrderId}`, {
        method: 'DELETE',
      });

      const data = await res.json();

      if (data.success) {
        toast.success('Order deleted successfully!');
        closeModal();
        loadOrders();
      } else {
        toast.error(data.error?.message || 'Failed to delete order');
      }
    } catch (err) {
      console.error('Error deleting order:', err);
      toast.error('Error deleting order');
    }
  });

  function closeModal() {
    const modal = document.getElementById('order-modal');
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    selectedOrderId = '';
    currentOrderData = null;
  }

  // Modal controls
  document.getElementById('close-modal')?.addEventListener('click', closeModal);
  document.getElementById('cancel-modal-btn')?.addEventListener('click', closeModal);

  const modal = document.getElementById('order-modal');
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Initialize
  loadOrders();
</script>
