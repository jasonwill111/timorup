---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import Button from '@components/ui/Button.astro';
---

<AdminLayout title="Public Sectors">
  <div class="container py-4 px-2 md:py-6">
    <!-- Page Header -->
    <div class="mb-4 md:mb-6 flex items-start justify-between gap-2">
      <h1 class="text-lg md:text-2xl font-bold min-w-0 truncate">All Public Sectors</h1>
      <Button id="add-btn" class="text-xs px-2 py-1 h-7 flex-shrink-0 whitespace-nowrap md:text-sm md:px-4 md:h-9">+ Add Public Sector</Button>
    </div>

    <!-- Search and Filters -->
    <div class="bg-card border rounded-lg p-3 md:p-4 mb-4">
      <div class="flex flex-col md:flex-row gap-3">
        <div class="flex-1">
          <input
            type="text"
            id="search-input"
            placeholder="Search by name or slug..."
            class="w-full px-3 py-2 border rounded-lg text-sm"
          />
        </div>
        <div class="flex gap-2">
          <select id="status-filter" class="px-3 py-2 border rounded-lg text-sm bg-background">
            <option value="">All Status</option>
            <option value="draft">Draft</option>
            <option value="live">Live</option>
            <option value="paid">Paid</option>
            <option value="expired">Expired</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Public Sectors List -->
    <div class="bg-card border rounded-lg p-3 md:p-4">
      <div class="flex items-center justify-between mb-4">
        <span id="count" class="text-xs text-muted-foreground">Loading...</span>
      </div>
      <div id="list" class="space-y-2">
        <p class="text-center text-muted-foreground py-4 text-sm">Loading...</p>
      </div>
    </div>
  </div>

  <!-- Create Public Sector Modal -->
  <div id="business-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
    <div class="bg-card border rounded-lg w-full max-w-2xl max-h-[90vh] overflow-y-auto">
      <div class="p-4 border-b flex items-center justify-between">
        <h2 class="text-lg font-bold" id="modal-title">Create Public Sector</h2>
        <button id="close-modal" class="p-1 hover:bg-muted rounded">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <form id="business-form" class="p-4 space-y-4">
        <div>
          <label for="biz-title" class="block text-sm font-medium mb-1">Public Sector Name *</label>
          <input type="text" id="biz-title" name="title" required class="w-full px-3 py-2 border rounded-md text-sm" />
        </div>
        <div>
          <label for="biz-slug" class="block text-sm font-medium mb-1">Slug *</label>
          <input type="text" id="biz-slug" name="slug" required class="w-full px-3 py-2 border rounded-md text-sm" />
        </div>
        <div>
          <label for="biz-email" class="block text-sm font-medium mb-1">Email</label>
          <input type="email" id="biz-email" name="email" class="w-full px-3 py-2 border rounded-md text-sm" />
        </div>
        <div>
          <label for="biz-phone" class="block text-sm font-medium mb-1">Phone</label>
          <input type="tel" id="biz-phone" name="phone" class="w-full px-3 py-2 border rounded-md text-sm" />
        </div>
        <div>
          <label for="biz-about" class="block text-sm font-medium mb-1">About Us</label>
          <div id="about-editor-container" class="min-h-[150px] border rounded-md overflow-hidden"></div>
        </div>
        <div>
          <label for="biz-updates" class="block text-sm font-medium mb-1">Latest Updates</label>
          <div id="updates-editor-container" class="min-h-[150px] border rounded-md overflow-hidden"></div>
        </div>
        <div class="flex gap-2 justify-end">
          <Button type="button" id="cancel-btn" variant="outline" class="text-xs py-1 h-8">Cancel</Button>
          <Button type="submit" class="text-xs py-1 h-8">Create</Button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  // Auth fetch helper
  async function authFetch(url, options = {}) {
    return fetch(url, {
      ...options,
      credentials: 'include',
      headers: {
        ...(options.body ? { 'Content-Type': 'application/json' } : {}),
        ...options.headers,
      },
    });
  }

  let businessList: PublicSectororData = [];
  let aboutContent = '';
  let updatesContent = '';

  // Load public-sectors
  async function loadPublicSectorores() {
    try {
      const res = await authFetch('/api/admin/public-sectors');
      const data = await res.json();

      const container = document.getElementById('public-sectors-list');
      const countEl = document.getElementById('public-sectors-count');
      if (!container) return;

      if (!data.success || data.data.length === 0) {
        container.innerHTML = '<p class="text-center text-muted-foreground py-8">No public-sectors yet</p>';
        if (countEl) countEl.textContent = '0 public-sectors';
        return;
      }

      businessList = data.data;
      renderPublicSectorores();
    } catch (err) {
      console.error('Error loading public-sectors:', err);
    }
  }

  // Render public-sectors with filters
  function renderPublicSectorores() {
    const container = document.getElementById('public-sectors-list');
    const countEl = document.getElementById('public-sectors-count');
    if (!container) return;

    const search = (document.getElementById('search-input') as HTMLInputElement)?.value.toLowerCase() || '';
    const status = (document.getElementById('status-filter') as HTMLSelectElement)?.value || '';

    const filtered = businessList.filter(biz => {
      const matchesSearch = !search ||
        biz.title?.toLowerCase().includes(search) ||
        biz.slug?.toLowerCase().includes(search);
      const matchesStatus = !status || biz.status === status;
      return matchesSearch && matchesStatus;
    });

    if (countEl) countEl.textContent = `${filtered.length} of ${businessList.length} public-sectors`;

    if (filtered.length === 0) {
      container.innerHTML = '<p class="text-center text-muted-foreground py-8">No public-sectors found</p>';
      return;
    }

    container.innerHTML = filtered.map((biz: PublicSectororData) => `
      <div class="flex items-center justify-between p-2 md:p-3 border rounded text-sm hover:bg-muted/30">
        <div class="min-w-0 flex-1">
          <p class="font-medium truncate">${escapeHtml(biz.title)}</p>
          <p class="text-xs text-muted-foreground">/${escapeHtml(biz.slug)}</p>
        </div>
        <div class="flex items-center gap-2 ml-2">
          <button class="text-xs px-2 py-1 border rounded hover:bg-muted edit-btn" data-id="${biz.id}">Edit</button>
          <span class="px-2 py-0.5 text-xs rounded-full ${biz.status === 'live' || biz.status === 'paid' ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200' : 'bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-200'}">${capitalizeFirst(biz.status)}</span>
          <select class="text-xs border rounded px-1 py-0.5 bg-background" onchange="updatePublicSectororStatus('${biz.id}', this.value)">
            <option value="draft" ${biz.status === 'draft' ? 'selected' : ''}>Draft</option>
            <option value="live" ${biz.status === 'live' ? 'selected' : ''}>Live</option>
            <option value="paid" ${biz.status === 'paid' ? 'selected' : ''}>Paid</option>
            <option value="expired" ${biz.status === 'expired' ? 'selected' : ''}>Expired</option>
          </select>
        </div>
      </div>
    `).join('');
  }

  function escapeHtml(str: string) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g, '&#39;');
  }

  function capitalizeFirst(str: string | null | undefined): string {
    if (!str) return '-';
    return str.charAt(0).toUpperCase() + str.slice(1);
  }
  
  // Auto-generate slug from title
  document.getElementById('biz-title')?.addEventListener('input', (e) => {
    const title = (e.target as HTMLInputElement).value;
    const slugInput = document.getElementById('biz-slug') as HTMLInputElement;
    if (slugInput && !slugInput.dataset.userModified) {
      slugInput.value = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    }
  });
  
  document.getElementById('biz-slug')?.addEventListener('input', (e) => {
    (e.target as HTMLInputElement).dataset.userModified = 'true';
  });
  
  // Modal controls
  const modal = document.getElementById('business-modal');
  const addBtn = document.getElementById('add-business-btn');
  const closeBtn = document.getElementById('close-modal');
  const cancelBtn = document.getElementById('cancel-btn');
  
  // Render editors with simple textareas
  function renderEditors(initialAbout = '', initialUpdates = '') {
    aboutContent = initialAbout;
    updatesContent = initialUpdates;

    const aboutContainer = document.getElementById('about-editor-container')!;
    const updatesContainer = document.getElementById('updates-editor-container')!;

    aboutContainer.innerHTML = `<textarea name="aboutUs" rows="4" class="w-full px-3 py-2 border rounded-md text-sm resize-y" placeholder="Write about your business...">${escapeHtml(initialAbout)}</textarea>`;
    updatesContainer.innerHTML = `<textarea name="latestUpdate" rows="4" class="w-full px-3 py-2 border rounded-md text-sm resize-y" placeholder="Latest news and updates...">${escapeHtml(initialUpdates)}</textarea>`;
  }

  addBtn?.addEventListener('click', () => {
    aboutContent = '';
    updatesContent = '';
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
    renderEditors('', '');
  });
  
  closeBtn?.addEventListener('click', () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
  });
  
  cancelBtn?.addEventListener('click', () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
  });
  
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }
  });
  
  // Form submission
  let editingId: string | null = null;

  document.getElementById('business-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);

    const businessData = {
      title: String(formData.get('title') || ''),
      slug: String(formData.get('slug') || ''),
      email: String(formData.get('email') || ''),
      contactNumber: String(formData.get('phone') || ''),
      aboutUs: aboutContent,
      latestUpdate: updatesContent,
      status: 'draft',
    };

    try {
      const isEdit = editingId !== null;
      const res = await authFetch('/api/admin/public-sectors' + (isEdit ? '/' + editingId : ''), {
        method: isEdit ? 'PUT' : 'POST',
        body: JSON.stringify(businessData),
      });

      const data = await res.json();

      if (data.success) {
        alert(isEdit ? 'Public Sector updated successfully!' : 'Public Sector created successfully!');
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
        (e.target as HTMLFormElement).reset();
        editingId = null;
        loadPublicSectorores();
      } else {
        alert(data.error?.message || 'Failed to save public sector');
      }
    } catch (err) {
      console.error('Error saving public sector:', err);
      alert('Error saving public sector');
    }
  });
  
  // Global function for status update
  (window as PublicSectororData).updatePublicSectororStatus = async function(id: string, status: string) {
    try {
      const res = await fetch(`/api/admin/public-sectors/${id}/status`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status }),
      });
      const data = await res.json();
      
      if (!data.success) {
        alert('Failed to update status');
        loadPublicSectorores();
      } else {
        alert('Status updated');
      }
    } catch (err) {
      console.error('Error updating status:', err);
      alert('Error updating status');
    }
  };
  
  // Event listeners for search and filter
  document.getElementById('search-input')?.addEventListener('input', renderPublicSectorores);
  document.getElementById('status-filter')?.addEventListener('change', renderPublicSectorores);

  // Edit button handler
  document.getElementById('list')?.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('.edit-btn') as HTMLButtonElement | null;
    if (!btn) return;

    const id = btn.dataset.id;
    if (!id) return;

    const entity = businessList.find(b => b.id === id);
    if (!entity) return;

    // Populate form
    (document.getElementById('biz-title') as HTMLInputElement).value = entity.title || '';
    (document.getElementById('biz-slug') as HTMLInputElement).value = entity.slug || '';
    (document.getElementById('biz-email') as HTMLInputElement).value = entity.email || '';
    (document.getElementById('biz-phone') as HTMLInputElement).value = entity.contactNumber || '';

    // Set modal title and show
    const modalTitle = document.getElementById('modal-title');
    if (modalTitle) modalTitle.textContent = 'Edit Public Sector';
    editingId = id;
    aboutContent = entity.aboutUs || '';
    updatesContent = entity.latestUpdate || '';
    renderEditors(aboutContent, updatesContent);

    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
  });

  // Initialize
  loadPublicSectorores();
</script>
