---
// Admin listing management page
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import Button from '../../../components/ui/Button.astro';
import { db } from '@/lib/db';
import { businessPages, categories } from '@/db/schema';
import { desc, eq, count } from 'drizzle-orm';
import { ENTITY_TYPES } from '@/lib/constants';

// Get all listings with counts
const listings = await db
  .select({
    id: businessPages.id,
    title: businessPages.title,
    entityType: businessPages.entityType,
    status: businessPages.status,
    categoryId: businessPages.categoryId,
    likes: businessPages.likes,
    ratingAverage: businessPages.ratingAverage,
    publishDate: businessPages.publishDate,
  })
  .from(businessPages)
  .orderBy(desc(businessPages.createdAt))
  .limit(100);

// Get categories for display
const allCategories = await db.select().from(categories).all();
const categoryMap = Object.fromEntries(allCategories.map(c => [c.id, c.name]));

const statusColors: Record<string, string> = {
  draft: 'bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300',
  live: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
  expired: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400',
  suspended: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400',
};

const entityColors: Record<string, string> = {
  business: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400',
  government: 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400',
  nonprofit: 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400',
};
---

<Layout title="Listing Management - Admin" requireAuth adminOnly>
  <div class="container py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold">Listing Management</h1>
        <p class="text-sm text-muted-foreground">Manage all listings (businesses, government, nonprofits)</p>
      </div>
      <a href="/admin/listing/new">
        <Button>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          New Listing
        </Button>
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <div class="bg-card rounded-lg border p-4">
        <div class="text-2xl font-bold">{listings.length}</div>
        <div class="text-xs text-muted-foreground">Total Listings</div>
      </div>
      <div class="bg-card rounded-lg border p-4">
        <div class="text-2xl font-bold">{listings.filter(l => l.entityType === 'business').length}</div>
        <div class="text-xs text-muted-foreground">Businesses</div>
      </div>
      <div class="bg-card rounded-lg border p-4">
        <div class="text-2xl font-bold">{listings.filter(l => l.entityType === 'government').length}</div>
        <div class="text-xs text-muted-foreground">Government</div>
      </div>
      <div class="bg-card rounded-lg border p-4">
        <div class="text-2xl font-bold">{listings.filter(l => l.entityType === 'nonprofit').length}</div>
        <div class="text-xs text-muted-foreground">Non-Profits</div>
      </div>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-4 mb-6">
      <select id="filter-type" class="h-10 px-3 rounded-md border border-input bg-background">
        <option value="">All Types</option>
        {ENTITY_TYPES.map(type => (
          <option value={type.value}>{type.label}</option>
        ))}
      </select>
      <select id="filter-status" class="h-10 px-3 rounded-md border border-input bg-background">
        <option value="">All Status</option>
        <option value="draft">Draft</option>
        <option value="live">Live</option>
        <option value="expired">Expired</option>
        <option value="suspended">Suspended</option>
      </select>
      <Input
        id="search"
        type="search"
        placeholder="Search listings..."
        class="w-64"
      />
    </div>

    <!-- Listings Table -->
    <div class="bg-card rounded-lg border overflow-hidden">
      <table class="w-full">
        <thead class="bg-muted/50">
          <tr>
            <th class="text-left px-4 py-3 text-sm font-medium">Title</th>
            <th class="text-left px-4 py-3 text-sm font-medium">Type</th>
            <th class="text-left px-4 py-3 text-sm font-medium">Category</th>
            <th class="text-left px-4 py-3 text-sm font-medium">Status</th>
            <th class="text-left px-4 py-3 text-sm font-medium">Rating</th>
            <th class="text-right px-4 py-3 text-sm font-medium">Actions</th>
          </tr>
        </thead>
        <tbody id="listings-body" class="divide-y">
          {listings.map(listing => (
            <tr
              class="listing-row hover:bg-muted/30"
              data-type={listing.entityType}
              data-status={listing.status}
              data-title={listing.title.toLowerCase()}
            >
              <td class="px-4 py-3">
                <div class="font-medium">{listing.title}</div>
                <div class="text-xs text-muted-foreground">
                  {listing.publishDate
                    ? `Published ${new Date(listing.publishDate).toLocaleDateString()}`
                    : 'Not published'
                  }
                </div>
              </td>
              <td class="px-4 py-3">
                <span class={`px-2 py-0.5 text-xs rounded-full ${entityColors[listing.entityType || 'business']}`}>
                  {listing.entityType || 'business'}
                </span>
              </td>
              <td class="px-4 py-3 text-sm">
                {categoryMap[listing.categoryId || ''] || '-'}
              </td>
              <td class="px-4 py-3">
                <span class={`px-2 py-0.5 text-xs rounded-full ${statusColors[listing.status || 'draft']}`}>
                  {listing.status || 'draft'}
                </span>
              </td>
              <td class="px-4 py-3">
                {listing.ratingAverage && listing.ratingAverage > 0 ? (
                  <span class="text-sm">
                    {listing.ratingAverage.toFixed(1)} ★
                  </span>
                ) : '-'}
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center justify-end gap-2">
                  <a
                    href={`/admin/listing/${listing.id}/edit`}
                    class="text-sm text-primary hover:underline"
                  >
                    Edit
                  </a>
                  <a
                    href={listing.entityType === 'business' ? `/business/${listing.id}` : `/organization/${listing.id}`}
                    target="_blank"
                    class="text-sm text-muted-foreground hover:text-foreground"
                  >
                    View →
                  </a>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>

      {listings.length === 0 && (
        <div class="text-center py-12 text-muted-foreground">
          No listings found
        </div>
      )}
    </div>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById('search') as HTMLInputElement;
  const typeFilter = document.getElementById('filter-type') as HTMLSelectElement;
  const statusFilter = document.getElementById('filter-status') as HTMLSelectElement;
  const rows = document.querySelectorAll('.listing-row');

  const filter = () => {
    const search = searchInput.value.toLowerCase();
    const type = typeFilter.value;
    const status = statusFilter.value;

    rows.forEach(row => {
      const el = row as HTMLElement;
      const title = el.dataset.title || '';
      const rowType = el.dataset.type || '';
      const rowStatus = el.dataset.status || '';

      const matchSearch = !search || title.includes(search);
      const matchType = !type || rowType === type;
      const matchStatus = !status || rowStatus === status;

      el.style.display = matchSearch && matchType && matchStatus ? '' : 'none';
    });
  };

  searchInput?.addEventListener('input', filter);
  typeFilter?.addEventListener('change', filter);
  statusFilter?.addEventListener('change', filter);
</script>
