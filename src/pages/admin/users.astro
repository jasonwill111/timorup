---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import Button from '@components/ui/Button.astro';
import { actions } from 'astro:actions';
---

<AdminLayout title="Users">
  <div class="container py-4 px-2 md:py-6">
    <!-- Page Header -->
    <div class="mb-4 md:mb-6">
      <h1 class="text-xl md:text-2xl font-bold">All Users</h1>
      <p class="text-sm text-muted-foreground mt-1">Manage registered users</p>
    </div>

    <!-- Search and Filters -->
    <div class="bg-card border rounded-lg p-3 md:p-4 mb-4">
      <div class="flex flex-col md:flex-row gap-3">
        <div class="flex-1">
          <input
            type="text"
            id="search-input"
            placeholder="Search by name or email..."
            class="w-full px-3 py-2 border rounded-lg text-sm"
          />
        </div>
        <div class="flex gap-2">
          <select id="role-filter" class="px-3 py-2 border rounded-lg text-sm bg-background">
            <option value="">All Roles</option>
            <option value="user">User</option>
            <option value="editor">Editor</option>
            <option value="admin">Admin</option>
            <option value="super_admin">Super Admin</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Users List -->
    <div class="bg-card border rounded-lg p-3 md:p-4">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-semibold text-sm md:text-base">Users</h3>
        <span id="users-count" class="text-xs text-muted-foreground">Loading...</span>
      </div>
      <div id="users-list" class="space-y-2">
        <p class="text-center text-muted-foreground py-4 text-sm">Loading...</p>
      </div>
    </div>
  </div>

  <!-- Edit User Modal -->
  <div id="edit-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
    <div class="bg-card border rounded-lg w-full max-w-md">
      <div class="p-4 border-b flex items-center justify-between">
        <h2 class="text-lg font-bold">Edit User</h2>
        <button id="close-modal" class="p-1 hover:bg-muted rounded">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <form id="user-form" class="p-4 space-y-4">
        <input type="hidden" id="user-id" name="id" />
        <div>
          <label for="user-name" class="block text-sm font-medium mb-1">Name *</label>
          <input type="text" id="user-name" name="name" required class="w-full px-3 py-2 border rounded-md text-sm" />
        </div>
        <div>
          <label for="user-email" class="block text-sm font-medium mb-1">Email *</label>
          <input type="email" id="user-email" name="email" required class="w-full px-3 py-2 border rounded-md text-sm" />
        </div>
        <div>
          <label for="user-phone" class="block text-sm font-medium mb-1">Phone</label>
          <input type="text" id="user-phone" name="phone" class="w-full px-3 py-2 border rounded-md text-sm" />
        </div>
        <div>
          <label for="user-role" class="block text-sm font-medium mb-1">Role</label>
          <select id="user-role" name="role" class="w-full px-3 py-2 border rounded-md text-sm bg-background" disabled>
            <option value="user">User</option>
            <option value="editor">Editor</option>
            <option value="admin">Admin</option>
            <option value="super_admin">Super Admin</option>
          </select>
          <p id="role-edit-note" class="text-xs text-muted-foreground mt-1 hidden">Only Super Admin can change roles</p>
        </div>
        <div class="flex gap-2 justify-end pt-2">
          <Button type="button" id="cancel-btn" variant="outline" class="text-xs py-1 h-8">Cancel</Button>
          <Button type="submit" class="text-xs py-1 h-8">Save</Button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  import { actions } from 'astro:actions';
  import { toast } from '../../stores/toast';

  let allUsers: UserData = [];
  let currentUserRole = 'user';

  // Auth fetch helper
  async function authFetch(url, options = {}) {
    return fetch(url, {
      ...options,
      credentials: 'include',
      headers: {
        ...(options.body ? { 'Content-Type': 'application/json' } : {}),
        ...options.headers,
      },
    });
  }

  // Check current user role
  async function checkUserRole() {
    try {
      const res = await authFetch('/api/auth/session');
      const data = await res.json();
      currentUserRole = data.user?.role || 'user';

      // Show/hide edit buttons based on role
      const roleSelect = document.getElementById('user-role') as HTMLSelectElement;
      const roleNote = document.getElementById('role-edit-note');
      if (currentUserRole === 'super_admin') {
        if (roleSelect) roleSelect.disabled = false;
        if (roleNote) roleNote.classList.remove('hidden');
      } else {
        if (roleSelect) roleSelect.disabled = true;
        if (roleNote) roleNote.classList.remove('hidden');
      }
    } catch (err) {
      console.error('Error checking user role:', err);
    }
  }

  // Load users
  async function loadUsers() {
    try {
      const res = await authFetch('/api/admin/users');
      const data = await res.json();

      if (!data.success) {
        toast.error(data.error?.message || 'Failed to load users');
        return;
      }

      allUsers = data.data || [];
      renderUsers();
    } catch (err) {
      console.error('Error loading users:', err);
      toast.error('Failed to load users');
    }
  }

  // Render users with filters
  function renderUsers() {
    const container = document.getElementById('users-list');
    const countEl = document.getElementById('users-count');
    if (!container || !countEl) return;

    const search = (document.getElementById('search-input') as HTMLInputElement)?.value.toLowerCase() || '';
    const role = (document.getElementById('role-filter') as HTMLSelectElement)?.value || '';

    const filtered = allUsers.filter(user => {
      const matchesSearch = !search ||
        user.name?.toLowerCase().includes(search) ||
        user.email?.toLowerCase().includes(search);
      const matchesRole = !role || user.role === role;
      return matchesSearch && matchesRole;
    });

    countEl.textContent = `${filtered.length} of ${allUsers.length} users`;

    if (filtered.length === 0) {
      container.innerHTML = '<p class="text-center text-muted-foreground py-8">No users found</p>';
      return;
    }

    container.innerHTML = filtered.map((user: UserData) => `
      <div class="flex items-center justify-between p-3 border rounded text-sm hover:bg-muted/30" data-user-id="${user.id}" data-user-name="${escapeHtml(user.name)}" data-user-email="${escapeHtml(user.email || '')}" data-user-phone="${escapeHtml(user.phone || '')}" data-user-role="${user.role}">
        <div class="min-w-0 flex-1">
          <p class="font-medium truncate">${escapeHtml(user.name)}</p>
          <p class="text-xs text-muted-foreground truncate">${escapeHtml(user.email || 'No email')}</p>
          <p class="text-xs text-muted-foreground truncate">${escapeHtml(user.phone || 'No phone')}</p>
        </div>
        <div class="flex items-center gap-2 ml-2">
          <span class="px-2 py-0.5 text-xs rounded-full ${getRoleClass(user.role)}">${user.role}</span>
          <button class="text-blue-500 hover:text-blue-600 text-xs px-2 py-1 edit-user-btn">Edit</button>
          <button class="text-red-500 hover:text-red-600 text-xs px-2 py-1 delete-user-btn" data-user-id="${user.id}">Del</button>
        </div>
      </div>
    `).join('');
  }
  
  function getRoleClass(role: string) {
    switch(role) {
      case 'super_admin': return 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200';
      case 'admin': return 'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200';
      case 'editor': return 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200';
      default: return 'bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-200';
    }
  }

  function escapeHtml(str: string) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g, '&#39;');
  }

  // Event delegation for edit/delete buttons
  document.getElementById('users-list')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const row = target.closest('[data-user-id]') as HTMLElement;
    if (!row) return;

    if (target.classList.contains('edit-user-btn')) {
      const id = row.dataset.userId || '';
      const name = row.dataset.userName || '';
      const email = row.dataset.userEmail || '';
      const phone = row.dataset.userPhone || '';
      const role = row.dataset.userRole || 'user';
      (document.getElementById('user-id') as HTMLInputElement).value = id;
      (document.getElementById('user-name') as HTMLInputElement).value = name;
      (document.getElementById('user-email') as HTMLInputElement).value = email;
      (document.getElementById('user-phone') as HTMLInputElement).value = phone;
      (document.getElementById('user-role') as HTMLSelectElement).value = role;
      const modal = document.getElementById('edit-modal');
      modal?.classList.remove('hidden');
      modal?.classList.add('flex');
    }

    if (target.classList.contains('delete-user-btn')) {
      const id = row.dataset.userId || '';
      if (confirm('Delete this user and all their data? This action cannot be undone.')) {
        deleteUser(id);
      }
    }
  });

  // Delete user
  async function deleteUser(id: string) {
    if (!confirm('Delete this user and all their data? This action cannot be undone.')) return;

    try {
      const result = await actions.admin.setUserRole({ userId: id, role: 'user' }).catch(() => null);
      // Use direct API for delete since no delete action exists
      const res = await fetch(`/api/admin/users/${id}`, { method: 'DELETE' });
      const data = await res.json();

      if (data.success) {
        toast.success('User deleted');
        loadUsers();
      } else {
        toast.error(data.error?.message || 'Failed to delete user');
      }
    } catch (err) {
      console.error('Error deleting user:', err);
      toast.error('Error deleting user');
    }
  };
  
  // Modal controls
  const modal = document.getElementById('edit-modal');
  const closeBtn = document.getElementById('close-modal');
  const cancelBtn = document.getElementById('cancel-btn');
  
  closeBtn?.addEventListener('click', () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
  });
  
  cancelBtn?.addEventListener('click', () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
  });
  
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }
  });
  
  // Form submission
  document.getElementById('user-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);

    const userId = formData.get('id') as string;
    const userData = {
      name: String(formData.get('name') || ''),
      email: String(formData.get('email') || ''),
      phone: String(formData.get('phone') || ''),
      role: String(formData.get('role') || 'user'),
    };
    const originalRole = (document.getElementById('users-list')?.querySelector(`[data-user-id="${userId}"]`) as HTMLElement)?.dataset.userRole || 'user';

    try {
      // Update basic info
      const res = await fetch(`/api/admin/users/${userId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(userData),
      });

      const data = await res.json();

      // If role changed and user is super_admin, use actions to update role
      if (data.success && userData.role !== originalRole && currentUserRole === 'super_admin') {
        try {
          const roleResult = await actions.admin.setUserRole({
            userId,
            role: userData.role as 'user' | 'editor' | 'admin' | 'super_admin',
          });
          if (!roleResult.success) {
            toast.error(roleResult.error?.message || 'Failed to update role');
            return;
          }
        } catch (err) {
          console.error('Error updating role:', err);
          toast.error('Failed to update role');
          return;
        }
      }

      if (data.success) {
        toast.success('User updated');
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
        loadUsers();
      } else {
        toast.error(data.error?.message || 'Failed to update user');
      }
    } catch (err) {
      console.error('Error updating user:', err);
      toast.error('Error updating user');
    }
  });
  
  // Event listeners for search and filter
  document.getElementById('search-input')?.addEventListener('input', renderUsers);
  document.getElementById('role-filter')?.addEventListener('change', renderUsers);

  // Initialize
  checkUserRole();
  loadUsers();
</script>
