---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import Button from '@components/ui/Button.astro';
---

<AdminLayout title="Categories">
  <div class="container py-4 px-2 md:py-6">
    <!-- Page Header -->
    <div class="mb-4 md:mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      <div>
        <h1 class="text-xl md:text-2xl font-bold">Categories</h1>
        <p class="text-sm text-muted-foreground">Manage categories for 4 entity types</p>
      </div>
      <Button id="add-category-btn" class="text-xs px-2 py-1 h-7 flex-shrink-0 whitespace-nowrap md:text-sm md:px-4 md:h-9">+ Add Category</Button>
    </div>

    <!-- Tabs -->
    <div class="flex gap-1 mb-4 border-b">
      <button class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent" data-table="business">Business</button>
      <button class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent" data-table="non_profit">Non-Profit</button>
      <button class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent" data-table="public_sector">Public Sector</button>
      <button class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent" data-table="listing">Listing</button>
    </div>

    <!-- Stats -->
    <div class="bg-card border rounded-lg p-3 mb-4 text-center">
      <p class="text-lg font-bold" id="stat-count">-</p>
      <p class="text-xs text-muted-foreground">categories in <span id="current-table-name">Business</span></p>
    </div>

    <!-- Filter -->
    <div class="bg-card border rounded-lg p-3 mb-4">
      <div class="flex flex-col sm:flex-row gap-2">
        <select id="level-filter" class="h-9 px-3 rounded-md border bg-background text-sm">
          <option value="">All Levels</option>
          <option value="parent">Parent (Top-level)</option>
          <option value="child">Sub-categories</option>
        </select>
        <select id="parent-filter" class="h-9 px-3 rounded-md border bg-background text-sm">
          <option value="">All Parents</option>
        </select>
        <input type="search" id="search" placeholder="Search categories..." class="h-9 px-3 rounded-md border bg-background text-sm flex-1" />
      </div>
    </div>

    <!-- Categories List -->
    <div class="bg-card border rounded-lg">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-muted/50">
            <tr>
              <th class="text-left p-3 font-medium">Category</th>
              <th class="text-left p-3 font-medium hidden md:table-cell">Entity</th>
              <th class="text-left p-3 font-medium hidden lg:table-cell">Level</th>
              <th class="text-left p-3 font-medium hidden lg:table-cell">Parent</th>
              <th class="text-left p-3 font-medium">Sort</th>
              <th class="text-right p-3 font-medium">Actions</th>
            </tr>
          </thead>
          <tbody id="categories-list">
            <tr>
              <td colspan="6" class="text-center p-8 text-muted-foreground">Loading...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Create/Edit Category Modal -->
  <div id="category-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4 overflow-y-auto">
    <div class="bg-card border rounded-lg w-full max-w-md my-8">
      <div class="p-4 border-b flex items-center justify-between">
        <h2 id="form-title" class="text-lg font-bold">Create Category</h2>
        <button id="close-modal" class="p-1 hover:bg-muted rounded">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <form id="category-form" class="p-4 space-y-4">
        <input type="hidden" id="cat-id" />

        <div>
          <label for="cat-name" class="block text-sm font-medium mb-1">Category Name *</label>
          <input type="text" id="cat-name" required class="w-full px-3 py-2 border rounded-md text-sm" placeholder="e.g. Restaurants" />
        </div>
        <div>
          <label for="cat-slug" class="block text-sm font-medium mb-1">Slug *</label>
          <input type="text" id="cat-slug" required class="w-full px-3 py-2 border rounded-md text-sm" placeholder="e.g. restaurants" />
        </div>
        <div>
          <label for="cat-entity-type" class="block text-sm font-medium mb-1">Entity Type *</label>
          <select id="cat-entity-type" required class="w-full px-3 py-2 border rounded-md text-sm">
            <option value="business">Business</option>
            <option value="nonprofit">Non-Profit</option>
            <option value="public_sector">Public Sector</option>
            <option value="listing">Listing</option>
            <option value="product">Product</option>
          </select>
          <p class="text-xs text-muted-foreground mt-1">Category type determines which listings can use this category</p>
        </div>
        <div>
          <label for="cat-parent" class="block text-sm font-medium mb-1">Parent Industry</label>
          <select id="cat-parent" class="w-full px-3 py-2 border rounded-md text-sm">
            <option value="">Top-level (Industry)</option>
          </select>
          <p class="text-xs text-muted-foreground mt-1">Leave empty for top-level industry categories</p>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label for="cat-icon" class="block text-sm font-medium mb-1">Icon (emoji)</label>
            <input type="text" id="cat-icon" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="e.g. 🍽️" maxlength="4" />
          </div>
          <div class="col-span-2">
            <label class="block text-sm font-medium mb-1">Image</label>
            <div id="cat-image-upload" class="border-2 border-dashed border-muted-foreground/25 rounded-lg p-3 text-center hover:border-muted-foreground/50 transition-colors cursor-pointer">
              <p class="text-xs text-muted-foreground">Click or drag to upload image</p>
            </div>
            <input type="file" id="cat-image-file" accept="image/*" class="hidden" />
            <div id="cat-image-preview" class="mt-2 hidden">
              <div class="relative inline-block">
                <img id="cat-preview-img" class="w-full max-h-32 rounded-lg object-cover" />
                <button type="button" id="remove-cat-image" class="absolute top-1 right-1 w-5 h-5 bg-red-500 text-white rounded-full text-xs">×</button>
              </div>
            </div>
            <input type="hidden" id="cat-image-id" name="image" value="" />
          </div>
        </div>
        <div>
          <label for="cat-sort" class="block text-sm font-medium mb-1">Sort Order</label>
          <input type="number" id="cat-sort" class="w-full px-3 py-2 border rounded-md text-sm" value="0" min="0" />
        </div>
        <div>
          <label for="cat-desc" class="block text-sm font-medium mb-1">Description</label>
          <textarea id="cat-desc" rows="2" class="w-full px-3 py-2 border rounded-md text-sm" placeholder="Brief description..."></textarea>
        </div>
        <div class="flex items-center gap-2">
          <input type="checkbox" id="cat-active" checked class="rounded" />
          <label for="cat-active" class="text-sm">Active</label>
        </div>
        <!-- formFields - only for listing and product categories -->
        <div id="formfields-section" class="hidden">
          <label for="cat-formfields" class="block text-sm font-medium mb-1">Form Fields (JSON)</label>
          <textarea id="cat-formfields" rows="4" class="w-full px-3 py-2 border rounded-md text-sm font-mono" placeholder='[{"name":"price","type":"number","label":"Price","required":true}]'></textarea>
          <p class="text-xs text-muted-foreground mt-1">Define custom form fields for this category. Format: JSON array of field definitions.</p>
        </div>
        <div class="flex gap-2 justify-end pt-2">
          <Button type="button" id="cancel-btn" variant="outline" class="text-xs py-1 h-8">Cancel</Button>
          <Button type="submit" id="submit-btn" class="text-xs py-1 h-8">Create</Button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  import { actions } from 'astro:actions';
  import { badges } from '@/lib/badges';
  import { injectModal, createDeleteDialog, showModal, hideModal } from '@/lib/modal';

  interface Category {
    id: string;
    name: string;
    slug: string;
    entityType: string;
    parentId: string | null;
    icon: string | null;
    image: string | null;
    sortOrder: number;
    description: string | null;
    isActive: boolean;
    formFields?: string | null;
  }

  let categories: Category[] = [];
  let parentCategories: Category[] = [];
  let editingId: string | null = null;
  let catImageId: string | null = null;
  let currentTable = 'business';
  const TABLE_NAMES: Record<string, string> = {
    business: 'Business',
    non_profit: 'Non-Profit',
    public_sector: 'Public Sector',
    listing: 'Listing'
  };

  // Tab click handler
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentTable = (btn as HTMLElement).dataset.table || 'business';
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('border-primary', 'text-primary'));
      btn.classList.add('border-primary', 'text-primary');
      document.getElementById('current-table-name').textContent = TABLE_NAMES[currentTable];
      loadCategories();
    });
  });
  // Init first tab
  document.querySelector('.tab-btn[data-table="business"]')?.classList.add('border-primary', 'text-primary');

  // Image upload handler
  document.getElementById('cat-image-upload')?.addEventListener('click', () => {
    document.getElementById('cat-image-file')?.click();
  });
  document.getElementById('cat-image-file')?.addEventListener('change', async (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;

    try {
      const result = await actions.media.uploadMedia({
        file,
        category: 'category',
      });

      if (result.success && result.data?.id) {
        catImageId = result.data.id;
        (document.getElementById('cat-image-id') as HTMLInputElement).value = result.data.id;
        (document.getElementById('cat-preview-img') as HTMLImageElement).src = result.data.url;
        document.getElementById('cat-image-preview')?.classList.remove('hidden');
        document.getElementById('cat-image-upload')?.classList.add('hidden');
      }
    } catch (err) {
      console.error('Upload error:', err);
    }
    (e.target as HTMLInputElement).value = '';
  });
  document.getElementById('remove-cat-image')?.addEventListener('click', () => {
    catImageId = null;
    (document.getElementById('cat-image-id') as HTMLInputElement).value = '';
    document.getElementById('cat-image-preview')?.classList.add('hidden');
    document.getElementById('cat-image-upload')?.classList.remove('hidden');
  });

  // Load categories
  async function loadCategories() {
    try {
      const result = await actions.admin.categories.getAll();
      if (result.success && result.data) {
        // Filter by current table/entity type on client side
        const entityTypeMap: Record<string, string> = {
          business: 'business',
          non_profit: 'nonprofit',
          public_sector: 'public_sector',
          listing: 'listing',
        };
        const targetType = entityTypeMap[currentTable] || currentTable;
        categories = result.data.filter((c: Category) => c.entityType === targetType);
        parentCategories = categories.filter((c: Category) => !c.parentId);
        renderCategories();
        updateStats();
        updateParentDropdown();
      }
    } catch (err) {
      console.error('Error loading categories:', err);
      showToast('Failed to load categories', 'error');
    }
  }

  // Update stats
  function updateStats() {
    const count = categories.length;
    document.getElementById('stat-count').textContent = String(count);

    const el = document.getElementById('stat-total');
    if (el) el.textContent = String(total);
    const businessEl = document.getElementById('stat-business');
    if (businessEl) businessEl.textContent = String(businessCount);
    const nonprofitEl = document.getElementById('stat-nonprofit');
    if (nonprofitEl) nonprofitEl.textContent = String(nonprofitCount);
  }

  // Update parent dropdown - filter by entity type
  function updateParentDropdown(entityType?: string) {
    const select = document.getElementById('cat-parent') as HTMLSelectElement;
    const filterSelect = document.getElementById('parent-filter') as HTMLSelectElement;

    // Filter by entity type if specified
    const filteredParents = entityType
      ? parentCategories.filter((c: Category) => c.entityType === entityType)
      : parentCategories;

    const options = filteredParents.map((c: Category) =>
      `<option value="${c.id}">${c.icon ? getIcon(c.icon) + ' ' : ''}${c.name}</option>`
    ).join('');

    if (select) {
      select.innerHTML = '<option value="">Top-level (Industry)</option>' + options;
    }
    if (filterSelect) {
      filterSelect.innerHTML = '<option value="">All Parents</option>' + options;
    }
  }

  // Get icon without prefix (strip "emoji:" if present)
  function getIcon(icon: string | null): string {
    if (!icon) return '';
    return icon.replace(/^emoji:/, '');
  }

  // Get parent name
  function getParentName(parentId: string | null): string {
    if (!parentId) return '-';
    const parent = categories.find((c: Category) => c.id === parentId);
    return parent ? parent.name : '-';
  }

  // Render categories list
  function renderCategories() {
    const container = document.getElementById('categories-list');
    if (!container) return;

    const entityFilter = (document.getElementById('entity-filter') as HTMLSelectElement)?.value || '';
    const levelFilter = (document.getElementById('level-filter') as HTMLSelectElement)?.value || '';
    const parentFilter = (document.getElementById('parent-filter') as HTMLSelectElement)?.value || '';
    const search = (document.getElementById('search') as HTMLInputElement)?.value.toLowerCase() || '';

    const filtered = categories.filter((cat: Category) => {
      const matchesEntity = !entityFilter || cat.entityType === entityFilter;
      const matchesLevel = !levelFilter ||
        (levelFilter === 'parent' && !cat.parentId) ||
        (levelFilter === 'child' && cat.parentId);
      const matchesParent = !parentFilter || cat.parentId === parentFilter;
      const matchesSearch = !search ||
        (cat.name && cat.name.toLowerCase().includes(search)) ||
        (cat.slug && cat.slug.toLowerCase().includes(search));
      return matchesEntity && matchesLevel && matchesParent && matchesSearch;
    });

    if (filtered.length === 0) {
      container.innerHTML = '<tr><td colspan="5" class="text-center p-8 text-muted-foreground">No categories found</td></tr>';
      return;
    }

    container.innerHTML = filtered.map((cat: Category) => `
      <tr class="border-t hover:bg-muted/50">
        <td class="p-3">
          <div class="flex items-center gap-2">
            ${cat.icon ? `<span class="text-lg">${getIcon(cat.icon)}</span>` : ''}
            <div>
              <span class="font-medium">${cat.name}</span>
              <p class="text-xs text-muted-foreground">/${cat.slug}</p>
            </div>
          </div>
        </td>
        <td class="p-3 hidden md:table-cell">
          ${currentTable === 'business'
            ? '<span class="px-2 py-0.5 text-xs rounded-full bg-blue-100 text-blue-800">Business</span>'
            : currentTable === 'non_profit'
              ? '<span class="px-2 py-0.5 text-xs rounded-full bg-purple-100 text-purple-800">Non-Profit</span>'
              : currentTable === 'public_sector'
                ? '<span class="px-2 py-0.5 text-xs rounded-full bg-cyan-100 text-cyan-800">Public Sector</span>'
                : '<span class="px-2 py-0.5 text-xs rounded-full bg-amber-100 text-amber-800">Listing</span>'
          }
        </td>
        <td class="p-3 hidden lg:table-cell">
          ${cat.parentId
            ? '<span class="px-2 py-0.5 text-xs rounded-full bg-green-100 text-green-800">Sub</span>'
            : '<span class="px-2 py-0.5 text-xs rounded-full bg-blue-100 text-blue-800">Industry</span>'
          }
        </td>
        <td class="p-3 hidden lg:table-cell text-muted-foreground text-sm">
          ${getParentName(cat.parentId)}
        </td>
        <td class="p-3 text-muted-foreground text-sm">
          ${cat.sortOrder || 0}
        </td>
        <td class="p-3 text-right">
          <button onclick="editCategory('${cat.id}')" class="p-1 hover:bg-primary/10 rounded text-primary" title="Edit">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </button>
          <button onclick="deleteCategory('${cat.id}')" class="p-1 hover:bg-red-100 rounded text-red-500" title="Delete">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          </button>
        </td>
      </tr>
    `).join('');
  }

  // Auto-generate slug from name
  document.getElementById('cat-name')?.addEventListener('input', (e) => {
    const name = (e.target as HTMLInputElement).value;
    const slugInput = document.getElementById('cat-slug') as HTMLInputElement;
    if (slugInput && !slugInput.dataset.userModified) {
      slugInput.value = name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    }
  });

  document.getElementById('cat-slug')?.addEventListener('input', (e) => {
    (e.target as HTMLInputElement).dataset.userModified = 'true';
  });

  // Modal controls
  const modal = document.getElementById('category-modal');
  const addBtn = document.getElementById('add-category-btn');
  const closeBtn = document.getElementById('close-modal');
  const cancelBtn = document.getElementById('cancel-btn');
  const formTitle = document.getElementById('form-title');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  function openModal() {
    editingId = null;
    catImageId = null;
    document.getElementById('category-form')?.reset();
    (document.getElementById('cat-slug') as HTMLInputElement).dataset.userModified = '';
    (document.getElementById('cat-id') as HTMLInputElement).value = '';
    (document.getElementById('cat-sort') as HTMLInputElement).value = '0';
    (document.getElementById('cat-active') as HTMLInputElement).checked = true;
    (document.getElementById('cat-image-id') as HTMLInputElement).value = '';
    (document.getElementById('cat-formfields') as HTMLTextAreaElement).value = '';
    document.getElementById('cat-image-preview')?.classList.add('hidden');
    document.getElementById('cat-image-upload')?.classList.remove('hidden');
    updateParentDropdown();
    updateFormFieldsVisibility();
    if (formTitle) formTitle.textContent = 'Create Category';
    if (submitBtn) submitBtn.textContent = 'Create';
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
  }

  // Show/hide formFields based on entity type
  function updateFormFieldsVisibility() {
    const entityType = (document.getElementById('cat-entity-type') as HTMLSelectElement)?.value;
    const formFieldsSection = document.getElementById('formfields-section');
    if (formFieldsSection) {
      if (entityType === 'listing' || entityType === 'product') {
        formFieldsSection.classList.remove('hidden');
      } else {
        formFieldsSection.classList.add('hidden');
      }
    }
  }

  // Listen for entity type changes
  document.getElementById('cat-entity-type')?.addEventListener('change', updateFormFieldsVisibility);

  function closeModalFn() {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    editingId = null;
  }

  addBtn?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModalFn);
  cancelBtn?.addEventListener('click', closeModalFn);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModalFn();
  });

  // Edit category
  window.editCategory = function(id: string) {
    const cat = categories.find((c: Category) => c.id === id);
    if (!cat) return;

    editingId = id;
    (document.getElementById('cat-id') as HTMLInputElement).value = id;
    (document.getElementById('cat-name') as HTMLInputElement).value = cat.name || '';
    (document.getElementById('cat-slug') as HTMLInputElement).value = cat.slug || '';
    (document.getElementById('cat-entity-type') as HTMLSelectElement).value = cat.entityType || 'business';
    (document.getElementById('cat-parent') as HTMLSelectElement).value = cat.parentId || '';
    (document.getElementById('cat-icon') as HTMLInputElement).value = cat.icon || '';
    (document.getElementById('cat-sort') as HTMLInputElement).value = String(cat.sortOrder || 0);
    (document.getElementById('cat-desc') as HTMLTextAreaElement).value = cat.description || '';
    (document.getElementById('cat-active') as HTMLInputElement).checked = cat.isActive !== false;
    (document.getElementById('cat-slug') as HTMLInputElement).dataset.userModified = 'true';

    // Load existing image
    catImageId = cat.image || null;
    if (cat.image) {
      (document.getElementById('cat-image-id') as HTMLInputElement).value = cat.image;
      (document.getElementById('cat-preview-img') as HTMLImageElement).src = `/api/media/${cat.image}`;
      document.getElementById('cat-image-preview')?.classList.remove('hidden');
      document.getElementById('cat-image-upload')?.classList.add('hidden');
    } else {
      (document.getElementById('cat-image-id') as HTMLInputElement).value = '';
      document.getElementById('cat-image-preview')?.classList.add('hidden');
      document.getElementById('cat-image-upload')?.classList.remove('hidden');
    }

    // Load formFields
    (document.getElementById('cat-formfields') as HTMLTextAreaElement).value = cat.formFields || '';
    updateFormFieldsVisibility();

    if (formTitle) formTitle.textContent = 'Edit Category';
    if (submitBtn) submitBtn.textContent = 'Save Changes';
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
  };

  // Form submission
  document.getElementById('category-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const categoryData: Omit<Category, 'id'> = {
      name: (document.getElementById('cat-name') as HTMLInputElement)?.value,
      slug: (document.getElementById('cat-slug') as HTMLInputElement)?.value,
      entityType: (document.getElementById('cat-entity-type') as HTMLSelectElement)?.value as 'business' | 'nonprofit' | 'public_sector' | 'listing' | 'product',
      parentId: (document.getElementById('cat-parent') as HTMLSelectElement)?.value || null,
      icon: (document.getElementById('cat-icon') as HTMLInputElement)?.value || '',
      image: (document.getElementById('cat-image-id') as HTMLInputElement)?.value || '',
      sortOrder: parseInt((document.getElementById('cat-sort') as HTMLInputElement)?.value || '0'),
      description: (document.getElementById('cat-desc') as HTMLTextAreaElement)?.value || '',
      isActive: (document.getElementById('cat-active') as HTMLInputElement)?.checked ?? true,
      formFields: (document.getElementById('cat-entity-type') as HTMLSelectElement)?.value === 'listing' ||
                  (document.getElementById('cat-entity-type') as HTMLSelectElement)?.value === 'product'
        ? (document.getElementById('cat-formfields') as HTMLTextAreaElement)?.value || null
        : null,
    };

    if (!categoryData.name || !categoryData.slug) {
      showToast('Name and slug are required', 'error');
      return;
    }

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = editingId ? 'Saving...' : 'Creating...';
    }

    try {
      let result;
      if (editingId) {
        result = await actions.admin.categories.update({ id: editingId, ...categoryData });
      } else {
        result = await actions.admin.categories.create(categoryData);
      }

      if (result.success) {
        showToast(editingId ? 'Category updated!' : 'Category created!');
        closeModalFn();
        loadCategories();
      } else {
        showToast(result.error?.message || 'Failed to save', 'error');
      }
    } catch (err) {
      showToast('Error saving category', 'error');
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = editingId ? 'Save Changes' : 'Create';
      }
    }
  });

  // Initialize delete confirmation modal
  const deleteModalHtml = createDeleteDialog({ id: 'delete-category-dialog', itemName: '' });
  const deleteModal = injectModal(deleteModalHtml);
  let deleteTargetId: string | null = null;

  (deleteModal.querySelector('[data-confirm-btn]') as HTMLButtonElement)?.addEventListener('click', async () => {
    if (!deleteTargetId) return;
    try {
      const result = await actions.admin.categories.delete({ id: deleteTargetId });
      if (result.success) {
        showToast('Category deleted');
        loadCategories();
      } else {
        showToast(result.error?.message || 'Failed to delete', 'error');
      }
    } catch {
      showToast('Error deleting category', 'error');
    }
  });

  // Delete category
  window.deleteCategory = function(id: string) {
    deleteTargetId = id;
    const cat = categories.find((c: Category) => c.id === id);
    const modal = document.getElementById('delete-category-dialog');
    if (modal) {
      const msgEl = modal.querySelector('.modal-body p');
      if (msgEl) msgEl.textContent = `Are you sure you want to delete "${cat?.name || 'this category'}"? This action cannot be undone.`;
    }
    showModal('delete-category-dialog');
  };

  // Filter listeners
  document.getElementById('level-filter')?.addEventListener('change', renderCategories);
  document.getElementById('parent-filter')?.addEventListener('change', renderCategories);
  document.getElementById('search')?.addEventListener('input', renderCategories);

  // Entity type change - update parent dropdown to show only matching parents
  document.getElementById('entity-filter')?.addEventListener('change', (e) => {
    const entityType = (e.target as HTMLSelectElement).value;
    // Reset parent filter when entity type changes - prevents stale selections
    const parentFilterSelect = document.getElementById('parent-filter') as HTMLSelectElement;
    if (parentFilterSelect) parentFilterSelect.value = '';
    updateParentDropdown(entityType);
    renderCategories(); // Re-render to apply entity type filter
  });

  // Initialize
  loadCategories();
</script>