---
// Organizations listing page - simplified for gov/NGOs/nonprofits
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import CardContent from '../../components/ui/CardContent.astro';
---

<Layout
  title="Organizations - TMBIZ"
  description="Government agencies, NGOs, and nonprofits in Timor-Leste"
>
  <div class="container py-8">
    <!-- Header -->
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold mb-2">Organizations in Timor-Leste</h1>
      <p class="text-muted-foreground">Government agencies, NGOs, nonprofits, and foundations</p>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-4 mb-8 justify-center">
      <select id="type-filter" class="px-4 py-2 border rounded-lg bg-background">
        <option value="">All Types</option>
        <option value="government">Government</option>
        <option value="ngo">NGO</option>
        <option value="nonprofit">Non-Profit</option>
        <option value="foundation">Foundation</option>
      </select>

      <select id="category-filter" class="px-4 py-2 border rounded-lg bg-background">
        <option value="">All Sectors</option>
      </select>

      <input
        type="search"
        id="search-input"
        placeholder="Search organizations..."
        class="px-4 py-2 border rounded-lg bg-background flex-1 max-w-md"
      />
    </div>

    <!-- Loading -->
    <div id="loading" class="text-center py-12">
      <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
    </div>

    <!-- Results -->
    <div id="results" class="hidden">
      <p id="results-count" class="text-muted-foreground mb-4"></p>
      <div id="orgs-grid" class="grid sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Organizations will be loaded here -->
      </div>
    </div>

    <!-- Empty State -->
    <div id="empty" class="hidden text-center py-12">
      <p class="text-muted-foreground mb-4">No organizations found.</p>
      <a href="/register?type=organization">
        <Button>Register Your Organization</Button>
      </a>
    </div>

    <!-- CTA Card -->
    <Card class="mt-12 bg-primary/10 border-primary/20">
      <CardContent class="p-8 text-center">
        <h2 class="text-2xl font-bold mb-2">Is your organization missing?</h2>
        <p class="text-muted-foreground mb-6">Register your government agency, NGO, or nonprofit to be listed on TMBIZ.</p>
        <div class="flex gap-4 justify-center">
          <a href="/register?type=organization">
            <Button size="lg">Register Organization</Button>
          </a>
          <a href="/businesses">
            <Button size="lg" variant="outline">Browse Businesses</Button>
          </a>
        </div>
      </CardContent>
    </Card>
  </div>
</Layout>

<script>
  let currentFilter = '';
  let currentCategory = '';
  let currentSearch = '';

  async function loadCategories() {
    try {
      const res = await fetch('/api/categories');
      const data = await res.json();
      if (data.success) {
        const select = document.getElementById('category-filter') as HTMLSelectElement;
        data.data.forEach((cat: any) => {
          const option = document.createElement('option');
          option.value = cat.slug;
          option.textContent = cat.name;
          select.appendChild(option);
        });
      }
    } catch (err) {
      console.error('Error loading categories:', err);
    }
  }

  async function loadOrganizations() {
    const grid = document.getElementById('orgs-grid');
    const loading = document.getElementById('loading');
    const results = document.getElementById('results');
    const empty = document.getElementById('empty');
    const count = document.getElementById('results-count');

    if (!grid || !loading || !results || !empty || !count) return;

    loading.classList.remove('hidden');
    results.classList.add('hidden');
    empty.classList.add('hidden');

    try {
      const params = new URLSearchParams();
      params.set('type', 'organization');
      if (currentFilter) params.set('organizationType', currentFilter);
      if (currentCategory) params.set('category', currentCategory);
      if (currentSearch) params.set('search', currentSearch);

      const res = await fetch(`/api/businesses?${params}`);
      const data = await res.json();

      loading.classList.add('hidden');

      if (!data.success || data.data.length === 0) {
        empty.classList.remove('hidden');
        return;
      }

      grid.innerHTML = '';
      data.data.forEach((org: any) => {
        const typeLabels: Record<string, string> = {
          government: 'Government',
          ngo: 'NGO',
          nonprofit: 'Non-Profit',
          foundation: 'Foundation',
        };

        const profileImg = org.profileImageId
          ? `/api/media/${org.profileImageId}`
          : `https://ui-avatars.com/api/?name=${encodeURIComponent(org.title)}&background=2563EB&color=fff`;

        const card = document.createElement('a');
        card.href = `/org/${org.slug}`;
        card.className = 'block';

        card.innerHTML = `
          <div class="card h-full border rounded-lg overflow-hidden hover:shadow-lg transition-shadow bg-card">
            <div class="aspect-video bg-gradient-to-br from-blue-100 to-blue-200 dark:from-blue-900/30 dark:to-blue-800/30">
              ${org.bannerImageId
                ? `<img src="/api/media/${org.bannerImageId}" class="w-full h-full object-cover" />`
                : `<div class="w-full h-full flex items-center justify-center text-4xl font-bold text-blue-600">${org.title.charAt(0)}</div>`
              }
            </div>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-2">
                <img src="${profileImg}" class="w-12 h-12 rounded-full object-cover" alt="" />
                <div>
                  <h3 class="font-semibold line-clamp-1">${org.title}</h3>
                  <span class="text-xs px-2 py-0.5 rounded-full bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400">
                    ${typeLabels[org.organizationType] || org.organizationType || 'Organization'}
                  </span>
                  ${org.verifiedBadge ? '<span class="text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-800">✓ Verified</span>' : ''}
                </div>
              </div>
              <p class="text-sm text-muted-foreground line-clamp-2">${org.aboutUs || org.categoryName || ''}</p>
              <div class="mt-3 flex flex-wrap gap-2 text-xs text-muted-foreground">
                ${org.contactNumber ? `<span>📞 ${org.countryCode || '+670'} ${org.contactNumber}</span>` : ''}
                ${org.address ? `<span>📍 ${org.address.split(',')[0]}</span>` : ''}
              </div>
            </div>
          </div>
        `;

        grid.appendChild(card);
      });

      count.textContent = `${data.data.length} organization${data.data.length !== 1 ? 's' : ''} found`;
      results.classList.remove('hidden');

    } catch (err) {
      console.error('Error loading organizations:', err);
      loading.classList.add('hidden');
      empty.classList.remove('hidden');
    }
  }

  // Event listeners
  document.getElementById('type-filter')?.addEventListener('change', (e) => {
    currentFilter = (e.target as HTMLSelectElement).value;
    loadOrganizations();
  });

  document.getElementById('category-filter')?.addEventListener('change', (e) => {
    currentCategory = (e.target as HTMLSelectElement).value;
    loadOrganizations();
  });

  let searchTimeout: number;
  document.getElementById('search-input')?.addEventListener('input', (e) => {
    clearTimeout(searchTimeout);
    searchTimeout = window.setTimeout(() => {
      currentSearch = (e.target as HTMLInputElement).value;
      loadOrganizations();
    }, 300);
  });

  // Init
  loadCategories();
  loadOrganizations();
</script>
