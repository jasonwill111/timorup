---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About TimorUp - Your All-in-One Information Platform in Timor-Leste"
  description="TimorUp is Timor-Leste's all-in-one information platform. Find businesses, explore organizations, buy & sell, and discover services — all in one place."
>
  <div class="container py-12 max-w-4xl">
    <!-- Hero Section -->
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        TimorUp
      </h1>
      <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
        Your All-in-One Information Platform in Timor-Leste
      </p>
      <p class="text-lg text-muted-foreground mt-4 max-w-xl mx-auto">
        Buy & sell • Find businesses • Discover services • Explore organizations
      </p>
    </div>

    <!-- About -->
    <div class="bg-card border rounded-2xl p-8 mb-8">
      <h2 class="text-2xl font-bold mb-4">What is TimorUp</h2>
      <p class="text-muted-foreground leading-relaxed mb-4">
        TimorUp is Timor-Leste's all-in-one information platform. Whether you're looking for a restaurant, need to sell your car, want to discover local NGOs, or need government contact information — it's all here.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mt-8">
        <div>
          <h3 class="font-semibold mb-2">Buy & Sell</h3>
          <p class="text-sm text-muted-foreground">Post classified ads for jobs, vehicles, property, electronics, and more. Free for the first 7 days.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-2">Find Businesses</h3>
          <p class="text-sm text-muted-foreground">Discover restaurants, hotels, shops, salons, mechanics, and local services with reviews and photos.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-2">Discover Services</h3>
          <p class="text-sm text-muted-foreground">Browse products from local sellers, compare prices, and contact sellers directly.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-2">Explore Organizations</h3>
          <p class="text-sm text-muted-foreground">Find NGOs, charitable organizations, volunteer opportunities, and community initiatives.</p>
        </div>
      </div>
    </div>

    <!-- Government Services -->
    <div class="bg-card border rounded-2xl p-8 mb-8">
      <h2 class="text-2xl font-bold mb-4">Government Services</h2>
      <p class="text-muted-foreground leading-relaxed mb-4">
        Access government contacts and public services. Find ministries, agencies, and public offices all in one place.
      </p>
    </div>

    <!-- Mission & Vision -->
    <div class="grid md:grid-cols-2 gap-6 mb-12">
      <div class="bg-card border rounded-2xl p-8">
        <h2 class="text-2xl font-bold mb-4">Our Mission</h2>
        <p class="text-muted-foreground leading-relaxed">
          Connecting Timor-Leste through information — one platform for everything local.
        </p>
      </div>
      <div class="bg-card border rounded-2xl p-8">
        <h2 class="text-2xl font-bold mb-4">Our Vision</h2>
        <p class="text-muted-foreground leading-relaxed">
          To be the essential guide for living, working, and doing business in Timor-Leste.
        </p>
      </div>
    </div>

    <!-- Stats will be added when data is available -->
    <!--
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      <div class="bg-card border rounded-xl p-6 text-center">
        <div class="text-3xl font-bold text-primary mb-2">500+</div>
        <div class="text-sm text-muted-foreground">Local Businesses</div>
      </div>
      <div class="bg-card border rounded-xl p-6 text-center">
        <div class="text-3xl font-bold text-primary mb-2">1,200+</div>
        <div class="text-sm text-muted-foreground">Classified Listings</div>
      </div>
      <div class="bg-card border rounded-xl p-6 text-center">
        <div class="text-3xl font-bold text-primary mb-2">100+</div>
        <div class="text-sm text-muted-foreground">Organizations</div>
      </div>
      <div class="bg-card border rounded-xl p-6 text-center">
        <div class="text-3xl font-bold text-primary mb-2">10K+</div>
        <div class="text-sm text-muted-foreground">Monthly Visitors</div>
      </div>
    </div>
    -->

    <!-- CTA -->
    <div class="bg-gradient-to-r from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-bold mb-4">Get Started Today</h2>
      <p class="text-muted-foreground mb-6 max-w-lg mx-auto">
        Whether you run a business, sell products, or represent an organization — TimorUp connects you with Timor-Leste.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/listings/create" class="inline-flex items-center justify-center px-6 py-3 bg-primary text-primary-foreground font-semibold rounded-lg hover:opacity-90 transition-opacity">
          Post Free Listing
        </a>
        <a href="/businesses" class="inline-flex items-center justify-center px-6 py-3 border border-input bg-background font-semibold rounded-lg hover:bg-muted transition-colors">
          Explore Now
        </a>
      </div>
    </div>

    <!-- Contact -->
    <div class="mt-12 text-center">
      <h3 class="font-bold mb-2">Get in Touch</h3>
      <p class="text-sm text-muted-foreground">
        Questions or suggestions? We'd love to hear from you.
      </p>
      <p class="text-sm mt-2">
        <a href="mailto:hello@timorup.com" class="text-primary hover:underline">hello@timorup.com</a>
      </p>
    </div>
  </div>
</Layout>
