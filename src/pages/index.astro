---
// Static page with Server Island for dynamic content
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import HomepageContent from '../components/islands/HomepageContent.astro';
---

<Layout title="TimorList - Business Directory for Timor-Leste">
  <!-- Hero - shorter on mobile -->
  <div class="relative h-[240px] sm:h-[300px] md:h-[400px] lg:h-[500px] bg-gradient-to-br from-amber-400 via-orange-400 to-amber-500 overflow-hidden">
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-4 sm:top-10 left-4 sm:left-10 w-16 sm:w-32 h-16 sm:h-32 bg-white/20 rounded-full blur-2xl"></div>
      <div class="absolute bottom-4 sm:bottom-10 right-4 sm:right-10 w-24 sm:w-48 h-24 sm:h-48 bg-white/20 rounded-full blur-3xl"></div>
    </div>
    <div class="relative z-10 h-full flex items-center justify-center">
      <div class="text-center text-white max-w-3xl px-4">
        <h1 class="text-3xl sm:text-4xl md:text-6xl font-bold mb-2 sm:mb-4 drop-shadow-lg">TimorList</h1>
        <p class="text-sm sm:text-lg md:text-xl mb-4 sm:mb-6 opacity-90">Discover Local Businesses in Timor-Leste</p>
        <div class="flex gap-3 sm:gap-4 justify-center flex-wrap">
          <a href="/listings">
            <Button size="lg" variant="default" class="bg-white text-amber-600 hover:bg-amber-50 font-semibold shadow-lg">Browse Directory</Button>
          </a>
          <a href="/listings/create">
            <Button size="lg" variant="ghost" class="text-white border-2 border-white/60 hover:bg-white/10 hover:border-white font-semibold">List Your Business</Button>
          </a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-10 sm:h-16">
        <path d="M0 120L60 110C120 100 240 80 360 70C480 60 600 60 720 65C840 70 960 80 1080 85C1200 90 1320 90 1380 90L1440 90V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
      </svg>
    </div>
  </div>

  <div class="container py-6 sm:py-12">
    <!-- Server Island: Dynamic content with skeleton fallback -->
    <HomepageContent server:defer>
      <div class="space-y-8">
        <!-- Featured Businesses Skeleton -->
        <section class="mb-6 sm:mb-12">
          <div class="flex items-center justify-between mb-4 sm:mb-6">
            <div class="h-6 sm:h-8 w-40 bg-muted rounded animate-pulse"></div>
            <div class="h-4 w-16 bg-muted rounded animate-pulse"></div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2 sm:gap-4">
            {[...Array(8)].map(() => (
              <div class="bg-card rounded-lg border p-3">
                <div class="aspect-square bg-muted rounded mb-3 animate-pulse"></div>
                <div class="h-4 bg-muted rounded w-3/4 mb-2 animate-pulse"></div>
                <div class="h-3 bg-muted rounded w-1/2 animate-pulse"></div>
              </div>
            ))}
          </div>
        </section>
        <!-- Featured Products Skeleton -->
        <section class="mb-6 sm:mb-12">
          <div class="flex items-center justify-between mb-4 sm:mb-6">
            <div class="h-6 sm:h-8 w-48 bg-muted rounded animate-pulse"></div>
            <div class="h-4 w-16 bg-muted rounded animate-pulse"></div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2 sm:gap-4">
            {[...Array(8)].map(() => (
              <div class="bg-card rounded-lg border p-3">
                <div class="aspect-square bg-muted rounded mb-3 animate-pulse"></div>
                <div class="h-4 bg-muted rounded w-3/4 mb-2 animate-pulse"></div>
                <div class="h-3 bg-muted rounded w-1/3 animate-pulse"></div>
              </div>
            ))}
          </div>
        </section>
      </div>
    </HomepageContent>

    <!-- CTA -->
    <section class="text-center py-12 bg-gradient-to-r from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 rounded-2xl">
      <h2 class="text-2xl font-bold mb-4">Ready to Grow Your Business?</h2>
      <p class="text-muted-foreground mb-6 max-w-xl mx-auto">Join thousands of businesses in Timor-Leste and reach more customers today.</p>
      <a href="/listings/create">
        <Button size="lg" class="bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-600 hover:to-orange-600">Create Your Business Page</Button>
      </a>
    </section>
  </div>
</Layout>
