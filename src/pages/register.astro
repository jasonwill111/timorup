---

import Layout from '../layouts/Layout.astro';
import Input from '../components/ui/Input.astro';
import AuthCard from '../components/forms/AuthCard.astro';
import FormMessage from '../components/forms/FormMessage.astro';
import LoadingButton from '../components/forms/LoadingButton.astro';
import PasswordInput from '../components/forms/PasswordInput.astro';
---

<Layout title="Register - TimorUp">
  <AuthCard
    title="Create an Account"
    description="Join TimorUp to promote your business"
    footerText="Already have an account?"
    footerLink={{ href: '/login', text: 'Sign in' }}
  >
    <form id="register-form" action="/api/auth/sign-up" class="space-y-4">
      <FormMessage id="form-message" type="error" />

      <div>
        <label for="name" class="block text-sm font-medium mb-1">Full Name</label>
        <Input
          id="name"
          name="name"
          type="text"
          placeholder="John Doe"
          required
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium mb-1">Email</label>
        <Input
          id="email"
          name="email"
          type="email"
          placeholder="your@email.com"
          required
        />
      </div>

      <div>
        <label for="phone" class="block text-sm font-medium mb-1">Phone (optional)</label>
        <Input
          id="phone"
          name="phone"
          type="tel"
          placeholder="+670 1234567"
        />
      </div>

      <PasswordInput
        id="password"
        name="password"
        label="Password (min 8 characters)"
        placeholder="‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚Ä?
      />

      <PasswordInput
        id="confirmPassword"
        name="confirmPassword"
        label="Confirm Password"
        placeholder="‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚Ä?
      />

      <LoadingButton id="submit-btn" defaultText="Create Account" loadingText="Creating account..." />

      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t"></div>
        </div>
        <div class="relative flex justify-center text-xs uppercase">
          <span class="bg-card px-2 text-muted-foreground">Or continue with</span>
        </div>
      </div>

      <div class="space-y-2">
        <a href="/api/auth/sign-in/google" class="w-full">
          <button type="button" class="w-full inline-flex items-center justify-center px-4 py-2 rounded-lg font-medium transition-colors border border-input bg-background hover:bg-accent">
            <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24">
              <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Continue with Google
          </button>
        </a>
        <a href="/api/auth/sign-in/facebook" class="w-full">
          <button type="button" class="w-full inline-flex items-center justify-center px-4 py-2 rounded-lg font-medium transition-colors border border-input bg-background hover:bg-accent">
            <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Continue with Facebook
          </button>
        </a>
      </div>
    </form>
  </AuthCard>
</Layout>

<script>
  const form = document.getElementById('register-form');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const btnText = document.getElementById('submit-btn-text');
  const btnLoading = document.getElementById('submit-btn-loading');
  const message = document.getElementById('form-message') as HTMLElement;

  function setLoading(loading: boolean) {
    if (submitBtn) submitBtn.disabled = loading;
    btnText?.classList.toggle('hidden', loading);
    btnLoading?.classList.toggle('hidden', !loading);
  }

  function showError(msg: string) {
    if (message) {
      message.textContent = msg;
      message.className = message.className
        .replace(/bg-green-\d+/g, 'bg-red-50')
        .replace(/text-green-\d+/g, 'text-red-700')
        .replace(/dark:bg-green-\d+/g, 'dark:bg-red-900/20')
        .replace(/dark:text-green-\d+/g, 'dark:text-red-400');
      message.classList.remove('hidden');
    }
  }

  function showSuccess(msg: string) {
    if (message) {
      message.textContent = msg;
      message.className = message.className
        .replace(/bg-red-\d+/g, 'bg-green-50')
        .replace(/text-red-\d+/g, 'text-green-700')
        .replace(/dark:bg-red-\d+/g, 'dark:bg-green-900/20')
        .replace(/dark:text-red-\d+/g, 'dark:text-green-400');
      message.classList.remove('hidden');
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const password = (document.getElementById('password') as HTMLInputElement)?.value;
    const confirm = (document.getElementById('confirmPassword') as HTMLInputElement)?.value;

    if (password !== confirm) {
      showError('Passwords do not match');
      return;
    }

    if (password.length < 8) {
      showError('Password must be at least 8 characters');
      return;
    }

    message?.classList.add('hidden');
    setLoading(true);

    const formData = new FormData(form);

    try {
      const response = await fetch('/api/auth/sign-up', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: formData.get('email'),
          password: formData.get('password'),
          name: formData.get('name')
        }),
        credentials: 'include'
      });

      const res = await response.json();
      setLoading(false);

      if (res.success) {
        showSuccess('Account created successfully! Redirecting...');
        setTimeout(() => {
          window.location.href = '/account';
        }, 1500);
      } else {
        showError(res.error?.message || 'Registration failed');
      }
    } catch {
      setLoading(false);
      showError('Network error. Please try again.');
    }
  });
</script>

