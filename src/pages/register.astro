---
import Layout from '../layouts/Layout.astro';
import Input from '../components/ui/Input.astro';
import AuthCard from '../components/forms/AuthCard.astro';
import FormMessage from '../components/forms/FormMessage.astro';
import LoadingButton from '../components/forms/LoadingButton.astro';
import PasswordInput from '../components/forms/PasswordInput.astro';
---

<Layout title="Register - TimorUp">
  <AuthCard
    title="Create an Account"
    description="Join TimorUp to promote your business"
    footerText="Already have an account"
    footerLink={{ href: '/login', text: 'Sign in' }}
  >
    <form id="register-form" class="space-y-4">
      <FormMessage id="form-message" type="error" />
      <div>
        <label for="name" class="block text-sm font-medium mb-1">Full Name</label>
        <Input id="name" name="name" type="text" placeholder="John Doe" required />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium mb-1">Email</label>
        <Input id="email" name="email" type="email" placeholder="your@email.com" required />
      </div>
      <PasswordInput id="password" name="password" label="Password" placeholder="••••••••" />
      <PasswordInput id="confirmPassword" name="confirmPassword" label="Confirm Password" placeholder="••••••••" />
      <LoadingButton id="submit-btn" defaultText="Create Account" loadingText="Creating..." />
    </form>
  </AuthCard>
</Layout>

<script>
  const form = document.getElementById('register-form');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    alert('test');
  });
</script>
