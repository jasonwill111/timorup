---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>500 - Server Error | TimorList</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #FDFBF7 0%, #F5F5F4 100%);
      }
      .container {
        text-align: center;
        padding: 2rem;
      }
      .code {
        font-size: 8rem;
        font-weight: 700;
        color: #FFD150;
        line-height: 1;
        text-shadow: 3px 3px 0 #E5B800;
      }
      h1 {
        font-size: 1.5rem;
        color: #18181b;
        margin: 1rem 0;
      }
      p {
        color: #71717a;
        line-height: 1.6;
        max-width: 400px;
        margin: 0 auto 2rem;
      }
      .btn {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
      }
      .btn-primary {
        background: #FFD150;
        color: #18181b;
      }
      .btn-primary:hover { background: #E5B800; }
      .btn-secondary {
        background: #fff;
        color: #18181b;
        border: 1px solid #E4E4E7;
        margin-left: 0.5rem;
      }
      .btn-secondary:hover { background: #F4F4F5; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="code">500</div>
      <h1>Something went wrong</h1>
      <p>We're sorry, but something unexpected happened on our server. Our team has been notified.</p>
      <div>
        <a href="/" class="btn btn-primary">Go Home</a>
        <button onclick="history.back()" class="btn btn-secondary">Go Back</button>
      </div>
    </div>
  </body>
</html>
