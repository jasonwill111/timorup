---
import Layout from '../layouts/Layout.astro';
import Input from '../components/ui/Input.astro';
import Button from '../components/ui/Button.astro';
import AuthCard from '../components/forms/AuthCard.astro';
import FormMessage from '../components/forms/FormMessage.astro';
import PasswordInput from '../components/forms/PasswordInput.astro';
---

<Layout title="Login - TimorUp">
  <AuthCard
    title="Welcome Back"
    description="Sign in to your account to continue"
    footerText="Don't have an account?"
    footerLink={{ href: '/register', text: 'Sign up' }}
  >
    <form id="login-form" class="space-y-4" novalidate>
      <FormMessage id="form-message" type="error" />

      <div>
        <label for="email" class="block text-sm font-medium mb-1">Email</label>
        <div class="relative">
          <Input
            id="email"
            name="email"
            type="email"
            placeholder="your@email.com"
            required
          />
          <span id="email-valid" class="hidden absolute right-3 top-1/2 -translate-y-1/2 text-green-500">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </span>
        </div>
        <p id="email-error" class="hidden text-sm text-red-500 mt-1">Please enter a valid email</p>
      </div>

      <div>
        <label for="password" class="block text-sm font-medium mb-1">Password</label>
        <div class="relative">
          <PasswordInput
            id="password"
            name="password"
            label=""
            placeholder="••••••••"
          />
          <span id="password-valid" class="hidden absolute right-3 top-1/2 -translate-y-1/2 text-green-500">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </span>
        </div>
        <p id="password-error" class="hidden text-sm text-red-500 mt-1">Password must be at least 8 characters</p>
      </div>

      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <input
            id="remember-me"
            name="rememberMe"
            type="checkbox"
            class="h-4 w-4 rounded border-gray-300"
          />
          <label for="remember-me" class="ml-2 text-sm text-muted-foreground">
            Remember me
          </label>
        </div>
        <a href="/forgot-password" class="text-sm text-muted-foreground hover:underline">
          Forgot password?
        </a>
      </div>

      <Button id="submit-btn" type="submit" class="w-full" size="lg">
        <span id="btn-text">Sign In</span>
        <span id="btn-spinner" class="hidden animate-spin ml-1">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </span>
      </Button>

      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t"></div>
        </div>
        <div class="relative flex justify-center text-xs uppercase">
          <span class="bg-card px-2 text-muted-foreground">Or continue with</span>
        </div>
      </div>

      <div class="space-y-2">
        <a href="/api/auth/sign-in/google" class="w-full">
          <button type="button" class="w-full inline-flex items-center justify-center px-4 py-2 rounded-lg font-medium transition-colors border border-input bg-background hover:bg-accent">
            <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24">
              <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Continue with Google
          </button>
        </a>
        <a href="/api/auth/sign-in/facebook" class="w-full">
          <button type="button" class="w-full inline-flex items-center justify-center px-4 py-2 rounded-lg font-medium transition-colors border border-input bg-background hover:bg-accent">
            <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Continue with Facebook
          </button>
        </a>
      </div>
    </form>
  </AuthCard>
</Layout>

<script>
  import { actions } from 'astro:actions';

  const form = document.getElementById('login-form') as HTMLFormElement | null;
  const emailInput = document.getElementById('email') as HTMLInputElement | null;
  const passwordInput = document.getElementById('password') as HTMLInputElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const btnText = document.getElementById('btn-text');
  const btnSpinner = document.getElementById('btn-spinner');
  const message = document.getElementById('form-message') as HTMLElement;
  const emailError = document.getElementById('email-error');
  const passwordError = document.getElementById('password-error');
  const emailValid = document.getElementById('email-valid');
  const passwordValid = document.getElementById('password-valid');

  function isValidEmail(email: string): boolean {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  function setEmailError(show: boolean, inputError: boolean = false) {
    emailError?.classList.toggle('hidden', !show);
    emailValid?.classList.toggle('hidden', !inputError);
    if (emailInput) {
      emailInput.classList.toggle('border-red-500', show);
      emailInput.classList.toggle('focus-visible:ring-red-500', show);
      emailInput.setAttribute('aria-invalid', show ? 'true' : 'false');
    }
  }

  function setPasswordError(show: boolean, inputError: boolean = false) {
    passwordError?.classList.toggle('hidden', !show);
    passwordValid?.classList.toggle('hidden', !inputError);
    if (passwordInput) {
      const pwField = passwordInput.closest('.relative')?.querySelector('input');
      pwField?.classList.toggle('border-red-500', show);
    }
  }

  function setLoading(loading: boolean) {
    if (submitBtn) {
      submitBtn.disabled = loading;
      btnText?.classList.toggle('hidden', loading);
      btnSpinner?.classList.toggle('hidden', !loading);
    }
  }

  emailInput?.addEventListener('blur', () => {
    const email = emailInput.value.trim();
    if (email && !isValidEmail(email)) {
      setEmailError(true, false);
    } else if (email && isValidEmail(email)) {
      setEmailError(false, true);
    } else {
      setEmailError(false, false);
    }
  });

  emailInput?.addEventListener('input', () => {
    if (emailInput.value && isValidEmail(emailInput.value.trim())) {
      setEmailError(false, true);
    }
  });

  passwordInput?.addEventListener('blur', () => {
    const password = passwordInput.value;
    if (password && password.length < 8) {
      setPasswordError(true, false);
    } else if (password && password.length >= 8) {
      setPasswordError(false, true);
    } else {
      setPasswordError(false, false);
    }
  });

  passwordInput?.addEventListener('input', () => {
    if (passwordInput.value && passwordInput.value.length >= 8) {
      setPasswordError(false, true);
    }
  });

  function showError(msg: string) {
    if (message) {
      message.textContent = msg;
      message.className = message.className
        .replace(/bg-green-\d+/g, 'bg-red-50')
        .replace(/text-green-\d+/g, 'text-red-700')
        .replace(/dark:bg-green-\d+/g, 'dark:bg-red-900/20')
        .replace(/dark:text-green-\d+/g, 'dark:text-red-400');
      message.classList.remove('hidden');
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    message?.classList.add('hidden');

    const email = emailInput?.value.trim() || '';
    const password = passwordInput?.value || '';

    let hasError = false;

    if (!email || !isValidEmail(email)) {
      setEmailError(true, false);
      hasError = true;
    }

    if (!password || password.length < 8) {
      setPasswordError(true, false);
      hasError = true;
    }

    if (hasError) return;

    setLoading(true);

    // Get rememberMe value from checkbox
    const rememberMeCheckbox = document.getElementById('remember-me') as HTMLInputElement;
    const rememberMe = rememberMeCheckbox?.checked || false;

    // Use lightAuth.signIn for Free Plan compatibility
    const { data, error } = await actions.auth.lightSignIn({
      email: email,
      password: password,
      rememberMe: rememberMe,
    });

    setLoading(false);

    if (error || !data?.success) {
      const msg = error?.message || data?.error?.message || 'Invalid email or password';
      showError(msg);
      return;
    }

    // Set session cookie (match the name used by auth verification)
    if (data?.token) {
      const cookieExpiry = rememberMe ? 7 * 24 * 60 * 60 : undefined;
      document.cookie = `better-auth.session_token=${data.token}; path=/; max-age=${cookieExpiry || ''}; SameSite=Lax`;
      window.location.assign('/account');
    }
  });
</script>

