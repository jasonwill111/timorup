---
import '../styles/globals.css';
import { Toaster } from 'sonner';

interface Props {
  title: string;
}

const { title } = Astro.props;
const fullTitle = title.includes('Admin') ? title : `${title} - Admin`;
---

<!DOCTYPE html>
<html lang="en">
