<style>
  @reference "../styles/globals.css";
  .nav-item {
    @apply flex items-center gap-2 px-2 py-2 min-h-9 rounded-lg text-sm text-muted-foreground transition-colors;
  }
  .nav-item:hover {
    @apply bg-muted text-foreground;
  }
  .nav-item.active {
    @apply bg-primary text-primary-foreground;
  }
  .nav-item.active:hover {
    @apply opacity-90;
  }
</style>

<script is:inline>
  (function() {
    // Initialize theme before page renders to prevent flash
    const theme = localStorage.getItem('theme') ||
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    document.documentElement.classList.toggle('dark', theme === 'dark');

    // Theme toggle functions
    function toggleTheme() {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    }

    // Attach to all theme toggles
    document.getElementById('admin-theme-toggle-desktop')?.addEventListener('click', toggleTheme);
    document.getElementById('admin-theme-toggle-mobile')?.addEventListener('click', toggleTheme);

    // Logout - use Better Auth signOut
    async function handleLogout() {
      if (confirm('Are you sure you want to log out?')) {
        try {
          await actions.auth.signOut();
        } catch (e) {
          console.error('Logout error:', e);
        }
        window.location.href = '/admin/login';
      }
    }
    document.getElementById('admin-logout-btn-desktop')?.addEventListener('click', handleLogout);
    document.getElementById('admin-logout-btn-mobile')?.addEventListener('click', handleLogout);

    // Mobile menu
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileMenuPanel = document.getElementById('mobile-menu-panel');
    const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');

    function openMobileMenu() {
      if (!mobileMenu || !mobileMenuPanel || !mobileMenuBackdrop) return;
      mobileMenu.classList.remove('hidden');
      mobileMenuPanel.offsetHeight;
      mobileMenuPanel.classList.remove('-translate-x-full');
      mobileMenuBackdrop.classList.remove('opacity-0');
    }

    function closeMobileMenu() {
      if (!mobileMenu || !mobileMenuPanel || !mobileMenuBackdrop) return;
      mobileMenuPanel.classList.add('-translate-x-full');
      mobileMenuBackdrop.classList.add('opacity-0');
      setTimeout(() => mobileMenu.classList.add('hidden'), 200);
    }

    mobileMenuBtn?.addEventListener('click', openMobileMenu);
    mobileMenuBackdrop?.addEventListener('click', closeMobileMenu);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu?.classList.contains('hidden')) closeMobileMenu();
    });

    // Highlight active nav item based on current path
    const path = window.location.pathname;
    document.querySelectorAll('.nav-item[data-section]').forEach(item => {
      const section = item.dataset.section;
      let isActive = false;
      if (section === 'dashboard' && path === '/admin') isActive = true;
      if (section !== 'dashboard' && section !== 'site' && path.includes(`/admin/${section}`)) isActive = true;
      if (section === 'site' && path === '/') isActive = true;
      item.classList.toggle('active', isActive);
    });
  })();
</script>
