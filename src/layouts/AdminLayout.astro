---
import '../styles/globals.css';
import ToastContainer from '../components/ui/ToastContainer.astro';
import { actions } from 'astro:actions';

interface Props {
  title: string;
}

const { title } = Astro.props;
const fullTitle = title.includes('Admin') ? title : `${title} - Admin`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Robots - admin pages should not be indexed -->
    <meta name="robots" content="noindex, nofollow" />
    <!-- Theme initialization - prevents flash of wrong theme -->
    <script is:inline>
      const theme = localStorage.getItem('theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
  </head>
  <body class="min-h-screen bg-background">
    <!-- Toast Container -->
    <ToastContainer />
    <!-- Mobile Header -->
    <header class="md:hidden fixed top-0 left-0 right-0 h-14 bg-card border-b z-50 flex items-center px-3 gap-2">
      <button id="mobile-menu-btn" class="p-2 -ml-2 hover:bg-muted rounded-lg flex-shrink-0">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
      <!-- Center: Logo + Timorlist -->
      <div class="flex-1 flex items-center justify-center gap-2 min-w-0">
        <div class="w-7 h-7 bg-brand-500 rounded-lg flex items-center justify-center flex-shrink-0">
          <span class="text-white font-bold text-sm">T</span>
        </div>
        <span class="font-bold text-sm truncate">Timorlist</span>
      </div>
      <!-- Right: Theme Toggle Only -->
      <div class="flex items-center gap-1 flex-shrink-0">
        <button id="admin-theme-toggle-mobile" class="p-2 hover:bg-muted rounded-lg">
          <svg class="w-5 h-5 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
          <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
        </button>
      </div>
    </header>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="md:hidden fixed inset-0 z-40 hidden">
      <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-200"></div>
      <div id="mobile-menu-panel" class="absolute left-0 top-0 h-full w-56 bg-card border-r pt-14 -translate-x-full transition-transform duration-200 ease-out">
