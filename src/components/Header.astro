---
import ThemeToggle from './ui/ThemeToggle.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const isLoggedIn = typeof window !== 'undefined' && (sessionStorage.getItem('userId') || localStorage.getItem('userId'));
---

<header class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="container max-w-6xl">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <div class="w-11 h-10 bg-brand-500 rounded-lg flex items-center justify-center">
          <span class="text-white font-bold text-lg">T</span>
        </div>
        <span class="font-bold text-xl hidden sm:inline-block">TimorList</span>
      </a>

      <!-- Desktop Navigation - ALL buttons 44px height -->
      <nav class="hidden md:flex items-center gap-1">
        <a
          href="/listings"
          class:list={[
            "text-sm font-medium transition-colors hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded-md px-3 h-10 flex items-center",
            currentPath.startsWith('/listings') ? "text-primary" : "text-muted-foreground"
          ]}
        >
          Directory
        </a>
        <a
          href="/products-services"
          class:list={[
            "text-sm font-medium transition-colors hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded-md px-3 h-10 flex items-center",
            currentPath.startsWith('/products-services') ? "text-primary" : "text-muted-foreground"
          ]}
        >
          Products & Services
        </a>
        <a
          href="/pricing"
          class:list={[
            "text-sm font-medium transition-colors hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded-md px-3 h-10 flex items-center",
            currentPath === '/pricing' ? "text-primary" : "text-muted-foreground"
          ]}
        >
          Pricing
        </a>
        <a
          href="/faq"
          class:list={[
            "text-sm font-medium transition-colors hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded-md px-3 h-10 flex items-center",
            currentPath === '/faq' ? "text-primary" : "text-muted-foreground"
          ]}
        >
          FAQ
        </a>
        <a
          href="/listings/create"
          class="text-sm font-medium bg-primary text-primary-foreground px-4 h-10 rounded-md hover:bg-primary/90 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 flex items-center"
        >
          + Create
        </a>
      </nav>

      <!-- Right Side - ALL buttons 44px height -->
      <div class="flex items-center gap-2">
        <ThemeToggle />

        <div id="desktop-auth" class="hidden md:flex items-center gap-2">
          {isLoggedIn ? (
            <div class="relative">
              <button id="avatar-dropdown-btn" class="w-11 h-10 rounded-lg bg-brand-500 flex items-center justify-center hover:opacity-80 transition-opacity">
                <span class="text-white text-sm font-medium">?</span>
              </button>
              <div id="avatar-dropdown" class="hidden absolute right-0 mt-2 w-40 bg-background border rounded-lg shadow-lg py-1 z-50">
                <a href="/account" class="block px-4 py-3 text-sm hover:bg-muted">My Account</a>
                <hr class="my-1 border-muted" />
                <button id="logout-btn" class="block w-full text-left px-4 py-3 text-sm text-red-500 hover:bg-muted">Log Out</button>
              </div>
            </div>
          ) : (
            <>
              <a href="/login" class="text-sm font-medium text-muted-foreground hover:text-primary px-3 h-10 rounded-md hover:bg-muted transition-colors flex items-center">
                Log in
              </a>
              <a href="/register" class="text-sm font-medium bg-primary text-primary-foreground px-4 h-10 rounded-md hover:bg-primary/90 transition-colors flex items-center">
                Sign Up
              </a>
            </>
          )}
        </div>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden w-11 h-10 rounded-md hover:bg-muted transition-colors flex items-center justify-center"
          aria-label="Open menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t">
    <nav class="container max-w-6xl py-4 space-y-2">
      <a href="/businesses" class:list={["block px-3 py-2 rounded-lg text-sm font-medium", currentPath.startsWith('/businesses') ? "bg-muted text-primary" : "text-muted-foreground"]}>
        Businesses
      </a>
      <a href="/categories" class:list={["block px-3 py-2 rounded-lg text-sm font-medium", currentPath.startsWith('/categories') ? "bg-muted text-primary" : "text-muted-foreground"]}>
        Categories
      </a>
      <a href="/pricing" class:list={["block px-3 py-2 rounded-lg text-sm font-medium", currentPath === '/pricing' ? "bg-muted text-primary" : "text-muted-foreground"]}>
        Pricing
      </a>
      <a href="/faq" class:list={["block px-3 py-2 rounded-lg text-sm font-medium", currentPath === '/faq' ? "bg-muted text-primary" : "text-muted-foreground"]}>
        FAQ
      </a>
      <div id="mobile-auth" class="border-t pt-2 mt-2">
        {isLoggedIn ? (
          <>
            <a href="/account" class="block px-3 py-2 rounded-lg text-sm font-medium text-muted-foreground">My Account</a>
            <button id="mobile-logout" class="block w-full text-left px-3 py-2 rounded-lg text-sm font-medium text-red-500">Log Out</button>
          </>
        ) : (
          <>
            <a href="/login" class="block px-3 py-2 rounded-lg text-sm font-medium text-muted-foreground">Log in</a>
            <a href="/register" class="block px-3 py-2 rounded-lg text-sm font-medium bg-brand-500 text-white text-center">Sign Up</a>
          </>
        )}
      </div>
    </nav>
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  document.getElementById('mobile-logout')?.addEventListener('click', async () => {
    try { await fetch('/api/auth/sign-out', { method: 'POST', credentials: 'include' }); }
    catch (e) { console.error('Logout error:', e); }
    finally {
      sessionStorage.removeItem('userId');
      localStorage.removeItem('userId');
      window.location.href = '/';
    }
  });

  function updateAuthState() {
    const userId = localStorage.getItem('userId') || sessionStorage.getItem('userId');
    const userName = localStorage.getItem('userName') || sessionStorage.getItem('userName');
    const desktopAuth = document.getElementById('desktop-auth');
    const mobileAuth = document.getElementById('mobile-auth');
    const initial = userName ? escapeHtml(userName).charAt(0).toUpperCase() : '?';

    if (userId) {
      if (desktopAuth) {
        desktopAuth.innerHTML = `
          <div class="relative">
            <button id="avatar-dropdown-btn" class="w-11 h-10 rounded-lg bg-brand-500 flex items-center justify-center hover:opacity-80 transition-opacity">
              <span class="text-white text-sm font-medium">${initial}</span>
            </button>
            <div id="avatar-dropdown" class="hidden absolute right-0 mt-2 w-40 bg-background border rounded-lg shadow-lg py-1 z-50">
              <a href="/account" class="block px-4 py-3 text-sm hover:bg-muted">My Account</a>
              <hr class="my-1 border-muted" />
              <button id="logout-btn" class="block w-full text-left px-4 py-3 text-sm text-red-500 hover:bg-muted">Log Out</button>
            </div>
          </div>
        `;
        setTimeout(() => {
          document.getElementById('avatar-dropdown-btn')?.addEventListener('click', (e) => {
            e.stopPropagation();
            document.getElementById('avatar-dropdown')?.classList.toggle('hidden');
          });
          document.getElementById('logout-btn')?.addEventListener('click', async () => {
            try { await fetch('/api/auth/sign-out', { method: 'POST', credentials: 'include' }); }
            catch (e) { console.error('Logout error:', e); }
            finally {
              localStorage.removeItem('userId');
              localStorage.removeItem('userName');
              sessionStorage.removeItem('userId');
              sessionStorage.removeItem('userName');
              window.location.href = '/';
            }
          });
          document.addEventListener('click', () => document.getElementById('avatar-dropdown')?.classList.add('hidden'));
        }, 0);
      }
      if (mobileAuth) {
        mobileAuth.innerHTML = `
          <a href="/account" class="block px-3 py-2 rounded-lg text-sm font-medium text-muted-foreground">My Account</a>
          <button id="mobile-logout" class="block w-full text-left px-3 py-2 rounded-lg text-sm font-medium text-red-500">Log Out</button>
        `;
      }
    }
  }

  updateAuthState();

  function escapeHtml(str: string) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }
</script>