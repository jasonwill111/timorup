---
interface Props {
  title: string;
  slug: string;
  priceAmount?: number | null;
  priceUnit?: string | null;
  categoryId?: string | null;
  condition?: string;
  location?: string;
  thumbnail?: string | null;
  imageIds?: string[];
  likes?: number;
  views?: number;
  class?: string;
}

const {
  title,
  slug,
  priceAmount = null,
  priceUnit = null,
  categoryId = null,
  condition = "",
  location = "",
  thumbnail = null,
  imageIds = [],
  likes = 0,
  views = 0,
  class: className = "",
} = Astro.props;

const href = `/listing/${slug}`;

// Format price display
function formatPrice(amount: number | null, unit: string | null): string {
  if (amount === null && unit === null) return "";
  if (unit === 'free') return "Free";
  if (unit === 'negotiable') return "Negotiable";
  if (amount === null) return "";
  const formatted = amount % 1 === 0 ? amount.toString() : amount.toFixed(2);
  return unit ? `$${formatted}${unit}` : `$${formatted}`;
}

const priceDisplay = formatPrice(priceAmount, priceUnit);

// Fixed gradient for all listings (category-based colors can be added later)
const gradientClass = "from-emerald-100 to-teal-100 dark:from-emerald-900/40 dark:to-teal-900/40";
---

<a href={href} class:list={["block group cursor-pointer", className]} data-card>
  <div class="relative bg-card rounded-lg border shadow-sm hover:shadow-md hover:border-primary/30 transition-all duration-200 overflow-hidden">
    <!-- Thumbnail -->
    <div class:list={["aspect-square relative overflow-hidden bg-gradient-to-br", gradientClass]}>
      {thumbnail ? (
        <img src={thumbnail} alt={title} class="w-full h-full object-cover" loading="lazy" />
      ) : (
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-4xl font-bold text-emerald-500/40">{title.charAt(0)}</span>
        </div>
      )}

      <!-- Price badge -->
      {priceDisplay && (
        <div class="absolute bottom-1.5 right-1.5 sm:bottom-2 sm:right-2 bg-black/80 backdrop-blur-sm px-1.5 py-0.5 sm:px-2 sm:py-1 rounded">
          <span class="text-white text-[10px] sm:text-xs font-semibold">{priceDisplay}</span>
        </div>
      )}
    </div>

    <!-- Content -->
    <div class="p-2 sm:p-3">
      <h3 class="font-medium sm:font-semibold text-xs sm:text-sm truncate group-hover:text-emerald-700 dark:group-hover:text-emerald-400 transition-colors leading-tight">
        {title}
      </h3>
      <div class="flex items-center justify-between mt-0.5">
        {location && (
          <span class="flex items-center gap-0.5 text-[10px] sm:text-xs text-muted-foreground truncate">
            <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            </svg>
            <span class="truncate">{location}</span>
          </span>
        )}
        {likes > 0 && (
          <span class="flex items-center gap-0.5 text-[10px] sm:text-xs text-muted-foreground">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
            <span>{likes}</span>
          </span>
        )}
      </div>
    </div>
  </div>
</a>