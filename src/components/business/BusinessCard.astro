---
interface Props {
  title: string;
  slug: string;
  category: string;
  thumbnail?: string | null;
  rating?: number;
  likes?: number;
  reviews?: number;
  location?: string;
  tag?: string;
  type?: 'business' | 'organization';
  orgType?: string;
  verified?: boolean;
  class?: string;
}

const {
  title,
  slug,
  category,
  thumbnail = null,
  rating = 0,
  likes = 0,
  reviews = 0,
  location = '',
  tag = '',
  type = 'business',
  orgType = '',
  verified = false,
  class: className = '',
} = Astro.props;

const href = type === 'organization' ? `/organization/${slug}` : `/business/${slug}`;
const isOrg = type === 'organization';

const orgTypeColors: Record<string, string> = {
  government: 'from-blue-100 to-blue-200 dark:from-blue-900/40 dark:to-blue-800/40',
  ngo: 'from-green-100 to-green-200 dark:from-green-900/40 dark:to-green-800/40',
  nonprofit: 'from-purple-100 to-purple-200 dark:from-purple-900/40 dark:to-purple-800/40',
  foundation: 'from-pink-100 to-pink-200 dark:from-pink-900/40 dark:to-pink-800/40',
};

const gradientClass = isOrg ? (orgTypeColors[orgType] || 'from-amber-100 to-orange-100') : 'from-amber-100 to-orange-100';
---

<a
  href={href}
  class:list={["block group cursor-pointer", className]}
  data-card
  data-title={title.toLowerCase()}
>
  <div class="relative bg-card rounded-xl border shadow-sm hover:shadow-lg hover:border-primary/30 transition-all duration-200 overflow-hidden">
    <!-- Thumbnail -->
    <div class:list={["aspect-[4/3] relative overflow-hidden bg-gradient-to-br", gradientClass]}>
      {thumbnail ? (
        <img src={thumbnail} alt={title} class="w-full h-full object-cover" loading="lazy" />
      ) : (
        <div class="absolute inset-0 flex items-center justify-center">
          <span class:list={["text-5xl font-bold", isOrg ? "text-blue-500/40" : "text-amber-500/40"]}>{title.charAt(0)}</span>
        </div>
      )}

      <!-- Top overlay: Save + Rating -->
      <div class="absolute top-2 left-2 right-2 flex justify-between items-start">
        <!-- Save button -->
        <button
          class="w-7 h-7 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center shadow-sm hover:bg-white hover:shadow-md transition-all cursor-pointer"
          title="Save"
          onclick={`event.preventDefault(); event.stopPropagation(); document.location.href='${href}'`}
        >
          <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
          </svg>
        </button>

        <!-- Badges row -->
        <div class="flex items-center gap-1">
          {verified && (
            <span class="bg-green-500 text-white text-[9px] px-1.5 py-0.5 rounded flex items-center gap-0.5 font-medium">
              <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.707-7.707a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Verified
            </span>
          )}
          {rating > 0 && (
            <span class="bg-black/70 backdrop-blur-sm px-1.5 py-0.5 rounded flex items-center gap-0.5 text-white text-xs font-medium">
              <svg class="w-3 h-3 text-amber-400 fill-current" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              <span>{rating.toFixed(1)}</span>
            </span>
          )}
        </div>
      </div>

      <!-- Bottom: Stats row -->
      {(likes > 0 || reviews > 0) && (
        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/50 to-transparent p-2">
          <div class="flex items-center justify-end gap-3 text-white text-xs">
            {likes > 0 && (
              <span class="flex items-center gap-0.5">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                </svg>
                <span class="font-medium">{likes}</span>
              </span>
            )}
            {reviews > 0 && (
              <span class="flex items-center gap-0.5">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                <span class="font-medium">{reviews}</span>
              </span>
            )}
          </div>
        </div>
      )}
    </div>

    <!-- Content: Icon + Number layout -->
    <div class="p-3">
      <!-- Title + Category (compact) -->
      <h3 class:list={["font-semibold text-sm truncate group-hover:text-amber-600 transition-colors leading-tight", isOrg && "group-hover:text-blue-600"]}>
        {title}
      </h3>
      <p class="text-xs text-muted-foreground truncate mt-0.5">{category}</p>

      <!-- Bottom stats row -->
      <div class="flex items-center justify-between mt-2 pt-2 border-t border-border/50">
        <!-- Location icon + short text -->
        {location && (
          <span class="flex items-center gap-1 text-[11px] text-muted-foreground">
            <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="truncate max-w-[80px]">{location}</span>
          </span>
        )}
        <!-- Tag pill -->
        {tag && (
          <span class:list={["text-[10px] px-1.5 py-0.5 rounded font-medium", isOrg ? "bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400" : "bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400"]}>
            {tag}
          </span>
        )}
      </div>
    </div>
  </div>
</a>