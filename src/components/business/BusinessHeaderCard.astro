---
// Reusable Business/Org Header Card Component
import Card from '@/components/ui/Card.astro';

interface Props {
  title: string;
  status?: 'live' | 'draft';
  category?: string;
  profileImageId?: string | null;
  contactName?: string | null;
  contactNumber?: string | null;
  countryCode?: string;
  email?: string | null;
  yearOfEstablishment?: string | null;
  entityType: 'business' | 'government' | 'nonprofit';
  slug?: string;
  showWhatsApp?: boolean;
}

const {
  title,
  status,
  category,
  profileImageId,
  contactName,
  contactNumber,
  countryCode = '+670',
  email,
  yearOfEstablishment,
  entityType,
  slug,
  showWhatsApp = false,
} = Astro.props;

// Type-based styling
const typeColors = {
  business: {
    gradient: 'from-amber-100 to-amber-200 dark:from-amber-900/30 dark:to-amber-800/30',
    icon: 'text-amber-500 bg-amber-50 dark:bg-amber-900/30',
  },
  government: {
    gradient: 'from-purple-100 to-purple-200 dark:from-purple-900/30 dark:to-purple-800/30',
    icon: 'text-purple-500 bg-purple-50 dark:bg-purple-900/30',
  },
  nonprofit: {
    gradient: 'from-orange-100 to-orange-200 dark:from-orange-900/30 dark:to-orange-800/30',
    icon: 'text-orange-500 bg-orange-50 dark:bg-orange-900/30',
  },
};

const colors = typeColors[entityType] || typeColors.business;
---

<Card class="overflow-hidden">
  <div class="p-4 md:p-6">
    <div class="flex flex-col lg:flex-row gap-4 md:gap-6">
      <!-- Profile Image -->
      <div class="flex-shrink-0 mx-auto lg:mx-0">
        <div class="w-24 h-24 md:w-28 md:h-28 rounded-2xl overflow-hidden bg-muted border-4 border-background shadow-lg">
          {profileImageId ? (
            <img src={`/api/media/${profileImageId}`} class="w-full h-full object-cover" alt={title} />
          ) : (
            <div class={`w-full h-full flex items-center justify-center text-4xl md:text-5xl font-bold ${colors.icon}`}>
              {title.charAt(0)}
            </div>
          )}
        </div>
      </div>

      <!-- Main Content -->
      <div class="flex-1 min-w-0 space-y-4">
        <!-- Title & Status Row -->
        <div class="flex items-start justify-between gap-4">
          <div class="space-y-1">
            <div class="flex items-center gap-2 flex-wrap">
              <h1 class="text-xl md:text-2xl font-bold">{title}</h1>
              {status === 'live' && (
                <span class="px-2.5 py-0.5 text-xs font-semibold rounded-full bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400">Live</span>
              )}
              {status === 'draft' && (
                <span class="px-2.5 py-0.5 text-xs font-semibold rounded-full bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400">Preview</span>
              )}
            </div>
            {category && (
              <p class="text-sm text-muted-foreground">{category}</p>
            )}
          </div>

          <!-- WhatsApp Button -->
          {showWhatsApp && contactNumber && (
            <a
              href={`https://wa.me/${contactNumber.replace(/\s/g, '')}?text=Hi, I'm interested in ${encodeURIComponent(title)}`}
              target="_blank"
              class="flex items-center gap-1.5 px-3 py-1.5 bg-[#25D366] hover:bg-[#20BD5A] text-white rounded-lg text-sm font-medium transition-colors flex-shrink-0"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp
            </a>
          )}
        </div>

        <!-- Contact Info - Stacked vertically -->
        <div class="space-y-2 text-sm">
          {contactNumber && (
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-muted-foreground flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <a href={`tel:${countryCode}${contactNumber}`} class="hover:text-primary font-medium">{countryCode} {contactNumber}</a>
            </div>
          )}
          {contactName && (
            <div class="flex items-center gap-2 text-muted-foreground">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span>{contactName}</span>
            </div>
          )}
          {email && (
            <div class="flex items-center gap-2 text-muted-foreground">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <a href={`mailto:${email}`} class="hover:text-primary">{email}</a>
            </div>
          )}
          {yearOfEstablishment && (
            <div class="flex items-center gap-2 text-muted-foreground">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <span>Est. {yearOfEstablishment}</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</Card>
