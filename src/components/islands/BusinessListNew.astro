---
// Server Island: Business list with client-side filtering
// Uses is:defer for streaming, renders immediately with fallback
import { getDb } from '@/lib/db';
import { businesses, businessCategories } from '@/db/schema';
import { desc, eq } from 'drizzle-orm';

const searchParams = Astro.url.searchParams;
const search = searchParams.get('q') || '';
const parentCat = searchParams.get('parent') || '';
const childCat = searchParams.get('child') || '';
const page = parseInt(searchParams.get('page') || '1', 10);
const LIMIT = 12;
const offset = (page - 1) * LIMIT;

// Fetch categories first
let parentCats: { id: string; name: string }[] = [];
let getChildren = (_pid: string) => [];

const db = await getDb();
if (db) {
  try {
    const allCats = await db.select({
      id: businessCategories.id,
      name: businessCategories.name,
      parentId: businessCategories.parentId,
    }).from(businessCategories).all();

    parentCats = allCats.filter(c => !c.parentId);
    getChildren = (pid: string) => allCats.filter(c => c.parentId === pid);
  } catch (e) {
    console.error('Categories error:', e);
  }
}

// Fetch businesses
let allEntities = [];
if (db) {
  try {
    // Simple query without orderBy
    const query = db.select().from(businesses);
    const raw = await query.all();
    console.log('[BusinessListNew] Raw businesses count:', raw.length);
    console.log('[BusinessListNew] First business:', JSON.stringify(raw[0]));
    allEntities = raw;
  } catch (e) {
    console.error('Query error:', e);
  }
}

console.log('[BusinessListNew] allEntities length:', allEntities.length);

const total = allEntities.length;
const totalPages = Math.ceil(total / LIMIT);
const entities = allEntities.slice(offset, offset + LIMIT);
---

<!-- Header with count -->
<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl sm:text-3xl font-bold">Businesses</h1>
  <span class="text-sm text-muted-foreground">{total} total</span>
</div>

<!-- Search & Filter -->
<form method="GET" action="/businesses" class="bg-card rounded-2xl border border-border/50 p-4 mb-6 shadow-sm">
  <div class="flex flex-col sm:flex-row gap-3">
    <div class="relative flex-1">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-muted-foreground transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input name="q" type="search" placeholder="Search businesses..." value={search}
        class="w-full h-11 pl-10 pr-4 rounded-xl border border-border bg-background focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200" />
    </div>
    <div class="flex gap-2">
      <select name="parent" onchange="this.form.submit()"
        class="h-11 px-4 rounded-xl border border-border bg-background text-sm cursor-pointer hover:border-primary/50 transition-colors">
        <option value="">All Categories</option>
        {parentCats.map(p => <option value={p.id} selected={parentCat === p.id}>{p.name}</option>)}
      </select>
      <select name="child" onchange="this.form.submit()"
        class="h-11 px-4 rounded-xl border border-border bg-background text-sm cursor-pointer hover:border-primary/50 transition-colors">
        <option value="">Subcategory</option>
        {getChildren(parentCat).map(c => <option value={c.id} selected={childCat === c.id}>{c.name}</option>)}
      </select>
    </div>
  </div>
</form>

<!-- Business Grid -->
{entities.length > 0 ? (
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    {entities.map(e => (
      <a href={`/business/${e.slug}`} class="group block bg-card rounded-2xl border border-border/50 shadow-sm hover:shadow-lg hover:border-primary/60 overflow-hidden cursor-pointer transition-all duration-200 hover:scale-[1.02] hover:-translate-y-1">
        <div class="aspect-[4/3] bg-gradient-to-br from-primary/10 to-primary/5 relative overflow-hidden">
          {e.profileImageId ? (
            <img src={`/api/media/${e.profileImageId}`} alt={e.title} class="w-full h-full object-cover" loading="lazy" />
          ) : (
            <div class="absolute inset-0 flex items-center justify-center">
              <svg class="w-16 h-16 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/>
              </svg>
            </div>
          )}
          {e.featured ? (
            <span class="absolute top-3 left-3 text-xs px-3 py-1.5 rounded-full bg-primary text-primary-foreground font-semibold shadow-md">
              Featured
            </span>
          ) : null}
        </div>
        <div class="p-4 space-y-3">
          <h3 class="font-bold text-base line-clamp-2 group-hover:text-primary transition-colors">{e.title}</h3>
          {e.address ? (
            <p class="text-sm text-muted-foreground flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-primary/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span class="truncate">{e.address?.split(',')[0] || e.address}</span>
            </p>
          ) : null}
          <div class="flex items-center gap-4 pt-2 border-t border-border/50">
            {e.ratingAverage > 0 ? (
              <div class="flex items-center gap-1.5">
                <div class="flex">
                  {[1,2,3,4,5].map(n => (
                    <svg class={`w-3.5 h-3.5 ${n <= Math.round(e.ratingAverage) ? 'text-amber-400 fill-amber-400' : 'text-gray-300 fill-gray-300'}`} viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  ))}
                </div>
                <span class="text-xs font-semibold">{e.ratingAverage.toFixed(1)}</span>
              </div>
            ) : null}
            {e.likes > 0 ? (
              <span class="flex items-center gap-1 text-xs text-muted-foreground">
                <svg class="w-3.5 h-3.5 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.682l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                {e.likes}
              </span>
            ) : null}
            <span class="flex items-center gap-1 text-xs text-muted-foreground ml-auto">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              {e.views > 999 ? `${(e.views/1000).toFixed(1)}k` : e.views}
            </span>
          </div>
        </div>
      </a>
    ))}
  </div>
) : (
  <div class="text-center py-16">
    <svg class="w-16 h-16 mx-auto text-muted-foreground/50 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/>
    </svg>
    <h3 class="text-lg font-medium mb-2">No businesses found</h3>
    <p class="text-muted-foreground">Try adjusting your search or filters</p>
  </div>
)}

<!-- Pagination -->
{totalPages > 1 && (
  <nav class="flex justify-center gap-2 mt-8" aria-label="Pagination">
    {page > 1 && (
      <a href={buildUrl({ page: String(page - 1) })} class="px-4 py-2 rounded-lg border hover:bg-muted transition-colors">
        Previous
      </a>
    )}
    {Array.from({ length: Math.min(5, totalPages) }, (_, i) => {
      const p = i + 1;
      return (
        <a href={buildUrl({ page: String(p) })} class={`px-4 py-2 rounded-lg border ${p === page ? 'bg-primary text-primary-foreground' : 'hover:bg-muted'}`}>
          {p}
        </a>
      );
    })}
    {page < totalPages && (
      <a href={buildUrl({ page: String(page + 1) })} class="px-4 py-2 rounded-lg border hover:bg-muted transition-colors">
        Next
      </a>
    )}
  </nav>
)}

<script is:inline>
  function buildUrl(params) {
    const p = new URLSearchParams(window.location.search);
    Object.entries(params).forEach(([k, v]) => {
      if (v) p.set(k, v);
    });
    return `/businesses?${p.toString()}`;
  }
</script>