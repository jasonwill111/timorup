---
// Server Island: Fetches dynamic content on the homepage
// This runs on the server and caches results
import { getDb } from '@/lib/db';
import { businesses, businessCategories, products } from '@/db/schema';
import { eq, desc, inArray } from 'drizzle-orm';
import { parseIcon, DEFAULT_CATEGORY_ICONS, getLucideIconPath } from '@/lib/icons';
import BusinessCard from '@/components/business/BusinessCard.astro';
import ProductCard from '@/components/business/ProductCard.astro';

// Define types for better TypeScript safety
type CategoryData = {
  id: string;
  name: string;
  slug: string;
  description: string | null;
  icon: string | null;
  count: number;
  iconType: string;
};

type ProductListing = {
  id: string;
  title: string;
  price: string;
  priceUnit: string;
  priceFields: { label: string; value: string; unit: string }[];
  serviceType: string;
  businessTitle: string;
  businessSlug: string;
};

type BusinessListing = {
  id: string;
  title: string;
  slug: string;
  tags: string[];
  likes: number;
  status: string;
  categoryId: string | null;
  profileImageId: string | null;
  category: string;
  rating: number;
  reviews: number;
  imageUrl: string;
  entityTypeDisplay: string;
  isNew: boolean;
};

const db = await getDb();

let featuredBusinesses: BusinessListing[] = [];
let featuredGovs: BusinessListing[] = [];
let featuredNgos: BusinessListing[] = [];
let featuredProducts: unknown[] = [];
let categoriesData: CategoryData[] = [];

try {
  const categoriesResult = await db.select({
    id: businessCategories.id,
    name: businessCategories.name,
    slug: businessCategories.slug,
    description: businessCategories.description,
    icon: businessCategories.icon,
  })
  .from(businessCategories)
  .limit(20);

  const categoryMap: Record<string, { name: string; icon: string }> = {};
  categoriesResult.forEach((c) => {
    categoryMap[c.id] = { name: c.name, icon: c.icon || '' };
  });

  const businessesResult = await db.select({
    id: businesses.id,
    title: businesses.title,
    slug: businesses.slug,
    tags: businesses.tags,
    likes: businesses.likes,
    status: businesses.status,
    categoryId: businesses.categoryId,
    profileImageId: businesses.profileImageId,
  })
  .from(businesses)
  .where(eq(businesses.status, 'live'))
  .orderBy(desc(businesses.likes))
  .limit(20);

  const allListings = businessesResult.map(b => {
    const tags = b.tags ? JSON.parse(b.tags) : [];
    const entityTypeDisplay = b.entityType === 'business' ? 'Business'
      : b.entityType === 'government' ? 'Government'
      : b.entityType === 'nonprofit' ? 'Nonprofit' : 'Business';
    return {
      id: b.id,
      title: b.title,
      slug: b.slug,
      category: categoryMap[b.categoryId || '']?.name || 'Business',
      rating: 0,
      reviews: 0,
      likes: b.likes || 0,
      location: 'Dili',
      tag: tags[0] || '',
      tags,
      profileImageId: b.profileImageId,
      entityType: b.entityType,
      entityTypeDisplay,
      isNew: false,
    };
  });

  featuredBusinesses = allListings
    .filter(b => b.entityType === 'business')
    .slice(0, 12);

  featuredGovs = allListings
    .filter(b => b.entityType === 'government')
    .slice(0, 3);

  featuredNgos = allListings
    .filter(b => b.entityType === 'nonprofit')
    .slice(0, 3);

  categoriesData = categoriesResult.map(c => {
    const icon = c.icon || '';
    const parsed = parseIcon(icon);
    const defaultIcon = DEFAULT_CATEGORY_ICONS[c.slug];
    return {
      id: c.id,
      name: c.name,
      slug: c.slug,
      description: c.description,
      count: 0,
      icon: parsed?.value || defaultIcon?.value || 'building',
      iconType: parsed?.type || defaultIcon?.type || 'lucide'
    };
  });

  const productsResult = await db.select({
    id: products.id,
    title: products.title,
    price: products.price,
    priceUnit: products.priceUnit,
    priceFields: products.priceFields,
    serviceType: products.serviceType,
    businessPageId: products.businessPageId,
  })
  .from(products)
  .innerJoin(businesses, eq(products.businessPageId, businesses.id))
  .where(eq(businesses.status, 'live'))
  .orderBy(desc(products.createdAt))
  .limit(12);

  const businessIds = [...new Set(productsResult.map(p => p.businessPageId))];
  const businessesForProducts = businessIds.length > 0
    ? await db.select({
        id: businesses.id,
        title: businesses.title,
        slug: businesses.slug,
      })
      .from(businesses)
      .where(inArray(businesses.id, businessIds))
    : [];

  const businessMap: Record<string, { title: string; slug: string }> = {};
  businessesForProducts.forEach(b => {
    businessMap[b.id] = { title: b.title, slug: b.slug };
  });

  featuredProducts = productsResult.map(p => {
    const business = businessMap[p.businessPageId] || {};
    const priceFields = p.priceFields ? JSON.parse(p.priceFields) : [];
    return {
      id: p.id,
      title: p.title,
      price: p.price || '',
      priceUnit: p.priceUnit || '',
      priceFields,
      serviceType: p.serviceType || 'product',
      businessTitle: business.title || '',
      businessSlug: business.slug || '',
    };
  });

} catch (e) {
  console.error('Failed to fetch database data:', e);
}

const mappedCategories = categoriesData;
---

<!-- Featured Businesses -->
<section class="mb-6 sm:mb-12">
  <div class="flex items-center justify-between mb-4 sm:mb-6">
    <h2 class="text-lg sm:text-2xl font-bold">Featured Businesses</h2>
    <a href="/listings?type=business" class="text-xs sm:text-sm text-amber-600 hover:text-amber-700 font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded cursor-pointer">View All →</a>
  </div>
  <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2 sm:gap-4">
    {featuredBusinesses.length > 0 ? featuredBusinesses.map((business: BusinessListing) => (
      <BusinessCard
        title={business.title}
        slug={business.slug}
        category={business.category}
        thumbnail={null}
        rating={business.rating}
        likes={business.likes}
        reviews={business.reviews}
        location={business.location}
        tag={business.tag}
        type={business.entityType}
      />
    )) : (
      <div class="col-span-full text-center py-8 text-muted-foreground">
        <p>No featured businesses yet.</p>
        <a href="/listings/create" class="text-amber-600 hover:underline">Add your business!</a>
      </div>
    )}
  </div>
</section>

<!-- Featured Government -->
{featuredGovs.length > 0 && (
  <section class="mb-6 sm:mb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-lg sm:text-2xl font-bold">Government</h2>
      <a href="/listings?type=govs" class="text-purple-600 hover:text-purple-700 font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded cursor-pointer">View All →</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {featuredGovs.map((gov: BusinessListing) => (
        <a href={`/business/${gov.slug}`} class="block bg-card rounded-xl border shadow-sm hover:shadow-lg hover:border-purple-300 transition-all overflow-hidden">
          <div class="aspect-square relative overflow-hidden bg-gradient-to-br from-purple-100 to-purple-200 dark:from-purple-900/40 dark:to-purple-800/40">
            {gov.profileImageId ? (
              <img src={`/api/media/${gov.profileImageId}`} alt={gov.title} class="w-full h-full object-cover" loading="lazy" />
            ) : (
              <span class="text-5xl font-bold text-purple-400">{gov.title.charAt(0)}</span>
            )}
          </div>
          <div class="p-3">
            <h3 class="font-semibold truncate group-hover:text-purple-600 transition-colors">{gov.title}</h3>
            <p class="text-xs text-muted-foreground truncate">{gov.category}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<!-- Featured NGOs -->
{featuredNgos.length > 0 && (
  <section class="mb-6 sm:mb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-lg sm:text-2xl font-bold">NGOs & Non-Profits</h2>
      <a href="/listings?type=ngos" class="text-orange-600 hover:text-orange-700 font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded cursor-pointer">View All →</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {featuredNgos.map((ngo: BusinessListing) => (
        <a href={`/business/${ngo.slug}`} class="block bg-card rounded-xl border shadow-sm hover:shadow-lg hover:border-orange-300 transition-all overflow-hidden">
          <div class="aspect-square relative overflow-hidden bg-gradient-to-br from-orange-100 to-orange-200 dark:from-orange-900/40 dark:to-orange-800/40">
            {ngo.profileImageId ? (
              <img src={`/api/media/${ngo.profileImageId}`} alt={ngo.title} class="w-full h-full object-cover" loading="lazy" />
            ) : (
              <span class="text-5xl font-bold text-orange-400">{ngo.title.charAt(0)}</span>
            )}
          </div>
          <div class="p-3">
            <h3 class="font-semibold truncate group-hover:text-orange-600 transition-colors">{ngo.title}</h3>
            <p class="text-xs text-muted-foreground truncate">{ngo.category}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<!-- Featured Products & Services -->
<section class="mb-6 sm:mb-12">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-lg sm:text-2xl font-bold">Featured Products & Services</h2>
    <a href="/products-services" class="text-amber-600 hover:text-amber-700 font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded cursor-pointer">View All →</a>
  </div>
  {featuredProducts.length > 0 ? (
    <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2 sm:gap-4">
      {featuredProducts.map((product: ProductListing) => (
        <ProductCard
          title={product.title}
          businessTitle={product.businessTitle}
          businessSlug={product.businessSlug}
          price={product.price}
          priceUnit={product.priceUnit}
          priceFields={product.priceFields}
          serviceType={product.serviceType}
          slug={product.id}
        />
      ))}
    </div>
  ) : (
    <div class="bg-gradient-to-r from-amber-50 to-orange-50 dark:from-amber-950/30 dark:to-orange-950/30 rounded-xl p-8 text-center">
      <p class="text-muted-foreground mb-4">No products available yet. Be the first to add one!</p>
      <a href="/listings/create">
        <button class="bg-primary text-primary-foreground px-4 py-2 rounded-lg font-medium hover:bg-primary/90 transition-colors">List Your Business</button>
      </a>
    </div>
  )}
</section>

<!-- Categories -->
<section class="mb-6 sm:mb-12">
  <h2 class="text-lg sm:text-2xl font-bold mb-4 sm:mb-6">Browse by Category</h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-4 gap-4">
    {mappedCategories.map((cat: CategoryData) => (
      <a href={`/listings?type=business&industry=${cat.slug}`} class="block cursor-pointer">
        <div class="p-4 text-center border rounded-xl hover:border-amber-500 hover:bg-amber-50 dark:hover:bg-amber-900/20 transition-all duration-200 hover:-translate-y-1 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2">
          <div class="w-8 h-8 mx-auto mb-2 text-amber-500 flex items-center justify-center">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={getLucideIconPath(cat.icon)} />
            </svg>
          </div>
          <p class="font-medium text-sm">{cat.name}</p>
        </div>
      </a>
    ))}
  </div>
</section>
