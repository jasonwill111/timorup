---
// Server Island: Fetches dynamic content on the homepage
// This runs on the server and caches results
import { getDb } from '@/lib/db';
import { businesses, listings, nonProfits, publicSectors } from '@/db/schema';
import { eq, desc, or } from 'drizzle-orm';
import BusinessCard from '@/components/business/BusinessCard.astro';
import ListingCard from '@/components/business/ListingCard.astro';

// Define types for better TypeScript safety

type BusinessListing = {
  id: string;
  title: string;
  slug: string;
  tags: string[];
  likes: number;
  status: string;
  categoryId: string | null;
  profileImageId: string | null;
  category: string;
  rating: number;
  reviews: number;
  location: string;
  tag: string;
  entityType: string;
  entityTypeDisplay: string;
  isNew: boolean;
};

type ListingItem = {
  id: string;
  title: string;
  slug: string;
  price: string;
  listingType: string;
  location: string;
  imageIds: string[];
  likes: number;
};

const db = await getDb();

// Guard: if db is null, show empty state
if (!db) {
  console.error('[HomepageContent] Database not available');
}

let featuredBusinesses: BusinessListing[] = [];
let featuredListings: ListingItem[] = [];
let featuredPublicSectors: BusinessListing[] = [];
let featuredNonProfits: BusinessListing[] = [];

try {
  if (!db) throw new Error('Database not initialized');

  // Featured Businesses (active/live/published, limit 12)
  const businessesResult = await db.select({
    id: businesses.id,
    title: businesses.title,
    slug: businesses.slug,
    tags: businesses.tags,
    likes: businesses.likes,
    status: businesses.status,
    categoryId: businesses.categoryId,
    profileImageId: businesses.profileImageId,
  })
  .from(businesses)
  .where(
    or(
      eq(businesses.status, 'active'),
      eq(businesses.status, 'live'),
      eq(businesses.status, 'published')
    )
  )
  .orderBy(desc(businesses.likes))
  .limit(12);

  featuredBusinesses = businessesResult.map(b => {
    const tags = b.tags ? JSON.parse(b.tags) : [];
    return {
      id: b.id,
      title: b.title,
      slug: b.slug,
      category: 'Business',
      rating: 0,
      reviews: 0,
      likes: b.likes || 0,
      location: 'Dili',
      tag: tags[0] || '',
      tags,
      profileImageId: b.profileImageId,
      entityType: 'business',
      entityTypeDisplay: 'Business',
      isNew: false,
    };
  });

  // Featured Listings (classified ads)
  const allListings = await db.select().from(listings).limit(12).all();
  const listingsResult = allListings.filter(l =>
    l.status === 'active' || l.status === 'published'
  );

  featuredListings = listingsResult.map(l => {
    const imageIds = l.imageIds ? JSON.parse(l.imageIds) : [];
    return {
      id: l.id,
      title: l.title,
      slug: l.slug,
      price: l.price || '',
      listingType: l.listingType || 'product',
      location: l.location || '',
      imageIds,
      likes: l.likes || 0,
    };
  });

  // Featured Public Sectors (active/live/published, limit 12)
  const publicSectorsResult = await db.select({
    id: publicSectors.id,
    title: publicSectors.title,
    slug: publicSectors.slug,
    tags: publicSectors.tags,
    likes: publicSectors.likes,
    status: publicSectors.status,
    categoryId: publicSectors.categoryId,
    profileImageId: publicSectors.profileImageId,
  })
  .from(publicSectors)
  .where(
    or(
      eq(publicSectors.status, 'active'),
      eq(publicSectors.status, 'live'),
      eq(publicSectors.status, 'published')
    )
  )
  .orderBy(desc(publicSectors.likes))
  .limit(12);

  featuredPublicSectors = publicSectorsResult.map(b => {
    const tags = b.tags ? JSON.parse(b.tags) : [];
    return {
      id: b.id,
      title: b.title,
      slug: b.slug,
      category: 'Public Sector',
      rating: 0,
      reviews: 0,
      likes: b.likes || 0,
      location: 'Dili',
      tag: tags[0] || '',
      tags,
      profileImageId: b.profileImageId,
      entityType: 'public-sector',
      entityTypeDisplay: 'Public Sector',
      isNew: false,
    };
  });

  // Featured Non-Profits (active/live/published, limit 12)
  const nonProfitsResult = await db.select({
    id: nonProfits.id,
    title: nonProfits.title,
    slug: nonProfits.slug,
    tags: nonProfits.tags,
    likes: nonProfits.likes,
    status: nonProfits.status,
    categoryId: nonProfits.categoryId,
    profileImageId: nonProfits.profileImageId,
  })
  .from(nonProfits)
  .where(
    or(
      eq(nonProfits.status, 'active'),
      eq(nonProfits.status, 'live'),
      eq(nonProfits.status, 'published')
    )
  )
  .orderBy(desc(nonProfits.likes))
  .limit(12);

  featuredNonProfits = nonProfitsResult.map(b => {
    const tags = b.tags ? JSON.parse(b.tags) : [];
    return {
      id: b.id,
      title: b.title,
      slug: b.slug,
      category: 'Non-Profit',
      rating: 0,
      reviews: 0,
      likes: b.likes || 0,
      location: 'Dili',
      tag: tags[0] || '',
      tags,
      profileImageId: b.profileImageId,
      entityType: 'non-profit',
      entityTypeDisplay: 'Non-Profit',
      isNew: false,
    };
  });

} catch (e) {
  console.error('Failed to fetch database data:', e);
}

const hasContent = featuredBusinesses.length > 0 || featuredListings.length > 0 || featuredPublicSectors.length > 0 || featuredNonProfits.length > 0;
---

{hasContent ? (
  <div class="space-y-8">
    <!-- Tab Navigation (Desktop) -->
    <div class="hidden md:flex items-center gap-1 border-b">
      <button
        class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-muted-foreground hover:text-foreground data-[active=true]:text-foreground data-[active=true]:border-primary transition-colors"
        data-tab="businesses"
        data-active="true"
      >
        Businesses
      </button>
      <button
        class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-muted-foreground hover:text-foreground data-[active=true]:text-foreground data-[active=true]:border-primary transition-colors"
        data-tab="listings"
        data-active="false"
      >
        Listings
      </button>
      <button
        class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-muted-foreground hover:text-foreground data-[active=true]:text-foreground data-[active=true]:border-primary transition-colors"
        data-tab="public-sectors"
        data-active="false"
      >
        Public Sectors
      </button>
      <button
        class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-muted-foreground hover:text-foreground data-[active=true]:text-foreground data-[active=true]:border-primary transition-colors"
        data-tab="non-profits"
        data-active="false"
      >
        Non-Profits
      </button>
    </div>

    <!-- Mobile: Select dropdown instead of tabs -->
    <div class="md:hidden">
      <select id="content-select" class="w-full p-3 rounded-lg border bg-card text-sm font-medium">
        <option value="businesses">Businesses</option>
        <option value="listings">Listings</option>
        <option value="public-sectors">Public Sectors</option>
        <option value="non-profits">Non-Profits</option>
      </select>
    </div>

    <!-- Content Panels -->
    <div id="tab-panels">
      <!-- Featured Businesses Panel -->
      <div class="tab-panel" data-panel="businesses">
        {featuredBusinesses.length > 0 ? (
          <>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-2 sm:gap-3">
              {featuredBusinesses.map((business: BusinessListing) => (
                <BusinessCard
                  title={business.title}
                  slug={business.slug}
                  category={business.category}
                  thumbnail={null}
                  rating={business.rating}
                  likes={business.likes}
                  reviews={business.reviews}
                  location={business.location}
                  tag={business.tag}
                  type={business.entityType}
                />
              ))}
            </div>
            <div class="mt-6 text-center">
              <a href="/businesses" class="inline-flex items-center gap-2 px-6 py-2.5 bg-primary text-primary-foreground rounded-lg font-medium hover:bg-primary/90 transition-colors">
                View All Businesses
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </>
        ) : (
          <div class="text-center py-12 bg-muted/30 rounded-xl">
            <p class="text-muted-foreground mb-4">No featured businesses yet.</p>
            <a href="/businesses/create" class="text-primary hover:underline">Add your business!</a>
          </div>
        )}
      </div>

      <!-- Featured Listings Panel -->
      <div class="tab-panel hidden" data-panel="listings">
        {featuredListings.length > 0 ? (
          <>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-2 sm:gap-3">
              {featuredListings.map((listing: ListingItem) => (
                <ListingCard
                  title={listing.title}
                  slug={listing.slug}
                  price={listing.price}
                  listingType={listing.listingType}
                  location={listing.location}
                  thumbnail={null}
                  imageIds={listing.imageIds}
                  likes={listing.likes}
                />
              ))}
            </div>
            <div class="mt-6 text-center">
              <a href="/listings" class="inline-flex items-center gap-2 px-6 py-2.5 bg-emerald-500 text-white rounded-lg font-medium hover:bg-emerald-600 transition-colors">
                View All Listings
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </>
        ) : (
          <div class="text-center py-12 bg-muted/30 rounded-xl">
            <p class="text-muted-foreground mb-4">No classified ads yet.</p>
            <a href="/listings/create" class="text-primary hover:underline">Post your ad!</a>
          </div>
        )}
      </div>

      <!-- Featured Public Sectors Panel -->
      <div class="tab-panel hidden" data-panel="public-sectors">
        {featuredPublicSectors.length > 0 ? (
          <>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-2 sm:gap-3">
              {featuredPublicSectors.map((sector: BusinessListing) => (
                <BusinessCard
                  title={sector.title}
                  slug={sector.slug}
                  category={sector.category}
                  thumbnail={null}
                  rating={sector.rating}
                  likes={sector.likes}
                  reviews={sector.reviews}
                  location={sector.location}
                  tag={sector.tag}
                  type={sector.entityType}
                />
              ))}
            </div>
            <div class="mt-6 text-center">
              <a href="/public-sectors" class="inline-flex items-center gap-2 px-6 py-2.5 bg-blue-500 text-white rounded-lg font-medium hover:bg-blue-600 transition-colors">
                View All Public Sectors
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </>
        ) : (
          <div class="text-center py-12 bg-muted/30 rounded-xl">
            <p class="text-muted-foreground mb-4">No public sectors available yet.</p>
            <a href="/public-sectors" class="text-primary hover:underline">Explore public sectors!</a>
          </div>
        )}
      </div>

      <!-- Featured Non-Profits Panel -->
      <div class="tab-panel hidden" data-panel="non-profits">
        {featuredNonProfits.length > 0 ? (
          <>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-2 sm:gap-3">
              {featuredNonProfits.map((nonprofit: BusinessListing) => (
                <BusinessCard
                  title={nonprofit.title}
                  slug={nonprofit.slug}
                  category={nonprofit.category}
                  thumbnail={null}
                  rating={nonprofit.rating}
                  likes={nonprofit.likes}
                  reviews={nonprofit.reviews}
                  location={nonprofit.location}
                  tag={nonprofit.tag}
                  type={nonprofit.entityType}
                />
              ))}
            </div>
            <div class="mt-6 text-center">
              <a href="/non-profits" class="inline-flex items-center gap-2 px-6 py-2.5 bg-rose-500 text-white rounded-lg font-medium hover:bg-rose-600 transition-colors">
                View All Non-Profits
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </>
        ) : (
          <div class="text-center py-12 bg-muted/30 rounded-xl">
            <p class="text-muted-foreground mb-4">No non-profits available yet.</p>
            <a href="/non-profits" class="text-primary hover:underline">Explore non-profits!</a>
          </div>
        )}
      </div>
    </div>
  </div>
) : (
  <div class="text-center py-16">
    <p class="text-muted-foreground mb-4">No content available yet. Be the first to add something!</p>
    <a href="/businesses/create" class="inline-block bg-primary text-primary-foreground px-6 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors">Get Started</a>
  </div>
)}

<script>
  // Tab switching logic
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.getAttribute('data-tab');

      // Update button states
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.setAttribute('data-active', b.getAttribute('data-tab') === tab ? 'true' : 'false');
      });

      // Show/hide panels
      document.querySelectorAll('.tab-panel').forEach(panel => {
        panel.classList.toggle('hidden', panel.getAttribute('data-panel') !== tab);
      });
    });
  });

  // Mobile select handler
  const mobileSelect = document.getElementById('content-select');
  if (mobileSelect) {
    mobileSelect.addEventListener('change', (e) => {
      const tab = (e.target as HTMLSelectElement).value;

      // Show correct panel on mobile (no tabs, just panel switching)
      document.querySelectorAll('.tab-panel').forEach(panel => {
        panel.classList.toggle('hidden', panel.getAttribute('data-panel') !== tab);
      });

      // Sync desktop tabs if visible
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.setAttribute('data-active', btn.getAttribute('data-tab') === tab ? 'true' : 'false');
      });
    });
  }
</script>