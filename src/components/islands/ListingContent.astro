---
// Server Island: Listing content with filtering and pagination
import { getDb } from '@/lib/db';
import { businesses, businessCategories } from '@/db/schema';
import { eq, desc, and } from 'drizzle-orm';
import { INDUSTRIES } from '@/lib/constants';
import Avatar from '@/components/ui/Avatar.astro';

interface Props {
  initialType?: string;
}

const { initialType } = Astro.props;
const PAGE_SIZE = 12;
// Read type from URL search params for filtering
const type = Astro.url.searchParams.get('type') || initialType || 'business';
const search = Astro.url.searchParams.get('search') || '';
const industry = Astro.url.searchParams.get('industry') || '';
const category = Astro.url.searchParams.get('category') || '';
const page = parseInt(Astro.url.searchParams.get('page') || '1');
const sort = Astro.url.searchParams.get('sort') || 'recent';

// Build entity type filter
const statusFilter = eq(businesses.status, 'live');
const organizationType = Astro.url.searchParams.get('orgType') || '';

// Combine filters
const whereCondition = statusFilter;

// Get categories for filter
const db = await getDb();
const allCategories = await db.select().from(businessCategories).all();

// Query listings with combined filter
const allListings = await db
  .select({
    id: businesses.id,
    title: businesses.title,
    slug: businesses.slug,
    organizationType: businesses.organizationType,
    industry: businesses.industry,
    categoryId: businesses.categoryId,
    profileImageId: businesses.profileImageId,
    address: businesses.address,
    ratingAverage: businesses.ratingAverage,
    likes: businesses.likes,
    createdAt: businesses.createdAt,
  })
  .from(businesses)
  .where(whereCondition)
  .orderBy(desc(businesses.createdAt))
  .all();

// Apply search/filter in memory
let filteredListings = allListings;

if (search) {
  filteredListings = filteredListings.filter(l =>
    l.title.toLowerCase().includes(search.toLowerCase())
  );
}

if (industry && type === 'business') {
  filteredListings = filteredListings.filter(l =>
    l.industry?.startsWith(industry)
  );
}

if (category) {
  filteredListings = filteredListings.filter(l =>
    l.categoryId === category
  );
}

// Sort
if (sort === 'name') {
  filteredListings.sort((a, b) => a.title.localeCompare(b.title));
} else if (sort === 'rating') {
  filteredListings.sort((a, b) => (b.ratingAverage || 0) - (a.ratingAverage || 0));
} else if (sort === 'popular') {
  filteredListings.sort((a, b) => (b.likes || 0) - (a.likes || 0));
}

// Pagination
const total = filteredListings.length;
const offset = (page - 1) * PAGE_SIZE;
const listings = filteredListings.slice(offset, offset + PAGE_SIZE);
const totalPages = Math.ceil(total / PAGE_SIZE);

// Get page base URL
const pageBase = `/listings?type=${type}`;
const getPageUrl = (p: number) => `${pageBase}&page=${p}&search=${search}&industry=${industry}&category=${category}&sort=${sort}&orgType=${organizationType}`;
---

<!-- Results Count -->
<div class="mb-4 text-sm flex items-center gap-2">
  <span class="text-muted-foreground">Showing</span>
  <span class="font-semibold text-foreground">{listings.length}</span>
  <span class="text-muted-foreground">of</span>
  <span class="font-semibold text-primary">{total}</span>
  <span class="text-muted-foreground">listings</span>
  {type !== 'business' && (
    <span class="ml-auto px-2 py-0.5 text-xs rounded-full bg-primary/10 text-primary font-medium">
      {type === 'non-profit' ? 'Non-Profit' : 'Personal'}
    </span>
  )}
</div>

<!-- Listings Grid -->
<div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 listing-grid">
  {listings.map(listing => (
    <a
      href={type === 'business' ? `/business/${listing.slug}` : type === 'non-profit' ? `/non-profit/${listing.slug}` : `/listings/${listing.slug}`}
      class="listing-card block bg-card rounded-xl border shadow-sm hover:shadow-lg hover:border-primary/30 transition-all duration-200 overflow-hidden group cursor-pointer"
    >
      <div class="aspect-square relative overflow-hidden">
        <Avatar
          src={listing.profileImageId ? `/api/media/${listing.profileImageId}` : null}
          fallback={listing.title}
          size="xl"
          class="w-full h-full rounded-none"
        />
        {listing.ratingAverage && listing.ratingAverage > 0 && (
          <div class="absolute top-2 right-2 bg-black/70 text-white text-xs px-2 py-0.5 rounded-full flex items-center gap-1">
            <svg class="w-3 h-3 text-amber-400 fill-current" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <span class="sr-only">Rating: {listing.ratingAverage.toFixed(1)} stars</span>
            <span aria-hidden="true">{listing.ratingAverage.toFixed(1)}</span>
          </div>
        )}
      </div>
      <div class="p-3">
        <h3 class="font-semibold text-sm truncate group-hover:text-primary transition-colors">{listing.title}</h3>
        {listing.address && (
          <p class="text-xs text-muted-foreground truncate mt-1">{listing.address.split(',')[0]}</p>
        )}
        {type === 'business' && industry && (
          <p class="text-xs text-muted-foreground mt-1">
            {Object.entries(INDUSTRIES).find(([k]) => k === industry)?.[1]?.items?.[0] || industry}
          </p>
        )}
      </div>
    </a>
  ))}
</div>

{listings.length === 0 && (
  <div class="text-center py-12 text-muted-foreground">
    No listings found
  </div>
)}

<!-- Pagination -->
{totalPages > 1 && (
  <div class="flex justify-center gap-2 mt-8">
    {page > 1 && (
      <a href={getPageUrl(page - 1)} class="px-4 py-2 border rounded hover:bg-muted">Previous</a>
    )}
    <span class="px-4 py-2">Page {page} of {totalPages}</span>
    {page < totalPages && (
      <a href={getPageUrl(page + 1)} class="px-4 py-2 border rounded hover:bg-muted">Next</a>
    )}
  </div>
)}