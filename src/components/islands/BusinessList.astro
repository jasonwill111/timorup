---
// Server Island: Businesses list
import { getDb } from '@/lib/db';
import { businesses } from '@/db/schema';
import { eq, desc } from 'drizzle-orm';

const db = await getDb();
const searchParams = Astro.url.searchParams;
const page = Math.max(1, Number(searchParams.get('page') || 1));
const search = searchParams.get('q') || '';
const PAGE_SIZE = 24;
const OFFSET = (page - 1) * PAGE_SIZE;

// Guard: if db is null, show empty state
if (!db) {
  console.error('[BusinessList] Database not available');
}

let allBusinesses = db
  ? await db
      .select()
      .from(businesses)
      .where(eq(businesses.status, 'published'))
      .orderBy(desc(businesses.createdAt))
      .all()
  : [];

// Search filter
if (search) {
  allBusinesses = allBusinesses.filter(b =>
    b.title.toLowerCase().includes(search.toLowerCase()) ||
    (b.aboutUs && b.aboutUs.toLowerCase().includes(search.toLowerCase()))
  );
}

// Pagination
const total = allBusinesses.length;
const paginated = allBusinesses.slice(OFFSET, OFFSET + PAGE_SIZE);
const totalPages = Math.ceil(total / PAGE_SIZE);
---

{paginated.length > 0 ? (
  <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    {paginated.map(business => (
      <a
        href={`/business/${business.slug}`}
        class="block bg-card rounded-xl border shadow-sm hover:shadow-lg hover:border-primary/30 transition-all duration-200 overflow-hidden"
      >
        <div class="aspect-square bg-muted flex items-center justify-center">
          <svg class="w-12 h-12 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-1 4h1m-1 4h1"/>
          </svg>
        </div>
        <div class="p-3">
          <h3 class="font-semibold text-sm truncate">{business.title}</h3>
          {business.address && (
            <p class="text-xs text-muted-foreground truncate">{business.address.split(',')[0]}</p>
          )}
          {business.industry && (
            <span class="text-xs px-2 py-0.5 rounded bg-primary/10 text-primary capitalize">{business.industry}</span>
          )}
        </div>
      </a>
    ))}
  </div>
) : (
  <div class="text-center py-12 text-muted-foreground">
    No businesses found
  </div>
)}

{totalPages > 1 && (
  <div class="flex justify-center gap-2 mt-8">
    {page > 1 && (
      <a href={`/businesses?page=${page - 1}`} class="px-4 py-2 border rounded">Previous</a>
    )}
    <span class="px-4 py-2">Page {page} of {totalPages}</span>
    {page < totalPages && (
      <a href={`/businesses?page=${page + 1}`} class="px-4 py-2 border rounded">Next</a>
    )}
  </div>
)}