---
// Grace Period Modal - Shown when subscription expired and in grace period
interface Props {
  businessSlug: string;
  daysRemaining: number;
}

const { businessSlug, daysRemaining } = Astro.props;
---

<div id="grace-period-modal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50">
  <div class="bg-white dark:bg-gray-800 rounded-lg p-8 max-w-md mx-4 text-center shadow-xl">
    <div class="text-6xl mb-4">⏰</div>
    <h2 class="text-2xl font-bold mb-4">Subscription Expired</h2>
    <p class="text-gray-600 dark:text-gray-300 mb-4">
      请及时为Business Page续费,否则60天之后会删除。谢谢配合!
    </p>
    <p class="text-lg font-semibold text-primary mb-6" id="grace-days-display">
      {daysRemaining} days remaining to renew
    </p>
    <a
      href={`/subscribe?business=${businessSlug}`}
      class="inline-block bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors"
    >
      Renew Now
    </a>
  </div>
</div>

<script>
  // Update days remaining display
  const daysDisplay = document.getElementById('grace-days-display');
  if (daysDisplay) {
    const daysRemaining = parseInt(daysDisplay.dataset.days || '60', 10);
    daysDisplay.textContent = `${daysRemaining} days remaining to renew`;
  }
</script>
