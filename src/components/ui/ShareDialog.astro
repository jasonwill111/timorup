---
// ShareDialog.astro - Reusable share button with social platforms
interface Props {
  url: string;
  title: string;
  description?: string;
  class?: string;
}

const { url, title, description = '', class: className = '' } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
const encodedDesc = encodeURIComponent(description);

// Social share URLs
const shareUrls = {
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
  twitter: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
  whatsapp: `https://wa.me/?text=${encodedTitle}%20${encodedUrl}`,
  telegram: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`,
  copy: url, // handled in JS
};
---

<button
  id="share-btn"
  class={`share-trigger px-3 py-1.5 rounded-lg border hover:bg-muted flex items-center gap-1.5 transition-colors cursor-pointer ${className}`}
  data-url={url}
  data-title={title}
  data-description={description}
  title="Share"
>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
  </svg>
  <span>Share</span>
</button>

<!-- Share Dialog -->
<div id="share-dialog" class="fixed inset-0 z-50 hidden">
  <!-- Backdrop -->
  <div id="share-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Dialog -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-background rounded-xl shadow-2xl border p-4 min-w-[280px] max-w-[320px]">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-semibold text-sm">Share to</h3>
      <button id="share-close" class="p-1 hover:bg-muted rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="grid grid-cols-4 gap-2">
      <!-- Facebook -->
      <button class="share-platform flex flex-col items-center gap-1.5 p-2 rounded-lg hover:bg-muted transition-colors" data-platform="facebook">
        <div class="w-9 h-9 rounded-full bg-blue-600 flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </div>
        <span class="text-xs text-muted-foreground">Facebook</span>
      </button>

      <!-- Instagram -->
      <button class="share-platform flex flex-col items-center gap-1.5 p-2 rounded-lg hover:bg-muted transition-colors" data-platform="instagram">
        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-purple-600 via-pink-500 to-orange-400 flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </div>
        <span class="text-xs text-muted-foreground">Instagram</span>
      </button>

      <!-- WhatsApp -->
      <button class="share-platform flex flex-col items-center gap-1.5 p-2 rounded-lg hover:bg-muted transition-colors" data-platform="whatsapp">
        <div class="w-9 h-9 rounded-full bg-green-500 flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </div>
        <span class="text-xs text-muted-foreground">WhatsApp</span>
      </button>

      <!-- TikTok -->
      <button class="share-platform flex flex-col items-center gap-1.5 p-2 rounded-lg hover:bg-muted transition-colors" data-platform="tiktok">
        <div class="w-9 h-9 rounded-full bg-black flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
          </svg>
        </div>
        <span class="text-xs text-muted-foreground">TikTok</span>
      </button>

      <!-- Viber -->
      <button class="share-platform flex flex-col items-center gap-1.5 p-2 rounded-lg hover:bg-muted transition-colors" data-platform="viber">
        <div class="w-9 h-9 rounded-full bg-violet-500 flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.013 6.208c-.155-1.648-1.085-2.883-2.652-3.442-1.421-.501-3.493-.358-5.093.358-1.601.716-2.474 2.017-2.552 3.584-.083 1.655.64 3.163 1.78 4.22l-.93 3.37 3.432-.93c.95.476 2.078.746 3.312.746.083 0 .164-.005.248-.006 1.63-.083 3.163-.64 4.22-1.779.999-1.086 1.56-2.482 1.56-3.921 0-.984-.32-1.94-.934-2.753-.63-.826-1.507-1.452-2.39-1.735-.277-.083-.557-.159-.84-.23l-.01-.023zm2.333-2.133c.42-.42.628-.97.628-1.563 0-.593-.207-1.143-.628-1.563-.42-.42-.97-.628-1.563-.628-.592 0-1.142.207-1.562.628-.42.42-.628.97-.628 1.563 0 .593.207 1.143.628 1.563.42.42.97.628 1.562.628.592 0 1.143-.207 1.563-.628zM6.52 2.9c.69 0 1.25.56 1.25 1.25s-.56 1.25-1.25 1.25-1.25-.56-1.25-1.25.56-1.25 1.25-1.25zm11.07 2.17c-.42.42-.628.97-.628 1.563 0 .593.208 1.143.628 1.563.42.42.97.628 1.563.628.592 0 1.143-.207 1.562-.628.42-.42.628-.97.628-1.563 0-.593-.207-1.143-.628-1.563-.419-.42-.97-.628-1.562-.628-.593 0-1.143.207-1.563.628zM12 0C8.495 0 5.18 1.655 2.803 4.585c-2.373 2.93-3.035 6.842-1.77 10.45l.07.2 1.77 6.39c.13.47.68.76 1.23.63l6.42-1.75h.02c3.65 1.29 7.72.61 10.54-1.82C24.32 15.09 25 11.77 25 8.27 25 3.7 19.29 0 12 0zm0 8.27c-2.08 0-3.76 1.68-3.76 3.76s1.68 3.76 3.76 3.76 3.76-1.68 3.76-3.76-1.68-3.76-3.76-3.76z"/>
          </svg>
        </div>
        <span class="text-xs text-muted-foreground">Viber</span>
      </button>

      <!-- X/Twitter -->
      <button class="share-platform flex flex-col items-center gap-1.5 p-2 rounded-lg hover:bg-muted transition-colors" data-platform="twitter">
        <div class="w-9 h-9 rounded-full bg-black flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </div>
        <span class="text-xs text-muted-foreground">X</span>
      </button>

      <!-- Telegram -->
      <button class="share-platform flex flex-col items-center gap-1.5 p-2 rounded-lg hover:bg-muted transition-colors" data-platform="telegram">
        <div class="w-9 h-9 rounded-full bg-blue-500 flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
        </div>
        <span class="text-xs text-muted-foreground">Telegram</span>
      </button>

      <!-- LinkedIn -->
      <button class="share-platform flex flex-col items-center gap-1.5 p-2 rounded-lg hover:bg-muted transition-colors" data-platform="linkedin">
        <div class="w-9 h-9 rounded-full bg-blue-700 flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <span class="text-xs text-muted-foreground">LinkedIn</span>
      </button>

      <!-- SMS -->
      <button class="share-platform flex flex-col items-center gap-1.5 p-2 rounded-lg hover:bg-muted transition-colors" data-platform="sms">
        <div class="w-9 h-9 rounded-full bg-gray-500 flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
          </svg>
        </div>
        <span class="text-xs text-muted-foreground">SMS</span>
      </button>

      <!-- Copy Link -->
      <button class="share-platform flex flex-col items-center gap-1.5 p-2 rounded-lg hover:bg-muted transition-colors" data-platform="copy">
        <div class="w-9 h-9 rounded-full bg-muted flex items-center justify-center">
          <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
        </div>
        <span class="text-xs text-muted-foreground">Copy</span>
      </button>
    </div>
  </div>
</div>

<script define:vars={{ shareUrls }}>
  const dialog = document.getElementById('share-dialog');
  const backdrop = document.getElementById('share-backdrop');
  const closeBtn = document.getElementById('share-close');
  const shareBtn = document.getElementById('share-btn');
  const platforms = document.querySelectorAll('.share-platform');

  let currentUrl = '';
  let currentTitle = '';

  function openDialog(e) {
    e.preventDefault();
    currentUrl = shareBtn?.dataset.url || '';
    currentTitle = shareBtn?.dataset.title || '';
    dialog?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeDialog() {
    dialog?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function shareTo(platform) {
    const encodedUrl = encodeURIComponent(currentUrl);
    const encodedTitle = encodeURIComponent(currentTitle);

    switch (platform) {
      case 'facebook':
        window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`, '_blank', 'width=600,height=400');
        break;
      case 'instagram':
        // Instagram doesn't have web share API, copy link instead
        navigator.clipboard.writeText(currentUrl);
        alert('Link copied! Open Instagram and paste.');
        break;
      case 'twitter':
        window.open(`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`, '_blank', 'width=600,height=400');
        break;
      case 'linkedin':
        window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`, '_blank', 'width=600,height=400');
        break;
      case 'whatsapp':
        window.open(`https://wa.me/?text=${encodedTitle}%20${encodedUrl}`, '_blank');
        break;
      case 'tiktok':
        // TikTok web share is limited, show message
        navigator.clipboard.writeText(currentUrl);
        alert('Link copied! Open TikTok and paste.');
        break;
      case 'viber':
        window.open(`viber://forward?text=${encodedTitle}%20${encodedUrl}`, '_blank');
        break;
      case 'telegram':
        window.open(`https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`, '_blank', 'width=600,height=400');
        break;
      case 'sms':
        window.open(`sms:?body=${encodedTitle}%20${encodedUrl}`, '_blank');
        break;
      case 'copy':
        navigator.clipboard.writeText(currentUrl).then(() => {
          closeDialog();
          // Show toast
          const toast = document.createElement('div');
          toast.className = 'fixed bottom-4 left-1/2 -translate-x-1/2 bg-green-500 text-white px-4 py-2 rounded-lg shadow-lg text-sm z-50';
          toast.textContent = 'Link copied!';
          document.body.appendChild(toast);
          setTimeout(() => toast.remove(), 2000);
        });
        return;
    }
    closeDialog();
  }

  // Event listeners
  shareBtn?.addEventListener('click', openDialog);
  backdrop?.addEventListener('click', closeDialog);
  closeBtn?.addEventListener('click', closeDialog);

  platforms.forEach(btn => {
    btn.addEventListener('click', () => {
      const platform = btn.dataset.platform;
      if (platform) shareTo(platform);
    });
  });

  // Close on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !dialog?.classList.contains('hidden')) {
      closeDialog();
    }
  });
</script>