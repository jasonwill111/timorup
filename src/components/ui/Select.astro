---
interface Option {
  value: string;
  label: string;
  disabled?: boolean;
}

interface Props {
  options?: Option[];
  class?: string;
  disabled?: boolean;
  required?: boolean;
  name?: string;
  id?: string;
  'data-slot'?: string;
}

const {
  options = [],
  class: className = '',
  disabled = false,
  required = false,
  name,
  id,
  'data-slot': slot = 'select',
  ...props
} = Astro.props;
---

<select
  class:list={[
    'flex h-11 w-full items-center justify-between rounded-md border border-input bg-background px-3 py-2.5 text-base ring-offset-background placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50',
    className
  ]}
  disabled={disabled}
  required={required}
  name={name}
  id={id}
  data-slot={slot}
  {...props}
>
  <slot />
  {options.map((option) => (
    <option value={option.value} disabled={option.disabled}>
      {option.label}
    </option>
  ))}
</select>
