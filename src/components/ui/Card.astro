---
interface Props {
  class?: string;
  hover?: boolean;
  'data-slot'?: string;
}

const {
  class: className = '',
  hover = false,
  'data-slot': slot = 'card',
  ...props
} = Astro.props;
---

<div
  class:list={[
    'rounded-2xl border bg-card text-card-foreground shadow',
    hover && 'transition-all duration-300 hover:shadow-xl hover:shadow-primary/10 hover:border-primary/30 hover:-translate-y-0.5',
    className
  ]}
  data-slot={slot}
  {...props}
>
  <slot />
</div>
