---
/**
 * LocationMap - Reusable Leaflet map component for business/org pages
 * Props:
 *   - id: unique map container ID
 *   - lat: latitude
 *   - lng: longitude
 *   - address: address text to display
 *   - openFn: name of global function to call on map click
 */
interface Props {
  id: string;
  lat: number;
  lng: number;
  address?: string;
  openFn?: string;
}

const { id, lat, lng, address = 'Location', openFn = 'openMap' } = Astro.props;
---

<div class="relative group">
  <div
    id={id}
    class="aspect-video rounded-xl overflow-hidden border shadow-md transition-all duration-300 md:group-hover:shadow-lg md:group-hover:scale-[1.02] cursor-pointer"
  ></div>

  <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent opacity-0 md:opacity-0 transition-opacity duration-300 pointer-events-none rounded-xl"></div>

  <div class="absolute bottom-3 left-3 right-3 flex justify-between items-end">
    <div class="bg-white/90 backdrop-blur-sm rounded-lg px-3 py-1.5 shadow-sm">
      <p class="text-xs font-medium text-foreground max-w-[60%] md:max-w-full truncate">{address}</p>
    </div>
    <button
      onclick={`${openFn}('${lat}', '${lng}')`}
      class="bg-brand-500 hover:bg-brand-600 text-white rounded-full px-3 py-2 text-xs sm:text-sm font-medium shadow-lg flex items-center gap-1 sm:gap-2 transition-all duration-200 hover:scale-105 active:scale-95 touch-manipulation min-h-[44px] min-w-[80px] sm:min-w-0 justify-center"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
      </svg>
      <span class="hidden xs:inline">Navigate</span>
    </button>
  </div>
</div>

{/* Copyable Address */}
{address && address !== 'Location' && (
  <div class="mt-2 flex items-center gap-2">
    <p class="text-xs text-muted-foreground select-all cursor-pointer flex-1 truncate" title="Click to copy">{address}</p>
    <button
      onclick={`navigator.clipboard.writeText('${address}').then(() => { const btn = this; btn.textContent = '✓'; setTimeout(() => btn.textContent = 'Copy', 1500); })`}
      class="text-xs text-muted-foreground hover:text-foreground transition-colors px-2 py-1 rounded hover:bg-muted"
    >
      Copy
    </button>
  </div>
)}

<script define:vars={{ lat, lng, address, id, openFn }}>
  // Global map initializer - call this from any page
  window.initLocationMap = window.initLocationMap || {};

  function initMap() {
    const mapEl = document.getElementById(id);
    if (!mapEl || mapEl._leaflet_id) return;

    // Load Leaflet if not present
    if (typeof window.L === 'undefined') {
      if (!document.querySelector('link[href*="leaflet"]')) {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
        document.head.appendChild(link);
      }
      if (!document.querySelector('script[src*="leaflet"]')) {
        const script = document.createElement('script');
        script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
        script.onload = createMap;
        document.head.appendChild(script);
      } else {
        createMap();
      }
    } else {
      createMap();
    }
  }

  function createMap() {
    const mapEl = document.getElementById(id);
    if (!mapEl || mapEl._leaflet_id) return;

    const map = window.L.map(id, {
      center: [lat, lng],
      zoom: 15,
      scrollWheelZoom: false,
      attributionControl: false,
      zoomControl: false,
    });

    window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      opacity: 0.9
    }).addTo(map);

    // Custom animated brand marker
    const icon = window.L.divIcon({
      html: `<div class="relative">
        <div class="absolute -top-8 left-1/2 -translate-x-1/2 animate-bounce">
          <div class="bg-brand-500 text-white p-3 rounded-full shadow-lg border-2 border-white">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          </div>
          <div class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-3 h-3 bg-brand-500 rotate-45"></div>
        </div>
      </div>`,
      iconSize: [32, 48],
      iconAnchor: [16, 48],
      className: 'custom-marker'
    });

    window.L.marker([lat, lng], { icon })
      .addTo(map)
      .bindPopup(`<div class="p-2"><strong class="text-sm">${address}</strong></div>`)
      .openPopup();

    // Click to navigate
    map.on('click', () => window[openFn]?.(lat, lng));

    // Store reference
    window.initLocationMap[id] = map;
  }

  // Initialize when DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
</script>
