---
interface Props {
  class?: string;
  'data-slot'?: string;
}

const {
  class: className = '',
  'data-slot': slot = 'card-title',
  ...props
} = Astro.props;
---

<h3
  class:list={[
    'text-2xl font-semibold leading-none tracking-tight',
    className
  ]}
  data-slot={slot}
  {...props}
>
  <slot />
</h3>
