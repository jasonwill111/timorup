---
interface MediaItem {
  id: string;
  url: string;
  type?: 'image' | 'video';
  thumbnail?: string;
  alt?: string;
}

interface Props {
  items: MediaItem[];
  title?: string;
  gridCols?: number;
  maxDisplay?: number;
  class?: string;
}

const {
  items = [],
  title = 'Photo Gallery',
  gridCols = 3,
  maxDisplay = 6,
  class: className = '',
} = Astro.props;

// Add type field based on URL extension if not specified
const mediaItems = items.slice(0, maxDisplay).map(item => ({
  ...item,
  type: item.type || (item.url.match(/\.(mp4|webm|ogg|mov)$/i) ? 'video' : 'image'),
}));

// Serialize for client
const mediaItemsJson = JSON.stringify(mediaItems);
---

<section class:list={["mb-6", className]}>
  <h3 class="font-semibold text-sm mb-3 flex items-center gap-2">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
    </svg>
    {title}
    {items.length > maxDisplay && (
      <span class="text-xs text-muted-foreground">({maxDisplay}/{items.length})</span>
    )}
  </h3>

  {mediaItems.length > 0 ? (
    <div
      id="media-gallery-grid"
      class="grid gap-2"
      style={`grid-template-columns: repeat(${gridCols}, 1fr)`}
    >
      {mediaItems.map((item, idx) => (
        <button
          class:list={[
            "media-gallery-item aspect-square rounded-lg overflow-hidden bg-muted cursor-pointer",
            "hover:opacity-90 transition-all duration-200",
            "focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
          ]}
          data-media-idx={idx}
          data-media-type={item.type}
          data-media-src={item.url}
          aria-label={`View ${item.type === 'video' ? 'video' : 'photo'} ${idx + 1}`}
        >
          {item.type === 'video' ? (
            <div class="relative w-full h-full group">
              <img
                src={item.thumbnail || item.url}
                alt={item.alt || `Video ${idx + 1}`}
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-black/40 flex items-center justify-center group-hover:bg-black/50 transition-colors">
                <div class="w-12 h-12 rounded-full bg-white/90 flex items-center justify-center">
                  <svg class="w-6 h-6 text-gray-800 ml-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
            </div>
          ) : (
            <img
              src={item.url}
              alt={item.alt || `Gallery ${idx + 1}`}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          )}
        </button>
      ))}
    </div>
  ) : (
    <div
      class="grid gap-2"
      style={`grid-template-columns: repeat(${gridCols}, 1fr)`}
    >
      {[...Array(Math.min(gridCols * 2, 6))].map(() => (
        <div class="aspect-square rounded-lg border-2 border-dashed border-muted-foreground/20 flex items-center justify-center bg-muted/30">
          <svg class="w-6 h-6 text-muted-foreground/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
      ))}
    </div>
  )}
</section>

<!-- Lightbox Modal -->
<div
  id="media-lightbox"
  class="fixed inset-0 z-50 bg-black/95 hidden opacity-0"
  aria-modal="true"
  role="dialog"
  aria-label="Media gallery viewer"
>
  <!-- Close button -->
  <button
    id="lightbox-close"
    class="absolute top-4 right-4 z-10 p-2 text-white/80 hover:text-white hover:bg-white/10 rounded-full transition-all duration-200"
    aria-label="Close gallery"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

  <!-- Navigation: Previous -->
  <button
    id="lightbox-prev"
    class="absolute left-2 md:left-4 top-1/2 -translate-y-1/2 z-10 p-2 md:p-3 text-white/80 hover:text-white hover:bg-white/10 rounded-full transition-all duration-200"
    aria-label="Previous"
  >
    <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
  </button>

  <!-- Navigation: Next -->
  <button
    id="lightbox-next"
    class="absolute right-2 md:right-4 top-1/2 -translate-y-1/2 z-10 p-2 md:p-3 text-white/80 hover:text-white hover:bg-white/10 rounded-full transition-all duration-200"
    aria-label="Next"
  >
    <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
  </button>

  <!-- Media container -->
  <div id="lightbox-media-container" class="flex items-center justify-center w-full h-full p-4 md:p-8">
    <div id="lightbox-content" class="max-w-full max-h-full"></div>
  </div>

  <!-- Counter -->
  <div id="lightbox-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/70 text-sm font-medium"></div>

  <!-- Thumbnails strip -->
  <div id="lightbox-thumbnails" class="absolute bottom-12 left-1/2 -translate-x-1/2 flex gap-1 max-w-[90vw] overflow-x-auto pb-2 px-4">
  </div>
</div>

<script define:vars={{ mediaItemsJson }}>
  const mediaItems = JSON.parse(mediaItemsJson);

  const lightbox = document.getElementById('media-lightbox');
  const content = document.getElementById('lightbox-content');
  const counter = document.getElementById('lightbox-counter');
  const thumbnailsContainer = document.getElementById('lightbox-thumbnails');
  const galleryItems = document.querySelectorAll('[data-media-idx]');

  let currentIdx = 0;
  let touchStartX = 0;
  let touchEndX = 0;

  function showMedia(idx: number) {
    if (!content || !counter || mediaItems.length === 0) return;
    currentIdx = (idx + mediaItems.length) % mediaItems.length;
    const item = mediaItems[currentIdx];

    content.innerHTML = '';

    if (item.type === 'video') {
      const video = document.createElement('video');
      video.src = item.url;
      video.controls = true;
      video.autoplay = true;
      video.className = 'max-w-full max-h-[80vh] md:max-h-[85vh] object-contain rounded-lg lightbox-media-enter';
      video.setAttribute('playsinline', '');
      content.appendChild(video);
    } else {
      const img = document.createElement('img');
      img.src = item.url;
      img.alt = item.alt || `Media ${currentIdx + 1}`;
      img.className = 'max-w-full max-h-[80vh] md:max-h-[85vh] object-contain rounded-lg lightbox-media-enter';
      img.loading = 'eager';
      content.appendChild(img);
    }

    counter.textContent = `${currentIdx + 1} / ${mediaItems.length}`;
    updateThumbnails();
  }

  function updateThumbnails() {
    if (!thumbnailsContainer) return;
    thumbnailsContainer.innerHTML = '';

    mediaItems.forEach((item: MediaItem, idx: number) => {
      const thumb = document.createElement('button');
      thumb.className = `flex-shrink-0 w-12 h-12 md:w-14 md:h-14 rounded-lg overflow-hidden border-2 transition-all duration-200 thumb-btn ${
        idx === currentIdx ? 'border-white scale-110' : 'border-transparent opacity-60 hover:opacity-100'
      }`;
      thumb.setAttribute('aria-label', `Go to media ${idx + 1}`);

      if (item.type === 'video') {
        const wrapper = document.createElement('div');
        wrapper.className = 'relative w-full h-full';
        const img = document.createElement('img');
        img.src = item.thumbnail || item.url;
        img.alt = '';
        img.className = 'w-full h-full object-cover';
        wrapper.appendChild(img);
        const playIcon = document.createElement('div');
        playIcon.className = 'absolute inset-0 flex items-center justify-center bg-black/30';
        playIcon.innerHTML = '<svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
        wrapper.appendChild(playIcon);
        thumb.appendChild(wrapper);
      } else {
        const img = document.createElement('img');
        img.src = item.url;
        img.alt = '';
        img.className = 'w-full h-full object-cover';
        thumb.appendChild(img);
      }

      thumb.addEventListener('click', () => {
        showMedia(idx);
        thumb.classList.add('thumb-click');
        setTimeout(() => thumb.classList.remove('thumb-click'), 200);
      });

      thumbnailsContainer.appendChild(thumb);
    });
  }

  function openLightbox(idx: number) {
    if (!lightbox) return;
    currentIdx = idx;
    showMedia(currentIdx);
    lightbox.classList.remove('hidden');
    lightbox.classList.add('lightbox-enter');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.classList.remove('lightbox-enter');
    lightbox.classList.add('lightbox-exit');
    setTimeout(() => {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('lightbox-exit');
      content.innerHTML = '';
      document.body.style.overflow = '';
    }, 200);
  }

  galleryItems.forEach((item) => {
    item.addEventListener('click', () => {
      const idx = parseInt(item.getAttribute('data-media-idx') || '0', 10);
      openLightbox(idx);
    });
  });

  document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
  document.getElementById('lightbox-prev')?.addEventListener('click', () => showMedia(currentIdx - 1));
  document.getElementById('lightbox-next')?.addEventListener('click', () => showMedia(currentIdx + 1));

  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox || e.target.id === 'lightbox-media-container') {
      closeLightbox();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox || lightbox.classList.contains('hidden')) return;
    switch (e.key) {
      case 'Escape': closeLightbox(); break;
      case 'ArrowLeft': showMedia(currentIdx - 1); break;
      case 'ArrowRight': showMedia(currentIdx + 1); break;
    }
  });

  lightbox?.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });

  lightbox?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    const swipeThreshold = 50;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > swipeThreshold) {
      diff > 0 ? showMedia(currentIdx + 1) : showMedia(currentIdx - 1);
    }
  }, { passive: true });
</script>

<style>
  #media-lightbox {
    backdrop-filter: blur(8px);
  }

  .lightbox-enter {
    animation: lightboxIn 0.25s ease-out forwards;
  }

  .lightbox-exit {
    animation: lightboxOut 0.2s ease-in forwards;
  }

  .lightbox-media-enter {
    animation: mediaIn 0.25s ease-out forwards;
  }

  .thumb-btn {
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .thumb-click {
    animation: thumbPop 0.2s ease-out;
  }

  #lightbox-thumbnails::-webkit-scrollbar {
    height: 4px;
  }

  #lightbox-thumbnails::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 2px;
  }

  #lightbox-thumbnails::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.3);
    border-radius: 2px;
  }

  #lightbox-thumbnails::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.5);
  }

  @keyframes lightboxIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes lightboxOut {
    from { opacity: 1; }
    to { opacity: 0; }
  }

  @keyframes mediaIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes thumbPop {
    0% { transform: scale(1); }
    50% { transform: scale(1.15); }
    100% { transform: scale(1); }
  }
</style>
