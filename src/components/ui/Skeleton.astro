---
interface Props {
  class?: string;
  'data-slot'?: string;
}

const {
  class: className = '',
  'data-slot': slot = 'skeleton',
  ...props
} = Astro.props;
---

<div
  class:list={[
    'animate-pulse rounded-md bg-muted',
    className
  ]}
  data-slot={slot}
  {...props}
>
  <slot />
</div>

<!-- Business Card Skeleton -->
<div class="block bg-card rounded-xl border shadow-sm overflow-hidden" data-skeleton="business-card">
  <div class="aspect-[4/3] bg-muted animate-pulse"></div>
  <div class="p-3">
    <div class="h-4 w-3/4 bg-muted rounded animate-pulse mb-2"></div>
    <div class="h-3 w-1/2 bg-muted rounded animate-pulse mb-3"></div>
    <div class="flex items-center justify-between pt-2 border-t border-border/50">
      <div class="h-3 w-16 bg-muted rounded animate-pulse"></div>
      <div class="h-5 w-12 bg-muted rounded animate-pulse"></div>
    </div>
  </div>
</div>

<!-- Product Card Skeleton -->
<div class="block bg-card rounded-xl border shadow-sm overflow-hidden" data-skeleton="product-card">
  <div class="aspect-square bg-muted animate-pulse"></div>
  <div class="p-3">
    <div class="h-4 w-3/4 bg-muted rounded animate-pulse mb-1"></div>
    <div class="h-3 w-1/2 bg-muted rounded animate-pulse mb-2"></div>
    <div class="h-5 w-20 bg-muted rounded animate-pulse"></div>
  </div>
</div>

<!-- Category Skeleton -->
<div class="p-4 text-center border rounded-xl" data-skeleton="category">
  <div class="w-10 h-10 mx-auto bg-muted rounded-lg animate-pulse mb-2"></div>
  <div class="h-4 w-16 mx-auto bg-muted rounded animate-pulse"></div>
</div>
