---
interface Props {
  class?: string;
  'data-slot'?: string;
}

const {
  class: className = '',
  'data-slot': slot = 'skeleton',
  ...props
} = Astro.props;
---

<div
  class:list={[
    'animate-pulse rounded-md bg-muted',
    className
  ]}
  data-slot={slot}
  {...props}
>
  <slot />
</div>
