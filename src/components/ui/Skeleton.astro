---
// Reusable Skeleton Loading Components
interface Props {
  variant?: 'line' | 'circle' | 'square' | 'card' | 'text' | 'avatar';
  width?: string;
  height?: string;
  class?: string;
  count?: number;
  'data-slot'?: string;
}

const {
  variant = 'line',
  width,
  height,
  class: className = '',
  count = 1,
  'data-slot': slot = 'skeleton',
  ...props
} = Astro.props;

const baseClass = 'bg-muted rounded animate-pulse';

const variantStyles = {
  line: 'h-4 w-full',
  circle: 'h-10 w-10 rounded-full',
  square: 'h-20 w-20 rounded-lg',
  text: 'h-4 w-3/4',
  avatar: 'h-10 w-10 rounded-full',
  card: 'aspect-[4/3] rounded-xl',
};

const style = [
  width ? `width: ${width}` : '',
  height ? `height: ${height}` : '',
].filter(Boolean).join('; ');
---

{count === 1 ? (
  <div
    class:list={[baseClass, variantStyles[variant] || variantStyles.line, className]}
    data-slot={slot}
    style={style || undefined}
    {...props}
  />
) : (
  Array.from({ length: count }).map(() => (
    <div
      class:list={[baseClass, variantStyles[variant] || variantStyles.line, className]}
      data-slot={slot}
      style={style || undefined}
      {...props}
    />
  ))
)}