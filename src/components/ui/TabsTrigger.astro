---
interface Props {
  value: string;
  class?: string;
  'data-slot'?: string;
}

const {
  value,
  class: className = '',
  'data-slot': slot = 'tabs-trigger',
  ...props
} = Astro.props;
---

<button
  type="button"
  class:list={[
    'inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-2.5 text-sm font-medium min-h-[44px] ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 data-active:bg-background data-active:text-foreground data-active:shadow-sm',
    className
  ]}
  data-tab-trigger={value}
  data-slot={slot}
  {...props}
>
  <slot />
</button>
