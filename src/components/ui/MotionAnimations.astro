---
// Motion animations for TimorUp - Enhanced UI/UX
---

<script>
import { animate, stagger, inView } from 'motion';

// ===== EXISTING FUNCTIONS =====

// Entrance animations
export function fadeInUp(selector: string, delay = 0) {
  const elements = document.querySelectorAll(selector);
  elements.forEach((el, i) => {
    animate(
      el,
      { opacity: [0, 1], y: [20, 0] },
      { duration: 0.4, delay: delay + i * 0.05, easing: [0.25, 0.1, 0.25, 1] }
    );
  });
}

// Text reveal animation
export function textReveal(element: Element, duration = 0.8) {
  const words = element.textContent?.split(' ') || [];
  const fragment = document.createDocumentFragment();
  words.forEach((word, i) => {
    const span = document.createElement('span');
    span.className = 'word-reveal';
    span.style.cssText = 'display: inline-block; opacity: 0; transform: translateY(100%)';
    span.textContent = word;
    fragment.appendChild(span);
  });
  element.textContent = '';
  element.appendChild(fragment);

  element.querySelectorAll('.word-reveal').forEach((word, i) => {
    animate(
      word,
      { opacity: [0, 1], y: [20, 0] },
      { duration, delay: i * 0.05, easing: 'ease-out' }
    );
  });
}

// Scale in animation
export function scaleIn(selector: string, delay = 0) {
  const elements = document.querySelectorAll(selector);
  elements.forEach((el, i) => {
    animate(
      el,
      { opacity: [0, 1], scale: [0.9, 1] },
      { duration: 0.3, delay: delay + i * 0.03, easing: 'ease-out' }
    );
  });
}

// Hover lift effect
export function addHoverLift(selector: string) {
  const elements = document.querySelectorAll(selector);
  elements.forEach(el => {
    el.addEventListener('mouseenter', () => {
      animate(el, { y: -4, boxShadow: '0 12px 24px rgba(0,0,0,0.1)' }, { duration: 0.2 });
    });
    el.addEventListener('mouseleave', () => {
      animate(el, { y: 0, boxShadow: '0 4px 6px rgba(0,0,0,0.05)' }, { duration: 0.2 });
    });
  });
}

// Slide in from left
export function slideInLeft(selector: string, delay = 0) {
  const elements = document.querySelectorAll(selector);
  elements.forEach((el, i) => {
    animate(
      el,
      { opacity: [0, 1], x: [-30, 0] },
      { duration: 0.4, delay: delay + i * 0.08, easing: [0.25, 0.1, 0.25, 1] }
    );
  });
}

// Slide in from right
export function slideInRight(selector: string, delay = 0) {
  const elements = document.querySelectorAll(selector);
  elements.forEach((el, i) => {
    animate(
      el,
      { opacity: [0, 1], x: [30, 0] },
      { duration: 0.4, delay: delay + i * 0.08, easing: [0.25, 0.1, 0.25, 1] }
    );
  });
}

// Button click feedback
export function addButtonFeedback(selector: string) {
  const elements = document.querySelectorAll(selector);
  elements.forEach(el => {
    el.addEventListener('mousedown', () => {
      animate(el, { scale: 0.95 }, { duration: 0.1 });
    });
    el.addEventListener('mouseup', () => {
      animate(el, { scale: 1 }, { duration: 0.1 });
    });
  });
}

// Link hover underline animation
export function addLinkUnderline(selector: string) {
  const elements = document.querySelectorAll(selector);
  elements.forEach(el => {
    el.addEventListener('mouseenter', () => {
      animate(el, { textDecorationThickness: [0, 2] }, { duration: 0.2 });
    });
    el.addEventListener('mouseleave', () => {
      animate(el, { textDecorationThickness: [2, 0] }, { duration: 0.2 });
    });
  });
}

// Counter animation
export function animateCounter(element: Element, target: number, duration = 1) {
  const start = 0;
  animate((t) => {
    const value = Math.round(start + (target - start) * t);
    element.textContent = value.toString();
  }, { duration });
}

// Filter tag click effect
export function addFilterClickEffect(selector: string) {
  const elements = document.querySelectorAll(selector);
  elements.forEach(el => {
    el.addEventListener('click', () => {
      animate(el, { scale: [1, 0.9, 1.05, 1] }, { duration: 0.3 });
    });
  });
}

// Card border glow on hover
export function addCardGlow(selector: string) {
  const elements = document.querySelectorAll(selector);
  elements.forEach(el => {
    el.addEventListener('mouseenter', () => {
      animate(el, { '--tw-shadow-color': 'rgba(255, 209, 80, 0.4)' }, { duration: 0.3 });
    });
    el.addEventListener('mouseleave', () => {
      animate(el, { '--tw-shadow-color': 'rgba(0, 0, 0, 0.05)' }, { duration: 0.3 });
    });
  });
}

// Staggered fade in for children
export function staggerFadeIn(parentSelector: string, childSelector: string, delay = 0) {
  const parent = document.querySelector(parentSelector);
  if (!parent) return;
  const children = parent.querySelectorAll(childSelector);
  children.forEach((child, i) => {
    animate(
      child,
      { opacity: [0, 1], y: [15, 0] },
      { duration: 0.35, delay: delay + i * 0.06, easing: [0.25, 0.1, 0.25, 1] }
    );
  });
}

// ===== NEW ENHANCED FUNCTIONS =====

// Modal/Dialog animations
export function modalIn(modalEl: Element) {
  const backdrop = modalEl.querySelector('.modal-backdrop') as HTMLElement;
  const content = modalEl.querySelector('.modal-content') as HTMLElement;

  if (backdrop) {
    animate(backdrop, { opacity: [0, 1] }, { duration: 0.2 });
  }
  if (content) {
    animate(content, { opacity: [0, 1], scale: [0.95, 1], y: [10, 0] }, { duration: 0.25, easing: [0.34, 1.56, 0.64, 1] });
  }
}

export function modalOut(modalEl: Element, onComplete?: () => void) {
  const backdrop = modalEl.querySelector('.modal-backdrop') as HTMLElement;
  const content = modalEl.querySelector('.modal-content') as HTMLElement;

  if (content) {
    animate(content, { opacity: [1, 0], scale: [1, 0.95], y: [0, -10] }, { duration: 0.2 }).finished.then(() => {
      if (backdrop) animate(backdrop, { opacity: [1, 0] }, { duration: 0.15 }).finished.then(() => onComplete?.());
      else onComplete?.();
    });
  } else if (backdrop) {
    animate(backdrop, { opacity: [1, 0] }, { duration: 0.15 }).finished.then(() => onComplete?.());
  } else {
    onComplete?.();
  }
}

// Toast/Notification animations
export function toastIn(toastEl: Element) {
  animate(toastEl, { opacity: [0, 1], x: [100, 0] }, { duration: 0.3, easing: [0.34, 1.56, 0.64, 1] });
}

export function toastOut(toastEl: Element, onComplete?: () => void) {
  animate(toastEl, { opacity: [1, 0], x: [0, 100] }, { duration: 0.25 }).finished.then(() => onComplete?.());
}

// Tab switch animation
export function tabSwitch(tabContent: Element, direction: 'left' | 'right' = 'right') {
  const xOffset = direction === 'right' ? 20 : -20;
  animate(tabContent, { opacity: [0, 1], x: [xOffset, 0] }, { duration: 0.25, easing: 'ease-out' });
}

// Accordion animation
export function accordionOpen(panel: HTMLElement) {
  panel.style.overflow = 'hidden';
  const height = panel.scrollHeight;
  animate(panel, { height: [0, height], opacity: [0, 1] }, { duration: 0.3, easing: 'ease-out' }).finished.then(() => {
    panel.style.height = 'auto';
  });
}

export function accordionClose(panel: HTMLElement) {
  panel.style.overflow = 'hidden';
  const height = panel.scrollHeight;
  animate(panel, { height: [height, 0], opacity: [1, 0] }, { duration: 0.25, easing: 'ease-in' }).finished.then(() => {
    panel.style.display = 'none';
  });
}

// Loading skeleton shimmer
export function addSkeletonShimmer(selector: string) {
  const elements = document.querySelectorAll(selector);
  elements.forEach(el => {
    const shimmer = document.createElement('div');
    shimmer.className = 'skeleton-shimmer';
    shimmer.style.cssText = `
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
      animation: shimmer 1.5s infinite;
    `;
    (el as HTMLElement).style.position = 'relative';
    el.appendChild(shimmer);
  });
}

// Dropdown menu animation
export function dropdownIn(dropdown: Element) {
  animate(dropdown, { opacity: [0, 1], scale: [0.95, 1], y: [-5, 0] }, { duration: 0.2, easing: [0.34, 1.56, 0.64, 1] });
}

export function dropdownOut(dropdown: Element, onComplete?: () => void) {
  animate(dropdown, { opacity: [1, 0], scale: [1, 0.95], y: [0, -5] }, { duration: 0.15 }).finished.then(() => onComplete?.());
}

// Image gallery lightbox
export function lightboxIn(imageEl: Element) {
  const clone = imageEl.cloneNode(true) as HTMLElement;
  clone.className = 'lightbox-image';
  clone.style.cssText = `
    position: fixed;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%) scale(0.9);
    max-width: 90vw; max-height: 90vh;
    object-fit: contain;
    z-index: 100;
    opacity: 0;
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
  `;
  document.body.appendChild(clone);

  // Create backdrop
  const backdrop = document.createElement('div');
  backdrop.className = 'lightbox-backdrop';
  backdrop.style.cssText = `
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.9);
    z-index: 99;
    opacity: 0;
  `;
  document.body.appendChild(backdrop);

  // Animate in
  timeline([
    [backdrop, { opacity: [0, 1] }, { duration: 0.2 }],
    [clone, { opacity: [0, 1], scale: [0.9, 1] }, { duration: 0.3, easing: [0.34, 1.56, 0.64, 1] }]
  ]);

  return { clone, backdrop };
}

export function lightboxOut(onComplete?: () => void) {
  const clone = document.querySelector('.lightbox-image');
  const backdrop = document.querySelector('.lightbox-backdrop');

  timeline([
    [clone, { opacity: [1, 0], scale: [1, 0.9] }, { duration: 0.2 }],
    [backdrop, { opacity: [1, 0] }, { duration: 0.15 }]
  ]).finished.then(() => {
    clone?.remove();
    backdrop?.remove();
    onComplete?.();
  });
}

// Form validation shake
export function formShake(formEl: Element) {
  animate(formEl, { x: [-10, 10, -8, 8, -5, 5, 0] }, { duration: 0.4, easing: 'ease-out' });
}

// Form success checkmark
export function formSuccess(inputEl: Element) {
  const originalBorder = (inputEl as HTMLElement).style.borderColor;
  animate(inputEl, { borderColor: ['currentColor', '#22c55e', '#22c55e'] }, { duration: 0.3 });
  setTimeout(() => {
    animate(inputEl, { borderColor: [originalBorder] }, { duration: 0.2 });
  }, 1500);
}

// Scroll progress indicator
export function initScrollProgress(indicatorEl: Element) {
  const updateProgress = () => {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = (scrollTop / docHeight) * 100;
    (indicatorEl as HTMLElement).style.width = `${progress}%`;
  };

  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();
}

// ===== NEW ENHANCED ANIMATIONS =====

// Page transition in
export function pageTransitionIn(container: string = 'main') {
  const main = document.querySelector(container) || document.body;
  animate(main, { opacity: [0, 1], y: [10, 0] }, { duration: 0.4, easing: 'ease-out' });
}

// Staggered grid entrance for cards
export function staggerGridEntrance(gridSelector: string, cardSelector: string = 'a', baseDelay = 0) {
  const grid = document.querySelector(gridSelector);
  if (!grid) return;

  const cards = grid.querySelectorAll(cardSelector);
  cards.forEach((card, i) => {
    animate(
      card,
      { opacity: [0, 1], y: [20, 0], scale: [0.95, 1] },
      { duration: 0.35, delay: baseDelay + i * 0.05, easing: [0.25, 0.1, 0.25, 1] }
    );
  });
}

// Button ripple effect
export function addRippleEffect(selector: string) {
  const buttons = document.querySelectorAll(selector);
  buttons.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const rect = (btn as HTMLElement).getBoundingClientRect();
      const x = (e as MouseEvent).clientX - rect.left;
      const y = (e as MouseEvent).clientY - rect.top;

      const ripple = document.createElement('span');
      ripple.className = 'ripple-effect';
      ripple.style.cssText = `
        position: absolute;
        border-radius: 50%;
        background: rgba(255,255,255,0.4);
        width: 10px; height: 10px;
        left: ${x}px; top: ${y}px;
        transform: translate(-50%, -50%) scale(0);
        animation: ripple 0.6s ease-out forwards;
        pointer-events: none;
      `;

      (btn as HTMLElement).style.position = 'relative';
      (btn as HTMLElement).style.overflow = 'hidden';
      btn.appendChild(ripple);

      setTimeout(() => ripple.remove(), 600);
    });
  });
}

// Section reveal on scroll
export function sectionReveal(selector: string, threshold = 0.15) {
  const sections = document.querySelectorAll(selector);
  sections.forEach(section => {
    inView(section as Element, () => {
      animate(section, { opacity: [0, 1], y: [30, 0] }, { duration: 0.5, easing: 'ease-out' });
    }, { amount: threshold });
  });
}

// Filter dropdown animation
export function animateFilters(selector: string) {
  const filters = document.querySelectorAll(selector);
  filters.forEach((filter, i) => {
    animate(filter, { opacity: [0, 1], x: [-10, 0] }, { duration: 0.25, delay: i * 0.03 });
  });
}

// Active nav item highlight
export function scrollSpyHighlight(selector: string, activeClass = 'text-primary font-semibold') {
  const navItems = document.querySelectorAll(selector);
  if (!navItems.length) return;

  const sectionIds = Array.from(navItems)
    .map(item => item.getAttribute('href')?.replace('#', ''))
    .filter(Boolean);

  const sections = sectionIds.map(id => document.getElementById(id!)).filter(Boolean);

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navItems.forEach(item => item.classList.remove(activeClass));
        const activeIndex = sections.indexOf(entry.target);
        if (activeIndex >= 0) navItems[activeIndex]?.classList.add(activeClass);
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });

  sections.forEach(section => section && observer.observe(section));
}

// Search input focus animation
export function animateSearchInput(selector: string) {
  const input = document.querySelector(selector) as HTMLInputElement;
  if (!input) return;

  input.addEventListener('focus', () => {
    animate(input, { scale: [1, 1.02], boxShadow: ['0 0 0 3px rgba(255,209,80,0.2)', '0 0 0 4px rgba(255,209,80,0.4)'] }, { duration: 0.2 });
  });
  input.addEventListener('blur', () => {
    animate(input, { scale: [1.02, 1], boxShadow: ['0 0 0 4px rgba(255,209,80,0.4)', '0 0 0 0 transparent'] }, { duration: 0.2 });
  });
}

// Pagination button stagger
export function animatePagination(selector: string) {
  const nav = document.querySelector(selector);
  if (!nav) return;

  const links = nav.querySelectorAll('a');
  links.forEach((link, i) => {
    animate(link, { opacity: [0, 1], y: [10, 0] }, { duration: 0.2, delay: i * 0.03 });
  });
}

// Loading skeleton pulse
export function addLoadingPulse(selector: string) {
  const elements = document.querySelectorAll(selector);
  elements.forEach(el => {
    animate(el, { opacity: [0.5, 1, 0.5] }, { duration: 1.5, repeat: Infinity });
  });
}

// Floating element bounce
export function addFloatingBounce(selector: string, intensity = 1) {
  const elements = document.querySelectorAll(selector);
  elements.forEach(el => {
    const animateFloat = () => {
      animate(el, { y: [0, -8 * intensity, 0] }, { duration: 2 + Math.random() });
      setTimeout(animateFloat, 2000 + Math.random() * 1000);
    };
    setTimeout(animateFloat, Math.random() * 2000);
  });
}

// Toast notification stack
const toastStack: Element[] = [];
export function stackedToast(toastEl: Element) {
  toastStack.push(toastEl);
  toastStack.forEach((t, i) => {
    animate(t, { y: [i * 70, i * 60] }, { duration: 0.2 });
  });
}

// Parallax effect for hero images
export function initParallax(elements: NodeListOf<Element>) {
  const handleParallax = () => {
    const scrollY = window.scrollY;
    elements.forEach(el => {
      const speed = parseFloat((el as HTMLElement).dataset.parallaxSpeed || '0.5');
      const yOffset = scrollY * speed;
      (el as HTMLElement).style.transform = `translateY(${yOffset}px)`;
    });
  };

  window.addEventListener('scroll', handleParallax, { passive: true });
}

// Image lazy load fade
export function lazyImageFade(imgEl: HTMLImageElement) {
  if (imgEl.dataset.loaded) return;
  imgEl.style.opacity = '0';
  imgEl.style.transition = 'opacity 0.4s ease-out';

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        imgEl.src = imgEl.dataset.src || imgEl.src;
        imgEl.style.opacity = '1';
        imgEl.dataset.loaded = 'true';
        observer.unobserve(imgEl);
      }
    });
  }, { rootMargin: '50px' });

  observer.observe(imgEl);
}

// ===== AUTO INITIALIZATION =====

document.addEventListener('DOMContentLoaded', () => {
  // Hero section text reveal
  const heroTitle = document.querySelector('h1');
  if (heroTitle) {
    textReveal(heroTitle, 0.3);
  }

  // Card hover effects - all entity cards
  addHoverLift('.listing-card, .product-card, .business-card, .entity-card');
  addCardGlow('.listing-card, .product-card, .business-card, .entity-card');

  // Form elements
  staggerFadeIn('form', 'input, select, textarea, button', 0.1);

  // Listings/products/entities staggered entrance
  staggerFadeIn('.grid', '.listing-card, .product-card, .entity-card, .bg-card a', 0.08);

  // Stats counter animation
  const statNumbers = document.querySelectorAll('[data-count]');
  statNumbers.forEach(el => {
    const target = parseInt(el.getAttribute('data-count') || '0', 10);
    inView(el, () => {
      animateCounter(el, target, 1.5);
    }, { amount: 0.5 });
  });

  // Button feedback
  addButtonFeedback('button, a.btn, [role="button"]');

  // Filter tag effects
  addFilterClickEffect('.filter-tag, .category-tag');

  // Link underline
  addLinkUnderline('nav a, footer a');

  // Business header sections
  setTimeout(() => {
    slideInLeft('.header-left-section', 0.1);
    slideInRight('.header-right-section', 0.15);
  }, 200);

  // Entrance animations for list pages
  setTimeout(() => {
    fadeInUp('.listing-card', 0.1);
    fadeInUp('a[href^="/business/"]', 0.08);
    fadeInUp('a[href^="/non-profit/"]', 0.08);
    fadeInUp('a[href^="/public-sector/"]', 0.08);
    fadeInUp('a[href^="/listing/"]', 0.08);
    scaleIn('.filter-select', 0.1);
  }, 100);

  // ===== NEW ENHANCED INITIALIZATION =====

  // Skeleton loading shimmer
  addSkeletonShimmer('.skeleton, .loading-placeholder');

  // Initialize parallax for hero images
  const parallaxImages = document.querySelectorAll('[data-parallax]');
  if (parallaxImages.length > 0) {
    initParallax(parallaxImages);
  }

  // Page transition in
  pageTransitionIn('main, [data-page-content]');

  // Staggered grid entrance for card grids
  staggerGridEntrance('.grid', 'a, .card, [data-animate-card]', 0.05);

  // Ripple effect on buttons
  addRippleEffect('button, a.btn, [role="button"], .cursor-pointer');

  // Section reveal on scroll
  sectionReveal('section, .animate-section');

  // Filter animations
  animateFilters('.filter-tag, select[name="parent"], select[name="child"]');

  // Search input animation
  animateSearchInput('input[type="search"], input[name="q"]');

  // Pagination animation
  animatePagination('nav[aria-label="Pagination"]');

  // Floating elements
  addFloatingBounce('.float, .floating, [data-float]');

  // Loading pulses
  addLoadingPulse('.loading, .skeleton');

  // Lightbox for images
  document.querySelectorAll('[data-lightbox]').forEach(img => {
    img.addEventListener('click', () => {
      lightboxIn(img);
    });
  });

  // Close lightbox on click outside
  document.addEventListener('click', (e) => {
    if (e.target === document.querySelector('.lightbox-backdrop')) {
      lightboxOut();
    }
  });

  // Escape key closes lightbox
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const lightbox = document.querySelector('.lightbox-image');
      if (lightbox) lightboxOut();
    }
  });

  // Scroll progress bar
  const scrollProgress = document.createElement('div');
  scrollProgress.className = 'scroll-progress-bar';
  scrollProgress.style.cssText = `
    position: fixed;
    top: 0; left: 0;
    height: 3px;
    background: linear-gradient(90deg, #FFD150, #ff6b6b);
    width: 0%;
    z-index: 9999;
    transition: width 0.1s ease-out;
  `;
  document.body.appendChild(scrollProgress);
  initScrollProgress(scrollProgress);
});
</script>

<style>
.word-reveal {
  will-change: transform, opacity;
}

@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

.skeleton-shimmer {
  pointer-events: none;
}

.scroll-progress-bar {
  pointer-events: none;
}

/* Ripple animation for buttons */
@keyframes ripple {
  to {
    transform: translate(-50%, -50%) scale(4);
    opacity: 0;
  }
}

.ripple-effect {
  pointer-events: none;
}

/* Page transition helper */
[data-page-content] {
  animation: pageIn 0.4s ease-out;
}

@keyframes pageIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Card stagger animation helper */
.grid [data-animate-card] {
  will-change: transform, opacity;
}

/* Search focus ring animation */
input[type="search"]:focus, input[name="q"]:focus {
  animation: searchGlow 0.3s ease-out;
}

@keyframes searchGlow {
  0% { box-shadow: 0 0 0 2px rgba(255,209,80,0.2); }
  50% { box-shadow: 0 0 0 4px rgba(255,209,80,0.4); }
  100% { box-shadow: 0 0 0 3px rgba(255,209,80,0.2); }
}

/* Floating animation */
[data-float] {
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}
</style>

