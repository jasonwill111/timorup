---
/**
 * CSS Animation Utilities for TimorUp
 *
 * Priority: Tailwind CSS first → Pure CSS for complex cases
 * Use Tailwind's transition utilities for simple animations
 * Use this file only for complex keyframes and selectors
 */
---

<style>
/* ===== Scroll Reveal ===== */
.reveal-on-scroll {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.5s ease-out, transform 0.5s ease-out;
}

.reveal-on-scroll.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.reveal-from-left {
  transform: translateX(-30px);
}
.reveal-from-left.is-visible {
  transform: translateX(0);
}

.reveal-scale {
  transform: scale(0.95);
}
.reveal-scale.is-visible {
  transform: scale(1);
}

/* ===== Card Hover Effects (Tailwind: hover:-translate-y-1) ===== */
.card-hover {
  transition: transform 0.2s ease-out, box-shadow 0.2s ease-out;
}

.card-hover:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1);
}

/* ===== Skeleton Shimmer ===== */
.skeleton::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.4),
    transparent
  );
  animation: shimmer 1.5s infinite;
  pointer-events: none;
}

@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

/* ===== Stagger Children ===== */
.stagger-children > * {
  opacity: 0;
  animation: staggerFadeIn 0.35s ease-out forwards;
}

.stagger-children > *:nth-child(1) { animation-delay: 0ms; }
.stagger-children > *:nth-child(2) { animation-delay: 50ms; }
.stagger-children > *:nth-child(3) { animation-delay: 100ms; }
.stagger-children > *:nth-child(4) { animation-delay: 150ms; }
.stagger-children > *:nth-child(5) { animation-delay: 200ms; }
.stagger-children > *:nth-child(n+6) { animation-delay: 250ms; }

@keyframes staggerFadeIn {
  from {
    opacity: 0;
    transform: translateY(15px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ===== Ripple Effect ===== */
.ripple {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
  width: 10px;
  height: 10px;
  transform: translate(-50%, -50%) scale(0);
  animation: ripple 0.6s ease-out forwards;
  pointer-events: none;
}

@keyframes ripple {
  to {
    transform: translate(-50%, -50%) scale(4);
    opacity: 0;
  }
}

/* ===== Toast/Dropdown Animations ===== */
.dropdown-enter {
  animation: dropdownIn 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.dropdown-exit {
  animation: dropdownOut 0.15s ease-out forwards;
}

@keyframes dropdownIn {
  from {
    opacity: 0;
    transform: scale(0.95) translateY(-5px);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

@keyframes dropdownOut {
  from {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
  to {
    opacity: 0;
    transform: scale(0.95) translateY(-5px);
  }
}

.toast-enter {
  animation: toastSlideIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes toastSlideIn {
  from {
    opacity: 0;
    transform: translateX(100%);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* ===== Accordion ===== */
.accordion-content {
  overflow: hidden;
  transition: height 0.3s ease-out;
}

/* ===== Reduced Motion ===== */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}
</style>
