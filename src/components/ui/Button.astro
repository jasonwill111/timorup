---
interface Props {
  variant?: 'default' | 'destructive' | 'outline' | 'secondary' | 'ghost' | 'link';
  size?: 'default' | 'sm' | 'md' | 'lg' | 'xl' | 'icon';
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  loading?: boolean;
  'data-slot'?: string;
}

const {
  variant = 'default',
  size = 'default',
  class: className = '',
  type = 'button',
  disabled = false,
  loading = false,
  'data-slot': slot = 'button',
  ...props
} = Astro.props;

const isDisabled = disabled || loading;

// Size object pattern (ricoui style) - consistent padding/sizing
const sizes = {
  default: 'h-11 px-4 py-2.5 rounded-md text-sm font-medium',
  sm: 'h-10 px-3 py-2 rounded-md text-sm',
  md: 'h-11 px-5 py-2.5 rounded-md text-sm font-medium',
  lg: 'h-12 px-6 py-3 rounded-lg text-base font-semibold',
  xl: 'h-14 px-8 py-4 rounded-xl text-lg font-semibold',
  icon: 'h-11 w-11',
};

// Hover shadow presets for enhanced interactions
const hoverShadows = {
  default: 'hover:shadow-lg hover:shadow-primary/20',
  destructive: 'hover:shadow-lg hover:shadow-destructive/20',
  outline: 'hover:shadow-md hover:shadow-foreground/10',
  secondary: 'hover:shadow-md hover:shadow-foreground/10',
  ghost: '',
  link: '',
};

const variants = {
  default: 'bg-primary text-primary-foreground shadow-sm hover:bg-primary/90',
  destructive: 'bg-destructive text-destructive-foreground shadow-sm hover:bg-destructive/90',
  outline: 'border border-primary text-primary hover:bg-primary/5',
  secondary: 'border border-primary text-primary hover:bg-primary/5',
  ghost: 'text-muted-foreground hover:text-primary hover:bg-muted',
  link: 'text-primary underline-offset-4 hover:underline',
};
---

<button
  type={type}
  disabled={isDisabled}
  data-slot={slot}
  class:list={[
    'inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-medium transition-all duration-200 rounded-md',
    'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2',
    'disabled:opacity-50 disabled:cursor-not-allowed pointer-events-none',
    variants[variant],
    sizes[size],
    hoverShadows[variant],
    className
  ]}
  {...props}
>
  <slot />
  {loading && (
    <span class="animate-spin ml-1">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
    </span>
  )}
</button>
