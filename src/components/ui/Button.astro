---
interface Props {
  variant?: 'default' | 'destructive' | 'outline' | 'secondary' | 'ghost' | 'link';
  size?: 'default' | 'sm' | 'md' | 'lg' | 'xl' | 'icon';
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  loading?: boolean;
  'data-slot'?: string;
}

const {
  variant = 'default',
  size = 'default',
  class: className = '',
  type = 'button',
  disabled = false,
  loading = false,
  'data-slot': slot = 'button',
  ...props
} = Astro.props;

const isDisabled = disabled || loading;

const variants = {
  default: 'bg-primary text-primary-foreground shadow-sm hover:bg-primary/90',
  destructive: 'bg-destructive text-destructive-foreground shadow-sm hover:bg-destructive/90',
  outline: 'border border-input bg-background shadow-sm hover:bg-accent hover:text-accent-foreground',
  secondary: 'bg-secondary text-secondary-foreground shadow-sm hover:bg-secondary/80',
  ghost: 'hover:bg-accent hover:text-accent-foreground',
  link: 'text-primary underline-offset-4 hover:underline',
};

const sizes = {
  default: 'h-11 px-4 py-2.5 rounded-md text-sm font-medium', // h-11 = 44px touch target
  sm: 'h-10 px-3 rounded-md text-sm', // h-10 = 40px
  md: 'h-11 px-5 py-2.5 rounded-md text-sm font-medium', // h-11 = 44px
  lg: 'h-12 px-8 py-3 rounded-md text-base font-semibold', // h-12 = 48px
  xl: 'h-14 px-10 py-4 rounded-lg text-lg font-semibold', // h-14 = 56px
  icon: 'h-11 w-11', // h-11 = 44px touch target
};
---

<button
  type={type}
  disabled={isDisabled}
  data-slot={slot}
  class:list={[
    'inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50',
    variants[variant],
    sizes[size],
    className
  ]}
  {...props}
>
  <slot />
  {loading && (
    <span class="animate-spin ml-1">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
    </span>
  )}
</button>
