---
import LucideIcon from './ui/LucideIcon.astro';

const currentYear = new Date().getFullYear();
---

<footer class="border-t bg-muted/30">
  <div class="container max-w-6xl py-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-2">
          <div class="w-7 h-7 bg-brand-500 rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-base">T</span>
          </div>
          <span class="font-bold text-lg">TimorUp</span>
        </a>
        <p class="text-muted-foreground text-xs mb-3 max-w-md">
          Discover local businesses, products & services near you. Restaurants, shops, salons, mechanics, and more.
        </p>
        <div class="flex gap-3">
          <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="social-link text-muted-foreground hover:text-primary transition-colors">
            <LucideIcon name="Facebook" size={16} class="w-4 h-4" />
          </a>
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="social-link text-muted-foreground hover:text-primary transition-colors">
            <LucideIcon name="Instagram" size={16} class="w-4 h-4" />
          </a>
          <a href="https://wa.me/670" class="social-link text-muted-foreground hover:text-primary transition-colors">
            <LucideIcon name="MessageCircle" size={16} class="w-4 h-4" />
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-semibold mb-2 text-sm">Quick Links</h3>
        <ul class="space-y-0.5">
          <li><a href="/businesses" class="text-xs text-muted-foreground hover:text-primary transition-colors">Business Directories</a></li>
          <li><a href="/products-services" class="text-xs text-muted-foreground hover:text-primary transition-colors">Products & Services</a></li>
          <li><a href="/listings" class="text-xs text-muted-foreground hover:text-primary transition-colors">Classified Ads</a></li>
          <li><a href="/pricing" class="text-xs text-muted-foreground hover:text-primary transition-colors">Pricing</a></li>
          <li><a href="/blog" class="text-xs text-muted-foreground hover:text-primary transition-colors">Blog</a></li>
          <li><a href="/faq" class="text-xs text-muted-foreground hover:text-primary transition-colors">FAQ</a></li>
          <li><a href="/listings/create" class="text-xs text-muted-foreground hover:text-primary transition-colors">Add Your Business</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="font-semibold mb-2 text-sm">Company</h3>
        <ul class="space-y-0.5">
          <li><a href="/about" class="text-xs text-muted-foreground hover:text-primary transition-colors">About Us</a></li>
          <li><a href="/contact" class="text-xs text-muted-foreground hover:text-primary transition-colors">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t mt-2 pt-2 flex flex-col sm:flex-row justify-between text-sm text-muted-foreground py-2">
      <span>&copy; {currentYear} TimorUp</span>
      <div class="flex gap-3">
        <a href="/privacy" class="hover:text-primary transition-colors">Privacy</a>
        <span>|</span>
        <a href="/terms" class="hover:text-primary transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .social-link {
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .social-link:hover {
    transform: scale(1.15);
  }
</style>
