---
interface ContactInfo {
  profileImageId?: string | null;
  title: string;
  contactNumber?: string | null;
  contactName?: string | null;
  email?: string | null;
  countryCode?: string;
  yearOfEstablishment?: number | null;
  verifiedBadge?: boolean;
  views?: number;
  likes?: number;
  saves?: number;
}

interface Props {
  info: ContactInfo;
  category?: { name: string } | null;
  organizationType?: string;
  type: 'business' | 'nonprofit';
  showWhatsApp?: boolean;
}

const {
  info,
  category,
  organizationType,
  type = 'business',
  showWhatsApp = false
} = Astro.props;

const typeLabels: Record<string, string> = {
  government: 'Government Agency',
  ngo: 'NGO',
};

const typeBadgeClass = organizationType === 'government'
  ? 'bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400'
  : organizationType === 'ngo'
    ? 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400'
    : 'bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-400';

const typeLabel = organizationType ? typeLabels[organizationType] : category?.name || 'Business';
---

<!-- Header Card -->
<div class="bg-card border rounded-2xl shadow-lg p-4 md:p-5 mb-6">
  <div class="flex flex-col lg:flex-row gap-5">
    <!-- Left Column: Profile + Info -->
    <div class="flex flex-row gap-4 lg:w-1/2 lg:items-start">
      <!-- Profile Image -->
      <div class="flex-shrink-0">
        <div class="w-20 h-20 md:w-24 md:h-24 rounded-xl overflow-hidden bg-muted border-2 border-background shadow-lg">
          {info.profileImageId ? (
            <img
              src={`/api/media/${info.profileImageId}`}
              class="w-full h-full object-cover"
              alt={info.title}
              loading="eager"
              decoding="auto"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-4xl md:text-5xl font-bold text-muted-foreground bg-primary/10">
              {info.title.charAt(0)}
            </div>
          )}
        </div>
      </div>

      <!-- Name + Contact Info -->
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="text-xl md:text-2xl font-bold">{info.title}</h1>
          {info.verifiedBadge && (
            <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400 flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Verified
            </span>
          )}
        </div>
        {typeLabel && (
          <p class="text-xs text-muted-foreground mt-0.5">{typeLabel}</p>
        )}
        <div class="mt-1 space-y-1">
          {info.contactNumber && (
            <div class="flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <span class="text-muted-foreground">{info.countryCode || '+670'} {info.contactNumber}</span>
            </div>
          )}
          {info.contactName && (
            <div class="flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span class="text-muted-foreground">{info.contactName}</span>
            </div>
          )}
          {info.email && (
            <div class="flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <span class="text-muted-foreground truncate">{info.email}</span>
            </div>
          )}
          {info.yearOfEstablishment && (
            <div class="flex items-center gap-2 text-xs text-muted-foreground">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <span>Est. {info.yearOfEstablishment}</span>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Right Column: Stats + Share + WhatsApp -->
    <div class="flex flex-col lg:w-1/2 lg:items-end lg:justify-start gap-3">
      <!-- Stats + Share in one row -->
      <div class="flex items-center gap-4 text-xs text-muted-foreground">
        <div class="flex items-center gap-1" title="Views">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
          <span>{info.views || 0}</span>
        </div>
        <div class="flex items-center gap-1" title="Likes">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
          <span>{info.likes || 0}</span>
        </div>
        <div class="flex items-center gap-1" title="Saves">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
          </svg>
          <span>{info.saves || 0}</span>
        </div>
        <button id="share-btn" class="p-1.5 rounded-lg border hover:bg-muted transition-colors" title="Share">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
          </svg>
        </button>
      </div>

      <!-- WhatsApp -->
      {showWhatsApp && info.contactNumber && (
        <a href={`https://wa.me/${info.contactNumber.replace(/\s/g, '')}?text=Hi, I'm interested in ${encodeURIComponent(info.title)}`} target="_blank" class="flex items-center gap-1.5 px-3 py-2 bg-[#25D366] hover:bg-[#20BD5A] text-white rounded-lg text-sm font-medium transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      )}
    </div>
  </div>
</div>
