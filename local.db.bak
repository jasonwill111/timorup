CREATE TABLE `orders` (
	`id` text PRIMARY KEY NOT NULL,
	`businessPageId` text NOT NULL,
	`userId` text NOT NULL,
	`planType` text NOT NULL,
	`amount` integer NOT NULL,
	`status` text DEFAULT 'unpaid',
	`expiryDate` integer,
	`paymentMethod` text,
	`paidDate` integer,
	`adminNotes` text,
	`createdAt` integer DEFAULT (strftime('%s', 'now')),
	`updatedAt` integer DEFAULT (strftime('%s', 'now'))
);
CREATE TABLE `ad_banners` (
	`id` text PRIMARY KEY NOT NULL,
	`title` text NOT NULL,
	`description` text,
	`imageId` text,
	`linkedBusinessPageId` text,
	`externalUrl` text,
	`isActive` integer DEFAULT true,
	`startDate` integer,
	`endDate` integer,
	`createdAt` integer DEFAULT (strftime('%s', 'now')),
	`updatedAt` integer DEFAULT (strftime('%s', 'now'))
);
CREATE TABLE `site_settings` (
	`id` text PRIMARY KEY NOT NULL,
	`key` text NOT NULL,
	`value` text,
	`updatedAt` integer DEFAULT (strftime('%s', 'now'))
);
CREATE UNIQUE INDEX `users_email_unique` ON `users` (`email`);
CREATE INDEX `users_email_idx` ON `users` (`email`);
CREATE UNIQUE INDEX `blog_posts_slug_unique` ON `blog_posts` (`slug`);
CREATE INDEX `blog_posts_author_idx` ON `blog_posts` (`author_id`);
CREATE INDEX `blog_posts_status_idx` ON `blog_posts` (`status`);
CREATE UNIQUE INDEX `categories_slug_unique` ON `categories` (`slug`);
CREATE UNIQUE INDEX `business_pages_slug_unique` ON `business_pages` (`slug`);
CREATE INDEX `business_owner_idx` ON `business_pages` (`ownerId`);
CREATE INDEX `business_status_idx` ON `business_pages` (`status`);
CREATE INDEX `products_business_idx` ON `products` (`businessPageId`);
CREATE INDEX `reviews_business_idx` ON `reviews` (`businessPageId`);
CREATE INDEX `reviews_user_idx` ON `reviews` (`userId`);
CREATE INDEX `orders_business_idx` ON `orders` (`businessPageId`);
CREATE INDEX `orders_user_idx` ON `orders` (`userId`);
CREATE UNIQUE INDEX `site_settings_key_unique` ON `site_settings` (`key`);
